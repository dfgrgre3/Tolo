# Database Configuration (Main for writes, Replica for reads)
DATABASE_URL="postgresql://username:password@localhost:5432/thanawy_db?pgbouncer=true"
# Direct URL is for Prisma migrations (bypasses PgBouncer)
DATABASE_URL_DIRECT="postgresql://username:password@localhost:5432/thanawy_db"
DATABASE_URL_REPLICA="postgresql://username:password@read-replica-host:5432/thanawy_db"

# Connection Pooling Configuration
PRISMA_CONNECTION_LIMIT=50
PRISMA_POOL_TIMEOUT=15
PRISMA_PGBOUNCER=true
# Query timeout in ms (prevents slow queries from exhausting pool)
PRISMA_QUERY_TIMEOUT=15000
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=50
DB_CONN_MAX_LIFETIME_MINUTES=60
DB_CONN_MAX_IDLE_MINUTES=30
DB_LOG_LEVEL=warn
RUN_DB_MIGRATIONS=false
DB_AUTO_MIGRATE=false

# Next.js Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Email Configuration (for notifications)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"

# Redis Configuration (for caching & distributed rate limiting)
REDIS_URL="redis://localhost:6379"
DISABLE_REDIS=false
REDIS_POOL_SIZE=100
REDIS_MIN_IDLE_CONNS=10
REDIS_MAX_RETRIES=5

# Global Storage & CDN (For Millions of Users)
S3_REGION="me-south-1" # Middle East region recommended for Egypt
S3_BUCKET_NAME="thanawy-assets-prod"
S3_ACCESS_KEY_ID="your-access-key-id"
S3_SECRET_ACCESS_KEY="your-secret-access-key"
NEXT_PUBLIC_CDN_URL="https://cdn.thanawy.app"

# API & Load Balancing
API_BASE_URL="https://api.thanawy.app"
ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_URL="http://elasticsearch:9200"

# Security Configuration
JWT_SECRET="your-jwt-secret-here"
ENCRYPTION_KEY="your-encryption-key-here"

# External Services
OPENAI_API_KEY="your-openai-api-key"
OPENROUTER_API_KEY="your-openrouter-api-key"
GEMINI_API_KEY="your-gemini-api-key"
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"

# Monitoring and Logging (Prometheus/Grafana)
LOG_LEVEL="info"
SENTRY_DSN="your-sentry-dsn"
ENABLE_PROMETHEUS=true

# Development/Production
NODE_ENV="production"

# Egyptian Payment Gateway (Paymob)
PAYMOB_API_KEY="your-paymob-api-key"
PAYMOB_HMAC_SECRET="your-paymob-hmac-secret"
PAYMOB_INTEGRATION_ID_CARD="your-card-integration-id"
PAYMOB_INTEGRATION_ID_FAWRY="your-fawry-integration-id"
PAYMOB_INTEGRATION_ID_WALLET="your-wallet-integration-id"
PAYMOB_IFRAME_ID="your-iframe-id"

# Feature Flags
NEXT_PUBLIC_ENABLE_LOGIN_COMPLEXITY=false
