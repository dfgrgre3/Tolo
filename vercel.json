{
  "framework": "nextjs",
  "installCommand": "npm install --prefix frontend --include=dev --legacy-peer-deps",
  "buildCommand": "npm run build --prefix frontend",
  "outputDirectory": "frontend/.next",
  "regions": [
    "fra1"
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "origin-when-cross-origin"
        }
      ]
    }
  ]
}
