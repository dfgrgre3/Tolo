{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/app/layout.tsx",
    "src/app/page.tsx",
    "src/app/api/**/route.ts",
    "scripts/*.ts",
    "scripts/*.mjs"
  ],
  "project": ["src/**/*.{ts,tsx}", "scripts/**/*.{ts,mjs}"],
  "ignore": [
    "scratch/**/*",
    "brain/**/*",
    "**/*.bak.*",
    "**/*.old.*"
  ],
  "ignoreDependencies": [
    "lucide-react"
  ]
}
