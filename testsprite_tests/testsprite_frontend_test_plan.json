  {
    "id": "TC007",
    "title": "Successful login redirects user to dashboard",
    "description": "Verifies a registered user can log in from /login and is redirected to /dashboard with dashboard content visible.",
    "category": "User Authentication (Login & Dashboard)",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/login\""
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Dashboard\" is visible"
      }
    ]
  },
