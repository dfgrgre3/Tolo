{
  "name": "thanawy-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "vercel-build": "npm install --prefix frontend --include=dev --legacy-peer-deps && npm run build --prefix frontend",
    "dev:frontend": "npm run dev --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "lint:frontend": "npm run lint --prefix frontend",
    "test:frontend": "npm run test --prefix frontend",
    "audit": "node scripts/comprehensive-error-check.mjs",
    "audit:fix": "node scripts/comprehensive-error-check.mjs --fix",
    "build": "npm run build:frontend"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.4.1",
    "ioredis": "^5.11.1",
    "next": "16.2.6",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  }
}
