  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:no-turbo": "next dev --no-turbo",
    "clear-cache": "powershell -ExecutionPolicy Bypass -File ./scripts/clear-cache.ps1",
    "build": "powershell -ExecutionPolicy Bypass -File ./scripts/build-safe.ps1",
    "build:safe": "powershell -ExecutionPolicy Bypass -File ./scripts/build-safe.ps1",
    "start": "next start",
    "clean": "node -e \"require('fs').rmSync('.next', {recursive: true, force: true})\"",
    "lint": "eslint",
    "type-check": "npx tsc --noEmit",
    "perf": "node scripts/check-server.js && npx lighthouse http://localhost:3000 --chrome-flags='--headless --disable-dev-shm-usage --no-sandbox --disable-setuid-sandbox --ignore-certificate-errors --allow-insecure-localhost' --output=json --output-path=./lighthouse-results.json --only-categories=performance",
