# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/thanawy_db?pgbouncer=true"
# Direct URL is for Prisma migrations (bypasses PgBouncer)
DATABASE_URL_DIRECT="postgresql://username:password@localhost:5432/thanawy_db"
# Read Replica for scaling reads (distribute GET queries across replicas)
DATABASE_URL_REPLICA="postgresql://username:password@read-replica-host:5432/thanawy_db?pgbouncer=true"
# Connection Pooling Configuration
PRISMA_CONNECTION_LIMIT=50
PRISMA_POOL_TIMEOUT=15
PRISMA_PGBOUNCER=true
# Query timeout to prevent slow queries from exhausting the pool (15 seconds)
PRISMA_QUERY_TIMEOUT=15000

# Next.js Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Email Configuration (for notifications)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"

# Redis Configuration (for caching)
REDIS_URL="redis://localhost:6379"

# File Upload Configuration
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="10485760" # 10MB in bytes

# API Configuration
API_BASE_URL="http://localhost:3000/api"

# Security Configuration
JWT_SECRET="your-jwt-secret-here"
ENCRYPTION_KEY="your-encryption-key-here"

# External Services
OPENAI_API_KEY="your-openai-api-key"
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"

# Monitoring and Logging
LOG_LEVEL="info"
SENTRY_DSN="your-sentry-dsn"

# Development/Production
NODE_ENV="production"

# Egyptian Payment Gateway (Paymob)
PAYMOB_API_KEY="your-paymob-api-key"
PAYMOB_HMAC_SECRET="your-paymob-hmac-secret"
PAYMOB_INTEGRATION_ID_CARD="your-card-integration-id"
PAYMOB_INTEGRATION_ID_FAWRY="your-fawry-integration-id"
PAYMOB_INTEGRATION_ID_WALLET="your-wallet-integration-id"
PAYMOB_IFRAME_ID="your-iframe-id"

# Feature Flags
NEXT_PUBLIC_ENABLE_LOGIN_COMPLEXITY=false

# Vercel specific
NEXT_PUBLIC_APP_NAME="Thanawy"
NEXT_PUBLIC_BASE_URL="https://your-app.vercel.app"
NEXT_PUBLIC_RP_ID="your-app.vercel.app"
SKIP_ENV_VALIDATION="true"
