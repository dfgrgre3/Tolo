# Database Configuration
# NOTE: In production, use a secrets manager (HashiCorp Vault, AWS Secrets Manager)
# or CI/CD secret injection. Never commit real credentials to version control.
DATABASE_URL="postgresql://username:password@localhost:5432/thanawy_db?pgbouncer=true"
DATABASE_URL_DIRECT="postgresql://username:password@localhost:5432/thanawy_db"
DATABASE_URL_REPLICA="postgresql://username:password@read-replica-host:5432/thanawy_db?pgbouncer=true"
PRISMA_CONNECTION_LIMIT=50
PRISMA_POOL_TIMEOUT=15
PRISMA_PGBOUNCER=true
PRISMA_QUERY_TIMEOUT=15000

# Next.js Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="CHANGE_ME_USE_SECRETS_MANAGER"
NEXT_PUBLIC_ADMIN_URL="https://admin.your-app.vercel.app"

# Email Configuration
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="CHANGE_ME"
EMAIL_PASS="CHANGE_ME_USE_SECRETS_MANAGER"

# Redis Configuration
REDIS_URL="redis://localhost:6379"

# File Upload Configuration
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="10485760"

# API Configuration
API_BASE_URL="http://localhost:3000/api"

# Security Configuration
# NOTE: Generate strong random secrets in production:
#   openssl rand -hex 32
JWT_SECRET="dfgrgre3-thanawy-secure-token-2026-v1-secret-key"
ENCRYPTION_KEY="CHANGE_ME_USE_SECRETS_MANAGER"

# External Services
OPENAI_API_KEY="CHANGE_ME_USE_SECRETS_MANAGER"
TWILIO_ACCOUNT_SID="CHANGE_ME"
TWILIO_AUTH_TOKEN="CHANGE_ME_USE_SECRETS_MANAGER"

# Monitoring and Logging
LOG_LEVEL="info"
SENTRY_DSN="CHANGE_ME"

# Development/Production
NODE_ENV="production"

# Egyptian Payment Gateway (Paymob)
PAYMOB_API_KEY="CHANGE_ME_USE_SECRETS_MANAGER"
PAYMOB_HMAC_SECRET="CHANGE_ME_USE_SECRETS_MANAGER"
PAYMOB_INTEGRATION_ID_CARD="CHANGE_ME"
PAYMOB_INTEGRATION_ID_FAWRY="CHANGE_ME"
PAYMOB_INTEGRATION_ID_WALLET="CHANGE_ME"
PAYMOB_IFRAME_ID="CHANGE_ME"

# Feature Flags
NEXT_PUBLIC_ENABLE_LOGIN_COMPLEXITY=false

# Vercel specific
NEXT_PUBLIC_APP_NAME="Thanawy"
NEXT_PUBLIC_BASE_URL="https://your-app.vercel.app"
NEXT_PUBLIC_RP_ID="your-app.vercel.app"
SKIP_ENV_VALIDATION="true"
