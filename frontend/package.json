{
  "name": "thanawy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "clear-cache": "npx rimraf .next/cache",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "clean": "npx rimraf .next",
    "lint": "eslint",
    "type-check": "npx tsc --noEmit",
    "perf": "node scripts/check-server.js && npx lighthouse http://localhost:3000 --chrome-flags='--headless --disable-dev-shm-usage --no-sandbox --disable-setuid-sandbox --ignore-certificate-errors --allow-insecure-localhost' --output=json --output-path=./lighthouse-results.json --only-categories=performance",
    "check:env": "tsx scripts/check-environment.ts",
    "check:errors": "node ../scripts/comprehensive-error-check.mjs",
    "check:errors:fix": "node ../scripts/comprehensive-error-check.mjs --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
