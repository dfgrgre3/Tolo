r\n  const messagesEndRef = useRef<HTMLDivElement>(null);\r\n\r\n  // в•ӘШҜв”ҳВ„в•ӘШІв”ҳГ в•Әв–’в”ҳГЁв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШІв”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГЁ в•ӘШӯв”ҳВ„в”ҳГ« в•ӘШӘв•ӘВ«в•Әв–’ в•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„в•ӘШұ\r\n  const scrollToBottom = () => {\r\n    messagesEndRef.current?.scrollIntoView({ behavior: 'smooth' });\r\n  };\r\n\r\n  useEffect(() => {\r\n    scrollToBottom();\r\n  }, [messages]);\r\n\r\n  const handleSubmit = async (e: React.FormEvent) => {\r\n    e.preventDefault();\r\n    if (!input.trim() || isLoading) return;\r\n\r\n    // в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ \r\n    const userMessage: Message = {\r\n      role: 'user',\r\n      content: input,\r\n      timestamp: new Date()\r\n    };\r\n    setMessages(prev => [...prev, userMessage]);\r\n    setInput('');\r\n    setIsLoading(true);\r\n\r\n    try {\r\n      // в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв•–в”ҳВ„в•ӘШ° в•ӘШӯв”ҳВ„в”ҳГ« в”ҳГӘв•ӘШҜв•ӘШҙв”ҳГ§в•ӘШұ в•ӘШ°в•Әв–’в”ҳГ в•ӘШҙв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•Әв•–в•ӘШ°в”ҳГЁв”ҳГ©в•ӘШҜв•ӘШІ\r\n      const response = await fetch('/api/ai/chat', {\r\n        method: 'POST',\r\n        headers: {\r\n          'Content-Type': 'application/json',\r\n        },\r\n        body: JSON.stringify({\r\n          messages: messages.map(msg => ({\r\n            role: msg.role,\r\n            content: msg.content\r\n          })),\r\n          provider: 'gemini' // в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в•ӘШҜв”ҳГ  Gemini в”ҳГўв•ӘВ«в”ҳГЁв•ӘШҜв•Әв–’ в•ӘШҜв”ҳВҒв•ӘШІв•Әв–’в•ӘШҜв•Әв•ўв”ҳГЁ\r\n        }),\r\n      });\r\n\r\n      if (!response.ok) {\r\n        throw new Error('в”ҳВҒв•Әв”Өв”ҳВ„в•ӘШІ в•Әв•Јв”ҳГ в”ҳВ„в”ҳГЁв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„ в•ӘШ°в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘВ» в•ӘШҜв”ҳВ„в•Әв–‘в”ҳГўв”ҳГЁ');\r\n      }\r\n\r\n      const data = await response.json();\r\n\r\n      // в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•Әв–’в•ӘВ» в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘВ»\r\n      const assistantMessage: Message = {\r\n        role: 'assistant',\r\n        content: data.message,\r\n        timestamp: new Date()\r\n      };\r\n      setMessages(prev => [...prev, assistantMessage]);\r\n    } catch (error) {\r\n      logger.error('Error sending message:', error);\r\n\r\n      // в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„в•ӘШұ в•ӘВ«в•Әв•–в•ӘШ«\r\n      const errorMessage: Message = {\r\n        role: 'assistant',\r\n        content: 'в•Әв•Јв•Әв–‘в•Әв–’в•ӘШҜв”ҳГҜв•ӘГ® в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в”ҳГ в•Әв•Јв•ӘШҜв”ҳВ„в•ӘШҙв•ӘШұ в•Әв•–в”ҳВ„в•ӘШ°в”ҳГў. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ« в”ҳВ„в•ӘШҜв•ӘШөв”ҳГ©в•ӘШҜв”ҳГҜ.',\r\n        timestamp: new Date()\r\n      };\r\n      setMessages(prev => [...prev, errorMessage]);\r\n    } finally {\r\n      setIsLoading(false);\r\n    }\r\n  };\r\n\r\n  const formatTime = (date: Date) => {\r\n    return date.toLocaleTimeString('ar-EG', {\r\n      hour: '2-digit',\r\n      minute: '2-digit'\r\n    });\r\n  };\r\n\r\n  return (\r\n    <div className={`bg-white rounded-xl shadow-lg flex flex-col h-full ${className}`}>\r\n      <div className=\"p-4 border-b border-gray-200\">\r\n        <div className=\"flex items-center gap-2\">\r\n          <div className=\"p-2 bg-blue-100 rounded-lg\">\r\n            <Bot className=\"h-5 w-5 text-blue-600\" />\r\n          </div>\r\n          <h3 className=\"font-bold text-lg text-gray-800\">{title}</h3>\r\n          <div className=\"ml-auto flex items-center gap-1 text-xs bg-green-100 text-green-800 px-2 py-1 rounded-full\">\r\n            <Zap className=\"h-3 w-3\" />\r\n            <span>Gemini 2.0 Flash</span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <div className=\"flex-1 overflow-y-auto p-4 space-y-4 max-h-[400px]\">\r\n        {messages.map((message, index) => (\r\n          <div\r\n            key={index}\r\n            className={`flex gap-3 ${message.role === 'user' ? 'justify-end' : 'justify-start'}`}\r\n          >\r\n            {message.role === 'assistant' && (\r\n              <div className=\"flex-shrink-0 w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center\">\r\n                <Bot className=\"h-4 w-4 text-blue-600\" />\r\n              </div>\r\n            )}\r\n\r\n            <div\r\n              className={`max-w-[80%] rounded-2xl px-4 py-3 ${\r\n                message.role === 'user'\r\n                  ? 'bg-blue-500 text-white rounded-tr-none'\r\n                  : 'bg-gray-100 text-gray-800 rounded-tl-none'\r\n              }`}\r\n            >\r\n              <div className=\"text-sm\">{message.content}</div>\r\n              <div\r\n                className={`text-xs mt-1 ${\r\n                  message.role === 'user' ? 'text-blue-100' : 'text-gray-500'\r\n                }`}\r\n              >\r\n                {formatTime(message.timestamp)}\r\n              </div>\r\n            </div>\r\n\r\n            {message.role === 'user' && (\r\n              <div className=\"flex-shrink-0 w-8 h-8 rounded-full bg-blue-500 flex items-center justify-center\">\r\n                <User className=\"h-4 w-4 text-white\" />\r\n              </div>\r\n            )}\r\n          </div>\r\n        ))}\r\n\r\n        {isLoading && (\r\n          <div className=\"flex gap-3 justify-start\">\r\n            <div className=\"flex-shrink-0 w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center\">\r\n              <Bot className=\"h-4 w-4 text-blue-600\" />\r\n            </div>\r\n            <div className=\"bg-gray-100 text-gray-800 rounded-2xl rounded-tl-none px-4 py-3\">\r\n              <div className=\"flex space-x-1\">\r\n                <div className=\"w-2 h-2 bg-gray-400 rounded-full animate-bounce\"></div>\r\n                <div className=\"w-2 h-2 bg-gray-400 rounded-full animate-bounce\" style={{ animationDelay: '0.2s' }}></div>\r\n                <div className=\"w-2 h-2 bg-gray-400 rounded-full animate-bounce\" style={{ animationDelay: '0.4s' }}></div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        )}\r\n\r\n        <div ref={messagesEndRef} />\r\n      </div>\r\n\r\n      <form onSubmit={handleSubmit} className=\"p-4 border-t border-gray-200\">\r\n        <div className=\"flex gap-2\">\r\n          <input\r\n            type=\"text\"\r\n            value={input}\r\n            onChange={(e) => setInput(e.target.value)}\r\n            placeholder={placeholder}\r\n            className=\"flex-1 border border-gray-300 rounded-full px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\"\r\n            disabled={isLoading}\r\n          />\r\n          <button\r\n            type=\"submit\"\r\n            className=\"bg-blue-500 hover:bg-blue-600 text-white rounded-full p-2 transition-colors disabled:opacity-50 disabled:cursor-not-allowed\"\r\n            disabled={isLoading || !input.trim()}\r\n          >\r\n            <Send className=\"h-5 w-5\" />\r\n          </button>\r\n        </div>\r\n      </form>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\ai\\components\\AIAssistantEnhanced.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'MessageSquare' is defined but never used. Allowed unused vars must match /^_/u.","line":4,"column":16,"nodeType":null,"messageId":"unusedVar","endLine":4,"endColumn":29},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'AlertCircle' is defined but never used. Allowed unused vars must match /^_/u.","line":4,"column":60,"nodeType":null,"messageId":"unusedVar","endLine":4,"endColumn":71},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'currentInput' is assigned a value but never used. Allowed unused vars must match /^_/u.","line":124,"column":11,"nodeType":null,"messageId":"unusedVar","endLine":124,"endColumn":23}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\r\n\r\nimport React, { useState, useRef, useEffect } from 'react';\r\nimport { Send, MessageSquare, Bot, User, Zap, Mic, MicOff, AlertCircle, Heart } from 'lucide-react';\r\n\rimport { logger } from '@/lib/logger';\n\ninterface Message {\r\n  role: 'user' | 'assistant';\r\n  content: string;\r\n  timestamp: Date;\r\n  sentiment?: {\r\n    sentiment: string;\r\n    score: number;\r\n    suggestions?: string[];\r\n  };\r\n}\r\n\r\ninterface AIAssistantEnhancedProps {\r\n  initialMessage?: string;\r\n  placeholder?: string;\r\n  title?: string;\r\n  className?: string;\r\n  userId?: string;\r\n}\r\n\r\nexport default function AIAssistantEnhanced({\r\n  initialMessage = \"в”ҳГ в•Әв–’в•ӘШөв•ӘШ°в•ӘШҜв”ҳГҜ! в•ӘШ«в”ҳВҶв•ӘШҜ в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘВ»в”ҳГў в•ӘШҜв”ҳВ„в•Әв–‘в”ҳГўв”ҳГЁ в”ҳВҒв”ҳГЁ в”ҳГ в”ҳВҶв•Әв•Ўв•ӘШұ в•ӘШів”ҳВҶв•ӘШҜв”ҳГӘв”ҳГЁ. в”ҳГўв”ҳГЁв”ҳВҒ в”ҳГЁв”ҳГ в”ҳГўв”ҳВҶв”ҳВҶв”ҳГЁ в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘВ»в•ӘШІв”ҳГў в•ӘШҜв”ҳВ„в”ҳГЁв”ҳГӘв”ҳГ в•ӘШ§\",\r\n  placeholder = \"в•ӘШҜв”ҳГўв•ӘШІв•ӘШ° в•Әв”Ӯв•ӘШ¬в•ӘШҜв”ҳВ„в”ҳГў в”ҳГ§в”ҳВҶв•ӘШҜ в•ӘШ«в”ҳГӘ в•ӘШҜв•Әв•ўв•Әв•‘в•Әв•– в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в”ҳГЁв”ҳГўв•Әв–’в”ҳГӘв”ҳВҒв”ҳГӘв”ҳВҶ в”ҳВ„в”ҳВ„в•ӘШІв•ӘШөв•ӘВ»в•ӘШі...\",\r\n  title = \"в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘВ» в•ӘШҜв”ҳВ„в•Әв–‘в”ҳГўв”ҳГЁ\",\r\n  className = \"\",\r\n  userId\r\n}: AIAssistantEnhancedProps) {\r\n  const [messages, setMessages] = useState<Message[]>([\r\n    {\r\n      role: 'assistant',\r\n      content: initialMessage,\r\n      timestamp: new Date()\r\n    }\r\n  ]);\r\n  const [input, setInput] = useState('');\r\n  const [isLoading, setIsLoading] = useState(false);\r\n  const [isListening, setIsListening] = useState(false);\r\n  const [sentimentAlert, setSentimentAlert] = useState<{ sentiment: string; suggestions?: string[] } | null>(null);\r\n  const messagesEndRef = useRef<HTMLDivElement>(null);\r\n  const recognitionRef = useRef<any>(null);\r\n\r\n  // Initialize speech recognition\r\n  useEffect(() => {\r\n    if (typeof window !== 'undefined' && 'webkitSpeechRecognition' in window) {\r\n      const SpeechRecognition = (window as any).webkitSpeechRecognition || (window as any).SpeechRecognition;\r\n      const recognition = new SpeechRecognition();\r\n      recognition.lang = 'ar-SA';\r\n      recognition.continuous = false;\r\n      recognition.interimResults = false;\r\n\r\n      recognition.onresult = (event: any) => {\r\n        const transcript = event.results[0][0].transcript;\r\n        setInput(transcript);\r\n        setIsListening(false);\r\n      };\r\n\r\n      recognition.onerror = (event: any) => {\r\n        logger.error('Speech recognition error:', event.error);\r\n        setIsListening(false);\r\n      };\r\n\r\n      recognition.onend = () => {\r\n        setIsListening(false);\r\n      };\r\n\r\n      recognitionRef.current = recognition;\r\n    }\r\n\r\n    return () => {\r\n      if (recognitionRef.current) {\r\n        recognitionRef.current.stop();\r\n      }\r\n    };\r\n  }, []);\r\n\r\n  // Scroll to bottom\r\n  const scrollToBottom = () => {\r\n    messagesEndRef.current?.scrollIntoView({ behavior: 'smooth' });\r\n  };\r\n\r\n  useEffect(() => {\r\n    scrollToBottom();\r\n  }, [messages]);\r\n\r\n  // Auto-hide sentiment alert\r\n  useEffect(() => {\r\n    if (sentimentAlert) {\r\n      const timer = setTimeout(() => setSentimentAlert(null), 10000);\r\n      return () => clearTimeout(timer);\r\n    }\r\n  }, [sentimentAlert]);\r\n\r\n  const startListening = () => {\r\n    if (recognitionRef.current && !isListening) {\r\n      setIsListening(true);\r\n      recognitionRef.current.start();\r\n    }\r\n  };\r\n\r\n  const stopListening = () => {\r\n    if (recognitionRef.current && isListening) {\r\n      recognitionRef.current.stop();\r\n      setIsListening(false);\r\n    }\r\n  };\r\n\r\n  const handleSubmit = async (e: React.FormEvent) => {\r\n    e.preventDefault();\r\n    if (!input.trim() || isLoading) return;\r\n\r\n    // Add user message\r\n    const userMessage: Message = {\r\n      role: 'user',\r\n      content: input,\r\n      timestamp: new Date()\r\n    };\r\n    setMessages(prev => [...prev, userMessage]);\r\n    const currentInput = input;\r\n    setInput('');\r\n    setIsLoading(true);\r\n\r\n    try {\r\n      // Send request to API\r\n      const response = await fetch('/api/ai/chat', {\r\n        method: 'POST',\r\n        headers: {\r\n          'Content-Type': 'application/json',\r\n        },\r\n        body: JSON.stringify({\r\n          messages: [...messages, userMessage].map(msg => ({\r\n            role: msg.role,\r\n            content: msg.content\r\n          })),\r\n          provider: 'gemini',\r\n          userId: userId\r\n        }),\r\n      });\r\n\r\n      if (!response.ok) {\r\n        throw new Error('в”ҳВҒв•Әв”Өв”ҳВ„в•ӘШІ в•Әв•Јв”ҳГ в”ҳВ„в”ҳГЁв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„ в•ӘШ°в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘВ» в•ӘШҜв”ҳВ„в•Әв–‘в”ҳГўв”ҳГЁ');\r\n      }\r\n\r\n      const data = await response.json();\r\n\r\n      // Show sentiment alert if negative sentiment detected\r\n      if (data.sentiment && (data.sentiment.sentiment === 'frustrated' || data.sentiment.sentiment === 'tired')) {\r\n        setSentimentAlert({\r\n          sentiment: data.sentiment.sentiment,\r\n          suggestions: data.sentiment.suggestions\r\n        });\r\n      }\r\n\r\n      // Add assistant response\r\n      const assistantMessage: Message = {\r\n        role: 'assistant',\r\n        content: data.message,\r\n        timestamp: new Date(),\r\n        sentiment: data.sentiment\r\n      };\r\n      setMessages(prev => [...prev, assistantMessage]);\r\n    } catch (error) {\r\n      logger.error('Error sending message:', error);\r\n\r\n      // Add error message\r\n      const errorMessage: Message = {\r\n        role: 'assistant',\r\n        content: 'в•Әв•Јв•Әв–‘в•Әв–’в•ӘШҜв”ҳГҜв•ӘГ® в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в”ҳГ в•Әв•Јв•ӘШҜв”ҳВ„в•ӘШҙв•ӘШұ в•Әв•–в”ҳВ„в•ӘШ°в”ҳГў. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ« в”ҳВ„в•ӘШҜв•ӘШөв”ҳГ©в•ӘШҜв”ҳГҜ.',\r\n        timestamp: new Date()\r\n      };\r\n      setMessages(prev => [...prev, errorMessage]);\r\n    } finally {\r\n      setIsLoading(false);\r\n    }\r\n  };\r\n\r\n  const formatTime = (date: Date) => {\r\n    return date.toLocaleTimeString('ar-EG', {\r\n      hour: '2-digit',\r\n      minute: '2-digit'\r\n    });\r\n  };\r\n\r\n  const getSentimentColor = (sentiment?: string) => {\r\n    switch (sentiment) {\r\n      case 'frustrated':\r\n        return 'bg-orange-100 text-orange-800 border-orange-300';\r\n      case 'tired':\r\n        return 'bg-yellow-100 text-yellow-800 border-yellow-300';\r\n      case 'positive':\r\n        return 'bg-green-100 text-green-800 border-green-300';\r\n      default:\r\n        return 'bg-gray-100 text-gray-800 border-gray-300';\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className={`bg-white rounded-xl shadow-lg flex flex-col h-full ${className}`}>\r\n      <div className=\"p-4 border-b border-gray-200\">\r\n        <div className=\"flex items-center gap-2\">\r\n          <div className=\"p-2 bg-blue-100 rounded-lg\">\r\n            <Bot className=\"h-5 w-5 text-blue-600\" />\r\n          </div>\r\n          <h3 className=\"font-bold text-lg text-gray-800\">{title}</h3>\r\n          <div className=\"ml-auto flex items-center gap-1 text-xs bg-green-100 text-green-800 px-2 py-1 rounded-full\">\r\n            <Zap className=\"h-3 w-3\" />\r\n            <span>Gemini 2.0 Flash</span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Sentiment Alert */}\r\n      {sentimentAlert && (\r\n        <div className={`mx-4 mt-2 p-3 rounded-lg border ${getSentimentColor(sentimentAlert.sentiment)} flex items-start gap-2`}>\r\n          <Heart className=\"h-5 w-5 flex-shrink-0 mt-0.5\" />\r\n          <div className=\"flex-1\">\r\n            <p className=\"font-semibold text-sm\">\r\n              {sentimentAlert.sentiment === 'frustrated' \r\n                ? 'в”ҳВҶв”ҳВ„в•ӘШҜв•ӘШөв•Әв•• в•ӘШ«в”ҳВҶв”ҳГў в•ӘШІв•ӘШ°в•ӘВ»в”ҳГӘ в”ҳГ в•ӘШөв•ӘШ°в•Әв•–в•ӘШҜв”ҳГҜ' \r\n                : 'в”ҳВҶв”ҳВ„в•ӘШҜв•ӘШөв•Әв•• в•ӘШ«в”ҳВҶв”ҳГў в•ӘШІв•ӘШ°в•ӘВ»в”ҳГӘ в”ҳГ в•ӘШІв•Әв•Јв•ӘШ°в•ӘШҜв”ҳГҜ'}\r\n            </p>\r\n            {sentimentAlert.suggestions && sentimentAlert.suggestions.length > 0 && (\r\n              <ul className=\"mt-1 text-xs list-disc list-inside\">\r\n                {sentimentAlert.suggestions.slice(0, 2).map((suggestion, idx) => (\r\n                  <li key={idx}>{suggestion}</li>\r\n                ))}\r\n              </ul>\r\n            )}\r\n          </div>\r\n          <button\r\n            onClick={() => setSentimentAlert(null)}\r\n            className=\"text-current opacity-70 hover:opacity-100\"\r\n          >\r\n            в”ңГ№\r\n          </button>\r\n        </div>\r\n      )}\r\n\r\n      <div className=\"flex-1 overflow-y-auto p-4 space-y-4 max-h-[400px]\">\r\n        {messages.map((message, index) => (\r\n          <div\r\n            key={index}\r\n            className={`flex gap-3 ${message.role === 'user' ? 'justify-end' : 'justify-start'}`}\r\n          >\r\n            {message.role === 'assistant' && (\r\n              <div className=\"flex-shrink-0 w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center\">\r\n                <Bot className=\"h-4 w-4 text-blue-600\" />\r\n              </div>\r\n            )}\r\n\r\n            <div\r\n              className={`max-w-[80%] rounded-2xl px-4 py-3 ${\r\n                message.role === 'user'\r\n                  ? 'bg-blue-500 text-white rounded-tr-none'\r\n                  : 'bg-gray-100 text-gray-800 rounded-tl-none'\r\n              }`}\r\n            >\r\n              <div className=\"text-sm\">{message.content}</div>\r\n              <div\r\n                className={`text-xs mt-1 flex items-center gap-2 ${\r\n                  message.role === 'user' ? 'text-blue-100' : 'text-gray-500'\r\n                }`}\r\n              >\r\n                <span>{formatTime(message.timestamp)}</span>\r\n                {message.sentiment && message.sentiment.sentiment === 'positive' && (\r\n                  <span className=\"text-green-600\">вүЎШ§ШЎГЁ</span>\r\n                )}\r\n              </div>\r\n            </div>\r\n\r\n            {message.role === 'user' && (\r\n              <div className=\"flex-shrink-0 w-8 h-8 rounded-full bg-blue-500 flex items-center justify-center\">\r\n                <User className=\"h-4 w-4 text-white\" />\r\n              </div>\r\n            )}\r\n          </div>\r\n        ))}\r\n\r\n        {isLoading && (\r\n          <div className=\"flex gap-3 justify-start\">\r\n            <div className=\"flex-shrink-0 w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center\">\r\n              <Bot className=\"h-4 w-4 text-blue-600\" />\r\n            </div>\r\n            <div className=\"bg-gray-100 text-gray-800 rounded-2xl rounded-tl-none px-4 py-3\">\r\n              <div className=\"flex space-x-1\">\r\n                <div className=\"w-2 h-2 bg-gray-400 rounded-full animate-bounce\"></div>\r\n                <div className=\"w-2 h-2 bg-gray-400 rounded-full animate-bounce\" style={{ animationDelay: '0.2s' }}></div>\r\n                <div className=\"w-2 h-2 bg-gray-400 rounded-full animate-bounce\" style={{ animationDelay: '0.4s' }}></div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        )}\r\n\r\n        <div ref={messagesEndRef} />\r\n      </div>\r\n\r\n      <form onSubmit={handleSubmit} className=\"p-4 border-t border-gray-200\">\r\n        <div className=\"flex gap-2\">\r\n          <input\r\n            type=\"text\"\r\n            value={input}\r\n            onChange={(e) => setInput(e.target.value)}\r\n            placeholder={placeholder}\r\n            className=\"flex-1 border border-gray-300 rounded-full px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\"\r\n            disabled={isLoading}\r\n          />\r\n          <button\r\n            type=\"button\"\r\n            onClick={isListening ? stopListening : startListening}\r\n            className={`rounded-full p-2 transition-colors ${\r\n              isListening \r\n                ? 'bg-red-500 hover:bg-red-600 text-white animate-pulse' \r\n                : 'bg-gray-200 hover:bg-gray-300 text-gray-700'\r\n            }`}\r\n            disabled={isLoading}\r\n            title={isListening ? 'в•ӘШӯв”ҳГЁв”ҳГ©в•ӘШҜв”ҳВҒ в•ӘШҜв”ҳВ„в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„' : 'в•ӘШ°в•ӘВ»в•ӘШ© в•ӘШҜв”ҳВ„в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв•Ўв”ҳГӘв•ӘШІв”ҳГЁ'}\r\n          >\r\n            {isListening ? <MicOff className=\"h-5 w-5\" /> : <Mic className=\"h-5 w-5\" />}\r\n          </button>\r\n          <button\r\n            type=\"submit\"\r\n            className=\"bg-blue-500 hover:bg-blue-600 text-white rounded-full p-2 transition-colors disabled:opacity-50 disabled:cursor-not-allowed\"\r\n            disabled={isLoading || !input.trim()}\r\n          >\r\n            <Send className=\"h-5 w-5\" />\r\n          </button>\r\n        </div>\r\n        {isListening && (\r\n          <p className=\"text-xs text-red-600 mt-2 text-center animate-pulse\">\r\n            вүЎШ§ВҺШ¬ в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв•ӘШІв”ҳГ в•ӘШҜв•Әв•Ј... в•ӘШІв•ӘШөв•ӘВ»в•ӘШі в•ӘШҜв”ҳВ„в•ӘШӘв”ҳВҶ\r\n          </p>\r\n        )}\r\n      </form>\r\n    </div>\r\n  );\r\n}\r\n\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\ai\\components\\ExamGenerator.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'useMemo' is defined but never used. Allowed unused vars must match /^_/u.","line":4,"column":40,"nodeType":null,"messageId":"unusedVar","endLine":4,"endColumn":47},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'getGeminiInfo' is defined but never used. Allowed unused vars must match /^_/u.","line":6,"column":10,"nodeType":null,"messageId":"unusedVar","endLine":6,"endColumn":23},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'AlertTitle' is defined but never used. Allowed unused vars must match /^_/u.","line":10,"column":35,"nodeType":null,"messageId":"unusedVar","endLine":10,"endColumn":45}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\r\n\"use client\";\r\n\r\nimport React, { useState, useCallback, useMemo } from 'react';\r\nimport { FileText, BookOpen, Calendar, Brain, Loader2, CheckCircle, Zap, AlertCircle, Save, X, RefreshCw } from 'lucide-react';\r\nimport { getGeminiInfo } from '@/lib/ai-config';\r\nimport { logger } from '@/lib/logger';\r\nimport { safeFetch } from \"@/lib/safe-client-utils\";\r\nimport { Button } from '@/components/ui/button';\r\nimport { Alert, AlertDescription, AlertTitle } from '@/components/ui/alert';\r\nimport { Input } from '@/components/ui/input';\r\nimport { Label } from '@/components/ui/label';\r\nimport { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';\r\n\r\ninterface Question {\r\n  question: string;\r\n  type: 'multiple_choice' | 'true_false' | 'short_answer';\r\n  options?: string[];\r\n  correctAnswer: string;\r\n  explanation: string;\r\n}\r\n\r\ninterface ExamGeneratorProps {\r\n  subjects: string[];\r\n  years: number[];\r\n  className?: string;\r\n}\r\n\r\nexport default function ExamGenerator({\r\n  subjects,\r\n  years,\r\n  className = \"\"\r\n}: ExamGeneratorProps) {\r\n  const [selectedSubject, setSelectedSubject] = useState('');\r\n  const [selectedYear, setSelectedYear] = useState('');\r\n  const [lesson, setLesson] = useState('');\r\n  const [difficulty, setDifficulty] = useState('');\r\n  const [questionCount, setQuestionCount] = useState(10);\r\n  const [isGenerating, setIsGenerating] = useState(false);\r\n  const [isSaving, setIsSaving] = useState(false);\r\n  const [examData, setExamData] = useState<{ examId?: string; questions?: Question[] } | null>(null);\r\n  const [error, setError] = useState('');\r\n  const [saveError, setSaveError] = useState('');\r\n  const [saveSuccess, setSaveSuccess] = useState(false);\r\n  const [retryCount, setRetryCount] = useState(0);\r\n\r\n  const handleSubmit = async (e: React.FormEvent) => {\r\n    e.preventDefault();\r\n    setError('');\r\n    setSaveError('');\r\n    setSaveSuccess(false);\r\n    \r\n    // Validation\r\n    if (!selectedSubject || !selectedYear || !lesson) {\r\n      setError('в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҙв•ӘШҜв•ӘШ© в”ҳГ в”ҳВ„в•ӘШ© в•ӘШҙв”ҳГ в”ҳГЁв•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШөв”ҳГ©в”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•–в”ҳВ„в”ҳГӘв•ӘШ°в•ӘШұ');\r\n      return;\r\n    }\r\n\r\n    if (lesson.trim().length < 3) {\r\n      setError('в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•Әв”Ӯ в”ҳГЁв•ӘШҙв•ӘШ° в•ӘШ«в”ҳВҶ в”ҳГЁв”ҳГўв”ҳГӘв”ҳВҶ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ©в”ҳВ„ 3 в•ӘШ«в•ӘШөв•Әв–’в”ҳВҒ');\r\n      return;\r\n    }\r\n\r\n    if (questionCount < 1 || questionCount > 50) {\r\n      setError('в•Әв•Јв•ӘВ»в•ӘВ» в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•ӘШ®в”ҳВ„в•ӘШұ в”ҳГЁв•ӘШҙв•ӘШ° в•ӘШ«в”ҳВҶ в”ҳГЁв”ҳГўв”ҳГӘв”ҳВҶ в•ӘШ°в”ҳГЁв”ҳВҶ 1 в”ҳГӘ 50');\r\n      return;\r\n    }\r\n\r\n    if (!difficulty && difficulty !== '') {\r\n      setError('в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҙв•ӘШҜв•ӘШ© в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’ в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГӘв”ҳГ« в•ӘШҜв”ҳВ„в•Әв•Ўв•Әв•Јв”ҳГӘв•ӘШ°в•ӘШұ');\r\n      return;\r\n    }\r\n\r\n    setIsGenerating(true);\r\n    setExamData(null);\r\n    setError('');\r\n    setSaveError('');\r\n    setSaveSuccess(false);\r\n\r\n    try {\r\n      const { data, error: responseError } = await safeFetch<{ examId?: string; questions?: Question[] }>(\r\n        '/api/ai/exam',\r\n        {\r\n          method: 'POST',\r\n          headers: {\r\n            'Content-Type': 'application/json',\r\n          },\r\n          body: JSON.stringify({\r\n            subject: selectedSubject,\r\n            year: selectedYear,\r\n            lesson: lesson.trim(),\r\n            difficulty: difficulty || undefined,\r\n            questionCount: Math.min(Math.max(1, questionCount), 50),\r\n            provider: 'gemini'\r\n          }),\r\n        },\r\n        null\r\n      );\r\n\r\n      if (responseError) {\r\n        const errorMessage = responseError.message || 'в”ҳВҒв•Әв”Өв”ҳВ„в•ӘШІ в•Әв•Јв”ҳГ в”ҳВ„в”ҳГЁв•ӘШұ в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ';\r\n        setError(errorMessage);\r\n        logger.error('Error generating exam:', responseError);\r\n        \r\n        // в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГЁв•ӘШұ в”ҳВҒв”ҳГЁ в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШ«в•ӘВ«в•Әв•–в•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•Әв”Өв•ӘШ°в”ҳГўв•ӘШұ\r\n        if (errorMessage.includes('network') || errorMessage.includes('timeout')) {\r\n          if (retryCount < 2) {\r\n            setTimeout(() => {\r\n              setRetryCount(prev => prev + 1);\r\n              handleSubmit(e as any);\r\n            }, 2000);\r\n          }\r\n        }\r\n      } else if (data) {\r\n        if (!data.questions || data.questions.length === 0) {\r\n          setError('в”ҳВ„в”ҳГ  в”ҳГЁв•ӘШІв”ҳГ  в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШ«в”ҳГЁ в•ӘШ«в•Әв”Ӯв•ӘШ®в”ҳВ„в•ӘШұ. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ«.');\r\n        } else {\r\n          setExamData(data);\r\n          setError('');\r\n          setRetryCount(0);\r\n        }\r\n      } else {\r\n        setError('в”ҳВ„в”ҳГ  в”ҳГЁв•ӘШІв”ҳГ  в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ«.');\r\n      }\r\n    } catch (err) {\r\n      logger.error('Error generating exam:', err);\r\n      setError(err instanceof Error ? err.message : 'в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв•Јв•Әв–’в”ҳГӘв”ҳВҒ');\r\n    } finally {\r\n      setIsGenerating(false);\r\n    }\r\n  };\r\n\r\n  const handleSaveExam = useCallback(async () => {\r\n    if (!examData?.questions || examData.questions.length === 0) {\r\n      setSaveError('в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в•ӘШ«в•Әв”Ӯв•ӘШ®в”ҳВ„в•ӘШұ в”ҳВ„в•ӘШөв”ҳВҒв•Әв••в”ҳГ§в•ӘШҜ');\r\n      return;\r\n    }\r\n\r\n    if (!selectedSubject || !selectedYear || !lesson) {\r\n      setSaveError('в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҙв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШІв•ӘШ«в”ҳГўв•ӘВ» в”ҳГ в”ҳВҶ в”ҳГ в”ҳВ„в•ӘШ© в•ӘШҙв”ҳГ в”ҳГЁв•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШөв”ҳГ©в”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•–в”ҳВ„в”ҳГӘв•ӘШ°в•ӘШұ');\r\n      return;\r\n    }\r\n\r\n    setIsSaving(true);\r\n    setSaveError('');\r\n    setSaveSuccess(false);\r\n\r\n    try {\r\n      // Create exam title\r\n      const examTitle = `в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ ${selectedSubject} - ${lesson} (${selectedYear})`;\r\n      \r\n      // First, create the exam record\r\n      const { data: examResult, error: examError } = await safeFetch<{ success: boolean; exam: { id: string } }>(\r\n        '/api/exams',\r\n        {\r\n          method: 'POST',\r\n          headers: {\r\n            'Content-Type': 'application/json',\r\n          },\r\n          body: JSON.stringify({\r\n            subject: selectedSubject,\r\n            title: examTitle,\r\n            year: parseInt(selectedYear),\r\n            url: '',\r\n            type: 'QUIZ'\r\n          }),\r\n        },\r\n        null\r\n      );\r\n\r\n      if (examError || !examResult?.success) {\r\n        throw new Error(examError?.message || 'в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•Әв”Ӯв•ӘШҙв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ');\r\n      }\r\n\r\n      setSaveSuccess(true);\r\n      setSaveError('');\r\n      \r\n      // Reset form after successful save\r\n      setTimeout(() => {\r\n        setExamData(null);\r\n        setSelectedSubject('');\r\n        setSelectedYear('');\r\n        setLesson('');\r\n        setDifficulty('');\r\n        setQuestionCount(10);\r\n        setSaveSuccess(false);\r\n      }, 2000);\r\n    } catch (err) {\r\n      logger.error('Error saving exam:', err);\r\n      setSaveError(err instanceof Error ? err.message : 'в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШөв”ҳВҒв•Әв•• в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ');\r\n    } finally {\r\n      setIsSaving(false);\r\n    }\r\n  }, [examData, selectedSubject, selectedYear, lesson]);\r\n\r\n  return (\r\n    <div className={`bg-white rounded-xl shadow-lg p-6 ${className}`}>\r\n      <div className=\"flex items-center gap-3 mb-6\">\r\n        <div className=\"p-2 bg-blue-100 rounded-lg\">\r\n          <FileText className=\"h-6 w-6 text-blue-600\" />\r\n        </div>\r\n        <h2 className=\"text-xl font-bold text-gray-800\">в”ҳГ в”ҳВҶв•Әв”Өв•ӘШ® в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•Әв–‘в”ҳГўв”ҳГЁ</h2>\r\n        <div className=\"ml-auto flex items-center gap-1 text-xs bg-green-100 text-green-800 px-2 py-1 rounded-full\">\r\n          <Zap className=\"h-3 w-3\" />\r\n          <span>Gemini 2.0 Flash</span>\r\n        </div>\r\n      </div>\r\n\r\n      {!examData ? (\r\n        <form onSubmit={handleSubmit} className=\"space-y-4\">\r\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\r\n            <div>\r\n              <Label htmlFor=\"selectedSubject\" className=\"mb-1\">\r\n                в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ <span className=\"text-red-500\">*</span>\r\n              </Label>\r\n              <div className=\"relative\">\r\n                <div className=\"absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none z-10\">\r\n                  <BookOpen className=\"h-5 w-5 text-gray-400\" aria-hidden=\"true\" />\r\n                </div>\r\n                <Select\r\n                  value={selectedSubject}\r\n                  onValueChange={setSelectedSubject}\r\n                  required\r\n                >\r\n                  <SelectTrigger className=\"pl-10\" id=\"selectedSubject\" aria-label=\"в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ\">\r\n                    <SelectValue placeholder=\"в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ\" />\r\n                  </SelectTrigger>\r\n                  <SelectContent>\r\n                    {subjects.map((subject) => (\r\n                      <SelectItem key={subject} value={subject}>\r\n                        {subject}\r\n                      </SelectItem>\r\n                    ))}\r\n                  </SelectContent>\r\n                </Select>\r\n              </div>\r\n            </div>\r\n\r\n            <div>\r\n              <Label htmlFor=\"selectedYear\" className=\"mb-1\">\r\n                в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВҶв•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв”ҳГЁв•ӘШұ <span className=\"text-red-500\">*</span>\r\n              </Label>\r\n              <div className=\"relative\">\r\n                <div className=\"absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none z-10\">\r\n                  <Calendar className=\"h-5 w-5 text-gray-400\" aria-hidden=\"true\" />\r\n                </div>\r\n                <Select\r\n                  value={selectedYear}\r\n                  onValueChange={setSelectedYear}\r\n                  required\r\n                >\r\n                  <SelectTrigger className=\"pl-10\" id=\"selectedYear\" aria-label=\"в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВҶв•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв”ҳГЁв•ӘШұ\">\r\n                    <SelectValue placeholder=\"в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВҶв•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв”ҳГЁв•ӘШұ\" />\r\n                  </SelectTrigger>\r\n                  <SelectContent>\r\n                    {years.map((year) => (\r\n                      <SelectItem key={year} value={String(year)}>\r\n                        {year}\r\n                      </SelectItem>\r\n                    ))}\r\n                  </SelectContent>\r\n                </Select>\r\n              </div>\r\n            </div>\r\n\r\n            <div>\r\n              <Label htmlFor=\"lesson\" className=\"mb-1\">\r\n                в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•Әв”Ӯ <span className=\"text-red-500\">*</span>\r\n              </Label>\r\n              <Input\r\n                id=\"lesson\"\r\n                type=\"text\"\r\n                value={lesson}\r\n                onChange={(e) => setLesson(e.target.value)}\r\n                placeholder=\"в•ӘШ«в•ӘВ»в•ӘВ«в”ҳВ„ в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•Әв”Ӯ\"\r\n                required\r\n                minLength={3}\r\n                maxLength={200}\r\n              />\r\n            </div>\r\n\r\n            <div>\r\n              <Label htmlFor=\"difficulty\" className=\"mb-1\">\r\n                в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГӘв”ҳГ« в•ӘШҜв”ҳВ„в•Әв•Ўв•Әв•Јв”ҳГӘв•ӘШ°в•ӘШұ (в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’в”ҳГЁ)\r\n              </Label>\r\n              <Select\r\n                value={difficulty}\r\n                onValueChange={setDifficulty}\r\n              >\r\n                <SelectTrigger id=\"difficulty\" aria-label=\"в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГӘв”ҳГ« в•ӘШҜв”ҳВ„в•Әв•Ўв•Әв•Јв”ҳГӘв•ӘШ°в•ӘШұ\">\r\n                  <SelectValue placeholder=\"в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГӘв”ҳГ« в•ӘШҜв”ҳВ„в•Әв•Ўв•Әв•Јв”ҳГӘв•ӘШ°в•ӘШұ\" />\r\n                </SelectTrigger>\r\n                <SelectContent>\r\n                  <SelectItem value=\"\">в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГӘв”ҳГ« в•ӘШҜв”ҳВ„в•Әв•Ўв•Әв•Јв”ҳГӘв•ӘШ°в•ӘШұ</SelectItem>\r\n                  <SelectItem value=\"в•Әв”Ӯв”ҳГ§в”ҳВ„\">в•Әв”Ӯв”ҳГ§в”ҳВ„</SelectItem>\r\n                  <SelectItem value=\"в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•–\">в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•–</SelectItem>\r\n                  <SelectItem value=\"в•Әв•Ўв•Әв•Јв•ӘШ°\">в•Әв•Ўв•Әв•Јв•ӘШ°</SelectItem>\r\n                </SelectContent>\r\n              </Select>\r\n            </div>\r\n\r\n            <div>\r\n              <Label htmlFor=\"questionCount\" className=\"mb-1\">\r\n                в•Әв•Јв•ӘВ»в•ӘВ» в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•ӘШ®в”ҳВ„в•ӘШұ\r\n              </Label>\r\n              <Input\r\n                id=\"questionCount\"\r\n                type=\"number\"\r\n                min=\"1\"\r\n                max=\"50\"\r\n                value={questionCount}\r\n                onChange={(e) => setQuestionCount(Math.max(1, Math.min(50, parseInt(e.target.value) || 10)))}\r\n                aria-label=\"в•Әв•Јв•ӘВ»в•ӘВ» в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•ӘШ®в”ҳВ„в•ӘШұ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ\"\r\n              />\r\n            </div>\r\n          </div>\r\n\r\n          {error && (\r\n            <Alert variant=\"destructive\" className=\"flex items-start gap-2\" role=\"alert\">\r\n              <AlertCircle className=\"h-5 w-5 mt-0.5 flex-shrink-0\" aria-hidden=\"true\" />\r\n              <div className=\"flex-1\">\r\n                <AlertDescription>{error}</AlertDescription>\r\n                {error.includes('network') || error.includes('timeout') ? (\r\n                  <Button\r\n                    variant=\"outline\"\r\n                    size=\"sm\"\r\n                    onClick={() => {\r\n                      setRetryCount(0);\r\n                      handleSubmit({ preventDefault: () => {} } as React.FormEvent);\r\n                    }}\r\n                    className=\"mt-2\"\r\n                  >\r\n                    <RefreshCw className=\"h-4 w-4 mr-2\" />\r\n                    в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ\r\n                  </Button>\r\n                ) : null}\r\n              </div>\r\n            </Alert>\r\n          )}\r\n\r\n          <button\r\n            type=\"submit\"\r\n            disabled={isGenerating}\r\n            className=\"w-full bg-blue-500 hover:bg-blue-600 text-white font-medium py-2 px-4 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2\"\r\n          >\r\n            {isGenerating ? (\r\n              <>\r\n                <Loader2 className=\"h-5 w-5 animate-spin\" />\r\n                в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ...\r\n              </>\r\n            ) : (\r\n              <>\r\n                <Brain className=\"h-5 w-5\" />\r\n                в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ\r\n              </>\r\n            )}\r\n          </button>\r\n        </form>\r\n      ) : (\r\n        <div className=\"space-y-6\">\r\n          <div className=\"flex items-center gap-2 text-green-600\">\r\n            <CheckCircle className=\"h-5 w-5\" />\r\n            <span className=\"font-medium\">в•ӘШІв”ҳГ  в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө!</span>\r\n          </div>\r\n\r\n          <div className=\"border border-gray-200 rounded-lg p-4\">\r\n            <h3 className=\"font-medium text-gray-800 mb-3\">в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•ӘШ®в”ҳВ„в•ӘШұ ({examData.questions?.length || 0})</h3>\r\n            <div className=\"space-y-4 max-h-96 overflow-y-auto pr-2\">\r\n              {examData.questions?.map((question, index) => (\r\n                <div key={index} className=\"border border-gray-200 rounded-lg p-4\">\r\n                  <div className=\"flex items-start gap-3\">\r\n                    <div className=\"flex-shrink-0 w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 font-medium\">\r\n                      {index + 1}\r\n                    </div>\r\n                    <div className=\"flex-1\">\r\n                      <p className=\"font-medium text-gray-800 mb-2\">{question.question}</p>\r\n\r\n                      {question.type === 'multiple_choice' && question.options && (\r\n                        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-2 mb-3\">\r\n                          {question.options.map((option, i) => (\r\n                            <div\r\n                              key={i}\r\n                              className={`p-2 rounded-lg border ${\r\n                                option === question.correctAnswer\r\n                                  ? 'border-green-500 bg-green-50'\r\n                                  : 'border-gray-200'\r\n                              }`}\r\n                            >\r\n                              {option}\r\n                            </div>\r\n                          ))}\r\n                        </div>\r\n                      )}\r\n\r\n                      {question.type === 'true_false' && (\r\n                        <div className=\"flex gap-4 mb-3\">\r\n                          <div\r\n                            className={`p-2 rounded-lg border ${\r\n                              question.correctAnswer === 'в•Әв•Ўв•ӘШө'\r\n                                ? 'border-green-500 bg-green-50'\r\n                                : 'border-gray-200'\r\n                            }`}\r\n                          >\r\n                            в•Әв•Ўв•ӘШө\r\n                          </div>\r\n                          <div\r\n                            className={`p-2 rounded-lg border ${\r\n                              question.correctAnswer === 'в•ӘВ«в•Әв•–в•ӘШ«'\r\n                                ? 'border-green-500 bg-green-50'\r\n                                : 'border-gray-200'\r\n                            }`}\r\n                          >\r\n                            в•ӘВ«в•Әв•–в•ӘШ«\r\n                          </div>\r\n                        </div>\r\n                      )}\r\n\r\n                      <div className=\"bg-blue-50 p-3 rounded-lg\">\r\n                        <p className=\"text-sm font-medium text-blue-800 mb-1\">в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШҙв•ӘШҜв•ӘШ°в•ӘШұ в•ӘШҜв”ҳВ„в•Әв•Ўв•ӘШөв”ҳГЁв•ӘШөв•ӘШұ:</p>\r\n                        <p className=\"text-blue-700\">{question.correctAnswer}</p>\r\n                        {question.explanation && (\r\n                          <>\r\n                            <p className=\"text-sm font-medium text-blue-800 mt-2 mb-1\">в•ӘШҜв”ҳВ„в•Әв”Өв•Әв–’в•ӘШө:</p>\r\n                            <p className=\"text-blue-700\">{question.explanation}</p>\r\n                          </>\r\n                        )}\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n              ))}\r\n            </div>\r\n          </div>\r\n\r\n          {saveSuccess && (\r\n            <Alert className=\"bg-green-50 border-green-200 text-green-800 flex items-center gap-2\">\r\n              <CheckCircle className=\"h-5 w-5 flex-shrink-0\" />\r\n              <AlertDescription>в•ӘШІв”ҳГ  в•ӘШөв”ҳВҒв•Әв•• в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө!</AlertDescription>\r\n            </Alert>\r\n          )}\r\n\r\n          {saveError && (\r\n            <Alert variant=\"destructive\" className=\"flex items-start gap-2\">\r\n              <AlertCircle className=\"h-5 w-5 mt-0.5 flex-shrink-0\" />\r\n              <AlertDescription>{saveError}</AlertDescription>\r\n            </Alert>\r\n          )}\r\n\r\n          <div className=\"flex gap-3\">\r\n            <Button\r\n              onClick={() => {\r\n                setExamData(null);\r\n                setError('');\r\n                setSaveError('');\r\n                setSaveSuccess(false);\r\n              }}\r\n              variant=\"outline\"\r\n              className=\"flex-1\"\r\n              disabled={isSaving}\r\n            >\r\n              <X className=\"h-4 w-4 mr-2\" />\r\n              в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»\r\n            </Button>\r\n            <Button \r\n              onClick={handleSaveExam}\r\n              className=\"flex-1\"\r\n              disabled={isSaving || !examData?.questions || examData.questions.length === 0}\r\n            >\r\n              {isSaving ? (\r\n                <>\r\n                  <Loader2 className=\"h-4 w-4 mr-2 animate-spin\" />\r\n                  в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШөв”ҳВҒв•Әв••...\r\n                </>\r\n              ) : (\r\n                <>\r\n                  <Save className=\"h-4 w-4 mr-2\" />\r\n                  в•ӘШөв”ҳВҒв•Әв•• в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ\r\n                </>\r\n              )}\r\n            </Button>\r\n          </div>\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\ai\\components\\TeacherSearch.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'getGeminiInfo' is defined but never used. Allowed unused vars must match /^_/u.","line":6,"column":10,"nodeType":null,"messageId":"unusedVar","endLine":6,"endColumn":23}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\r\n\"use client\";\r\n\r\nimport React, { useState } from 'react';\r\nimport { Search, User, Star, ExternalLink, Youtube, Loader2, BookOpen, Zap } from 'lucide-react';\r\nimport { getGeminiInfo } from '@/lib/ai-config';\r\n\rimport { logger } from '@/lib/logger';\n\ninterface Teacher {\r\n  name: string;\r\n  subject: string;\r\n  url?: string;\r\n  description?: string;\r\n  rating?: number;\r\n  thumbnail?: string;\r\n}\r\n\r\ninterface TeacherSearchProps {\r\n  subjects: string[];\r\n  platforms?: string[];\r\n  className?: string;\r\n}\r\n\r\nexport default function TeacherSearch({\r\n  subjects,\r\n  platforms = ['в”ҳГЁв”ҳГӘв•ӘШІв”ҳГЁв”ҳГӘв•ӘШ°', 'в”ҳГ в”ҳВҶв•Әв•Ўв•ӘШұ в•ӘВ»в•Әв–’в”ҳГӘв•Әв”Ӯ', 'в”ҳГ в”ҳВҶв•Әв•Ўв•ӘШұ в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯв•ӘШІв”ҳГЁ', 'в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ«'],\r\n  className = \"\"\r\n}: TeacherSearchProps) {\r\n  const [selectedSubject, setSelectedSubject] = useState('');\r\n  const [keywords, setKeywords] = useState('');\r\n  const [selectedPlatform, setSelectedPlatform] = useState('');\r\n  const [isSearching, setIsSearching] = useState(false);\r\n  const [teachers, setTeachers] = useState<{\r\n    localTeachers: Teacher[];\r\n    aiTeachers: Teacher[];\r\n    youtubeResults: Teacher[];\r\n  } | null>(null);\r\n  const [error, setError] = useState('');\r\n\r\n  const handleSubmit = async (e: React.FormEvent) => {\r\n    e.preventDefault();\r\n    if (!selectedSubject) {\r\n      setError('в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҙв•ӘШҜв•ӘШ© в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ');\r\n      return;\r\n    }\r\n\r\n    setIsSearching(true);\r\n    setError('');\r\n    setTeachers(null);\r\n\r\n    try {\r\n      const response = await fetch('/api/ai/teachers', {\r\n        method: 'POST',\r\n        headers: {\r\n          'Content-Type': 'application/json',\r\n        },\r\n        body: JSON.stringify({\r\n          subject: selectedSubject,\r\n          keywords: keywords || undefined,\r\n          platform: selectedPlatform || undefined,\r\n          provider: 'gemini' // в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в•ӘШҜв”ҳГ  Gemini в”ҳГўв•ӘВ«в”ҳГЁв•ӘШҜв•Әв–’ в•ӘШҜв”ҳВҒв•ӘШІв•Әв–’в•ӘШҜв•Әв•ўв”ҳГЁ\r\n        }),\r\n      });\r\n\r\n      if (!response.ok) {\r\n        let errorMessage = 'в”ҳВҒв•Әв”Өв”ҳВ„в•ӘШІ в•Әв•Јв”ҳГ в”ҳВ„в”ҳГЁв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШөв•ӘШі в•Әв•Јв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯв”ҳГЁв”ҳВҶ';\r\n        \r\n        try {\r\n          const errorData = await response.json();\r\n          if (errorData && errorData.error) {\r\n            errorMessage = errorData.error;\r\n          }\r\n        } catch (e) {\r\n          logger.error('Error parsing error response:', e);\r\n          // в•ӘШӯв•Әв–‘в•ӘШҜ в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШІв•ӘШөв”ҳВ„в”ҳГЁв”ҳВ„ в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘШҙв•ӘШҜв•ӘШ°в•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ«в•Әв•–в•ӘШ«в•ӘГ® в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„в•ӘШұ в•Әв•Јв•ӘШҜв”ҳГ в•ӘШұ в•ӘШ°в”ҳВҶв•ӘШҜв•ӘШ©в”ҳГҜ в•Әв•Јв”ҳВ„в”ҳГ« в•Әв–’в”ҳГ в•Әв–“ в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ\r\n          if (response.status === 401) {\r\n            errorMessage = 'в”ҳГ в•Әв”Өв”ҳГўв”ҳВ„в•ӘШұ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Ўв•ӘШҜв•ӘВ»в”ҳГ©в•ӘШұ. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ«.';\r\n          } else if (response.status === 403) {\r\n            errorMessage = 'в”ҳГ в”ҳВҒв•ӘШІв•ӘШҜв•ӘШө API в”ҳВ„в”ҳВҖ Google Gemini в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в”ҳГ§в”ҳГЁв•ӘШ«. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в•ӘШІв”ҳГӘв•ӘШҜв•Әв•Ўв”ҳВ„ в”ҳГ в•Әв•Ј в”ҳВҒв•Әв–’в”ҳГЁв”ҳГ© в•ӘШҜв”ҳВ„в•ӘВ»в•Әв•Јв”ҳГ .';\r\n          } else if (response.status === 500) {\r\n            errorMessage = 'в”ҳГ в•Әв”Өв”ҳГўв”ҳВ„в•ӘШұ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШҜв•ӘВ»в”ҳГ . в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ« в”ҳВ„в•ӘШҜв•ӘШөв”ҳГ©в•ӘШҜв”ҳГҜ.';\r\n          } else if (response.status === 429) {\r\n            errorMessage = 'в•ӘШІв”ҳГ  в•ӘШІв•ӘШҙв•ӘШҜв”ҳГӘв•Әв–“ в•ӘШөв•ӘВ» в•ӘШҜв”ҳВ„в•Әв•–в”ҳВ„в•ӘШ°в•ӘШҜв•ӘШІ. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ« в•ӘШ°в•Әв•Јв•ӘВ» в”ҳГ©в”ҳВ„в”ҳГЁв”ҳВ„.';\r\n          }\r\n        }\r\n        \r\n        // в”ҳВ„в•ӘШҜ в•ӘШІв•Әв–’в”ҳГ в”ҳГЁ в•ӘШҜв”ҳВ„в•ӘВ«в•Әв•–в•ӘШ« в”ҳГ§в”ҳВҶв•ӘШҜв•ӘГ® в•ӘШ°в”ҳВ„ в”ҳГ©в”ҳГ  в•ӘШ°в•ӘШІв•Әв•Јв”ҳГЁв”ҳГЁв”ҳВҶв”ҳГ§ в”ҳГ в•ӘШ°в•ӘШҜв•Әв”Өв•Әв–’в•ӘШұ\r\n        setError(errorMessage);\r\n        setIsSearching(false);\r\n        return;\r\n      }\r\n\r\n      let data;\r\n      try {\r\n        data = await response.json();\r\n        \r\n        // в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в”ҳГ в”ҳВҶ в•ӘШ«в”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШІв•ӘШөв•ӘШІв”ҳГӘв”ҳГЁ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•ӘШөв”ҳГ©в”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•–в”ҳВ„в”ҳГӘв•ӘШ°в•ӘШұ\r\n        if (!data || (typeof data !== 'object')) {\r\n          throw new Error('в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•Әв•‘в”ҳГЁв•Әв–’ в•Әв•Ўв•ӘШҜв”ҳВ„в•ӘШөв•ӘШұ в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШҜв•ӘВ»в”ҳГ ');\r\n        }\r\n        \r\n        // в•ӘШҜв”ҳВ„в•ӘШІв•ӘШ«в”ҳГўв•ӘВ» в”ҳГ в”ҳВҶ в”ҳГӘв•ӘШҙв”ҳГӘв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШөв”ҳГ©в”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•ӘШҜв•Әв”Ӯв”ҳГЁв•ӘШұ\r\n        if (!data.localTeachers || !data.aiTeachers || !data.youtubeResults) {\r\n          // в•ӘШӯв•Әв–‘в•ӘШҜ в”ҳГўв•ӘШҜв”ҳВҶв•ӘШІ в”ҳГ§в”ҳВҶв•ӘШҜв”ҳГў в•ӘШөв”ҳГ©в”ҳГӘв”ҳВ„ в”ҳГ в”ҳВҒв”ҳГ©в”ҳГӘв•ӘВ»в•ӘШұв•ӘГ® в”ҳГ©в”ҳГ  в•ӘШ°в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ®в”ҳГ§в•ӘШҜ\r\n          data.localTeachers = data.localTeachers || [];\r\n          data.aiTeachers = data.aiTeachers || [];\r\n          data.youtubeResults = data.youtubeResults || [];\r\n        }\r\n        \r\n        setTeachers(data);\r\n      } catch (parseError) {\r\n        logger.error('Error parsing response data:', parseError);\r\n        setError('в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в”ҳВҒв”ҳГЁ в•ӘШІв•ӘШөв”ҳВ„в”ҳГЁв”ҳВ„ в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘШҙв•ӘШҜв•ӘШ°в•ӘШұ. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ«.');\r\n        setIsSearching(false);\r\n        return;\r\n      }\r\n    } catch (err) {\r\n      logger.error('Error searching teachers:', err);\r\n      let errorMessage = 'в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв•Јв•Әв–’в”ҳГӘв”ҳВҒ';\r\n      \r\n      if (err instanceof Error) {\r\n        errorMessage = err.message;\r\n        \r\n        // в•ӘШІв•ӘШөв•Әв”Ӯв”ҳГЁв”ҳВҶ в•Әв–’в•Әв”Ӯв•ӘШҜв•ӘШ®в”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ«в•Әв•–в•ӘШ« в•ӘШҜв”ҳВ„в•Әв”Өв•ӘШҜв•ӘШ®в•Әв•Јв•ӘШұ\r\n        if (errorMessage.includes('API key') || errorMessage.includes('в”ҳГ в”ҳВҒв•ӘШІв•ӘШҜв•ӘШө API')) {\r\n          errorMessage = 'в”ҳГ в”ҳВҒв•ӘШІв•ӘШҜв•ӘШө API в”ҳВ„в”ҳВҖ Google Gemini в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в”ҳГ§в”ҳГЁв•ӘШ«. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в•ӘШІв”ҳГӘв•ӘШҜв•Әв•Ўв”ҳВ„ в”ҳГ в•Әв•Ј в”ҳВҒв•Әв–’в”ҳГЁв”ҳГ© в•ӘШҜв”ҳВ„в•ӘВ»в•Әв•Јв”ҳГ  в”ҳВ„в•ӘШөв”ҳВ„ в”ҳГ§в•Әв–‘в”ҳГ§ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Өв”ҳГўв”ҳВ„в•ӘШұ.';\r\n        } else if (errorMessage.includes('fetch')) {\r\n          errorMessage = 'в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„ в•ӘШ°в•ӘВ«в•ӘВ»в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•Әв–‘в”ҳГўв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШҜв•Әв•Ўв•Әв•–в”ҳВҶв•ӘШҜв•Әв•Јв”ҳГЁ. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в”ҳГ в”ҳВҶ в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШІв•Әв–’в”ҳВҶв•ӘШІ в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ«.';\r\n        }\r\n      }\r\n      \r\n      setError(errorMessage);\r\n    } finally {\r\n      setIsSearching(false);\r\n    }\r\n  };\r\n\r\n  const renderStars = (rating?: number) => {\r\n    if (!rating) return null;\r\n\r\n    return (\r\n      <div className=\"flex items-center gap-1\">\r\n        {[...Array(5)].map((_, i) => (\r\n          <Star\r\n            key={i}\r\n            className={`h-4 w-4 ${\r\n              i < Math.floor(rating) ? 'text-yellow-400 fill-yellow-400' : 'text-gray-300'\r\n            }`}\r\n          />\r\n        ))}\r\n        <span className=\"text-sm text-gray-600 ml-1\">{rating.toFixed(1)}</span>\r\n      </div>\r\n    );\r\n  };\r\n\r\n  const renderTeacherCard = (teacher: Teacher, source: string) => (\r\n    <div key={`${teacher.name}-${source}`} className=\"border border-gray-200 rounded-lg p-4 hover:shadow-md transition-shadow\">\r\n      <div className=\"flex items-start gap-4\">\r\n        {teacher.thumbnail ? (\r\n          <img\r\n            src={teacher.thumbnail}\r\n            alt={teacher.name}\r\n            className=\"w-16 h-16 rounded-lg object-cover\"\r\n          />\r\n        ) : (\r\n       