components/ui/progress\";\r\nimport { RadioGroup, RadioGroupItem } from '@/components/ui/radio-group';\r\nimport { Checkbox } from '@/components/ui/checkbox';\r\nimport { Badge } from \"@/components/ui/badge\";\r\nimport { AlertCircle, CheckCircle, Clock, BookOpen, Brain, Lightbulb, Award } from 'lucide-react';\r\nimport { Alert, AlertDescription, AlertTitle } from '@/components/ui/alert';\r\n\r\nimport { logger } from '@/lib/logger';\r\n\r\ninterface Question {\r\n  id: string;\r\n  text: string;\r\n  type: 'multiple-choice' | 'true-false' | 'short-answer' | 'essay';\r\n  options?: string[];\r\n  correctAnswer?: string | string[];\r\n  explanation?: string;\r\n  difficulty: 'easy' | 'medium' | 'hard';\r\n  points: number;\r\n}\r\n\r\ninterface Test {\r\n  id: string;\r\n  title: string;\r\n  subject: string;\r\n  questions: Question[];\r\n  timeLimit?: number; // in minutes\r\n  createdAt: Date;\r\n}\r\n\r\ninterface Answer {\r\n  questionId: string;\r\n  value: string | string[];\r\n}\r\n\r\ninterface TestResult {\r\n  testId: string;\r\n  answers: Answer[];\r\n  score: number;\r\n  totalPoints: number;\r\n  timeSpent: number; // in seconds\r\n  completedAt: Date;\r\n  feedback: {\r\n    correctAnswers: number;\r\n    incorrectAnswers: number;\r\n    strengths: string[];\r\n    improvementAreas: string[];\r\n    recommendations: string[];\r\n  };\r\n}\r\n\r\nconst subjects = [\r\n  { value: 'math', label: 'в•ӘШҜв”ҳВ„в•Әв–’в”ҳГЁв•ӘШҜв•Әв•ўв”ҳГЁв•ӘШҜв•ӘШІ' },\r\n  { value: 'science', label: 'в•ӘШҜв”ҳВ„в•Әв•Јв”ҳВ„в”ҳГӘв”ҳГ ' },\r\n  { value: 'history', label: 'в•ӘШҜв”ҳВ„в•ӘШІв•ӘШҜв•Әв–’в”ҳГЁв•ӘВ«' },\r\n  { value: 'arabic', label: 'в•ӘШҜв”ҳВ„в”ҳВ„в•Әв•‘в•ӘШұ в•ӘШҜв”ҳВ„в•Әв•Јв•Әв–’в•ӘШ°в”ҳГЁв•ӘШұ' },\r\n  { value: 'english', label: 'в•ӘШҜв”ҳВ„в”ҳВ„в•Әв•‘в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШҙв”ҳВ„в”ҳГЁв•Әв–“в”ҳГЁв•ӘШұ' },\r\n  { value: 'physics', label: 'в•ӘШҜв”ҳВ„в”ҳВҒв”ҳГЁв•Әв–“в”ҳГЁв•ӘШҜв•ӘШ©' },\r\n  { value: 'chemistry', label: 'в•ӘШҜв”ҳВ„в”ҳГўв”ҳГЁв”ҳГ в”ҳГЁв•ӘШҜв•ӘШ©' },\r\n  { value: 'biology', label: 'в•ӘШҜв”ҳВ„в•ӘШ«в•ӘШөв”ҳГЁв•ӘШҜв•ӘШ©' },\r\n  { value: 'computer', label: 'в•Әв•Јв”ҳВ„в”ҳГӘв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв•Әв”Ӯв•ӘШ°' },\r\n];\r\n\r\nconst difficultyLevels = [\r\n  { value: 'easy', label: 'в•Әв”Ӯв”ҳГ§в”ҳВ„' },\r\n  { value: 'medium', label: 'в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•–' },\r\n  { value: 'hard', label: 'в•Әв•Ўв•Әв•Јв•ӘШ°' },\r\n  { value: 'mixed', label: 'в”ҳГ в•ӘВ«в•ӘШІв”ҳВ„в•Әв•–' },\r\n];\r\n\r\nconst questionTypes = [\r\n  { value: 'multiple-choice', label: 'в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’ в”ҳГ в”ҳВҶ в”ҳГ в•ӘШІв•Әв•Јв•ӘВ»в•ӘВ»' },\r\n  { value: 'true-false', label: 'в•Әв•Ўв•ӘШө/в•ӘВ«в•Әв•–в•ӘШ«' },\r\n  { value: 'short-answer', label: 'в•ӘШӯв•ӘШҙв•ӘШҜв•ӘШ°в•ӘШұ в”ҳГ©в•Әв•Ўв”ҳГЁв•Әв–’в•ӘШұ' },\r\n  { value: 'essay', label: 'в”ҳГ в”ҳГ©в•ӘШҜв”ҳВ„' },\r\n];\r\n\r\nexport default function TestPage() {\r\n  const [testConfig, setTestConfig] = useState({\r\n    subject: '',\r\n    difficulty: 'mixed' as 'easy' | 'medium' | 'hard' | 'mixed',\r\n    questionCount: 10,\r\n    questionTypes: ['multiple-choice'] as string[],\r\n    timeLimit: 30,\r\n  });\r\n\r\n  const [test, setTest] = useState<Test | null>(null);\r\n  const [currentQuestionIndex, setCurrentQuestionIndex] = useState(0);\r\n  const [answers, setAnswers] = useState<Answer[]>([]);\r\n  const [testState, setTestState] = useState<'config' | 'loading' | 'in-progress' | 'completed'>('config');\r\n  const [timeRemaining, setTimeRemaining] = useState(0);\r\n  const [testResult, setTestResult] = useState<TestResult | null>(null);\r\n  const [isGenerating, setIsGenerating] = useState(false);\r\n  const [generationProgress, setGenerationProgress] = useState(0);\r\n\r\n  // Handle timer\r\n  useEffect(() => {\r\n    let timer: NodeJS.Timeout;\r\n    if (testState === 'in-progress' && timeRemaining > 0) {\r\n      timer = setTimeout(() => {\r\n        setTimeRemaining(timeRemaining - 1);\r\n      }, 1000);\r\n    } else if (testState === 'in-progress' && timeRemaining === 0) {\r\n      handleSubmitTest();\r\n    }\r\n    return () => clearTimeout(timer);\r\n  }, [testState, timeRemaining]);\r\n\r\n  const handleGenerateTest = async () => {\r\n    setIsGenerating(true);\r\n    setTestState('loading');\r\n    setGenerationProgress(0);\r\n\r\n    // Simulate progress\r\n    const progressInterval = setInterval(() => {\r\n      setGenerationProgress(prev => {\r\n        if (prev >= 90) {\r\n          clearInterval(progressInterval);\r\n          return 90;\r\n        }\r\n        return prev + 10;\r\n      });\r\n    }, 300);\r\n\r\n    try {\r\n      // API call to generate test with AI\r\n      const response = await fetch('/api/generate-test', {\r\n        method: 'POST',\r\n        headers: {\r\n          'Content-Type': 'application/json',\r\n        },\r\n        body: JSON.stringify(testConfig),\r\n      });\r\n\r\n      if (!response.ok) {\r\n        throw new Error('Failed to generate test');\r\n      }\r\n\r\n      const data = await response.json();\r\n      const newTest = data.test as Test;\r\n\r\n      setTest(newTest);\r\n      setAnswers([]);\r\n      setCurrentQuestionIndex(0);\r\n      setTimeRemaining(newTest.timeLimit! * 60);\r\n      setTestState('in-progress');\r\n      setGenerationProgress(100);\r\n    } catch (error) {\r\n      logger.error('Error generating test:', error);\r\n      alert('в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШҜв•ӘВ«в•ӘШІв•ӘШ°в•ӘШҜв•Әв–’. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ«.');\r\n    } finally {\r\n      setIsGenerating(false);\r\n      clearInterval(progressInterval);\r\n    }\r\n  };\r\n\r\n  const handleAnswerChange = (questionId: string, value: string | string[]) => {\r\n    setAnswers(prev => {\r\n      const existingAnswerIndex = prev.findIndex(a => a.questionId === questionId);\r\n      if (existingAnswerIndex !== -1) {\r\n        const newAnswers = [...prev];\r\n        newAnswers[existingAnswerIndex] = { questionId, value };\r\n        return newAnswers;\r\n      } else {\r\n        return [...prev, { questionId, value }];\r\n      }\r\n    });\r\n  };\r\n\r\n  const handleNextQuestion = () => {\r\n    if (test && currentQuestionIndex < test.questions.length - 1) {\r\n      setCurrentQuestionIndex(currentQuestionIndex + 1);\r\n    }\r\n  };\r\n\r\n  const handlePrevQuestion = () => {\r\n    if (currentQuestionIndex > 0) {\r\n      setCurrentQuestionIndex(currentQuestionIndex - 1);\r\n    }\r\n  };\r\n\r\n  const handleSubmitTest = async () => {\r\n    if (!test) return;\r\n\r\n    // Simulate progress\r\n    setIsGenerating(true);\r\n    setTestState('loading');\r\n    setGenerationProgress(0);\r\n\r\n    const progressInterval = setInterval(() => {\r\n      setGenerationProgress(prev => {\r\n        if (prev >= 90) {\r\n          clearInterval(progressInterval);\r\n          return 90;\r\n        }\r\n        return prev + 20;\r\n      });\r\n    }, 500);\r\n\r\n    try {\r\n      // API call to evaluate test with AI\r\n      const response = await fetch('/api/evaluate-test', {\r\n        method: 'POST',\r\n        headers: {\r\n          'Content-Type': 'application/json',\r\n        },\r\n        body: JSON.stringify({\r\n          testId: test.id,\r\n          answers,\r\n          questions: test.questions,\r\n          timeSpent: test.timeLimit! * 60 - timeRemaining\r\n        }),\r\n      });\r\n\r\n      if (!response.ok) {\r\n        throw new Error('Failed to evaluate test');\r\n      }\r\n\r\n      const data = await response.json();\r\n      const result = data.result as TestResult;\r\n\r\n      setTestResult(result);\r\n      setTestState('completed');\r\n      setGenerationProgress(100);\r\n    } catch (error) {\r\n      logger.error('Error evaluating test:', error);\r\n      alert('в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШІв”ҳГ©в”ҳГЁв”ҳГЁв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШҜв•ӘВ«в•ӘШІв•ӘШ°в•ӘШҜв•Әв–’. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ«.');\r\n    } finally {\r\n      setIsGenerating(false);\r\n      clearInterval(progressInterval);\r\n    }\r\n  };\r\n\r\n  const handleRestartTest = () => {\r\n    setTestState('config');\r\n    setTest(null);\r\n    setTestResult(null);\r\n    setAnswers([]);\r\n  };\r\n\r\n  const formatTime = (seconds: number) => {\r\n    const mins = Math.floor(seconds / 60);\r\n    const secs = seconds % 60;\r\n    return `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;\r\n  };\r\n\r\n  const getScoreColor = (score: number, total: number) => {\r\n    const percentage = (score / total) * 100;\r\n    if (percentage >= 80) return 'text-green-600';\r\n    if (percentage >= 60) return 'text-yellow-600';\r\n    return 'text-red-600';\r\n  };\r\n\r\n  if (testState === 'config') {\r\n    return (\r\n      <div className=\"container mx-auto py-8 px-4 max-w-4xl\">\r\n        <div className=\"text-center mb-10\">\r\n          <h1 className=\"text-3xl font-bold mb-4 flex items-center justify-center gap-2\">\r\n            <Brain className=\"h-8 w-8 text-blue-600\" />\r\n            в•ӘШҜв”ҳВ„в•ӘШҜв•ӘВ«в•ӘШІв•ӘШ°в•ӘШҜв•Әв–’ в•ӘШҜв”ҳВ„в•Әв–‘в•ӘШҜв•ӘШІв”ҳГЁ в•ӘШҜв”ҳВ„в•Әв–‘в”ҳГўв”ҳГЁ\r\n          </h1>\r\n          <p className=\"text-gray-600\">\r\n            в”ҳГ©в”ҳГ  в•ӘШ°в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШҜв•ӘВ«в•ӘШІв•ӘШ°в•ӘШҜв•Әв–’ в”ҳГ в•ӘВ«в•Әв•Ўв•Әв•Ў в•ӘШ°в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в•ӘШҜв”ҳГ  в•ӘШҜв”ҳВ„в•Әв–‘в”ҳГўв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШҜв•Әв•Ўв•Әв•–в”ҳВҶв•ӘШҜв•Әв•Јв”ҳГЁ в”ҳГӘв•ӘШҜв•ӘВ«в•ӘШІв•ӘШ°в•Әв–’ в”ҳГ в•Әв•Јв•Әв–’в”ҳВҒв•ӘШІв”ҳГў в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв”ҳГЁ в•ӘШІв•ӘВ«в•ӘШІв•ӘШҜв•Әв–’в”ҳГ§в•ӘШҜ\r\n          </p>\r\n        </div>\r\n\r\n        <Card className=\"mb-8\">\r\n          <CardHeader>\r\n            <CardTitle className=\"flex items-center gap-2\">\r\n              <BookOpen className=\"h-5 w-5\" />\r\n              в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘВ«в•ӘШІв•ӘШ°в•ӘШҜв•Әв–’\r\n            </CardTitle>\r\n            <CardDescription>\r\n              в”ҳГ©в”ҳГ  в•ӘШ°в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘВ» в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘВ«в•ӘШІв•ӘШ°в•ӘШҜв•Әв–’ в•ӘШҜв”ҳВ„в•Әв–‘в”ҳГЁ в•ӘШІв•Әв–’в”ҳГЁв•ӘВ» в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ©в”ҳГ§\r\n            </CardDescription>\r\n          </CardHeader>\r\n          <CardContent className=\"space-y-6\">\r\n            <div className=\"space-y-2\">\r\n              <Label htmlFor=\"subject\">в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв”ҳГЁв•ӘШұ</Label>\r\n              <Select value={testConfig.subject} onValueChange={(value) => setTestConfig({...testConfig, subject: value})}>\r\n                <SelectTrigger>\r\n                  <SelectValue placeholder=\"в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв”ҳГЁв•ӘШұ\" />\r\n                </SelectTrigger>\r\n                <SelectContent>\r\n                  {subjects.map(subject => (\r\n                    <SelectItem key={subject.value} value={subject.value}>{subject.label}</SelectItem>\r\n                  ))}\r\n                </SelectContent>\r\n              </Select>\r\n            </div>\r\n\r\n            <div className=\"space-y-2\">\r\n              <Label htmlFor=\"difficulty\">в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГӘв”ҳГ« в•ӘШҜв”ҳВ„в•Әв•Ўв•Әв•Јв”ҳГӘв•ӘШ°в•ӘШұ</Label>\r\n              <Select value={testConfig.difficulty} onValueChange={(value) => setTestConfig({...testConfig, difficulty: value as any})}>\r\n                <SelectTrigger>\r\n                  <SelectValue />\r\n                </SelectTrigger>\r\n                <SelectContent>\r\n                  {difficultyLevels.map(level => (\r\n                    <SelectItem key={level.value} value={level.value}>{level.label}</SelectItem>\r\n                  ))}\r\n                </SelectContent>\r\n              </Select>\r\n            </div>\r\n\r\n            <div className=\"space-y-2\">\r\n              <Label htmlFor=\"questionCount\">в•Әв•Јв•ӘВ»в•ӘВ» в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•ӘШ®в”ҳВ„в•ӘШұ: {testConfig.questionCount}</Label>\r\n              <Input \r\n                id=\"questionCount\"\r\n                type=\"range\" \r\n                min=\"5\" \r\n                max=\"30\" \r\n                value={testConfig.questionCount} \r\n                onChange={(e) => setTestConfig({...testConfig, questionCount: parseInt(e.target.value)})}\r\n              />\r\n            </div>\r\n\r\n            <div className=\"space-y-2\">\r\n              <Label>в•ӘШ«в”ҳВҶв”ҳГӘв•ӘШҜв•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•ӘШ®в”ҳВ„в•ӘШұ</Label>\r\n              <div className=\"grid grid-cols-2 gap-2\">\r\n                {questionTypes.map(type => (\r\n                  <div key={type.value} className=\"flex items-center space-x-2\">\r\n                    <Checkbox \r\n                      id={type.value}\r\n                      checked={testConfig.questionTypes.includes(type.value)}\r\n                      onCheckedChange={(checked) => {\r\n                        if (checked) {\r\n                          setTestConfig({\r\n                            ...testConfig, \r\n                            questionTypes: [...testConfig.questionTypes, type.value]\r\n                          });\r\n                        } else {\r\n                          setTestConfig({\r\n                            ...testConfig, \r\n                            questionTypes: testConfig.questionTypes.filter(t => t !== type.value)\r\n                          });\r\n                        }\r\n                      }}\r\n                    />\r\n                    <Label htmlFor={type.value}>{type.label}</Label>\r\n                  </div>\r\n                ))}\r\n              </div>\r\n            </div>\r\n\r\n            <div className=\"space-y-2\">\r\n              <Label htmlFor=\"timeLimit\">в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в•Әв–“в”ҳГ в”ҳВҶв”ҳГЁв•ӘШұ (в•ӘШ°в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ©): {testConfig.timeLimit}</Label>\r\n              <Input \r\n                id=\"timeLimit\"\r\n                type=\"range\" \r\n                min=\"10\" \r\n                max=\"120\" \r\n                step=\"5\"\r\n                value={testConfig.timeLimit} \r\n                onChange={(e) => setTestConfig({...testConfig, timeLimit: parseInt(e.target.value)})}\r\n              />\r\n            </div>\r\n          </CardContent>\r\n          <CardFooter>\r\n            <Button \r\n              onClick={handleGenerateTest} \r\n              className=\"w-full\" \r\n              disabled={!testConfig.subject || isGenerating}\r\n            >\r\n              {isGenerating ? 'в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШҜв•ӘВ«в•ӘШІв•ӘШ°в•ӘШҜв•Әв–’...' : 'в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШҜв•ӘВ«в•ӘШІв•ӘШ°в•ӘШҜв•Әв–’'}\r\n            </Button>\r\n          </CardFooter>\r\n        </Card>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  if (testState === 'loading') {\r\n    return (\r\n      <div className=\"container mx-auto py-8 px-4 max-w-4xl\">\r\n        <Card>\r\n          <CardHeader>\r\n            <CardTitle className=\"flex items-center gap-2\">\r\n              <Brain className=\"h-5 w-5\" />\r\n              {test ? 'в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШІв”ҳГ©в”ҳГЁв”ҳГЁв”ҳГ  в•ӘШӯв•ӘШҙв•ӘШҜв•ӘШ°в•ӘШҜв•ӘШІв”ҳГў...' : 'в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШҜв•ӘВ«в•ӘШІв•ӘШ°в•ӘШҜв•Әв–’...'}\r\n            </CardTitle>\r\n          </CardHeader>\r\n          <CardContent className=\"space-y-4\">\r\n            <Progress value={generationProgress} className=\"w-full\" />\r\n            <p className=\"text-center text-gray-600\">\r\n              {test ? 'в”ҳГЁв”ҳГ©в”ҳГӘв”ҳГ  в•ӘШҜв”ҳВ„в•Әв–‘в”ҳГўв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШҜв•Әв•Ўв•Әв•–в”ҳВҶв•ӘШҜв•Әв•Јв”ҳГЁ в•ӘШ°в•ӘШІв•ӘШөв”ҳВ„в”ҳГЁв”ҳВ„ в•ӘШӯв•ӘШҙв•ӘШҜв•ӘШ°в•ӘШҜв•ӘШІв”ҳГў в”ҳГӘв•ӘШІв”ҳГ©в•ӘВ»в”ҳГЁв”ҳГ  в•ӘШІв”ҳГ©в”ҳГЁв”ҳГЁв”ҳГ  в•ӘВ»в”ҳГ©в”ҳГЁв”ҳГ©...' : 'в”ҳГЁв”ҳГ©в”ҳГӘв”ҳГ  в•ӘШҜв”ҳВ„в•Әв–‘в”ҳГўв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШҜв•Әв•Ўв•Әв•–в”ҳВҶв•ӘШҜв•Әв•Јв”ҳГЁ в•ӘШ°в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШҜв•ӘВ«в•ӘШІв•ӘШ°в•ӘШҜв•Әв–’ в”ҳГ в•ӘВ«в•Әв•Ўв•Әв•Ў в”ҳВ„в”ҳГў...'}\r\n            </p>\r\n          </CardContent>\r\n        </Card>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  if (testState === 'in-progress' && test) {\r\n    const currentQuestion = test.questions[currentQuestionIndex];\r\n    const currentAnswer = answers.find(a => a.questionId === currentQuestion.id)?.value || '';\r\n    const progress = ((currentQuestionIndex + 1) / test.questions.length) * 100;\r\n\r\n    return (\r\n      <div className=\"container mx-auto py-8 px-4 max-w-4xl\">\r\n        <div className=\"mb-6 flex justify-between items-center\">\r\n          <div>\r\n            <h1 className=\"text-2xl font-bold\">{test.title}</h1>\r\n            <p className=\"text-gray-600\">в•ӘШҜв”ҳВ„в•Әв”Ӯв•ӘШ¬в•ӘШҜв”ҳВ„ {currentQuestionIndex + 1} в”ҳГ в”ҳВҶ {test.questions.length}</p>\r\n          </div>\r\n          <div className=\"flex items-center gap-2 bg-blue-50 px-3 py-2 rounded-lg\">\r\n            <Clock className=\"h-5 w-5 text-blue-600\" />\r\n            <span className=\"font-medium\">{formatTime(timeRemaining)}</span>\r\n          </div>\r\n        </div>\r\n\r\n        <Progress value={progress} className=\"mb-8\" />\r\n\r\n        <Card className=\"mb-8\">\r\n          <CardHeader>\r\n            <div className=\"flex justify-between items-start\">\r\n              <div>\r\n                <CardTitle className=\"text-xl\">{currentQuestion.text}</CardTitle>\r\n                <div className=\"flex gap-2 mt-2\">\r\n                  <Badge variant={\r\n                    currentQuestion.difficulty === 'easy' ? 'default' : \r\n                    currentQuestion.difficulty === 'medium' ? 'secondary' : 'destructive'\r\n                  }>\r\n                    {currentQuestion.difficulty === 'easy' ? 'в•Әв”Ӯв”ҳГ§в”ҳВ„' : \r\n                     currentQuestion.difficulty === 'medium' ? 'в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•–' : 'в•Әв•Ўв•Әв•Јв•ӘШ°'}\r\n                  </Badge>\r\n                  <Badge variant=\"outline\">{currentQuestion.points} в”ҳВҶв”ҳГ©в•Әв•–в•ӘШұ</Badge>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </CardHeader>\r\n          <CardContent className=\"space-y-4\">\r\n            {currentQuestion.type === 'multiple-choice' && currentQuestion.options && (\r\n              <RadioGroup \r\n                value={currentAnswer as string} \r\n                onValueChange={(value) => handleAnswerChange(currentQuestion.id, value)}\r\n              >\r\n                {currentQuestion.options.map((option, index) => (\r\n                  <div key={index} className=\"flex items-center space-x-2\">\r\n                    <RadioGroupItem value={option} id={`option-${index}`} />\r\n                    <Label htmlFor={`option-${index}`}>{option}</Label>\r\n                  </div>\r\n                ))}\r\n              </RadioGroup>\r\n            )}\r\n\r\n            {currentQuestion.type === 'true-false' && (\r\n              <RadioGroup \r\n                value={currentAnswer as string} \r\n                onValueChange={(value) => handleAnswerChange(currentQuestion.id, value)}\r\n              >\r\n                <div className=\"flex items-center space-x-2\">\r\n                  <RadioGroupItem value=\"true\" id=\"true\" />\r\n                  <Label htmlFor=\"true\">в•Әв•Ўв•ӘШөв”ҳГЁв•ӘШө</Label>\r\n                </div>\r\n                <div className=\"flex items-center space-x-2\">\r\n                  <RadioGroupItem value=\"false\" id=\"false\" />\r\n                  <Label htmlFor=\"false\">в•ӘВ«в•Әв•–в•ӘШ«</Label>\r\n                </div>\r\n              </RadioGroup>\r\n            )}\r\n\r\n            {currentQuestion.type === 'short-answer' && (\r\n              <Textarea \r\n                value={currentAnswer as string}\r\n                onChange={(e) => handleAnswerChange(currentQuestion.id, e.target.value)}\r\n                placeholder=\"в•ӘШҜв”ҳГўв•ӘШІв•ӘШ° в•ӘШӯв•ӘШҙв•ӘШҜв•ӘШ°в•ӘШІв”ҳГў в”ҳГ§в”ҳВҶв•ӘШҜ...\"\r\n                rows={3}\r\n              />\r\n            )}\r\n\r\n            {currentQuestion.type === 'essay' && (\r\n              <Textarea \r\n                value={currentAnswer as string}\r\n                onChange={(e) => handleAnswerChange(currentQuestion.id, e.target.value)}\r\n                placeholder=\"в•ӘШҜв”ҳГўв•ӘШІв•ӘШ° в”ҳГ в”ҳГ©в•ӘШҜв”ҳВ„в”ҳГў в”ҳГ§в”ҳВҶв•ӘШҜ...\"\r\n                rows={6}\r\n              />\r\n            )}\r\n          </CardContent>\r\n          <CardFooter className=\"flex justify-between\">\r\n            <Button \r\n              variant=\"outline\" \r\n              onClick={handlePrevQuestion}\r\n              disabled={currentQuestionIndex === 0}\r\n            >\r\n              в•ӘШҜв”ҳВ„в•Әв”Ӯв•ӘШ¬в•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв”Ӯв•ӘШҜв•ӘШ°в”ҳГ©\r\n            </Button>\r\n            <div className=\"flex gap-2\">\r\n              {currentQuestionIndex === test.questions.length - 1 ? (\r\n                <Button onClick={handleSubmitTest}>\r\n                  в•ӘШӯв”ҳВҶв”ҳГ§в•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШҜв•ӘВ«в•ӘШІв•ӘШ°в•ӘШҜв•Әв–’\r\n                </Button>\r\n              ) : (\r\n                <Button onClick={handleNextQuestion}>\r\n                  в•ӘШҜв”ҳВ„в•Әв”Ӯв•ӘШ¬в•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШҜв”ҳВ„в”ҳГЁ\r\n                </Button>\r\n              )}\r\n            </div>\r\n          </CardFooter>\r\n        </Card>\r\n\r\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4 mb-8\">\r\n          <Card>\r\n            <CardContent className=\"pt-6\">\r\n              <div className=\"flex items-center gap-2\">\r\n                <CheckCircle className=\"h-5 w-5 text-green-500\" />\r\n                <span>в•ӘШІв”ҳГ в•ӘШІ в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШҙв•ӘШҜв•ӘШ°в•ӘШұ: {answers.length}</span>\r\n              </div>\r\n            </CardContent>\r\n          </Card>\r\n          <Card>\r\n            <CardContent className=\"pt-6\">\r\n              <div className=\"flex items-center gap-2\">\r\n                <AlertCircle className=\"h-5 w-5 text-yellow-500\" />\r\n                <span>в”ҳГ в•ӘШІв•ӘШ°в”ҳГ©в”ҳГЁ: {test.questions.length - answers.length}</span>\r\n              </div>\r\n            </CardContent>\r\n          </Card>\r\n          <Card>\r\n            <CardContent className=\"pt-6\">\r\n              <div className=\"flex items-center gap-2\">\r\n                <Award className=\"h-5 w-5 text-blue-500\" />\r\n                <span>в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в•ӘШҜв”ҳВ„в”ҳГўв”ҳВ„в”ҳГЁв•ӘШұ: {test.questions.reduce((sum, q) => sum + q.points, 0)}</span>\r\n              </div>\r\n            </CardContent>\r\n          </Card>\r\n        </div>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  if (testState === 'completed' && testResult && test) {\r\n    const percentage = Math.round((testResult.score / testResult.totalPoints) * 100);\r\n\r\n    return (\r\n      <div className=\"container mx-auto py-8 px-4 max-w-4xl\">\r\n        <div className=\"text-center mb-10\">\r\n          <h1 className=\"text-3xl font-bold mb-4 flex items-center justify-center gap-2\">\r\n            <Award className=\"h-8 w-8 text-yellow-500\" />\r\n            в”ҳВҶв•ӘШІв•ӘШҜв•ӘШ®в•ӘШҙ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘВ«в•ӘШІв•ӘШ°в•ӘШҜв•Әв–’\r\n          </h1>\r\n          <p className=\"text-gray-600\">\r\n            в”ҳВ„в”ҳГ©в•ӘВ» в•ӘШ«в”ҳГўв”ҳГ в”ҳВ„в•ӘШІ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘВ«в•ӘШІв•ӘШ°в•ӘШҜв•Әв–’ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө! в•ӘШӯв”ҳВ„в”ҳГЁв”ҳГў в•ӘШІв”ҳГ©в”ҳГЁв”ҳГЁв”ҳГ  в•ӘШ«в•ӘВ»в•ӘШҜв•ӘШ®в”ҳГў\r\n          </p>\r\n        </div>\r\n\r\n        <Card className=\"mb-8\">\r\n          <CardHeader>\r\n            <CardTitle>в•ӘШҜв”ҳВ„в”ҳВҶв•ӘШІв”ҳГЁв•ӘШҙв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШҙв”ҳГ в•ӘШҜв”ҳВ„в”ҳГЁв•ӘШұ</CardTitle>\r\n          </CardHeader>\r\n          <CardContent>\r\n            <div className=\"flex flex-col items-center justify-center space-y-4\">\r\n              <div className={`text-5xl font-bold ${getScoreColor(testResult.score, testResult.totalPoints)}`}>\r\n                {percentage}%\r\n              </div>\r\n              <div className=\"text-xl\">\r\n                {testResult.score} в”ҳГ в”ҳВҶ {testResult.totalPoints} в”ҳВҶв”ҳГ©в•Әв•–в•ӘШұ\r\n              </div>\r\n              <div className=\"text-gray-600\">\r\n                в”ҳГӘв”ҳГ©в•ӘШІ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘВ«в•ӘШІв•ӘШ°в•ӘШҜв•Әв–’: {formatTime(testResult.timeSpent)}\r\n              </div>\r\n            </div>\r\n          </CardContent>\r\n        </Card>\r\n\r\n        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6 mb-8\">\r\n          <Card>\r\n            <CardHeader>\r\n              <CardTitle className=\"flex items-center gap-2\">\r\n                <CheckCircle className=\"h-5 w-5 text-green-500\" />\r\n                в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШҙв•ӘШҜв•ӘШ°в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•Әв•Ўв•ӘШөв”ҳГЁв•ӘШөв•ӘШұ\r\n              </CardTitle>\r\n            </CardHeader>\r\n            <CardContent>\r\n              <div className=\"text-3xl font-bold text-green-600 text-center\">\r\n                {testResult.feedback.correctAnswers}\r\n              </div>\r\n            </CardContent>\r\n          </Card>\r\n\r\n          <Card>\r\n            <CardHeader>\r\n              <CardTitle className=\"flex items-center gap-2\">\r\n                <AlertCircle className=\"h-5 w-5 text-red-500\" />\r\n                в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШҙв•ӘШҜв•ӘШ°в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШҜв•Әв•–в•ӘШ®в•ӘШұ\r\n              </CardTitle>\r\n            </CardHeader>\r\n            <CardContent>\r\n              <div className=\"text-3xl font-bold text-red-600 text-center\">\r\n                {testResult.feedback.incorrectAnswers}\r\n              </div>\r\n            </CardContent>\r\n          </Card>\r\n        </div>\r\n\r\n        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6 mb-8\">\r\n          <Card>\r\n            <CardHeader>\r\n              <CardTitle className=\"flex items-center gap-2\">\r\n                <Lightbulb className=\"h-5 w-5 text-yellow-500\" />\r\n                в”ҳВҶв”ҳГ©в•ӘШҜв•Әв•– в•ӘШҜв”ҳВ„в”ҳГ©в”ҳГӘв•ӘШұ\r\n              </CardTitle>\r\n            </CardHeader>\r\n            <CardContent>\r\n              <ul className=\"space-y-2\">\r\n                {testResult.feedback.strengths.map((strength, index) => (\r\n                  <li key={index} className=\"flex items-start gap-2\">\r\n                    <CheckCircle className=\"h-4 w-4 text-green-500 mt-0.5 flex-shrink-0\" />\r\n                    <span>{strength}</span>\r\n                  </li>\r\n                ))}\r\n              </ul>\r\n            </CardContent>\r\n          </Card>\r\n\r\n          <Card>\r\n            <CardHeader>\r\n              <CardTitle className=\"flex items-center gap-2\">\r\n                <AlertCircle className=\"h-5 w-5 text-blue-500\" />\r\n                в”ҳГ в•ӘШҙв•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв•Әв”Ӯв”ҳГЁв”ҳВҶ\r\n              </CardTitle>\r\n            </CardHeader>\r\n            <CardContent>\r\n              <ul className=\"space-y-2\">\r\n                {testResult.feedback.improvementAreas.map((area, index) => (\r\n                  <li key={index} className=\"flex items-start gap-2\">\r\n                    <AlertCircle className=\"h-4 w-4 text-blue-500 mt-0.5 flex-shrink-0\" />\r\n                    <span>{area}</span>\r\n                  </li>\r\n                ))}\r\n              </ul>\r\n            </CardContent>\r\n          </Card>\r\n        </div>\r\n\r\n        <Card className=\"mb-8\">\r\n          <CardHeader>\r\n            <CardTitle className=\"flex items-center gap-2\">\r\n              <BookOpen className=\"h-5 w-5 text-purple-500\" />\r\n              в•ӘШІв”ҳГӘв•Әв•Ўв”ҳГЁв•ӘШҜв•ӘШІ в”ҳВ„в”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв•ӘШұ\r\n            </CardTitle>\r\n          </CardHeader>\r\n          <CardContent>\r\n            <ul className=\"space-y-3\">\r\n              {testResult.feedback.recommendations.map((recommendation, index) => (\r\n                <li key={index} className=\"flex items-start gap-2 p-3 bg-purple-50 rounded-lg\">\r\n                  <span className=\"font-bold text-purple-700\">{index + 1}.</span>\r\n                  <span>{recommendation}</span>\r\n                </li>\r\n              ))}\r\n            </ul>\r\n          </CardContent>\r\n        </Card>\r\n\r\n        <div className=\"flex justify-center\">\r\n          <Button onClick={handleRestartTest} size=\"lg\">\r\n            в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШҜв•ӘВ«в•ӘШІв•ӘШ°в•ӘШҜв•Әв–’ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»\r\n          </Button>\r\n        </div>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  return null;\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(education)\\contests\\new\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(education)\\courses\\[id]\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(education)\\courses\\components\\CourseCard.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(education)\\courses\\components\\CoursesFilter.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(education)\\courses\\components\\CoursesHero.tsx","messages":[],"suppressedMessages"