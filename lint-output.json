eacher.rating)}\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  );\r\n\r\n  return (\r\n    <div className={`bg-white rounded-xl shadow-lg p-6 ${className}`}>\r\n      <div className=\"flex items-center gap-3 mb-6\">\r\n        <div className=\"p-2 bg-blue-100 rounded-lg\">\r\n          <Search className=\"h-6 w-6 text-blue-600\" />\r\n        </div>\r\n        <h2 className=\"text-xl font-bold text-gray-800\">в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШөв•ӘШі в•Әв•Јв”ҳВҶ в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯв”ҳГЁв”ҳВҶ</h2>\r\n        <div className=\"ml-auto flex items-center gap-1 text-xs bg-green-100 text-green-800 px-2 py-1 rounded-full\">\r\n          <Zap className=\"h-3 w-3\" />\r\n          <span>Gemini 2.0 Flash</span>\r\n        </div>\r\n      </div>\r\n\r\n      {!teachers ? (\r\n        <form onSubmit={handleSubmit} className=\"space-y-4\">\r\n          <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\r\n            <div>\r\n              <label className=\"block text-sm font-medium text-gray-700 mb-1\">\r\n                в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ <span className=\"text-red-500\">*</span>\r\n              </label>\r\n              <select\r\n                value={selectedSubject}\r\n                onChange={(e) => setSelectedSubject(e.target.value)}\r\n                className=\"block w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\"\r\n                required\r\n              >\r\n                <option value=\"\">в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ</option>\r\n                {subjects.map((subject) => (\r\n                  <option key={subject} value={subject}>\r\n                    {subject}\r\n                  </option>\r\n                ))}\r\n              </select>\r\n            </div>\r\n\r\n            <div>\r\n              <label className=\"block text-sm font-medium text-gray-700 mb-1\">\r\n                в”ҳГўв”ҳВ„в”ҳГ в•ӘШҜв•ӘШІ в”ҳ