,"source":"\"use client\";\r\n\r\nimport React, { useState, useEffect, useMemo, useRef, memo, useCallback } from \"react\";\r\nimport Link from \"next/link\";\r\nimport { motion, AnimatePresence } from \"framer-motion\";\r\nimport { safeFetch } from \"@/lib/safe-client-utils\";\r\nimport { logger } from '@/lib/logger';\r\nimport { AlertCircle, RefreshCw, Sword, Shield, Scroll, Trophy, Skull, Target, Clock, Swords, CheckCircle2 } from \"lucide-react\";\r\nimport { rpgCommonStyles, SUBJECT_EMOJIS } from \"../constants\";\r\nimport type { Exam, SubjectWithExams } from \"../types\";\r\nimport StatCard from \"../StatCard\";\r\n\r\n// --- Skeleton Components ---\r\nconst SubjectCardSkeleton = () => (\r\n    <div className=\"bg-white/5 border border-white/10 rounded-2xl p-6 text-center animate-pulse h-[180px] w-full\" />\r\n);\r\n\r\n// --- Presentational Components ---\r\nconst SubjectCard = memo(({ emoji, name, onClick }: { emoji: string; name: string; onClick: () => void }) => (\r\n    <motion.button\r\n        onClick={onClick}\r\n        whileHover={{ y: -8, scale: 1.05 }}\r\n        whileTap={{ scale: 0.95 }}\r\n        className={`${rpgCommonStyles.card} group w-full flex flex-col items-center justify-center gap-5 hover:border-red-500/40 hover:bg-black/40 transition-all duration-500 transform min-h-[180px] relative overflow-hidden backdrop-blur-2xl p-6`}\r\n        aria-label={`в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁ в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ ${name}`}\r\n    >\r\n        <div className=\"absolute inset-0 bg-gradient-to-b from-white/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500\" />\r\n        <div className=\"text-6xl drop-shadow-[0_0_15px_rgba(255,255,255,0.3)] group-hover:scale-125 transition-transform duration-500 filter group-hover:brightness-125 relative z-10\" role=\"img\" aria-hidden=\"true\">{emoji}</div>\r\n        <div className=\"text-xl font-black text-gray-100 group-hover:text-red-400 transition-colors tracking-tight relative z-10\">{name}</div>\r\n        <div className=\"text-[10px] font-black uppercase tracking-[0.2em] text-red-500/0 group-hover:text-red-500/100 transition-all duration-500 mt-1 relative z-10\">в•ӘШ°в•ӘВ»в•ӘШҜв”ҳГЁв•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Јв•Әв–’в”ҳГўв•ӘШұ</div>\r\n    </motion.button>\r\n));\r\nSubjectCard.displayName = \"SubjectCard\";\r\n\r\n// --- Modal Component ---\r\nconst ExamsModal = memo(({ subject, onClose }: { subject: SubjectWithExams | null; onClose: () => void }) => {\r\n    const handleEsc = useCallback((event: KeyboardEvent) => {\r\n        if (event.key === 'Escape') onClose();\r\n    }, [onClose]);\r\n\r\n    useEffect(() => {\r\n        window.addEventListener('keydown', handleEsc);\r\n        return () => window.removeEventListener('keydown', handleEsc);\r\n    }, [handleEsc]);\r\n\r\n    if (!subject) return null;\r\n\r\n    const difficultyStyles = {\r\n        \"в•Әв”Ӯв”ҳГ§в”ҳВ„\": \"bg-green-500/10 text-green-400 border-green-500/20\",\r\n        \"в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•–\": \"bg-yellow-500/10 text-yellow-400 border-yellow-500/20\",\r\n        \"в•Әв•Ўв•Әв•Јв•ӘШ°\": \"bg-red-500/10 text-red-400 border-red-500/20\",\r\n    } as const;\r\n\r\n    return (\r\n        <div \r\n            className=\"fixed inset-0 bg-black/80 backdrop-blur-sm flex items-center justify-center p-4 z-50 animate-in fade-in duration-200\" \r\n            onClick={onClose}\r\n            role=\"dialog\"\r\n            aria-modal=\"true\"\r\n        >\r\n            <div \r\n                className=\"bg-[#0f172a] border border-white/10 rounded-2xl shadow-2xl w-full max-w-2xl max-h-[85vh] overflow-hidden flex flex-col animate-in zoom-in-95 duration-200\" \r\n                onClick={(e) => e.stopPropagation()}\r\n            >\r\n                {/* Header */}\r\n                <div className=\"bg-[#1e293b]/50 p-6 border-b border-white/10 flex justify-between items-center shrink-0\">\r\n                    <h3 className=\"text-xl md:text-2xl font-bold text-white flex items-center gap-3\">\r\n                        <span className=\"text-3xl filter drop-shadow-md\">{subject.emoji}</span>\r\n                        <span>в”ҳГ в•Әв•Јв•ӘШҜв•Әв–’в”ҳГў {subject.name}</span>\r\n                    </h3>\r\n                    <button \r\n                        onClick={onClose} \r\n                        className=\"text-gray-400 hover:text-white hover:bg-white/10 p-2 rounded-full transition-colors\"\r\n                        aria-label=\"в•ӘШӯв•Әв•‘в”ҳВ„в•ӘШҜв”ҳГ©\"\r\n                    >\r\n                        <AlertCircle className=\"w-6 h-6 rotate-45\" />\r\n                    </button>\r\n                </div>\r\n                \r\n                {/* Content */}\r\n                <div className=\"overflow-y-auto p-6 space-y-4 custom-scrollbar\">\r\n                    {subject.exams.length > 0 ? (\r\n                         subject.exams.map((exam) => (\r\n                        <div key={exam.id} className=\"group relative overflow-hidden rounded-xl border border-white/5 bg-white/5 p-4 transition-all hover:border-primary/30 hover:bg-white/10 hover:shadow-lg hover:shadow-primary/5\">\r\n                            <div className=\"flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 relative z-10\">\r\n                                <div>\r\n                                    <h4 className=\"font-bold text-lg text-gray-100 group-hover:text-primary transition-colors flex items-center gap-2\">\r\n                                        {exam.title}\r\n                                        {exam.difficulty === 'в•Әв•Ўв•Әв•Јв•ӘШ°' && <Skull className=\"w-4 h-4 text-red-500 animate-pulse\" />}\r\n                                        {exam.isCompleted && <CheckCircle2 className=\"w-4 h-4 text-green-500\" />}\r\n                                    </h4>\r\n                                    <div className=\"flex flex-wrap items-center gap-3 text-xs text-gray-400 mt-2\">\r\n                                        <span className=\"flex items-center gap-1 bg-white/5 px-2 py-1 rounded\"><Clock className=\"w-3 h-3\" /> {exam.duration} в•ӘВ»в”ҳГ©в”ҳГЁв”ҳГ©в•ӘШұ</span>\r\n                                        <span className=\"flex items-center gap-1 bg-white/5 px-2 py-1 rounded\"><Target className=\"w-3 h-3\" /> {exam.questionCount} в•Әв”Ӯв•ӘШ¬в•ӘШҜв”ҳВ„</span>\r\n                                        <span className={`px-2 py-1 rounded border ${difficultyStyles[exam.difficulty] || ''}`}>{exam.difficulty}</span>\r\n                                    </div>\r\n                                </div>\r\n                                <Link \r\n                                    href={`/exams/${exam.id}`}\r\n                                    className=\"bg-primary hover:bg-primary/90 text-primary-foreground px-6 py-2.5 rounded-lg font-bold shadow-[0_0_15px_rgba(124,58,237,0.3)] hover:shadow-[0_0_25px_rgba(124,58,237,0.5)] transition-all duration-300 w-full sm:w-auto text-center flex items-center justify-center gap-2\"\r\n                                >\r\n                                    <Sword className=\"w-4 h-4\" />\r\n                                    <span>в•ӘШ°в•ӘВ»в•ӘШ© в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШІв•ӘШҜв”ҳВ„</span>\r\n                                </Link>\r\n                            </div>\r\n                        </div>\r\n                    ))\r\n                    ) : (\r\n                        <div className=\"text-center py-12 text-gray-500 flex flex-col items-center\">\r\n                            <Scroll className=\"w-16 h-16 mb-4 opacity-20\" />\r\n                            <p className=\"text-lg font-medium\">в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ  в”ҳГ в•ӘШІв•ӘШҜв•ӘШөв•ӘШұ в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШҜв”ҳГҜ в”ҳВҒв”ҳГЁ в”ҳГ§в•Әв–‘в”ҳГ§ в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•Әв•–в”ҳГ©в•ӘШұ.</p>\r\n                            <p className=\"text-sm opacity-60 mt-2\">в•Әв•Јв•ӘВ» в”ҳВ„в•ӘШҜв•ӘШөв”ҳГ©в•ӘШҜв”ҳГҜв•ӘГ® в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв•ӘВ»в•ӘШұ в”ҳГЁв•ӘВ«в•Әв•–в•Әв•–в”ҳГӘв”ҳВҶ в”ҳВ„в”ҳГ в•Әв•Јв•ӘШҜв•Әв–’в”ҳГў в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ.</p>\r\n                        </div>\r\n                    )}\r\n                </div>\r\n            </div>\r\n        </div>\r\n    );\r\n});\r\nExamsModal.displayName = \"ExamsModal\";\r\n\r\n// --- Main Component ---\r\nconst ExamsSectionComponent = () => {\r\n    const [loading, setLoading] = useState(true);\r\n    const [subjects, setSubjects] = useState<SubjectWithExams[]>([]);\r\n    const [stats, setStats] = useState<{ icon: React.ReactNode; value: string; label: string; color: string }[]>([]);\r\n    const [searchTerm, setSearchTerm] = useState(\"\");\r\n    const [selectedSubject, setSelectedSubject] = useState<SubjectWithExams | null>(null);\r\n    const [error, setError] = useState<string | null>(null);\r\n    const [retryCount, setRetryCount] = useState(0);\r\n    const abortControllerRef = useRef<AbortController | null>(null);\r\n\r\n    // Fetch Logic\r\n    useEffect(() => {\r\n        const fetchExamsData = async () => {\r\n            if (abortControllerRef.current) abortControllerRef.current.abort(\"Cancelling previous request\");\r\n            abortControllerRef.current = new AbortController();\r\n            \r\n            setLoading(true);\r\n            setError(null);\r\n            \r\n            try {\r\n                // TODO: Replace with actual stricter typed response if available\r\n                const { data: examsData, error: examsError } = await safeFetch<Exam[]>(\r\n                    \"/api/exams\",\r\n                    { signal: abortControllerRef.current.signal, cache: 'no-store' },\r\n                    []\r\n                );\r\n\r\n                if (examsError) {\r\n                    if (examsError instanceof Error && examsError.name === 'AbortError') return;\r\n                    throw new Error(examsError.message || \"Failed to fetch exams\");\r\n                }\r\n\r\n                if (!examsData || !Array.isArray(examsData)) {\r\n                     // Empty state handling or throw error\r\n                     setSubjects([]);\r\n                     setStats([]);\r\n                     return;\r\n                }\r\n\r\n                const subjectMap = new Map<string, SubjectWithExams>();\r\n                \r\n                examsData.forEach((exam: Exam) => {\r\n                    const subjectName = exam.subject || \"в•Әв•Јв•ӘШҜв”ҳГ \";\r\n                    if (!subjectMap.has(subjectName)) {\r\n                        subjectMap.set(subjectName, {\r\n                            id: subjectName,\r\n                            emoji: SUBJECT_EMOJIS[subjectName] || \"ШёШЈВӨЩҠв••ВҸ\",\r\n                            name: subjectName,\r\n                            exams: []\r\n                        });\r\n                    }\r\n                    \r\n                    const subject = subjectMap.get(subjectName);\r\n                    if (subject) {\r\n                        subject.exams.push({\r\n                            ...exam,\r\n                            title: exam.title || \"в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁ в”ҳГ в•ӘШҙв”ҳГ§в”ҳГӘв”ҳВ„\",\r\n                            duration: exam.duration || 60,\r\n                            questionCount: exam.questionCount || 10,\r\n                            difficulty: exam.difficulty || \"в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•–\"\r\n                        });\r\n                    }\r\n                });\r\n\r\n                setSubjects(Array.from(subjectMap.values()));\r\n\r\n                const totalExams = examsData.length;\r\n                const totalQuestions = examsData.reduce((sum, exam) => sum + (exam.questionCount || 0), 0);\r\n                \r\n                setStats([\r\n                    { icon: <Scroll />, value: `${totalExams}+`, label: \"в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ в”ҳГ в•ӘШІв•ӘШҜв•ӘШөв•ӘШұ\", color: \"from-blue-500 to-cyan-500\" },\r\n                    { icon: <Trophy />, value: `2000+`, label: \"в•ӘШ°в•Әв•–в”ҳВ„ в”ҳГ в•Әв”Өв•ӘШҜв•Әв–’в”ҳГў\", color: \"from-amber-400 to-orange-500\" },\r\n                    { icon: <Sword />, value: `${totalQuestions}+`, label: \"в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁ (в•Әв”Ӯв•ӘШ¬в•ӘШҜв”ҳВ„)\", color: \"from-red-500 to-rose-600\" }\r\n                ]);\r\n\r\n            } catch (err) {\r\n                if (err instanceof Error && err.name === 'AbortError') return;\r\n                logger.error(\"Error fetching exams data:\", err);\r\n                setError(\"в”ҳВ„в”ҳГ  в”ҳВҶв•ӘШІв”ҳГ в”ҳГўв”ҳВҶ в”ҳГ в”ҳВҶ в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ»в•Әв•Јв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ  в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШҜв•ӘВ»в”ҳГ  в•ӘШҜв”ҳВ„в•Әв–’в•ӘШ®в”ҳГЁв•Әв”Ӯв”ҳГЁ.\");\r\n            } finally {\r\n                setLoading(false);\r\n            }\r\n        };\r\n\r\n        fetchExamsData();\r\n        return () => { if (abortControllerRef.current) abortControllerRef.current.abort(\"Component unmounted\"); };\r\n    }, [retryCount]);\r\n\r\n    const filteredSubjects = useMemo(() => {\r\n        if (!searchTerm.trim()) return subjects;\r\n        const searchLower = searchTerm.toLowerCase().trim();\r\n        return subjects.filter(subject =>\r\n            subject.name.toLowerCase().includes(searchLower) ||\r\n            subject.exams.some(exam => exam.title.toLowerCase().includes(searchLower))\r\n        );\r\n    }, [subjects, searchTerm]);\r\n\r\n    return (\r\n        <section className={`${rpgCommonStyles.glassPanel} px-4 py-12 !mt-12 overflow-hidden`}>\r\n             <div className=\"absolute inset-0 bg-[url('/grid-pattern.svg')] opacity-5 pointer-events-none mix-blend-overlay\"></div>\r\n\r\n            <div className=\"relative z-10 max-w-7xl mx-auto\">\r\n                {/* Section Header */}\r\n                <div className=\"text-center mb-16 relative\">\r\n                    <div className=\"absolute top-0 left-1/2 -translate-x-1/2 w-64 h-64 bg-red-600/10 rounded-full blur-[100px] -z-10\" />\r\n                    <motion.div \r\n                        initial={{ scale: 0.8, rotate: -10 }}\r\n                        whileInView={{ scale: 1, rotate: 0 }}\r\n                        className=\"inline-flex items-center justify-center p-5 mb-8 rounded-[2rem] bg-black/60 border-2 border-red-500/40 backdrop-blur-2xl shadow-[0_0_40px_rgba(239,68,68,0.3)] ring-1 ring-white/10\"\r\n                    >\r\n                        <Swords className=\"w-12 h-12 text-red-500 filter drop-shadow-[0_0_10px_rgba(239,68,68,0.5)]\" />\r\n                    </motion.div>\r\n                    <h2 id=\"exams-heading\" className={`text-5xl md:text-7xl font-black mb-6 tracking-tighter ${rpgCommonStyles.goldText}`}>\r\n                         в•Әв”Ӯв•ӘШҜв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Јв•ӘШҜв•Әв–’в”ҳГў (ARENA)\r\n                    </h2>\r\n                    <p className=\"text-gray-400 mb-8 max-w-3xl mx-auto text-xl font-medium border-x-2 border-red-500/20 px-8 leading-relaxed\">\r\n                        в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•Әв”Ӯв”ҳВ„в•ӘШҜв•ӘШөв”ҳГў (в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ) в”ҳГӘв•ӘШҜв•Әв”Ӯв•ӘШІв•Әв•Јв•ӘВ» в”ҳВ„в”ҳГ в”ҳГӘв•ӘШҜв•ӘШҙв”ҳГ§в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШҜв•ӘШІ. в”ҳГўв”ҳВ„ в•ӘШҜв”ҳВҶв•ӘШІв•Әв•Ўв•ӘШҜв•Әв–’ в”ҳГЁв”ҳГ©в•Әв–’в•ӘШ°в”ҳГў в”ҳГ в”ҳВҶ в”ҳВҶв”ҳГЁв”ҳВ„ в•Әв–’в•ӘШІв•ӘШ°в•ӘШұ \"в•ӘШҜв”ҳВ„в•ӘШ°в•Әв•–в”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•Әв•–в”ҳГӘв•Әв–’в”ҳГЁ\".\r\n                    </p>\r\n                </div>\r\n                \r\n                {/* Stats Grid */}\r\n                <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-6 mb-16 max-w-4xl mx-auto px-4\">\r\n                    {loading ? Array.from({ length: 3 }).map((_, i) => (\r\n                        <div key={i} className=\"h-32 bg-white/5 rounded-2xl animate-pulse\" />\r\n                    )) : stats.map((stat, idx) => (\r\n                        <StatCard \r\n                            key={idx} \r\n                            {...stat} \r\n                            color={stat.color} \r\n                            delay={idx * 0.1} \r\n                        />\r\n                    ))}\r\n                </div>\r\n\r\n                {/* Main Content Area */}\r\n                <div className=\"rounded-3xl border border-white/10 bg-black/20 backdrop-blur-md p-6 md:p-10 shadow-2xl\">\r\n                    <div className=\"flex flex-col md:flex-row items-center justify-between gap-8 mb-10 border-b border-white/5 pb-8\">\r\n                        <div className=\"text-center md:text-right w-full md:w-auto\">\r\n                            <p className=\"font-bold text-2xl text-gray-100 mb-2\">в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в”ҳГ в”ҳВҶв•Әв•–в”ҳГ©в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Јв•Әв–’в”ҳГўв•ӘШұ</p>\r\n                            <p className=\"text-sm text-gray-400\">в•ӘШөв•ӘВ»в•ӘВ» в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ в”ҳВ„в•ӘШ°в•ӘВ»в•ӘШ© в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ в•ӘШІв•ӘШҜв•ӘШөв•ӘШұ</p>\r\n                        </div>\r\n                        <div className=\"relative w-full md:w-96 group\">\r\n                            <input \r\n                                type=\"text\"\r\n                                placeholder=\"вүЎШ§ВӨВҚ в•ӘШҜв•ӘШ°в•ӘШөв•ӘШі в•Әв•Јв”ҳВҶ в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁ в•ӘШ«в”ҳГӘ в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ...\"\r\n                                value={searchTerm}\r\n                                onChange={(e) => setSearchTerm(e.target.value)}\r\n                                className=\"w-full px-5 py-4 rounded-xl bg-black/40 border border-white/10 text-white placeholder:text-gray-500 focus:ring-2 focus:ring-primary/50 focus:border-primary/50 focus:outline-none transition-all pl-12 shadow-inner text-lg\"\r\n                            />\r\n                            <div className=\"absolute inset-0 rounded-xl bg-gradient-to-r from-primary/10 to-purple-500/10 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none -z-10 blur-xl\"></div>\r\n                        </div>\r\n                    </div>\r\n                    \r\n                    <div className=\"grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6\">\r\n                        {loading ? Array(5).fill(0).map((_, i) => <SubjectCardSkeleton key={i} />)\r\n                                 : filteredSubjects.map((subject) => (\r\n                                     <SubjectCard key={subject.name} {...subject} onClick={() => setSelectedSubject(subject)} />\r\n                                 ))\r\n                        }\r\n                    </div>\r\n                    \r\n                    {error && (\r\n                        <div className=\"text-center py-8 mx-auto max-w-md mt-8 animate-in fade-in\">\r\n                            <div className=\"bg-red-500/10 border border-red-500/20 rounded-xl p-6 flex flex-col items-center gap-4\">\r\n                                <AlertCircle className=\"h-10 w-10 text-red-400\" />\r\n                                <p className=\"font-medium text-red-100 text-lg\">{error}</p>\r\n                                <button \r\n                                    onClick={() => { setRetryCount(prev => prev + 1); setError(null); }} \r\n                                    className=\"mt-2 text-sm bg-red-500/20 hover:bg-red-500/30 text-white px-6 py-2 rounded-lg transition-colors flex items-center gap-2 border border-red-500/30\"\r\n                                >\r\n                                    <RefreshCw className=\"w-4 h-4\" /> в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„\r\n                                </button>\r\n                            </div>\r\n                        </div>\r\n                    )}\r\n                    \r\n                    { !loading && !error && filteredSubjects.length === 0 && (\r\n                        <div className=\"text-center py-20 text-gray-500 col-span-full\">\r\n                            <Shield className=\"w-20 h-20 mx-auto mb-6 opacity-20\" />\r\n                            <p className=\"text-xl font-medium\">в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в•Әв”Ӯв•ӘШҜв•ӘШөв•ӘШҜв•ӘШІ в”ҳГ в•Әв•Јв•Әв–’в”ҳГўв•ӘШұ в•ӘШІв•Әв•–в•ӘШҜв•ӘШ°в”ҳГ© в•ӘШ°в•ӘШөв•ӘШів”ҳГў.</p>\r\n                            <p className=\"text-sm mt-2 opacity-60\">в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШөв•ӘШі в•ӘШ°в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в•ӘШҜв”ҳГ  в”ҳГўв”ҳВ„в”ҳГ в•ӘШҜв•ӘШІ в”ҳГ в”ҳВҒв•ӘШІв•ӘШҜв•ӘШөв”ҳГЁв•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ«.</p>\r\n                        </div>\r\n                    )}\r\n                </div>\r\n            </div>\r\n            \r\n            <ExamsModal subject={selectedSubject} onClose={() => setSelectedSubject(null)} />\r\n        </section>\r\n    );\r\n};\r\n\r\nexport const ExamsSection = memo(ExamsSectionComponent);\r\nexport default ExamsSection;\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\components\\home\\sections\\FeaturesSection.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\components\\home\\sections\\IntelligentRecommendationsSection.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\components\\home\\sections\\LevelProgressSection.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Trophy' is defined but never used. Allowed unused vars must match /^_/u.","line":6,"column":10,"nodeType":null,"messageId":"unusedVar","endLine":6,"endColumn":16}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\n\nimport React from 'react';\nimport { motion } from 'framer-motion';\nimport { User } from '@/types/user';\nimport { Trophy, Zap, Crown, Target } from 'lucide-react';\n\ninterface LevelProgressProps {\n  user: User;\n}\n\nexport const LevelProgressSection = ({ user }: LevelProgressProps) => {\n  // Gamification Data Logic with Fallbacks\n  const level = user.level || 1;\n  const currentXP = user.xp || 0;\n  const nextLevelXP = user.xpToNextLevel || 1000;\n  const progressPercent = Math.min((currentXP / nextLevelXP) * 100, 100);\n  const rankTitle = user.rank || \"в”ҳГ в•ӘШ°в•ӘШІв•ӘВ»в•ӘШ® в•Әв•–в”ҳГ в”ҳГӘв•ӘШө\";\n  const remainingXP = nextLevelXP - currentXP;\n\n  return (\n    <motion.div\n      initial={{ opacity: 0, y: 20 }}\n      animate={{ opacity: 1, y: 0 }}\n      transition={{ duration: 0.5 }}\n      className=\"relative overflow-hidden rounded-[2rem] border border-white/10 bg-black/40 p-8 shadow-[0_8px_32px_rgba(0,0,0,0.4)] backdrop-blur-xl transition-all hover:bg-black/50 hover:border-white/20\"\n    >\n      {/* Decorative Background Effects (RPG Style) */}\n      <div className=\"absolute top-0 right-0 -mt-10 -mr-10 h-64 w-64 rounded-full bg-violet-400/20 blur-3xl mix-blend-overlay animate-pulse-slow\"></div>\n      <div className=\"absolute bottom-0 left-0 -mb-10 -ml-10 h-48 w-48 rounded-full bg-indigo-400/20 blur-3xl mix-blend-overlay\"></div>\n      \n      {/* Grid Pattern Overlay */}\n      <div className=\"absolute inset-0 bg-[url('/grid-pattern.svg')] opacity-10\"></div>\n\n      <div className=\"relative z-10 flex flex-col lg:flex-row items-center justify-between gap-8\">\n        \n        {/* Avatar & Rank Info */}\n        <div className=\"flex flex-col sm:flex-row items-center gap-6 w-full lg:w-auto text-center sm:text-right\">\n          <div className=\"relative group\">\n            {/* Avatar Ring Progress */}\n            <svg className=\"h-24 w-24 -rotate-90 transform text-transparent\" viewBox=\"0 0 100 100\">\n              <circle cx=\"50\" cy=\"50\" r=\"46\" stroke=\"currentColor\" strokeWidth=\"3\" className=\"text-white/20\" fill=\"none\" />\n              <circle\n                cx=\"50\"\n                cy=\"50\"\n                r=\"46\"\n                stroke=\"currentColor\"\n                strokeWidth=\"3\"\n                className=\"text-yellow-400 drop-shadow-[0_0_8px_rgba(250,204,21,0.5)]\"\n                fill=\"none\"\n                strokeDasharray=\"289\"\n                strokeDashoffset={289 - (289 * progressPercent) / 100}\n                style={{ transition: 'stroke-dashoffset 1s ease-in-out' }}\n              />\n            </svg>\n            \n            {/* Actual Avatar Image */}\n            <div className=\"absolute inset-2 overflow-hidden rounded-full border-2 border-white/50 shadow-inner bg-white/10\">\n              <img \n                src={user.avatar || `https://ui-avatars.com/api/?name=${encodeURIComponent(user.name || 'User')}&background=random&color=fff&bold=true`} \n                alt={user.name || 'User'} \n                className=\"h-full w-full object-cover transition-transform duration-500 group-hover:scale-110\"\n              />\n            </div>\n\n            {/* Level Badge */}\n            <div className=\"absolute -bottom-2 -right-2 flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-yellow-300 to-yellow-600 text-sm font-black text-yellow-900 shadow-lg ring-2 ring-violet-900 transform rotate-12 group-hover:rotate-0 transition-all duration-300\">\n              {level}\n            </div>\n          </div>\n          \n          <div className=\"text-white space-y-1\">\n            <h2 className=\"text-2xl font-bold flex flex-col sm:flex-row items-center gap-2\">\n              <span className=\"drop-shadow-md\">{user.name || 'в•Әв•–в•ӘШҜв”ҳВ„в•ӘШ° в”ҳГ в•ӘШҙв•ӘШІв”ҳГ§в•ӘВ»'}</span>\n              <span className=\"inline-flex items-center gap-1 rounded-full bg-white/10 px-3 py-0.5 text-xs font-medium text-yellow-200 ring-1 ring-inset ring-white/20 backdrop-blur-sm\">\n                <Crown className=\"h-3 w-3 text-yellow-400\" />\n                {rankTitle}\n              </span>\n            </h2>\n            <p className=\"text-base text-indigo-100/90 font-medium\">\n              в”ҳГ в•Әв•‘в•ӘШҜв”ҳГ в•Әв–’в•ӘШІв”ҳГў в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Јв”ҳВ„в”ҳГЁв”ҳГ в”ҳГЁв•ӘШұ в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГ в•Әв–’в•ӘШұ! вүЎШ§ШЈВҖ\n            </p>\n          </div>\n        </div>\n\n        {/* XP Progress Bar Section */}\n        <div className=\"flex-1 w-full lg:max-w-xl bg-black/20 rounded-2xl p-4 backdrop-blur-sm border border-white/5\">\n          <div className=\"flex justify-between items-end mb-2\">\n            <div className=\"flex flex-col\">\n              <span className=\"text-xs font-semibold uppercase tracking-wider text-indigo-300 mb-1\">в”ҳВҶв”ҳГ©в•ӘШҜв•Әв•– в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШ°в•Әв–’в•ӘШұ (XP)</span>\n              <span className=\"text-lg font-bold text-white flex items-center gap-2\">\n                <Zap className=\"h-5 w-5 text-yellow-400 fill-yellow-400\" />\n                {currentXP.toLocaleString()}\n              </span>\n            </div>\n            <div className=\"text-right\">\n               <span className=\"text-xs text-indigo-200\">в•ӘШҜв”ҳВ„в”ҳГ§в•ӘВ»в”ҳВҒ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШҜв”ҳВ„в”ҳГЁ</span>\n               <div className=\"text-sm font-semibold text-white flex items-center gap-1 justify-end\">\n                 <Target className=\"h-3 w-3\" />\n                 {nextLevelXP.toLocaleString()}\n               </div>\n            </div>\n          </div>\n          \n          {/* 3D Progress Bar Container */}\n          <div className=\"relative h-6 w-full overflow-hidden rounded-full bg-gray-900/50 shadow-inner ring-1 ring-white/5\">\n            <motion.div\n              initial={{ width: 0 }}\n              animate={{ width: `${progressPercent}%` }}\n              transition={{ duration: 1.5, ease: \"easeOut\" }}\n              className=\"relative h-full rounded-full bg-gradient-to-l from-yellow-400 via-orange-500 to-pink-600 shadow-[0_0_15px_rgba(251,146,60,0.5)]\"\n            >\n                {/* Shimmer Effect */}\n                <div className=\"absolute inset-0 bg-gradient-to-r from-transparent via-white/40 to-transparent w-1/2 -skew-x-12 animate-[shimmer_2s_infinite]\"></div>\n            </motion.div>\n          </div>\n          \n          <div className=\"mt-3 flex justify-between items-center text-xs\">\n            <span className=\"text-indigo-200/80 font-medium\">в•ӘШІв•ӘШ°в”ҳГ©в”ҳГ« {remainingXP} в”ҳВҶв”ҳГ©в•Әв•–в•ӘШұ в”ҳВ„в”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГӘв”ҳГ« {level + 1}</span>\n            <span className=\"text-yellow-300 font-bold\">{Math.round(progressPercent)}%</span>\n          </div>\n        </div>\n      \n      </div>\n    </motion.div>\n  );\n};\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\components\\home\\sections\\LiveActivityFeedSection.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'CheckCircle2' is defined but never used. Allowed unused vars must match /^_/u.","line":12,"column":3,"nodeType":null,"messageId":"unusedVar","endLine":12,"endColumn":15},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Trophy' is defined but never used. Allowed unused vars must match /^_/u.","line":13,"column":3,"nodeType":null,"messageId":"unusedVar","endLine":13,"endColumn":9},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Users' is defined but never used. Allowed unused vars must match /^_/u.","line":15,"column":3,"nodeType":null,"messageId":"unusedVar","endLine":15,"endColumn":8},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Zap' is defined but never used. Allowed unused vars must match /^_/u.","line":16,"column":3,"nodeType":null,"messageId":"unusedVar","endLine":16,"endColumn":6},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'TrendingUp' is defined but never used. Allowed unused vars must match /^_/u.","line":17,"column":3,"nodeType":null,"messageId":"unusedVar","endLine":17,"endColumn":13},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'MessageSquare' is defined but never used. Allowed unused vars must match /^_/u.","line":18,"column":3,"nodeType":null,"messageId":"unusedVar","endLine":18,"endColumn":16},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'setIsLive' is assigned a value but never used. Allowed unused vars must match /^_/u.","line":92,"column":18,"nodeType":null,"messageId":"unusedVar","endLine":92,"endColumn":27}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":7,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\r\n\r\nimport { useState, useEffect, memo } from \"react\";\r\nimport { motion, AnimatePresence } from \"framer-motion\";\r\nimport { Card, CardContent } from \"@/components/ui/card\";\r\nimport { Badge } from \"@/components/ui/badge\";\r\nimport { safeFetch } from \"@/lib/safe-client-utils\";\r\nimport { getSafeUserId } from \"@/lib/safe-client-utils\";\r\nimport { \r\n  Activity,\r\n  Clock,\r\n  CheckCircle2,\r\n  Trophy,\r\n  BookOpen,\r\n  Users,\r\n  Zap,\r\n  TrendingUp,\r\n  MessageSquare,\r\n  Bell\r\n} from \"lucide-react\";\r\nimport { formatDistanceToNow } from \"date-fns\";\r\nimport { ar } from \"date-fns/locale\";\r\nimport { logger } from '@/lib/logger';\r\nimport { rpgCommonStyles } from \"../constants\";\r\n\r\n// Note: Arabic locale may not be available in all date-fns versions\r\n// Fallback to English if Arabic locale is not found\r\n\r\ninterface ActivityItem {\r\n  id: string;\r\n  type: \"achievement\" | \"task_completed\" | \"exam_finished\" | \"study_session\" | \"milestone\" | \"notification\";\r\n  title: string;\r\n  description: string;\r\n  timestamp: Date;\r\n  icon: React.ReactNode;\r\n  color: string;\r\n  user?: string;\r\n}\r\n\r\ninterface Notification {\r\n  id: string;\r\n  type: string;\r\n  title: string;\r\n  message?: string;\r\n  description?: string;\r\n  createdAt?: string | Date;\r\n  timestamp?: string | Date;\r\n  userId?: string;\r\n}\r\n\r\ninterface StudySession {\r\n  id: string;\r\n  subject?: string;\r\n  subjectId?: string;\r\n  duration?: number;\r\n  durationMin?: number;\r\n  startTime?: string | Date;\r\n  createdAt?: string | Date;\r\n  timestamp?: string | Date;\r\n}\r\n\r\ninterface NotificationsApiResponse {\r\n  data?: {\r\n    notifications?: Notification[];\r\n  };\r\n  notifications?: Notification[];\r\n}\r\n\r\ninterface StudySessionsApiResponse {\r\n  data?: StudySession[];\r\n  sessions?: StudySession[];\r\n}\r\n\r\nfunction extractNotifications(payload: NotificationsApiResponse | Notification[] | null): Notification[] {\r\n  if (!payload) return [];\r\n  if (Array.isArray(payload)) return payload;\r\n  if (Array.isArray(payload.notifications)) return payload.notifications;\r\n  if (Array.isArray(payload.data?.notifications)) return payload.data.notifications;\r\n  return [];\r\n}\r\n\r\nfunction extractStudySessions(payload: StudySessionsApiResponse | StudySession[] | null): StudySession[] {\r\n  if (!payload) return [];\r\n  if (Array.isArray(payload)) return payload;\r\n  if (Array.isArray(payload.sessions)) return payload.sessions;\r\n  if (Array.isArray(payload.data)) return payload.data;\r\n  return [];\r\n}\r\n\r\nexport const LiveActivityFeedSection = memo(function LiveActivityFeedSection() {\r\n  const [activities, setActivities] = useState<ActivityItem[]>([]);\r\n  const [isLive, setIsLive] = useState(true);\r\n\r\n  useEffect(() => {\r\n    const fetchActivities = async () => {\r\n      const userId = getSafeUserId();\r\n      \r\n      try {\r\n        const { data, error } = await safeFetch<NotificationsApiResponse | Notification[]>(\r\n          `/api/notifications${userId ? `?userId=${userId}` : ''}`,\r\n          undefined,\r\n          null\r\n        );\r\n\r\n        const notifications = extractNotifications(data);\r\n        if (!error && notifications.length > 0) {\r\n          const transformedActivities = notifications.map((notification) => ({\r\n            id: notification.id || `activity-${Date.now()}-${Math.random()}`,\r\n            type: (notification.type as ActivityItem['type']) || \"notification\",\r\n            title: notification.title || \"в•Әв•–в”¬Шӯв•Әв•–в”¬в”Өв•Әв•–в”¬в•Јв•Әв•–в”¬ШҜв•Әв•–в”¬в–’ в•Әв•–в”¬Шҙв•Әв•–в”¬В»в•Әв••в”ҳв•Јв•Әв•–в”¬В»\",\r\n            description: notification.message || notification.description || \"\",\r\n            timestamp: new Date(notification.createdAt || notification.timestamp || Date.now()),\r\n            icon: <Bell className=\"h-5 w-5\" />,\r\n            color: \"text-blue-400 bg-blue-500/10 border-blue-500/20\",\r\n            user: notification.userId\r\n          }));\r\n\r\n          setActivities(transformedActivities);\r\n        } else {\r\n          const { data: sessionsData } = await safeFetch<StudySessionsApiResponse | StudySession[]>(\r\n            `/api/study-sessions${userId ? `?userId=${userId}` : ''}`,\r\n            undefined,\r\n            null\r\n          );\r\n          const sessions = extractStudySessions(sessionsData);\r\n\r\n          if (sessions.length > 0) {\r\n            const sessionActivities = sessions.slice(0, 5).map((session) => ({\r\n              id: `session-${session.id}`,\r\n              type: \"study_session\" as const,\r\n              title: `в•Әв•–в”¬Шҙв•Әв••ШёВҖШҰв•Әв•–в”¬в”Ӯв•Әв•–в”¬Шұ в•Әв•–в”¬В»в•Әв•–в”¬в–’в•Әв•–в”¬ШҜв•Әв•–в”¬в”Ӯв•Әв•–в”¬Шұ: ${session.subject || session.subjectId || 'в•Әв•Јв•ӘШҜв”ҳГ '}`,\r\n              description: `${session.duration ?? session.durationMin ?? 0} в•Әв•–в”¬В»в•Әв••ШёВҖШЈв•Әв••в”ҳв•Јв•Әв••ШёВҖШЈв•Әв•–в”¬Шұ в•Әв••ШёВҖШ®в•Әв••ШёВҖШЁ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬В»в•Әв•–в”¬в–’в•Әв•–в”¬ШҜв•Әв•–в”¬в”Ӯв•Әв•–в”¬Шұ`,\r\n              timestamp: new Date(session.createdAt || session.startTime || session.timestamp || Date.now()),\r\n              icon: <BookOpen className=\"h-5 w-5\" />,\r\n              color: \"text-emerald-400 bg-emerald-5