t\t\t\t\terrorMessage = \"в•ӘШҙв•ӘВ»в•ӘШҜв”ҳГӘв”ҳВ„ в”ҳГ©в•ӘШҜв•Әв•Јв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в”ҳГӘв•ӘШҙв”ҳГӘв•ӘВ». в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШІв•Әв”Өв•Әв•‘в”ҳГЁв”ҳВ„ migrations\";\r\n\t\t\t\t\terrorCode = 'TABLE_NOT_FOUND';\r\n\t\t\t\t} else if (error.message.includes('timeout')) {\r\n\t\t\t\t\terrorMessage = \"в•ӘШҜв”ҳВҶв•ӘШІв”ҳГ§в•ӘШІ в”ҳГ в”ҳГ§в”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в•Әв•–в”ҳВ„в•ӘШ°. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ«\";\r\n\t\t\t\t\terrorCode = 'REQUEST_TIMEOUT';\r\n\t\t\t\t}\r\n\t\t\t} else {\r\n\t\t\t\terrorDetails = String(error);\r\n\t\t\t}\r\n\r\n\t\t\treturn createStandardErrorResponse(\r\n\t\t\t\terror,\r\n\t\t\t\terrorMessage\r\n\t\t\t);\r\n\t\t}\r\n\t});\r\n}\r\n\r\nexport async function POST(request: NextRequest) {\r\n\treturn opsWrapper(request, async (req) => {\r\n\t\ttry {\r\n\t\t\t// Parse request body with timeout protection using standardized helper\r\n\t\t\tconst bodyResult = await parseRequestBody<{\r\n\t\t\t\tsubject?: string;\r\n\t\t\t\ttitle?: string;\r\n\t\t\t\tyear?: number;\r\n\t\t\t\turl?: string;\r\n\t\t\t\ttype?: ExamType;\r\n\t\t\t}>(req, {\r\n\t\t\t\tmaxSize: 2048, // 2KB max\r\n\t\t\t\trequired: true,\r\n\t\t\t});\r\n\r\n\t\t\tif (!bodyResult.success) {\r\n\t\t\t\treturn bodyResult.error;\r\n\t\t\t}\r\n\r\n\t\t\tconst body = bodyResult.data;\r\n\r\n\t\t\tconst { subject, subjectId, title, year, url, type = ExamType.OTHER } = body as any;\r\n\t\t\tconst finalSubjectId = subjectId || subject;\r\n\r\n\t\t\t// Validate required fields\r\n\t\t\tif (!finalSubjectId) {\r\n\t\t\t\tconst response = NextResponse.json(\r\n\t\t\t\t\t{ error: \"в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»\tв•ӘШұ в”ҳГ в•Әв•–в”ҳВ„в”ҳГӘв•ӘШ°в•ӘШұ\", code: 'MISSING_SUBJECT' },\r\n\t\t\t\t\t{ status: 400 }\r\n\t\t\t\t);\r\n\t\t\t\treturn addSecurityHeaders(response);\r\n\t\t\t}\r\n\r\n\t\t\tif (!title || typeof title !== 'string' || title.trim().length === 0) {\r\n\t\t\t\tc