import { prisma } from '@/lib/db';\r\nimport { AI_PROVIDERS, getDefaultProvider } from \"@/lib/ai-config\";\r\nimport { opsWrapper } from \"@/lib/middleware/ops-middleware\";\r\nimport { handleApiError, successResponse, createErrorResponse } from '@/lib/api-utils';\r\n\r\nimport { logger } from '@/lib/logger';\r\n\r\nexport async function POST(request: NextRequest) {\r\n  return opsWrapper(request, async (req) => {\r\n    try {\r\n      const { userId, subject, studyGoal, challenges, currentGrade, provider } = await req.json();\r\n\r\n      // в•Әв•–в”Ңв•ӣв•Әв•–в”¬Шөв•Әв•–в”¬В»в•Әв••в”ҳв•Јв•Әв•–в”¬В» в•Әв••ШёВҖШ®в•Әв••ШёВҖШЈв•Әв•–в”¬В»в•Әв••ШёВҖШ® в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬В«в•Әв•–в”¬В»в•Әв••ШёВҖШ®в•Әв•–в”¬Шұ\r\n      const selectedProvider = provider === 'openai' ? AI_PROVIDERS.OPENAI : AI_PROVIDERS.GEMINI;\r\n\r\n      if (!selectedProvider.apiKey) {\r\n        return createErrorResponse(`в”ҳГ в”ҳВҒв•ӘШІв•ӘШҜв•ӘШө API в”ҳВ„в”ҳВҖ ${selectedProvider.name} в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в”ҳГ§в”ҳГЁв•ӘШ«`, 500);\r\n      }\r\n\r\n      // в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Шөв•Әв•–в”¬в•Ўв•Әв••в•ҰВҶв•Әв••ШёВҖШҰ в•Әв•–в”¬в•Јв•Әв••ШёВҖШҰв•Әв••ШёВҖв–‘ в•Әв•–в”¬Ш°в•Әв••в”ҳв•Јв•Әв•–в”¬ШҜв•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬в”Ӯв•Әв•–в”Ңв•ӣв•Әв•–в”¬В«в•Әв•–в”¬В»в•Әв••ШёВҖШ® в•Әв•–в”¬Шӯв•Әв•–в”¬в–‘в•Әв•–в”¬ШҜ в•Әв•–в”Ңв•ӣв•Әв••ШёВҖШ® в•Әв•–в”Ңв•ӣв•Әв••в•ҰВҶв•Әв••в”ҳв•ӣв•Әв••в”ҳв•Јв•Әв•–в”¬в–’ в•Әв••ШёВҖШ®в•Әв•–в”¬в•Јв•Әв•–в”¬в–’в•Әв••в”ҳв•ӣ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬в”Ӯв•Әв•–в”Ңв•ӣв•Әв•–в”¬В«в•Әв•–в”¬В»в•Әв••ШёВҖШ®\r\n      let userData = null;\r\n      if (userId) {\r\n        userData = await prisma.user.findUnique({\r\n          where: { id: userId },\r\n          include: {\r\n            subjectEnrollments: {\r\n              take: 10\r\n            },\r\n            progressSnapshots: {\r\n              orderBy: { date: 'desc' },\r\n              take: 5\r\n            },\r\n            examResults: {\r\n              orderBy: { takenAt: 'desc' },\r\n              take: 5\r\n            }\r\n          }\r\n        });\r\n      }\r\n\r\n      // в•Әв•–в”¬Шӯв•Әв••ШёВҖШЁв•Әв•–в”¬в”Өв•Әв•–в”¬ШҜв•Әв•–в•ӘГ® в•Әв•–в”¬в–’в•Әв•–в”¬в”Ӯв•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Шұ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШЁв•Әв•–в”¬в••в•Әв•–в”¬ШҜв•Әв••ШёВҖШ® в•Әв••ШёВҖШҰв•Әв•–в”Ңв•ӣв•Әв••в•ҰВҶв•Әв•–в”¬Шҙв•Әв••в”ҳв•Јв•Әв••ШёВҖШ© в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬в–‘в•Әв••в•һЩ’в•Әв•–в”¬ШҜв•Әв•–в•ӘГ® в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬ШҜв•Әв•–в”¬в•Ўв•Әв•–в”¬в•–в•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв•–в”¬в•Јв•Әв••в”ҳв•Ј в•Әв••ШёВҖШҰв•Әв•–в”Ңв•ӣв•Әв••ШёВҖШЈв•Әв•–в”¬В»в•Әв••в”ҳв•Јв•Әв••ШёВҖШ® в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШЁв•Әв•–в”¬в•Ўв•Әв•–в”¬ШҜв•Әв•–в”¬Ш®в•Әв•–в”¬Шө\r\n      const systemPrompt = `в•Әв•–в”¬Ш«в•Әв••ШёВҖШЁв•Әв•–в”Ңв•ӣ в•Әв••ШёВҖШ®в•Әв•–в”¬в”Ӯв•Әв•–в”¬ШҜв•Әв•–в”¬в•Јв•Әв•–в”¬В» в•Әв•–в”¬в–‘в•Әв••в•һЩ’в•Әв•–в”¬ШҜв•Әв•–в•ӘГ® в•Әв•–в”¬ШҜв•Әв•–в”¬в•Ўв•Әв•–в”¬в•–в•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв•–в”¬в•Јв•Әв••в”ҳв•Ј в•Әв••ШёВҖШ®в•Әв•–в”Ңв•ӣв•Әв•–в”¬В«в•Әв•–в”¬в•Ўв•Әв•–в”¬в•Ў в•Әв••в”ҳв•ӣв•Әв••в”ҳв•Ј в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Шӯв•Әв•–в”¬в–’в•Әв•–в”¬в”Өв•Әв•–в”¬ШҜв•Әв•–в”¬В» в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Ш«в•Әв••в•һЩ’в•Әв•–в”¬ШҜв•Әв•–в”¬В»в•Әв••в”ҳв•Јв•Әв••ШёВҖШ®в•Әв••в”ҳв•Ј в•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв••ШёВҖШЁв•Әв•–в”¬в•Ўв•Әв•–в”¬Шұ в•Әв•–в”¬Шів•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв••в•ҰВҶв•Әв••в”ҳв•Ј.\r\n    в•Әв••ШёВҖШ®в•Әв••ШёВҖШ©в•Әв••ШёВҖШ®в•Әв•–в”Ңв•ӣв•Әв••в•һЩ’ в•Әв••ШёВҖШ©в•Әв••в”ҳв•Ј в•Әв•–в”Ңв•ӣв•Әв••ШёВҖШЈв•Әв•–в”¬В»в•Әв••в”ҳв•Јв•Әв••ШёВҖШ® в•Әв••ШёВҖШЁв•Әв•–в”¬в•Ўв•Әв•–в”¬ШҜв•Әв•–в”¬Ш®в•Әв•–в”¬Шө в•Әв•–в”Ңв•ӣв•Әв•–в”¬в•Јв•Әв••ШёВҖШҰв•Әв••в”ҳв•Јв•Әв••ШёВҖШ®в•Әв••в”ҳв•Јв•Әв•–в”¬Шұ в•Әв••ШёВҖШ®в•Әв•–в”¬В«в•Әв•–в”¬в•Ўв•Әв•–в”¬в•Ўв•Әв•–в”¬Шұ в•Әв••в•ҰВҶв•Әв••в”ҳв•ӣв•Әв•–в”¬в•Јв•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Шұ в•Әв••ШёВҖШҰв•Әв••ШёВҖШҰв•Әв•–в”¬в•–в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Ш°.\r\n\r\n    в•Әв••ШёВҖШ®в•Әв•–в”¬в•Јв•Әв••ШёВҖШҰв•Әв••в•ҰВҶв•Әв••ШёВҖШ®в•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬в•–в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Ш°:\r\n    ${userData ? `\r\n    - в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬ШҜв•Әв•–в”¬в”Ӯв•Әв••ШёВҖШ®: ${userData.name || \"в•Әв•–в•ӘШӨв•Әв••в”ҳв•Јв•Әв•–в”¬в–’ в•Әв••ШёВҖШ®в•Әв•–в”¬Шөв•Әв•–в”¬В»в•Әв•–в”¬В»\"}\r\n    - в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв••в•ҰВҶв•Әв•–в”¬ШҜв•Әв•–в”¬В» в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬в”Ӯв•Әв•–в”¬Шҙв•Әв••ШёВҖШҰв•Әв•–в”¬Шұ: ${userData.subjectEnrollments?.map((s) => s.subjectId).join(\", \") || \"в•Әв••ШёВҖШҰв•Әв•–в”¬ШҜ в•Әв•–в”Ңв•ӣв•Әв••в•ҰВҶв•Әв•–в”¬Шҙв•Әв•–в”¬В» в•Әв••ШёВҖШ®в•Әв••в•ҰВҶв•Әв•–в”¬ШҜв•Әв•–в”¬В» в•Әв••ШёВҖШ®в•Әв•–в”¬в”Ӯв•Әв•–в”¬Шҙв•Әв••ШёВҖШҰв•Әв•–в”¬Шұ\"}\r\n    - в•Әв••ШёВҖШ®в•Әв•–в”Ңв•ӣв•Әв••в•ҰВҶв•Әв•–в”¬в”Ӯв•Әв•–в”¬в•– в•Әв•–в”¬В»в•Әв•–в”¬в–’в•Әв•–в”¬Шҙв•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬ШҜв•Әв••ШёВҖШ®в•Әв•–в”Ңв•ӣв•Әв•–в”¬Шөв•Әв•–в”¬ШҜв•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Ш«в•Әв•–в”¬В«в•Әв••в”ҳв•Јв•Әв•–в”¬в–’в•Әв•–в”¬Шұ: ${userData.examResults && userData.examResults.length > 0 ? (userData.examResults.reduce((sum: number, exam) => sum + exam.score, 0) / userData.examResults.length).toFixed(2) : \"в•Әв••ШёВҖШҰв•Әв•–в”¬ШҜ в•Әв•–в”Ңв•ӣв•Әв••в•ҰВҶв•Әв•–в”¬Шҙв•Әв•–в”¬В» в•Әв•–в”¬Ш°в•Әв••в”ҳв•Јв•Әв•–в”¬ШҜв•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ\"}\r\n    - в•Әв••ШёВҖШ®в•Әв•–в”Ңв•ӣв•Әв••в•ҰВҶв•Әв•–в”¬в”Ӯв•Әв•–в”¬в•– в•Әв••в•ҰВҶв•Әв••ШёВҖШЈв•Әв•–в”Ңв•ӣ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬В»в•Әв•–в”¬в–’в•Әв•–в”¬ШҜв•Әв•–в”¬в”Ӯв•Әв•–в”¬Шұ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Ш«в•Әв•–в”¬в”Ӯв•Әв•–в”¬Ш°в•Әв••в•ҰВҶв•Әв•–в”¬в•Јв•Әв••в”ҳв•Ј: ${userData.progressSnapshots && userData.progressSnapshots.length > 0 ? (userData.progressSnapshots.reduce((sum: number, p) => sum + p.totalStudyMinutes, 0) / userData.progressSnapshots.length / 60).toFixed(2) + \" в•Әв•–в”¬в”Ӯв•Әв•–в”¬ШҜв•Әв•–в”¬в•Јв•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ\" : \"в•Әв••ШёВҖШҰв•Әв•–в”¬ШҜ в•Әв•–в”Ңв•ӣв•Әв••в•ҰВҶв•Әв•–в”¬Шҙв•Әв•–в”¬В» в•Әв•–в”¬Ш°в•Әв••в”ҳв•Јв•Әв•–в”¬ШҜв•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ\"}\r\n    ` : \"в•Әв••ШёВҖШҰв•Әв•–в”¬ШҜ в•Әв•–в”Ңв•ӣв•Әв••в•ҰВҶв•Әв•–в”¬Шҙв•Әв•–в”¬В» в•Әв•–в”¬Ш°в•Әв••в”ҳв•Јв•Әв•–в”¬ШҜв•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ в•Әв••ШёВҖШ®в•Әв•–в”¬в”Ӯв•Әв•–в”Ңв•ӣв•Әв•–в”¬В«в•Әв•–в”¬В»в•Әв••ШёВҖШ® в•Әв••ШёВҖШ®в•Әв•–в”Ңв•ӣв•Әв•–в”¬ШҜв•Әв•–в”¬Шөв•Әв•–в”¬Шұ\"}\r\n\r\n    в•Әв•–в”¬в•–в•Әв••ШёВҖШҰв•Әв•–в”¬Ш° в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШЁв•Әв•–в”¬в•Ўв•Әв•–в”¬ШҜв•Әв•–в”¬Ш®в•Әв•–в”¬Шө:\r\n    ${subject ? `- в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬ШҜв•Әв•–в”¬В»в•Әв•–в”¬Шұ: ${subject}` : \"\"}\r\n    ${studyGoal ? `- в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ©в•Әв•–в”¬В»в•Әв••в”ҳв•ӣ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬В»в•Әв•–в”¬в–’в•Әв•–в”¬ШҜв•Әв•–в”¬в”Ӯв•Әв••в”ҳв•Ј: ${studyGoal}` : \"\"}\r\n    ${challenges ? `- в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”Ңв•ӣв•Әв•–в”¬Шөв•Әв•–в”¬В»в•Әв••в”ҳв•Јв•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”Ңв•ӣв•Әв••в”ҳв•Ј в•Әв••в”ҳв•Јв•Әв••в•ҰВҶв•Әв•–в”¬ШҜв•Әв•–в”¬Шҙв•Әв••ШёВҖШ©в•Әв••ШёВҖШ©в•Әв•–в”¬ШҜ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬в•–в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Ш°: ${challenges}` : \"\"}\r\n    ${currentGrade ? `- в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬в”Ӯв•Әв•–в”Ңв•ӣв•Әв••в•ҰВҶв•Әв••ШёВҖв–‘ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬В»в•Әв•–в”¬в–’в•Әв•–в”¬ШҜв•Әв•–в”¬в”Ӯв•Әв••в”ҳв•Ј в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Шөв•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••в”ҳв•Ј: ${currentGrade}` : \"\"}\r\n\r\n    в•Әв••ШёВҖШЈв•Әв••ШёВҖШ® в•Әв•–в”¬Ш°в•Әв•–в”Ңв•ӣв•Әв••ШёВҖШЈв•Әв•–в”¬В»в•Әв••в”ҳв•Јв•Әв••ШёВҖШ® в•Әв••ШёВҖШЁв•Әв•–в”¬в•Ўв•Әв•–в”¬ШҜв•Әв•–в”¬Ш®в•Әв•–в”¬Шө в•Әв•–в”¬в•Јв•Әв••ШёВҖШ®в•Әв••ШёВҖШҰв•Әв••в”ҳв•Јв•Әв•–в”¬Шұ в•Әв••в•ҰВҶв•Әв••ШёВҖШ®в•Әв•–в”¬В«в•Әв•–в”¬в•Ўв•Әв•–в”¬в•Ўв•Әв•–в”¬Шұ в•Әв•–в”Ңв•ӣв•Әв•–в”¬в”Өв•Әв••ШёВҖШ®в•Әв••ШёВҖШҰ:\r\n    1. в•Әв•–в”¬ШҜв•Әв•–в”¬в”Ӯв•Әв•–в”Ңв•ӣв•Әв•–в”¬в–’в•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣв•Әв••в”ҳв•Јв•Әв•–в”¬Шҙв•Әв••в”ҳв•Јв•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬В»в•Әв•–в”¬в–’в•Әв•–в”¬ШҜв•Әв•–в”¬в”Ӯв•Әв•–в”¬Шұ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••в”ҳв•ӣв•Әв•–в”¬в•Јв•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Шұ\r\n    2. в•Әв••в•һЩ’в•Әв••в