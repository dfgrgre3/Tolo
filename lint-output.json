utton variant=\"destructive\" size=\"sm\" onClick={refetch} className=\"w-full sm:w-auto mt-4 sm:mt-0 shadow-lg shadow-destructive/20 rounded-xl\">\n\t\t\t\t\t\t\t\t\t\tв•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ\n\t\t\t\t\t\t\t\t\t</Button>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t</CardContent>\n\t\t\t\t\t\t</Card>\n\t\t\t\t\t</motion.div>\n\t\t\t\t)}\n\n\t\t\t\t{/* Main Content */}\n\t\t\t\t{!loading && !error && (\n\t\t\t\t\t<div className=\"space-y-10\">\n\t\t\t\t\t\t{/* Setup Celebration Animation if needed */}\n\t\t\t\t\t\t<AnimatePresence>\n\t\t\t\t\t\t\t{showCelebration && (\n\t\t\t\t\t\t\t\t<motion.div \n\t\t\t\t\t\t\t\t\tinitial={{ opacity: 0, height: 0 }}\n\t\t\t\t\t\t\t\t\tanimate={{ opacity: 1, height: 'auto' }}\n\t\t\t\t\t\t\t\t\texit={{ opacity: 0, height: 0 }}\n\t\t\t\t\t\t\t\t\tclassName=\"bg-gradient-to-r from-yellow-500/20 via-primary/20 to-purple-500/20 rounded-3xl p-1 mb-8\"\n\t\t\t\t\t\t\t\t>\n\t\t\t\t\t\t\t\t\t<div className=\"bg-background/80 backdrop-blur-xl rounded-[22px] p-6 flex items-center justify-between\">\n\t\t\t\t\t\t\t\t\t\t<div className=\"flex items-center gap-4\">\n\t\t\t\t\t\t\t\t\t\t\t<span className=\"text-4xl animate-bounce\">вүЎШ§ВҺГ«</span>\n\t\t\t\t\t\t\t\t\t\t\t<div>\n\t\t\t\t\t\t\t\t\t\t\t\t<h3 className=\"text-xl font-bold bg-gradient-to-r from-yellow-500 to-primary bg-clip-text text-transparent\">\n\t\t\t\t\t\t\t\t\t\t\t\t\tв•ӘШІв”ҳГ§в•ӘШҜв”ҳВҶв”ҳГЁв”ҳВҶв•ӘШҜ! в”ҳВ„в”ҳГ©в•ӘВ» в•ӘШөв•Әв•Ўв”ҳВ„в•ӘШІ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШӯв”ҳВҶв•ӘШҙв•ӘШҜв•Әв–“в•ӘШҜв•ӘШІ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ\n\t\t\t\t\t\t\t\t\t\t\t\t</h3>\n\t\t\t\t\t\t\t\t\t\t\t\t<p className=\"text-muted-foreground mt-1 text-sm\">в•ӘШ«в”ҳВҶв•ӘШІ в•ӘШІв”ҳГ©в”ҳГӘв”ҳГ  в•ӘШ°в•Әв•Јв”ҳГ в”ҳВ„ в•Әв–’в•ӘШҜв•ӘШ®в•Әв•Јв•ӘГ® в•ӘШҜв•Әв”Ӯв•ӘШІв”ҳГ в•Әв–’ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШІв”ҳГ©в•ӘВ»в”ҳГ !</p>\n\t\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t\t<Button variant=\"ghost\" size=\"icon\" onClick={() => setShowCelebration(false)} className=\"rounded-full bg-background/50 hover:bg-background\">\n\t\t\t\t\t\t\t\t\t\t\t<span className=\"sr-only\">в•ӘШӯв•Әв•‘в”ҳВ„в•ӘШҜв”ҳГ©</span>\n\t\t\t\t\t\t\t\t\t\t\t<svg width=\"15\" height=\"15\" viewBox=\"0 0 15 15\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M11.7816 4.03157C12.0062 3.80702 12.0062 3.44295 11.7816 3.2184C11.5571 2.99385 11.193 2.99385 10.9685 3.2184L7.50005 6.68682L4.03164 3.2184C3.80708 2.99385 3.44301 2.99385 3.21846 3.2184C2.99391 3.44295 2.99391 3.80702 3.21846 4.03157L6.68688 7.49999L3.21846 10.9684C2.99391 11.193 2.99391 11.557 3.21846 11.7816C3.44301 12.0061 3.80708 12.0061 4.03164 11.7816L7.50005 8.31316L10.9685 11.7816C11.193 12.0061 11.5571 12.0061 11.7816 11.7816C12.0062 11.557 12.0062 11.193 11.7816 10.9684L8.31322 7.49999L11.7816 4.03157Z\" fill=\"currentColor\" fillRule=\"evenodd\" clipRule=\"evenodd\"></path></svg>\n\t\t\t\t\t\t\t\t\t\t</Button>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t</motion.div>\n\t\t\t\t\t\t\t)}\n\t\t\t\t\t\t</AnimatePresence>\n\n\t\t\t\t\t\t{/* Statistics */}\n\t\t\t\t\t\t{stats && (\n\t\t\t\t\t\t\t<motion.div\n\t\t\t\t\t\t\t\tinitial={{ opacity: 0, y: 20 }}\n\t\t\t\t\t\t\t\tanimate={{ opacity: 1, y: 0 }}\n\t\t\t\t\t\t\t\ttransition={{ delay: 0.1, duration: 0.5 }}\n\t\t\t\t\t\t\t>\n\t\t\t\t\t\t\t\t<AchievementStats stats={stats} userProgress={userProgress} />\n\t\t\t\t\t\t\t</motion.div>\n\t\t\t\t\t\t)}\n\n\t\t\t\t\t\t{/* Quick Overview Badges */}\n\t\t\t\t\t\t<motion.div \n\t\t\t\t\t\t\tclassName=\"flex flex-wrap gap-3\"\n\t\t\t\t\t\t\tinitial={{ opacity: 0 }}\n\t\t\t\t\t\t\tanimate={{ opacity: 1 }}\n\t\t\t\t\t\t\ttransition={{ delay: 0.2 }}\n\t\t\t\t\t\t>\n\t\t\t\t\t\t\t<div className=\"flex items-center gap-2 bg-secondary/40 backdrop-blur-sm px-4 py-2 rounded-full border border-border/50 text-sm font-medium\">\n\t\t\t\t\t\t\t\t<Trophy className=\"w-4 h-4 text-primary\" />\n\t\t\t\t\t\t\t\t<span>в•ӘШӯв•ӘШҙв”ҳГ в•ӘШҜв”ҳВ„в”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШҙв•ӘШҜв•Әв–“в•ӘШҜв•ӘШІ: {achievements.length}</span>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<div className=\"flex items-center gap-2 bg-secondary/40 backdrop-blur-sm px-4 py-2 rounded-full border border-border/50 text-sm font-medium\">\n\t\t\t\t\t\t\t\t<Star className=\"w-4 h-4 text-yellow-500\" />\n\t\t\t\t\t\t\t\t<span>в•ӘШІв”ҳГ  в•ӘШҜв”ҳГўв•ӘШІв•Әв”Ӯв•ӘШҜв•ӘШ°: {stats?.earned || 0}</span>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<div className=\"flex items-center gap-2 bg-secondary/40 backdrop-blur-sm px-4 py-2 rounded-full border border-border/50 text-sm font-medium\">\n\t\t\t\t\t\t\t\t<Lock className=\"w-4 h-4 text-muted-foreground\" />\n\t\t\t\t\t\t\t\t<span>в”ҳГ в•ӘШІв•ӘШ°в”ҳГ©в”ҳГЁ: {stats?.locked || 0}</span>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</motion.div>\n\n\t\t\t\t\t\t{/* Grid Layout Layout for Filters and content */}\n\t\t\t\t\t\t<div className=\"flex flex-col xl:flex-row gap-8\">\n\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t{/* Left Sidebar for Filters */}\n\t\t\t\t\t\t\t<div className=\"xl:w-80 flex-shrink-0\">\n\t\t\t\t\t\t\t\t<div className=\"sticky top-24\">\n\t\t\t\t\t\t\t\t\t<AchievementFilters filters={filters} onFiltersChange={setFilters} />\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t{/* Right Content Area */}\n\t\t\t\t\t\t\t<div className=\"flex-1 space-y-10 min-w-0\">\n\t\t\t\t\t\t\t\t{/* Recent Achievements Section */}\n\t\t\t\t\t\t\t\t{recentAchievements.length > 0 && filters.status === 'all' && filters.category === 'all' && filters.search === '' && (\n\t\t\t\t\t\t\t\t\t<motion.div\n\t\t\t\t\t\t\t\t\t\tinitial={{ opacity: 0, y: 20 }}\n\t\t\t\t\t\t\t\t\t\tanimate={{ opacity: 1, y: 0 }}\n\t\t\t\t\t\t\t\t\t\ttransition={{ delay: 0.2 }}\n\t\t\t\t\t\t\t\t\t\tclassName=\"relative\"\n\t\t\t\t\t\t\t\t\t>\n\t\t\t\t\t\t\t\t\t\t<div className=\"flex items-center justify-between mb-6\">\n\t\t\t\t\t\t\t\t\t\t\t<div className=\"flex items-center gap-3\">\n\t\t\t\t\t\t\t\t\t\t\t\t<div className=\"p-2 bg-yellow-500/10 rounded-xl relative\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t<div className=\"absolute inset-0 bg-yellow-500/20 blur-md rounded-xl\" />\n\t\t\t\t\t\t\t\t\t\t\t\t\t<Sparkles className=\"h-6 w-6 text-yellow-500 relative z-10\" />\n\t\t\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t\t\t\t<h2 className=\"text-2xl font-bold bg-gradient-to-l from-foreground to-foreground/70 bg-clip-text text-transparent\">в•ӘШ«в•ӘШөв•ӘВ»в•ӘШі в•ӘШӯв”ҳВҶв•ӘШҙв•ӘШҜв•Әв–“в•ӘШҜв•ӘШІв”ҳГў</h2>\n\t\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t\t<div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5\">\n\t\t\t\t\t\t\t\t\t\t\t{filteredAchievements\n\t\t\t\t\t\t\t\t\t\t\t\t.filter((a) => recentAchievements.includes(a.id))\n\t\t\t\t\t\t\t\t\t\t\t\t.map((achievement, index) => (\n\t\t\t\t\t\t\t\t\t\t\t\t\t<AchievementCard\n\t\t\t\t\t\t\t\t\t\t\t\t\t\tkey={`recent-${achievement.id}`}\n\t\t\t\t\t\t\t\t\t\t\t\t\t\tachievement={achievement}\n\t\t\t\t\t\t\t\t\t\t\t\t\t\tindex={index}\n\t\t\t\t\t\t\t\t\t\t\t\t\t/>\n\t\t\t\t\t\t\t\t\t\t\t\t))}\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t</motion.div>\n\t\t\t\t\t\t\t\t)}\n\n\t\t\t\t\t\t\t\t{/* All Achievements Grid */}\n\t\t\t\t\t\t\t\t<div>\n\t\t\t\t\t\t\t\t\t<div className=\"flex flex-wrap items-center justify-between gap-4 mb-6\">\n\t\t\t\t\t\t\t\t\t\t<h2 className=\"text-2xl font-bold bg-gradient-to-l from-foreground to-foreground/70 bg-clip-text text-transparent flex items-center gap-3\">\n\t\t\t\t\t\t\t\t\t\t\tв”ҳГ в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШҙв•ӘШҜв•Әв–“в•ӘШҜв•ӘШІ\n\t\t\t\t\t\t\t\t\t\t\t{filteredAchievements.length !== achievements.length && (\n\t\t\t\t\t\t\t\t\t\t\t\t<Badge variant=\"default\" className=\"bg-primary/10 text-primary border-primary/20 hover:bg-primary/20 px-3 font-semibold rounded-full\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t{filteredAchievements.length} в”ҳВҶв•ӘШІв”ҳГЁв•ӘШҙв•ӘШұ\n\t\t\t\t\t\t\t\t\t\t\t\t</Badge>\n\t\t\t\t\t\t\t\t\t\t\t)}\n\t\t\t\t\t\t\t\t\t\t</h2>\n\t\t\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t\t\t{filteredAchievements.length === 0 ? (\n\t\t\t\