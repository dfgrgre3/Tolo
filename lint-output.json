\"h-5 w-5 rotate-270\" />\r\n              )}\r\n            </Button>\r\n          </div>\r\n\r\n          {/* User info */}\r\n          {/* User info removed */}\r\n\r\n\r\n          {/* Navigation items */}\r\n          <div className=\"p-4 overflow-y-auto h-[calc(100vh-200px)]\">\r\n            <nav className=\"space-y-1\" role=\"menu\">\r\n              {navigationItems.map((item) => {\r\n                const itemIsActive = isActive(item.href);\r\n                const isSubmenuOpen = activeSubmenu === item.title;\r\n                return (\r\n                  <div key={item.title}>\r\n                    <Link href={item.href} prefetch={false}>\r\n                      <div\r\n                        className={`flex items-center justify-between p-3 rounded-lg transition-colors ${\r\n                          itemIsActive\r\n                            ? 'bg-blue-50 text-blue-600 font-medium'\r\n                            : 'hover:bg-gray-100'\r\n                        }`}\r\n                        role=\"menuitem\"\r\n                      >\r\n                        <div className=\"flex items-center gap-3 min-w-0\">\r\n                          {item.icon}\r\n                          {isExpanded && (\r\n                            <motion.span\r\n                              initial={{ opacity: 0 }}\r\n                              animate={{ opacity: 1 }}\r\n                              exit={{ opacity: 0 }}\r\n                              className=\"truncate\"\r\n                            >\r\n                              {item.title}\r\n                            </motion.span>\r\n                          )}\r\n                        </div>\r\n                        {isExpanded && (\r\n                          <motion.div\r\n                            initial={{ opacity: 0 }}\r\n                            animate={{ opacity: 1 }}\r\n                            exit={{ opacity: 0 }}\r\n                            className=\"flex items-center gap-2 flex-shrink-0\"\r\n                          >\r\n                            {item.badge && (\r\n                              <Badge variant=\"secondary\" className=\"text-xs\">\r\n                                {item.badge}\r\n                              </Badge>\r\n                            )}\r\n                            {item.subItems && (\r\n                              <Button\r\n                                variant=\"ghost\"\r\n                                size=\"icon\"\r\n                                className=\"h-5 w-5 p-0\"\r\n                                onClick={(e) => {\r\n                                  e.preventDefault();\r\n                                  e.stopPropagation();\r\n                                  toggleSubmenu(item.title);\r\n                                }}\r\n                                aria-label={isSubmenuOpen ? 'Close submenu' : 'Open submenu'}\r\n                                aria-expanded={isSubmenuOpen}\r\n                              >\r\n                                {isSubmenuOpen ? (\r\n                                  <ChevronDown className=\"h-4 w-4\" />\r\n                                ) : (\r\n                                  <ChevronRight className=\"h-4 w-4\" />\r\n                                )}\r\n                              </Button>\r\n                            )}\r\n                          </motion.div>\r\n                        )}\r\n                      </div>\r\n                    </Link>\r\n                    {isExpanded && item.subItems && isSubmenuOpen && (\r\n                      <motion.div\r\n                        initial={{ opacity: 0, height: 0 }}\r\n                        animate={{ opacity: 1, height: 'auto' }}\r\n                        exit={{ opacity: 0, height: 0 }}\r\n                        className=\"mr-6 mt-1 space-y-1\"\r\n                        role=\"group\"\r\n                      >\r\n                        {