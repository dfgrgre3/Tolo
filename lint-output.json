\n              <>\r\n                <Loader2 className=\"h-5 w-5 animate-spin\" />\r\n                в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШөв•ӘШі...\r\n              </>\r\n            ) : (\r\n              <>\r\n                <Search className=\"h-5 w-5\" />\r\n                в•ӘШ°в•ӘШөв•ӘШі в•Әв•Јв”ҳВҶ в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯв”ҳГЁв”ҳВҶ\r\n              </>\r\n            )}\r\n          </button>\r\n        </form>\r\n      ) : (\r\n        <div className=\"space-y-6\">\r\n          <div className=\"flex items-center justify-between\">\r\n            <h3 className=\"font-medium text-gray-800\">в”ҳВҶв•ӘШІв•ӘШҜв•ӘШ®в•ӘШҙ в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШөв•ӘШі</h3>\r\n            <button\r\n              onClick={() => {\r\n                setTeachers(null);\r\n                setError('');\r\n              }}\r\n              className=\"text-blue-500 hover:text-blue-700 text-sm font-medium\"\r\n            >\r\n              в•ӘШ°в•ӘШөв•ӘШі в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»\r\n            </button>\r\n          </div>\r\n\r\n          {teachers.localTeachers.length > 0 && (\r\n            <div>\r\n              <h4 className=\"text-sm font-medium text-gray-700 mb-3\">в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯв”ҳГЁв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв”ҳВҒв”ҳГӘв•Әв••в”ҳГЁв”ҳВҶ ({teachers.localTeachers.length})</h4>\r\n              <div className=\"space-y-3\">\r\n                {teachers.localTeachers.map((teacher) => renderTeacherCard(teacher, 'local'))}\r\n              </div>\r\n            </div>\r\n          )}\r\n\r\n          {teachers.aiTeachers.length > 0 && (\r\n            <div>\r\n              <h4 className=\"text-sm font-medium text-gray-700 mb-3\">в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯв”ҳГЁв”ҳВҶ в”ҳГ в”ҳГӘв•Әв•Ўв”ҳГ« в•ӘШ°в”ҳГ§в”ҳГ  ({teachers.aiTeachers.length})</h4>\r\n              <div className=\"space-y-3\">\r\n                {teachers.aiTeachers.map((teacher) => renderTeacherCard(teacher, 'ai'))}\r\n              </div>\r\n            </div>\r\n          )}\r\n\r\n          {teachers.youtubeResults.length > 0 && (\r\n            <div>\r\n              <h4 className=\"text-sm font-medium text-gray-700 mb-3\">в”ҳГ©в”ҳВҶв”ҳГӘв•ӘШҜв•ӘШІ в”ҳГЁв”ҳГӘв•ӘШІв”ҳГЁв”ҳГӘв•ӘШ° ({teachers.youtubeResults.length})</h4>\r\n              <div className=\"space-y-3\">\r\n                {teachers.youtubeResults.map((teacher) => renderTeacherCard(teacher, 'youtube'))}\r\n              </div>\r\n            </div>\r\n          )}\r\n\r\n          {teachers.localTeachers.length === 0 && \r\n           teachers.aiTeachers.length === 0 && \r\n           teachers.youtubeResults.length === 0 && (\r\n            <div className=\"text-center py-8 text-gray-500\">\r\n              в”ҳВ„в”ҳГ  в”ҳГЁв•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•Әв•Јв•ӘШів”ҳГӘв•Әв–’ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШ«в”ҳГЁ в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯв”ҳГЁв”ҳВҶ. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ« в•ӘШ°в”ҳГўв”ҳВ„в”ҳГ в•ӘШҜв•ӘШІ в”ҳГ в”ҳВҒв•ӘШІв•ӘШҜв•ӘШөв”ҳГЁв•ӘШұ в”ҳГ в•ӘВ«в•ӘШІв”ҳВ„в”ҳВҒв•ӘШұ.\r\n            </div>\r\n          )}\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\ai\\components\\TipsGenerator.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Zap' is defined but never used. Allowed unused vars must match /^_/u.","line":5,"column":87,"nodeType":null,"messageId":"unusedVar","endLine":5,"endColumn":90},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'getGeminiInfo' is defined but never used. Allowed unused vars must match /^_/u.","line":6,"column":10,"nodeType":null,"messageId":"unusedVar","endLine":6,"endColumn":23}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\r\n\"use client\";\r\n\r\nimport React, { useState } from 'react';\r\nimport { Lightbulb, BookOpen, Target, AlertTriangle, CheckCircle, Loader2, RefreshCw, Zap } from 'lucide-react';\r\nimport { getGeminiInfo } from '@/lib/ai-config';\r\n\rimport { logger } from '@/lib/logger';\n\ninterface Tip {\r\n  category: 'в•ӘШҜв•Әв”Ӯв•ӘШІв•Әв–’в•ӘШҜв•ӘШІв”ҳГЁв•ӘШҙв”ҳГЁв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв•ӘШұ' | 'в•ӘШҜв”ҳВ„в•ӘШІв•Әв•‘в”ҳВ„в•ӘШ° в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШҜв•ӘШІ' | 'в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Ўв•ӘШҜв•ӘВ»в•Әв–’ в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Јв”ҳВ„в”ҳГЁв”ҳГ в”ҳГЁв•ӘШұ' | 'в•ӘШҜв”ҳВ„в•ӘВ«в•Әв•–в•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв”ҳГЁв•ӘШұ' | 'в•ӘШІв•ӘШөв•Әв”Ӯв”ҳГЁв”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ»в•ӘШҜв•ӘШ©';\r\n  title: string;\r\n  content: string;\r\n  priority: 'high' | 'medium' | 'low';\r\n}\r\n\r\ninterface TipsGeneratorProps {\r\n  subjects?: string[];\r\n  userId?: string;\r\n  className?: string;\r\n}\r\n\r\nexport default function TipsGenerator({\r\n  subjects = [],\r\n  userId,\r\n  className = \"\"\r\n}: TipsGeneratorProps) {\r\n  const [selectedSubject, setSelectedSubject] = useState('');\r\n  const [studyGoal, setStudyGoal] = useState('');\r\n  const [challenges, setChallenges] = useState('');\r\n  const [currentGrade, setCurrentGrade] = useState('');\r\n  const [isGenerating, setIsGenerating] = useState(false);\r\n  const [tipsData, setTipsData] = useState<{ tips?: Tip[]; summary?: string } | null>(null);\r\n  const [error, setError] = useState('');\r\n\r\n  const handleSubmit = async (e: React.FormEvent) => {\r\n    e.preventDefault();\r\n    setIsGenerating(true);\r\n    setError('');\r\n    setTipsData(null);\r\n\r\n    try {\r\n      const response = await fetch('/api/ai/tips', {\r\n        method: 'POST',\r\n        headers: {\r\n          'Content-Type': 'application/json',\r\n        },\r\n        body: JSON.stringify({\r\n          userId,\r\n          subject: selectedSubject || undefined,\r\n          studyGoal: studyGoal || undefined,\r\n          challenges: challenges || undefined,\r\n          currentGrade: currentGrade || undefined,\r\n          provider: 'gemini' // в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в•ӘШҜв”ҳГ  Gemini в”ҳГўв•ӘВ«в”ҳГЁв•ӘШҜв•Әв–’ в•ӘШҜв”ҳВҒв•ӘШІв•Әв–’в•ӘШҜв•Әв•ўв”ҳГЁ\r\n        }),\r\n      });\r\n\r\n      if (!response.ok) {\r\n        const errorData = await response.json();\r\n        throw new Error(errorData.error || 'в”ҳВҒв•Әв”Өв”ҳВ„в•ӘШІ в•Әв•Јв”ҳГ в”ҳВ„в”ҳГЁв•ӘШұ в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в”ҳВҶв•Әв•Ўв•ӘШҜв•ӘШ®в•ӘШө');\r\n      }\r\n\r\n      const data = await response.json();\r\n      setTipsData(data);\r\n    } catch (err) {\r\n      logger.error('Error generating tips:', err);\r\n      setError(err instanceof Error ? err.message : 'в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв•Јв•Әв–’в”ҳГӘв”ҳВҒ');\r\n    } finally {\r\n      setIsGenerating(false);\r\n    }\r\n  };\r\n\r\n  const getCategoryIcon = (category: Tip['category']) => {\r\n    switch (category) {\r\n      case 'в•ӘШҜв•Әв”Ӯв•ӘШІв•Әв–’в•ӘШҜв•ӘШІв”ҳГЁв•ӘШҙв”ҳГЁв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв•ӘШұ':\r\n        return <BookOpen className=\"h-5 w-5\" />;\r\n      case 'в•ӘШҜв”ҳВ„в•ӘШІв•Әв•‘в”ҳВ„в•ӘШ° в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШҜв•ӘШІ':\r\n        return <AlertTriangle className=\"h-5 w-5\" />;\r\n      case 'в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Ўв•ӘШҜв•ӘВ»в•Әв–’ в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Јв”ҳВ„в”ҳГЁв”ҳГ в”ҳГЁв•ӘШұ':\r\n        return <BookOpen className=\"h-5 w-5\" />;\r\n      case 'в•ӘШҜв”ҳВ„в•ӘВ«в•Әв•–в•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв”ҳГЁв•ӘШұ':\r\n        return <Target className=\"h-5 w-5\" />;\r\n      case 'в•ӘШІв•ӘШөв•Әв”Ӯв”ҳГЁв”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ»в•ӘШҜв•ӘШ©':\r\n        return <CheckCircle className=\"h-5 w-5\" />;\r\n      default:\r\n        return <Lightbulb className=\"h-5 w-5\" />;\r\n    }\r\n  };\r\n\r\n  const getCategoryColor = (category: Tip['category']) => {\r\n    switch (category) {\r\n      case 'в•ӘШҜв•Әв”Ӯв•ӘШІв•Әв–’в•ӘШҜв•ӘШІв”ҳГЁв•ӘШҙв”ҳГЁв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв•ӘШұ':\r\n        return 'bg-blue-100 text-blue-800';\r\n      case 'в•ӘШҜв”ҳВ„в•ӘШІв•Әв•‘в”ҳВ„в•ӘШ° в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШҜв•ӘШІ':\r\n        return 'bg-yellow-100 text-yellow-800';\r\n      case 'в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Ўв•ӘШҜв•ӘВ»в•Әв–’ в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Јв”ҳВ„в”ҳГЁв”ҳГ в”ҳГЁв•ӘШұ':\r\n        return 'bg-green-100 text-green-800';\r\n      case 'в•ӘШҜв”ҳВ„в•ӘВ«в•Әв•–в•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв”ҳГЁв•ӘШұ':\r\n        return 'bg-purple-100 text-purple-800';\r\n      case 'в•ӘШІв•ӘШөв•Әв”Ӯв”ҳГЁв”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ»в•ӘШҜв•ӘШ©':\r\n        return 'bg-indigo-100 text-indigo-800';\r\n      default:\r\n        return 'bg-gray-100 text-gray-800';\r\n    }\r\n  };\r\n\r\n  const getPriorityColor = (priority: Tip['priority']) => {\r\n    switch (priority) {\r\n      case 'high':\r\n        return 'bg-red-100 text-red-800';\r\n      case 'medium':\r\n        return 'bg-yellow-100 text-yellow-800';\r\n      case 'low':\r\n        return 'bg-green-100 text-green-800';\r\n      default:\r\n        return 'bg-gray-100 text-gray-800';\r\n    }\r\n  };\r\n\r\n  const getPriorityText = (priority: Tip['priority']) => {\r\n    switch (priority) {\r\n      case 'high':\r\n        return 'в•Әв•Јв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШұ';\r\n      case 'medium':\r\n        return 'в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•–в•ӘШұ';\r\n      case 'low':\r\n        return 'в”ҳГ в”ҳВҶв•ӘВ«в”ҳВҒв•Әв•ўв•ӘШұ';\r\n      default:\r\n        return '';\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className={`bg-white rounded-xl shadow-lg p-6 ${className}`}>\r\n      <div className=\"flex items-center gap-3 mb-6\">\r\n        <div className=\"p-2 bg-blue-100 rounded-lg\">\r\n          <Lightbulb className=\"h-6 w-6 text-blue-600\" />\r\n        </div>\r\n        <h2 className=\"text-xl font-bold text-gray-800\">в•ӘШҜв”ҳВ„в”ҳВҶв•Әв•Ўв•ӘШҜв•ӘШ®в•ӘШө в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Јв”ҳВ„в”ҳГЁв”ҳГ в”ҳГЁв•ӘШұ</h2>\r\n        <div className=\"ml-auto text-xs bg-green-100 text-green-800 px-2 py-1 rounded-full\">\r\n          Gemini 2.0 Flash\r\n        </div>\r\n      </div>\r\n\r\n      {!tipsData ? (\r\n        <form onSubmit={handleSubmit} className=\"space-y-4\">\r\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\r\n            {subjects.length > 0 && (\r\n              <div>\r\n                <label className=\"block text-sm font-medium text-gray-700 mb-1\">\r\n                  в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ (в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’в”ҳГЁ)\r\n                </label>\r\n                <select\r\n                  value={selectedSubject}\r\n                  onChange={(e) => setSelectedSubject(e.target.value)}\r\n                  className=\"block w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\"\r\n                >\r\n                  <option value=\"\">в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ</option>\r\n                  {subjects.map((subject) => (\r\n                    <option key={subject} value={subject}>\r\n                      {subject}\r\n                    </option>\r\n                  ))}\r\n                </select>\r\n              </div>\r\n            )}\r\n\r\n            <div>\r\n              <label className=\"block text-sm font-medium text-gray-700 mb-1\">\r\n                в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГӘв”ҳГ« в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв”ҳГЁ (в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’в”ҳГЁ)\r\n              </label>\r\n              <input\r\n                type=\"text\"\r\n                value={currentGrade}\r\n                onChange={(e) => setCurrentGrade(e.target.value)}\r\n                placeholder=\"в”ҳГ в•ӘШів•ӘШҜв”ҳВ„: в•ӘШ«в”ҳГӘв”ҳВ„ в•ӘШів•ӘШҜв”ҳВҶв”ҳГӘв”ҳГЁв•ӘГ® в•ӘШів•ӘШҜв”ҳВ„в•ӘШі в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в”ҳГЁ...\"\r\n                className=\"block w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\"\r\n              />\r\n            </div>\r\n\r\n            <div>\r\n              <label className=\"block text-sm font-medium text-gray-700 mb-1\">\r\n                в•ӘШҜв”ҳВ„в”ҳГ§в•ӘВ»в”ҳВҒ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв”ҳГЁ (в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’в”ҳГЁ)\r\n              </label>\r\n              <input\r\n                type=\"text\"\r\n                value={studyGoal}\r\n                onChange={(e) => setStudyGoal(e.target.value)}\r\n                placeholder=\"в”ҳГ в•ӘШів•ӘШҜв”ҳВ„: в•ӘШІв•ӘШөв•Әв”Ӯв”ҳГЁв”ҳВҶ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІв•ӘГ® в”ҳВҒв”ҳГ§в”ҳГ  в”ҳГ в”ҳВҒв•ӘШҜв”ҳГ§в”ҳГЁв”ҳГ  в•Әв•Ўв•Әв•Јв•ӘШ°в•ӘШұ...\"\r\n                className=\"block w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\"\r\n              />\r\n            </div>\r\n\r\n            <div>\r\n              <label className=\"block text-sm font-medium text-gray-700 mb-1\">\r\n                в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШҜв•ӘШІ (в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’в”ҳГЁ)\r\n              </label>\r\n              <input\r\n                type=\"text\"\r\n                value={challenges}\r\n                onChange={(e) => setChallenges(e.target.value)}\r\n                placeholder=\"в”ҳГ в•ӘШів•ӘШҜв”ҳВ„: в•Әв•Ўв•Әв•Јв”ҳГӘв•ӘШ°в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШөв”ҳВҒв•Әв••в•ӘГ® в”ҳГ©в”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•Әв–’в”ҳГўв”ҳГЁв•Әв–“...\"\r\n                className=\"block w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\"\r\n              />\r\n            </div>\r\n          </div>\r\n\r\n          {error && (\r\n            <div className=\"bg-red-50 text-red-700 p-3 rounded-lg\">\r\n              {error}\r\n            </div>\r\n          )}\r\n\r\n          <button\r\n            type=\"submit\"\r\n            disabled={isGenerating}\r\n            className=\"w-full bg-blue-500 hover:bg-blue-600 text-white font-medium py-2 px-4 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2\"\r\n          >\r\n            {isGenerating ? (\r\n              <>\r\n                <Loader2 className=\"h-5 w-5 animate-spin\" />\r\n                в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в”ҳВҶв•Әв•Ўв•ӘШҜв•ӘШ®в•ӘШө...\r\n              </>\r\n            ) : (\r\n              <>\r\n                <Lightbulb className=\"h-5 w-5\" />\r\n                в•ӘШҜв•ӘШөв•Әв•Ўв”ҳВ„ в•Әв•Јв”ҳВ„в”ҳГ« в”ҳВҶв•Әв•Ўв•ӘШҜв•ӘШ®в•ӘШө в•ӘШІв•Әв•Јв”ҳВ„в”ҳГЁв”ҳГ в”ҳГЁв•ӘШұ\r\n              </>\r\n            )}\r\n          </button>\r\n        </form>\r\n      ) : (\r\n        <div className=\"space-y-6\">\r\n          <div className=\"flex items-center justify-between\">\r\n            <h3 className=\"font-medium text-gray-800\">в”ҳВҶв•Әв•Ўв•ӘШҜв•ӘШ®в•ӘШө в”ҳГ в•ӘВ«в•Әв•Ўв•Әв•Ўв•ӘШұ в”ҳВ„в”ҳГў</h3>\r\n            <button\r\n              onClick={() => {\r\n                setTipsData(null);\r\n                setError('');\r\n              }}\r\n              className=\"text-blue-500 hover:text-blue-700 text-sm font-medium flex items-center gap-1\"\r\n            >\r\n              <RefreshCw className=\"h-4 w-4\" />\r\n              в”ҳВҶв•Әв•Ўв•ӘШҜв•ӘШ®в•ӘШө в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ\r\n            </button>\r\n          </div>\r\n\r\n          {tipsData.summary && (\r\n            <div className=\"bg-blue-50 border border-blue-200 rounded-lg p-4\">\r\n              <h4 className=\"font-medium text-blue-800 mb-2\">в”ҳГ в”ҳВ„в•ӘВ«в•Әв•Ў в•ӘШҜв”ҳВ„в”ҳВҶв•Әв•Ўв•ӘШҜв•ӘШ®в•ӘШө</h4>\r\n              <p className=\"text-blue-700\">{tipsData.summary}</p>\r\n            </div>\r\n          )}\r\n\r\n          <div className=\"space-y-4\">\r\n            {tipsData.tips?.map((tip, index) => (\r\n              <div key={index} className=\"border border-gray-200 rounded-lg p-4 hover:shadow-md transition-shadow\">\r\n                <div className=\"flex items-start justify-between mb-3\">\r\n                  <div className=\"flex items-center gap-2\">\r\n                    <div className={`p-2 rounded-lg ${getCategoryColor(tip.category)}`}>\r\n                      {getCategoryIcon(tip.category)}\r\n                    </div>\r\n                    <h4 className=\"font-bold text-gray-800\">{tip.title}</h4>\r\n                  </div>\r\n                  <span className={`text-xs px-2 py-1 rounded-full ${getPriorityColor(tip.priority)}`}>\r\n                    {getPriorityText(tip.priority)}\r\n                  </span>\r\n                </div>\r\n                <p className=\"text-gray-600\">{tip.content}</p>\r\n              </div>\r\n            ))}\r\n          </div>\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\ai\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'BookOpen' is defined but never used. Allowed unused vars must match /^_/u.","line":5,"column":66,"nodeType":null,"messageId":"unusedVar","endLine":5,"endColumn":74}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\r\n\"use client\";\r\n\r\nimport React, { useState } from 'react';\r\nimport { Brain, Bot, MessageSquare, FileText, Search, Lightbulb, BookOpen, Zap } from 'lucide-react';\r\nimport AIAssistant from './components/AIAssistant';\r\nimport ExamGenerator from './components/ExamGenerator';\r\nimport TeacherSearch from './components/TeacherSearch';\r\nimport TipsGenerator from './components/TipsGenerator';\r\nimport { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';\r\nimport { PageContainer } from \"@/components/ui/PageContainer\";\r\nimport { Card, CardContent, CardHeader, CardTitle } from \"@/components/ui/card\";\r\n\r\nexport default function AILearningPage() {\r\n  const [activeTab, setActiveTab] = useState('assistant');\r\n\r\n  // в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘШҜв•ӘВ» в”ҳВ„в”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв