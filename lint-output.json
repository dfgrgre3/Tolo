rom \"react\";\n// в•ӘШІв”ҳГ  в•ӘШӯв•Әв–“в•ӘШҜв”ҳВ„в•ӘШұ в”ҳВҶв•Әв••в•ӘШҜв”ҳГ  в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„\n\r\nasync function getUserId(): Promise<string | null> {\r\n\t// Get user ID from auth token - only run on client side\r\n\t// Token is in httpOnly cookie - no need to send Authorization header\r\n\ttry {\r\n\t\tconst res = await fetch(\"/api/auth/me\", {\r\n\t\t\tcredentials: \"include\",\r\n\t\t});\r\n\t\t\r\n\t\tif (!res.ok) return null;\r\n\t\t\r\n\t\tconst data = await res.json();\r\n\t\treturn data.user.id;\r\n\t} catch (error) {\n\t\tconsole.error(\"Error getting user ID:\", error);\n\t\treturn null;\n\t}\n}\n\r\ntype Reminder = {\r\n\tid: string;\r\n\ttitle: string;\r\n\tmessage?: string | null;\r\n\tremindAt: string; // ISO\r\n\trepeat?: string | null; // \"daily\" | \"weekly\" | cron(not supported)\r\n};\r\n\r\nfunction getNextOccurrence(reminder: Reminder, now: Date): Date | null {\r\n\tconst base = new Date(reminder.remindAt);\r\n\tif (!reminder.repeat) {\r\n\t\treturn base >= now ? base : null;\r\n\t}\r\n\tif (reminder.repeat === \"daily\") {\r\n\t\tconst next = new Date(base);\r\n\t\twhile (next < now) {\r\n\t\t\tnext.setDate(next.getDate() + 1);\r\n\t\t}\r\n\t\treturn next;\r\n\t}\r\n\tif (reminder.repeat === \"weekly\") {\r\n\t\tconst next = new Date(base);\r\n\t\twhile (next < now) {\r\n\t\t\tnext.setDate(next.getDate() + 7);\r\n\t\t}\r\n\t\treturn next;\r\n\t}\r\n\treturn null;\r\n}\r\n\r\nexport default function NotificationsClient() {\r\n\tconst [enabled, setEnabled] = useState(false);\r\n\tconst [mounted, setMounted] = useState(false);\r\n\tconst timersRef = useRef<{ id: string; occurrence: string; timer: number }[]>([]);\r\n\tconst notifiedRef = useRef<Set<string>>(new Set());\r\n\r\n\tuseEffect(() => {\r\n\t\tsetMounted(true);\r\n\t\tif (typeof window === \"undefined\" || typeof Notification === \"undefined\") return;\r\n\t\tif (Notification.permission === \"granted\") setEnabled(true);\r\n\t}, []);\r\n\r\n\tuseEffect(() => {\r\n\t\tif (typeof window === \"undefined\" || typeof Notification === \"undefined\") return;\r\n\t\tif (Notification.permission !== \"granted\" || !enabled) return;\r\n\t\tlet active = true;\r\n\t\t(async () => {\r\n\t\t\tconst userId = await getUserId();\r\n\t\t\tif (!userId) return; // Skip if not authenticated\r\n\t\t\tconst loadAndSchedule = async () => {\r\n\t\t\t\tif (!active) return;\n\t\t\t\ttry {\r\n\t\t\t\tconst res = await fetch(`/api/reminders?userId=${userId}`);\r\n\t\t\t\tconst json = await res.json();\n\t\t\t\tconst reminders: Reminder[] = (Array.isArray(json) ? json : json.data) || [];\r\n\t\t\t\t// Clear existing timers\r\n\t\t\t\ttimersRef.current.forEach((t) => clearTimeout(t.timer));\r\n\t\t\t\ttimersRef.current = [];\r\n\t\t\t\tconst now = new Date();\r\n\t\t\t\tfor (const r of reminders) {\r\n\t\t\t\t\tconst next = getNextOccurrence(r, now);\r\n\t\t\t\t\tif (!next) continue;\r\n\t\t\t\t\tconst notifyAt = new Date(next.getTime() - 10 * 60 * 1000);\r\n\t\t\t\t\tif (notifyAt < now) {\r\n\t\t\t\t\t\t// If window passed but within 1 minute, notify immediately\r\n\t\t\t\t\t\tif (now.getTime() - notifyAt.getTime() < 60 * 1000) {\r\n\t\t\t\t\t\t\tconst key = `${r.id}:${next.toISOString()}`;\r\n\t\t\t\t\t\t\tif (!notifiedRef.current.has(key)) {\r\n\t\t\t\t\t\t\t\tnotifiedRef.current.add(key);\r\n\t\t\t\t\t\t\t\tnew Notification(r.title, { body: r.message || \"в•ӘШІв•Әв–‘в”ҳГўв”ҳГЁв•Әв–’ в•ӘШ°в•Әв•Јв•ӘВ» 10 в•ӘВ»в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ©\" });\r\n\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t\tcontinue;\r\n\t\t\t\t\t}\r\n\t\t\t\t\tconst delay = notifyAt.getTime() - now.getTime();\r\n\t\t\t\t\tconst occurrenceKey = `${r.id}:${next.toISOString()}`;\r\n\t\t\t\t\tif (notifiedRef.current.has(occurrenceKey)) continue;\r\n\t\t\t\t\tconst timer = window.setTimeout(() => {\r\n\t\t\t\t\t\tif (notifiedRef.current.has(occurrenceKey)) return;\r\n\t\t\t\t\t\tnotifiedRef.current.add(occurrenceKey);\r\n\t\t\t\t\t\tnew Notification(r.title, { body: r.message || \"в•ӘШІв•Әв–‘в”ҳГўв”ҳГЁв•Әв–’ в•ӘШ°в•Әв•Јв•ӘВ» 10 в•ӘВ»в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ©\" });\r\n\t\t\t\t\t}, delay);\r\n\t\t\t\t\ttimersRef.current.push({ id: r.id, occurrence: next.toISOString(), timer });\r\n\t\t\t\t}\r\n\t\t\t\t} catch (error) {\n\t\t\t\t\tconsole.error(\"Error in loadAndSchedule:\", error);\n\t\t\t\t}\n\t\t\t};\r\n\t\t\tawait loadAndSchedule();\r\n\t\t\tconst interval = window.setInterval(loadAndSchedule, 60 * 1000);\r\n\t\t\treturn () => {\r\n\t\t\t\tactive = false;\r\n\t\t\t\tclearInterval(interval);\r\n\t\t\t\ttimersRef.current.forEach((t) => clearTimeout(t.timer));\r\n\t\t\t\ttimersRef.current = [];\r\n\t\t\t};\r\n\t\t})();\r\n\t}, [mounted]);\r\n\r\n\tfunction requestPermission() {\r\n\t\tif (typeof Notification === \"undefined\") return;\r\n\t\tNotification.requestPermission().then((perm) => setEnabled(perm === \"granted\"));\r\n\t}\r\n\r\n\t// Prevent hydration mismatch by returning consistent content\r\n\tif (!mounted || typeof Notification === \"undefined\") {\r\n\t\treturn (\r\n\t\t\t<div className=\"mx-auto max-w-7xl px-4 py-2 text-xs text-muted-foreground opacity-0\">\r\n\t\t\t\t{/* Placeholder to prevent hydration mismatch */}\r\n\t\t\t\t<div className=\"h-6\"></div>\r\n\t\t\t</div>\r\n\t\t);\r\n\t}\r\n\r\n\tif (Notification.permission !== \"granted\") {\r\n\t\treturn (\r\n\t\t\t<div className=\"mx-auto max-w-7xl px-4 py-2 text-xs text-muted-foreground\">\r\n\t\t\t\t<button className=\"px-2 py-1 border rounded-md\" onClick={requestPermission} aria-label=\"в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ\">в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„ в•ӘШӯв•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШІв•Әв–‘в”ҳГўв”ҳГЁв•Әв–’в•ӘШҜв•ӘШІ</button>\r\n\t\t\t</div>\r\n\t\t);\r\n\t}\r\n\treturn null;\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\components\\common\\Navbar.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'cn' is defined but never used. Allowed unused vars must match /^_/u.","line":3,"column":10,"nodeType":null,"messageId":"unusedVar","endLine":3,"endColumn":12}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import Link from \"next/link\";\nimport { Button } from \"@/components/ui/button\";\nimport { cn } from \"@/lib/utils\";\nimport { BookOpen, Menu } from \"lucide-react\";\n\nexport function Navbar() {\n  return (\n    <header className=\"fixed top-0 z-50 w-full border-b border-white/10 bg-background/80 backdrop-blur-md\">\n      <div className=\"container mx-auto flex h-16 items-center justify-between px-4\">\n        {/* Logo */}\n        <Link href=\"/\" className=\"flex items-center gap-2\">\n          <div className=\"flex h-8 w-8 items-center justify-center rounded-lg bg-primary text-primary-foreground\">\n            <BookOpen className=\"h-5 w-5\" />\n          </div>\n          <span className=\"text-xl font-bold tracking-tight\">Tolo</span>\n        </Link>\n\n        {/* Desktop Nav */}\n        <nav className=\"hidden md:flex items-center gap-8\">\n          <Link href=\"/features\" className=\"text-sm font-medium text-muted-foreground transition-colors hover:text-primary\">\n            Features\n          </Link>\n          <Link href=\"/pricing\" className=\"text-sm font-medium text-muted-foreground transition-colors hover:text-primary\">\n            Pricing\n          </Link>\n          <Link href=\"/about\" className=\"text-sm font-medium text-muted-foreground transition-colors hover:text-primary\">\n            About\n          </Link>\n        </nav>\n\n        {/* Actions */}\n        <div className=\"hidden md:flex items-center gap-4\">\n          <Button variant=\"ghost\" size=\"sm\">\n            Sign In\n          </Button>\n          <Button size=\"sm\">Get Started</Button>\n        </div>\n\n        {/* Mobile Menu Toggle (Placeholder) */}\n        <Button variant=\"ghost\" size=\"icon\" className=\"md:hidden\">\n          <Menu className=\"h-5 w-5\" />\n        </Button>\n      </div>\n    </header>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\components\\common\\NetworkMonitor.tsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'isOnline'. Either include it or remove the dependency array.","line":16,"column":6,"nodeType":"ArrayExpression","endLine":16,"endColumn":8,"suggestions":[{"desc":"Update the dependencies array to be: [isOnline]","fix":{"range":[447,449],"text":"[isOnline]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\n\nimport { useEffect, useRef } from 'react';\nimport { useNetworkStatus } from '@/hooks/use-network-status';\nimport { toast } from 'sonner';\n\nexport function NetworkMonitor() {\n  const isOnline = useNetworkStatus();\n  const prevStatusRef = useRef<boolean>(true);\n  const mountedRef = useRef<boolean>(false);\n\n  useEffect(() => {\n    // Initialize refs on mount\n    prevStatusRef.current = isOnline;\n    mountedRef.current = true;\n  }, []); // Only runs once on mount\n\n  useEffect(() => {\n    if (!mountedRef.current) return;\n\n    // Only trigger if status CHANGED\n    if (prevStatusRef.current !== isOnline) {\n      if (!isOnline) {\n        toast.error('в•ӘШҜв”ҳВҶв”ҳГ©в•Әв•–в•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„ в•ӘШ°в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШІв•Әв–’в”ҳВҶв•ӘШІ', {\n          description: 'в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в”ҳГ в”ҳВҶ в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв”Өв•ӘШ°в”ҳГўв•ӘШұ',\n          id: 'network-status',\n          duration: Infinity,\n        });\n      } else {\n        toast.success('в•ӘШІв”ҳГ в•ӘШІ в•ӘШҜв•Әв”Ӯв•ӘШІв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„', {\n          description: 'в•ӘШ«в”ҳВҶв•ӘШІ в”ҳГ в•ӘШІв•Әв•Ўв”ҳВ„ в•ӘШ°в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШІв•Әв–’в”ҳВҶв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШӘв”ҳВҶ',\n          id: 'network-status', // Replace the error toast\n          duration: 4000,\n        });\n      }\n      prevStatusRef.current = isOnline;\n    }\n  }, [isOnline]);\n\n  return null;\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\components\\dashboard\\DashboardStatsCards.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Badge' is defined but never used. Allowed unused vars must match /^_/u.","line":3,"column":10,"nodeType":null,"messageId":"unusedVar","endLine":3,"endColumn":15}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React from 'react';\r\nimport { Card, CardContent, CardHeader, CardTitle } from '../ui/card';\r\nimport { Badge } from '../ui/badge';\r\nimport { Clock, Calendar, Target, TrendingUp } from 'lucide-react';\r\n\r\n/**\r\n * в•ӘШӯв•ӘШөв•Әв•Ўв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШҜв•ӘШІ в”ҳВ„в”ҳГӘв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГўв”ҳГ \r\n */\r\nexport interface DashboardStats {\r\n  /** в•ӘШӯв•ӘШҙв”ҳГ в•ӘШҜв”ҳВ„в”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ  */\r\n  totalTasks: number;\r\n  /** в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв•ӘШІв”ҳГ в”ҳВ„в•ӘШұ */\r\n  completedTasks: number;\r\n  /** в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГ©в•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•Әв•‘в•Әв–’в”ҳГ© в•ӘШҜв”ҳВ„в”ҳГЁв”ҳГӘв”ҳГ  (в•ӘШ°в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ©) */\r\n  todayTimeSpent: number;\r\n  /** в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГ©в•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•Әв•‘в•Әв–’в”ҳГ© в”ҳГ§в•Әв–‘в•ӘШҜ в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•ӘШ°в”ҳГӘв•Әв•Ј (в•ӘШ°в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ©) */\r\n  weekTimeSpent: number;\r\n  /** в•Әв•Јв•ӘВ»в•ӘВ» в•ӘШҜв”ҳВ„в•ӘШ«в•ӘШөв•ӘВ»в•ӘШҜв•ӘШі в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв•ӘВ»в”ҳГ в•ӘШұ */\r\n  upcomingEvents: number;\r\n  /** в”ҳГ в•Әв•Јв•ӘВ»в”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШҙв•ӘШҜв•Әв–“ (в”ҳВҶв•Әв”Ӯв•ӘШ°в•ӘШұ в”ҳГ в•ӘШ®в”ҳГӘв”ҳГЁв•ӘШұ) */\r\n  completionRate: number;\r\n}\r\n\r\n/**\r\n * в•ӘВ«в•Әв•Ўв•ӘШҜв•ӘШ®в•Әв•Ў в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶ в•ӘШӯв•ӘШөв•Әв•Ўв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШҜв•ӘШІ в”ҳВ„в”ҳГӘв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГўв”ҳГ \r\n */\r\nexport interface DashboardStatsProps {\r\n  /** в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШөв•Әв•Ўв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШҜв•ӘШІ */\r\n  stats: DashboardStats;\r\n}\r\n\r\n/**\r\n * в•ӘШІв”ҳВҶв•Әв”Ӯв”ҳГЁв”ҳГ© в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГ©в•ӘШІ в”ҳГ в”ҳВҶ в•ӘВ»в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ© в•ӘШӯв”ҳВ„в”ҳГ« в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘШҜв•ӘШІ в”ҳГӘв•ӘВ»в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ©\r\n */\r\nconst formatTime = (minutes: number): string => {\r\n  const hours = Math.floor(minutes / 60);\r\n  const mins = minutes % 60;\r\n  \r\n  if (hours === 0) {\r\n    return `${mins} в•ӘВ»в”ҳГ©в”ҳГЁв”ҳГ©в•ӘШұ`;\r\n  }\r\n  \r\n  return `${hours} в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘШұ${mins > 0 ? ` в”ҳГӘ ${mins} в•ӘВ»в”ҳГ©в”ҳГЁв”ҳГ©в•ӘШұ` : ''}`;\r\n};\r\n\r\n/**\r\n * в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶ в•ӘШӯв•ӘШөв•Әв•Ўв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШҜв•ӘШІ в”ҳВ„в”ҳГӘв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГўв”ҳГ \r\n * \r\n * в”ҳГЁв•Әв•Јв•Әв–’в•Әв•ў в”ҳГ в”ҳВ„в•ӘВ«в•Әв•Ў в•Әв”Ӯв•Әв–’в”ҳГЁв•Әв•Ј в”ҳВ„в•ӘШ«в•ӘВ»в•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ \r\n * \r\n * @example\r\n * ```tsx\r\n * <DashboardStatsCards stats={{\r\n *   totalTasks: 10,\r\n *   completedTasks: 7,\r\n *   todayTimeSpent: 120,\r\n *   weekTimeSpent: 600,\r\n *   upcomingEvents: 3,\r\n *   completionRate: 70\r\n * }} />\r\n * ```\r\n */\r\nexport const DashboardStatsCards: React.FC<DashboardStatsProps> = React.memo(({ stats }) => {\r\n  const statsCards = [\r\n    {\r\n      title: 'в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ ',\r\n      value: `${stats.completedTasks}/${stats.totalTasks}`,\r\n      description: 'в”ҳГ в”ҳГўв•ӘШІв”ҳГ в”ҳВ„в•ӘШұ',\r\n      icon: Target,\r\n      color: 'text-blue-600',\r\n      bgColor: 'bg-blue-50',\r\n    },\r\n    {\r\n      title: 'в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГ©в•ӘШІ в•ӘШҜв”ҳВ„в”ҳГЁв”ҳГӘв”ҳГ ',\r\n      value: formatTime(stats.todayTimeSpent),\r\n      description: 'в”ҳГӘв”ҳГ©в•ӘШІ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв•ӘШұ',\r\n      icon: Clock,\r\n      color: 'text-green-600',\r\n      bgColor: 'bg-green-50',\r\n    },\r\n    {\r\n      title: 'в•ӘШҜв”ҳВ„в•ӘШ«в•ӘШөв•ӘВ»в•ӘШҜв•ӘШі в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв•ӘВ»в”ҳГ в•ӘШұ',\r\n      value: stats.upcomingEvents.toString(),\r\n      description: 'в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШҙв•ӘВ»в”ҳГӘв”ҳВ„',\r\n      icon: Calendar,\r\n      color: 'text-purple-600',\r\n      bgColor: 'bg-purple-50',\r\n    },\r\n    {\r\n      title: 'в”ҳГ в•Әв•Јв•ӘВ»в”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШҙв•ӘШҜв•Әв–“',\r\n      value: `${stats.completionRate}%`,\r\n      description: 'в”ҳГ§в•Әв–‘в•ӘШҜ в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•ӘШ°в”ҳГӘв•Әв•Ј',\r\n      icon: TrendingUp,\r\n      color: 'text-orange-600',\r\n      bgColor: 'bg-orange-50',\r\n    },\r\n  ];\r\n\r\n  return (\r\n    <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6\">\r\n      {statsCards.map((stat, index) => {\r\n        const Icon = stat.icon;\r\n        return (\r\n          <Card \r\n            key={index} \r\n            className=\"hover:shadow-lg transition-shadow duration-300\"\r\n          >\r\n            <CardHeader className=\"flex flex-row items-center justify-between space-y-0 pb-2\">\r\n              <CardTitle className=\"text-sm font-medium\">\r\n                {stat.title}\r\n              </CardTitle>\r\n              <div className={`${stat.bgColor} p-2 rounded-lg`}>\r\n                <Icon className={`h-4 w-4 ${stat.color}`} />\r\n              </div>\r\n            </CardHeader>\r\n            <CardContent>\r\n              <div className=\"text-2xl font-bold\">{stat.value}</div>\r\n              <p className=\"text-xs text-muted-foreground mt-1\">\r\n                {stat.description}\r\n              </p>\r\n            </CardContent>\r\n          </Card>\r\n        );\r\n      })}\r\n    </div>\r\n  );\r\n});\r\n\r\nDashboardStatsCards.displayName = 'DashboardStatsCards';\r\n\r\nexport default DashboardStatsCards;\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\components\\dashboard\\SectionHeader.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Card' is defined but never used. Allowed unused vars must match /^_/u.","line":2,"column":10,"nodeType":null,"messageId":"unusedVar","endLine":2,"endColumn":14},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'CardContent' is defined but never used. Allowed unused vars must match /^_/u.","line":2,"column":16,"nodeType":null,"messageId":"unusedVar","endLine":2,"endColumn":27},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'CardHeader' is defined but never used. Allowed unused vars must match /^_/u.","line":2,"column":29,"nodeType":null,"messageId":"unusedVar","endLine":2,"endColumn":39},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'CardTitle' is defined but never used. Allowed unused vars must match /^_/u.","line":2,"column":41,"nodeType":null,"messageId":"unusedVar","endLine":2,"endColumn":50}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React from 'react';\r\nimport { Card, CardContent, CardHeader, CardTitle } from '../ui/card';\r\nimport { Button } from '../ui/button';\r\nimport { Plus, Filter, Search } from 'lucide-react';\r\nimport { Input } from '../ui/input';\r\n\r\n/**\r\n * в•ӘВ«в•Әв•Ўв•ӘШҜв•ӘШ®в•Әв•Ў в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶ в•Әв–’в•ӘШ«в•Әв”Ӯ в•ӘШҜв”ҳВ„в”ҳГ©в•Әв”Ӯв”ҳГ \r\n */\r\nexport interface SectionHeaderProps {\r\n  /** в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ©в•Әв”Ӯв”ҳГ  */\r\n  title: string;\r\n  /** в”ҳГӘв•Әв•Ўв”ҳВҒ в•ӘШҜв”ҳВ„в”ҳГ©в•Әв”Ӯв”ҳГ  (в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’в”ҳГЁ) */\r\n  description?: string;\r\n  /** в”ҳГ§в”ҳВ„ в”ҳГЁв•ӘШІв”ҳГ  в•Әв•Јв•Әв–’в•Әв•ў в•Әв–“в•Әв–’ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұв•ӘШ§ */\r\n  showAddButton?: boolean;\r\n  /** в”ҳВҶв•Әв•Ў в•Әв–“в•Әв–’ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ */\r\n  addButtonText?: string;\r\n  /** в•ӘВ»в•ӘШҜв”ҳВ„в•ӘШұ callback в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ©в•Әв–’ в•Әв•Јв”ҳВ„в”ҳГ« в•Әв–“в•Әв–’ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ */\r\n  onAdd?: () => void;\r\n  /** в”ҳГ§в”ҳВ„ в”ҳГЁв•ӘШІв”ҳГ  в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШөв•ӘШів•ӘШ§ */\r\n  showSearch?: boolean;\r\n  /** placeholder в”ҳВ„в”ҳВ„в•ӘШ°в•ӘШөв•ӘШі */\r\n  searchPlaceholder?: string;\r\n  /** в”ҳГ©в”ҳГЁв”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШөв•ӘШі */\r\n  searchValue?: string;\r\n  /** в•ӘВ»в•ӘШҜв”ҳВ„в•ӘШұ callback в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШөв•ӘШі */\r\n  onSearchChange?: (value: string) => void;\r\n  /** в”ҳГ§в”ҳВ„ в”ҳГЁв•ӘШІв”ҳГ  в•Әв•Јв•Әв–’в•Әв•ў в•Әв–“в•Әв–’ в•ӘШҜв”ҳВ„в”ҳВҒв”ҳВ„в•ӘШІв•Әв–’в•ӘШ§ */\r\n  showFilter?: boolean;\r\n  /** в•ӘВ»в•ӘШҜв”ҳВ„в•ӘШұ callback в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ©в•Әв–’ в•Әв•Јв”ҳВ„в”ҳГ« в•Әв–“в•Әв–’ в•ӘШҜв”ҳВ„в”ҳВҒв”ҳВ„в•ӘШІв•Әв–’ */\r\n  onFilter?: () => void;\r\n  /** в•Әв•Јв”ҳВҶв•ӘШҜв•Әв•Ўв•Әв–’ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв”ҳГЁв•ӘШұ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•Әв–’в•ӘШ«в•Әв”Ӯ */\r\n  actions?: React.ReactNode;\r\n}\r\n\r\n/**\r\n * в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶ в•Әв–’в•ӘШ«в•Әв”Ӯ в•ӘШҜв”ҳВ„в”ҳГ©в•Әв”Ӯв”ҳГ \r\n * \r\n * в•Әв–’в•ӘШ«в•Әв”Ӯ в”ҳГ©в•ӘШҜв•ӘШ°в”ҳВ„ в”ҳВ„в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в•ӘШҜв”ҳГ  в”ҳВ„в•ӘШ«в”ҳГ©в•Әв”Ӯв•ӘШҜв”ҳГ  в”ҳВ„в”ҳГӘв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГўв”ҳГ \r\n * \r\n * @example\r\n * ```tsx\r\n * <SectionHeader \r\n *   title=\"в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ \"\r\n *   description=\"в•ӘШӯв•ӘВ»в•ӘШҜв•Әв–’в•ӘШұ в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ в”ҳГў в•ӘШҜв”ҳВ„в”ҳГЁв”ҳГӘв”ҳГ в”ҳГЁв•ӘШұ\"\r\n *   showAddButton\r\n *   addButtonText=\"в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ\"\r\n *   onAdd={() => console.log('Add task')}\r\n * />\r\n * ```\r\n */\r\nexport const SectionHeader: React.FC<SectionHeaderProps> = React.memo(({\r\n  title,\r\n  description,\r\n  showAddButton = false,\r\n  addButtonText = 'в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ',\r\n  onAdd,\r\n  showSearch = false,\r\n  searchPlaceholder = 'в•ӘШ°в•ӘШөв•ӘШі...',\r\n  searchValue = '',\r\n  onSearchChange,\r\n  showFilter = false,\r\n  onFilter,\r\n  actions,\r\n}) => {\r\n  return (\r\n    <div className=\"flex flex-col space-y-4 mb-4\">\r\n      <div className=\"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4\">\r\n        <div>\r\n          <h2 className=\"text-2xl font-bold tracking-tight\">{title}</h2>\r\n          {description && (\r\n            <p className=\"text-sm text-muted-foreground mt-1\">\r\n              {description}\r\n            </p>\r\n          )}\r\n        </div>\r\n        \r\n        <div className=\"flex items-center gap-2\">\r\n          {showFilter && (\r\n            <Button\r\n              variant=\"outline\"\r\n              size=\"sm\"\r\n              onClick={onFilter}\r\n              className=\"gap-2\"\r\n            >\r\n              <Filter className=\"h-4 w-4\" />\r\n              в”ҳВҒв”ҳВ„в•ӘШІв•Әв–’\r\n            </Button>\r\n          )}\r\n          \r\n          {showAddButton && (\r\n            <Button\r\n              onClick={onAdd}\r\n              size=\"sm\"\r\n              className=\"gap-2\"\r\n            >\r\n              <Plus className=\"h-4 w-4\" />\r\n              {addButtonText}\r\n            </Button>\r\n          )}\r\n          \r\n          {actions}\r\n        </div>\r\n      </div>\r\n      \r\n      {showSearch && (\r\n        <div className=\"relative\">\r\n          <Search className=\"absolute right-3 top-1/2 transform -translate-y-1/2 h-4 w-4 text-muted-foreground\" />\r\n          <Input\r\n            type=\"text\"\r\n            placeholder={searchPlaceholder}\r\n            value={searchValue}\r\n            onChange={(e) => onSearchChange?.(e.target.value)}\r\n            className=\"pr-10\"\r\n          />\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n});\r\n\r\nSectionHeader.displayName = 'SectionHeader';\r\n\r\nexport default SectionHeader;\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\components