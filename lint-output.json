sk.id} \n          className={`border-l-4 transition-all duration-200 hover:shadow-md ${\n            task.priority === 2 ? 'border-red-500' : \n            task.priority === 1 ? 'border-yellow-500' : 'border-green-500'\n          } ${task.status === TaskStatus.COMPLETED ? 'opacity-75 bg-green-50' : ''}`}\n        >\n          <CardHeader>\n            <CardTitle className=\"flex items-center justify-between\">\n              <div className=\"flex items-center space-x-2\">\n                <Checkbox\n                  checked={task.status === TaskStatus.COMPLETED}\n                  onCheckedChange={() => onStatusChange(task.id, task.status)}\n                  disabled={task.status === TaskStatus.COMPLETED}\n                />\n                <span className={`${task.status === TaskStatus.COMPLETED ? 'line-through text-gray-500' : ''}`}>\n                  {task.title}\n                </span>\n              </div>\n              <div className=\"flex items-center space-x-1\">\n                <Button variant=\"ghost\" size=\"sm\" onClick={() => onEdit(task)}>\n                  <Edit className=\"h-4 w-4\" />\n                </Button>\n                <Dialog>\n                  <DialogTrigger asChild>\n                    <Button variant=\"ghost\" size=\"sm\">\n                      <Trash2 className=\"h-4 w-4 text-red-500\" />\n                    </Button>\n                  </DialogTrigger>\n                  <DialogContent>\n                    <DialogHeader>\n                      <DialogTitle>в”ҳГ§в”ҳВ„ в•ӘШ«в”ҳВҶв•ӘШІ в”ҳГ в•ӘШІв•ӘШ«в”ҳГўв•ӘВ»в•ӘШ§</DialogTitle>\n                      <DialogDescription>\n                        в”ҳГ§в•Әв–‘в•ӘШҜ в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШҙв•Әв–’в•ӘШҜв•ӘШ© в•Әв”Ӯв”ҳГЁв”ҳГ©в”ҳГӘв”ҳГ  в•ӘШ°в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ в”ҳВҶв”ҳГ§в•ӘШҜв•ӘШ®в”ҳГЁв•ӘШҜв”ҳГҜ. в”ҳВ„в•ӘШҜ в”ҳГЁв”ҳГ в”ҳГўв”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШІв•Әв–’в•ӘШҜв•ӘШҙв•Әв•Ј в•Әв•Јв”ҳВҶ в”ҳГ§в•Әв–‘в•ӘШҜ в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШҙв•Әв–’в•ӘШҜв•ӘШ©.\n                      </DialogDescription>\n                    </DialogHeader>\n                    <DialogFooter>\n                      <Button \n                        variant=\"outline\" \n                        onClick={() => {}}\n                      >\n                        в•ӘШӯв”ҳВ„в•Әв•‘в•ӘШҜв•ӘШ©\n                      </Button>\n                      <Button \n                        variant=\"destructive\" \n                        onClick={() => onDelete(task.id)}\n                      >\n                        в•ӘШөв•Әв–‘в”ҳВҒ\n                      </Button>\n                    </DialogFooter>\n                  </DialogContent>\n                </Dialog>\n              </div>\n            </CardTitle>\n          </CardHeader>\n          <CardContent>\n            <div className=\"flex flex-col gap-2\">\n              <div className=\"flex items-center justify-between\">\n                <div className=\"flex items-center gap-1\">\n                  {getStatusIcon(task.status)}\n                  <span className=\"text-sm text-gray-500 capitalize\">\n                    {task.status === TaskStatus.PENDING && 'в”ҳГ©в”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШҜв”ҳВҶв•ӘШІв•Әв••в•ӘШҜв•Әв–’'}\n                    {task.status === TaskStatus.IN_PROGRESS && 'в”ҳГ©в”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҶв”ҳВҒв”ҳГЁв•Әв–‘'}\n                    {task.status === TaskStatus.COMPLETED && 'в”ҳГ в”ҳГўв•ӘШІв”ҳГ в”ҳВ„в•ӘШұ'}\n                  </span>\n                </div>\n                {getPriorityBadge(task.priority)}\n              </div>\n              \n              {task.description && (\n                <p className=\"text-sm text-gray-600 mt-2\">{task.description}</p>\n              )}\n              \n              <div className=\"flex flex-wrap gap-2 mt-2\">\n                {task.subject && (\n                  <Badge variant=\"secondary\" className=\"text-xs\">\n                    {task.subject}\n                  </Badge>\n                )}\n                \n                {task.dueAt