e ExamResult {\r\n  id: string;\r\n  exam: Exam;\r\n  score: number;\r\n  takenAt: string;\r\n  teacherId?: string;\r\n  teacher?: {\r\n    id: string;\r\n    name: string;\r\n  };\r\n}\r\n\r\ninterface UserGrade {\r\n  id: string;\r\n  subject: string;\r\n  grade: number;\r\n  maxGrade: number;\r\n  date: string;\r\n  notes?: string;\r\n  isOnline: boolean;\r\n  assignmentType: string;\r\n  teacherId?: string;\r\n  teacher?: {\r\n    id: string;\r\n    name: string;\r\n  };\r\n  examResultId?: string;\r\n}\r\n\r\ninterface SubjectAverage {\r\n  subject: string;\r\n  _avg: {\r\n    grade: number;\r\n  };\r\n}\r\n\r\ninterface ExamGradesProps {\r\n  userId: string;\r\n  subjects: string[];\r\n  teachers?: { id: string; name: string; subject: string }[];\r\n}\r\n\r\nexport default function ExamGrades({ userId, subjects, teachers = [] }: ExamGradesProps) {\r\n  const [activeTab, setActiveTab] = useState('exams');\r\n  const [examResults, setExamResults] = useState<ExamResult[]>([]);\r\n  const [userGrades, setUserGrades] = useState<UserGrade[]>([]);\r\n  const [subjectAverages, setSubjectAverages] = useState<SubjectAverage[]>([]);\r\n  const [availableExams, setAvailableExams] = useState<Exam[]>([]);\r\n  const [isLoading, setIsLoading] = useState(true);\r\n  const [isSubmitting, setIsSubmitting] = useState(false);\r\n  const [showAddGradeForm, setShowAddGradeForm] = useState(false);\r\n  const [showAddExamForm, setShowAddExamForm] = useState(false);\r\n  const [error, setError] = useState<string | null>(null);\r\n  const [submitError, setSubmitError] = useState<string | null>(null);\r\n\r\n  // в”ҳВҶв”ҳГ в”ҳГӘв•Әв–‘в•ӘШҙ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ\r\n  const [newGrade, setNewGrade] = useState({\r\n    subject: '',\r\n    grade: '',\r\n    maxGrade: '100',\r\n    date: new Date().toISOString().split('T')[0],\r\n    notes: '',\r\n    isOnline: false,\r\n    assignmentType: 'OTHER',\r\n    teacherId: ''\r\n  });\r\n\r\n  // в”ҳВҶв”ҳГ в”ҳГӘв•Әв–‘в•ӘШҙ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в”ҳВҶв•ӘШІв”ҳГЁв•ӘШҙв•ӘШұ в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ\r\n  const [newExamResult, setNewExamResult] = useState({\r\n    examId: '',\r\n    score: '',\r\n    teacherId: '',\r\n    notes: '',\r\n    isOnline: false\r\n  });\r\n\r\n  // в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ в•ӘШ«в”ҳВҶв”ҳГӘв•ӘШҜв•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГӘв•ӘШҜв•ӘШҙв•ӘШ°в•ӘШҜв•ӘШІ\r\n  const assignmentTypes = [\r\n    { value: 'EXAM', label: 'в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ' },\r\n    { value: 'QUIZ', label: 'в•ӘШҜв•ӘВ«в•ӘШІв•ӘШ°в•ӘШҜв•Әв–’ в”ҳГ©в•Әв•Ўв”ҳГЁв•Әв–’' },\r\n    { value: 'HOMEWORK', label: 'в”ҳГӘв•ӘШҜв•ӘШҙв•ӘШ° в”ҳГ в”ҳВҶв•Әв–“в”ҳВ„в”ҳГЁ' },\r\n    { value: 'PROJECT', label: 'в”ҳГ в•Әв”Өв•Әв–’в”ҳГӘв•Әв•Ј' },\r\n    { value: 'PARTICIPATION', label: 'в”ҳГ в•Әв”Өв•ӘШҜв•Әв–’в”ҳГўв•ӘШұ' },\r\n    { value: 'OTHER', label: 'в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ«' }\r\n  ];\r\n\r\n  // в•ӘШҙв”ҳВ„в•ӘШ° в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶ\r\n  useEffect(() => {\r\n    fetchData();\r\n  }, [userId]);\r\n\r\n  const fetchData = useCallback(async () => {\r\n    if (!userId) return;\r\n    \r\n    setIsLoading(true);\r\n    setError(null);\r\n    \r\n    try {\r\n      // в•ӘШҙв”ҳВ„в•ӘШ° в”ҳВҶв•ӘШІв•ӘШҜв•ӘШ®в•ӘШҙ в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в”ҳГӘв•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІ в”ҳВҒв”ҳГЁ в”ҳВҶв”ҳВҒв•Әв”Ӯ в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГ©в•ӘШІ\r\n      const [examsResponse, gradesResponse, examsListResponse] = await Promise.allSettled([\r\n        safeFetch<{ exams: ExamResult[]; grades: UserGrade[] }>(\r\n          `/api/exams/grades?userId=${userId}`,\r\n          undefined,\r\n          { exams: [], grades: [] }\r\n        ),\r\n        safeFetch<{ grades: UserGrade[]; averages: SubjectAverage[] }>(\r\n          `/api/grades?userId=${userId}`,\r\n          undefined,\r\n          { grades: [], averages: [] }\r\n        ),\r\n        safeFetch<Exam[]>(\r\n          \"/api/exams\",\r\n          undefined,\r\n          []\r\n        )\r\n      ]);\r\n\r\n      // в”ҳГ в•Әв•Јв•ӘШҜв”ҳВ„в•ӘШҙв•ӘШұ в”ҳВҶв•ӘШІв•ӘШҜв•ӘШ®в•ӘШҙ в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ\r\n      if (examsResponse.status === 'fulfilled' && !examsResponse.value.error) {\r\n        setExamResults(examsResponse.value.data?.exams || []);\r\n        setUserGrades(examsResponse.value.data?.grades || []);\r\n      } else {\r\n        logger.error('Error fetching exam results:', examsResponse.status === 'rejected' ? examsResponse.reason : examsResponse.value.error);\r\n        setError(\"в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„ в”ҳВҶв•ӘШІв•ӘШҜв•ӘШ®в•ӘШҙ в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ\");\r\n      }\r\n\r\n      // в”ҳГ в•Әв•Јв•ӘШҜв”ҳВ„в•ӘШҙв•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІ в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•–в•ӘШҜв•ӘШІ\r\n      if (gradesResponse.status === 'fulfilled' && !gradesResponse.value.error) {\r\n        const gradesData = gradesResponse.value.data;\r\n        if (gradesData?.grades) {\r\n          setUserGrades(prev => {\r\n            // в•ӘВ»в”ҳГ в•ӘШҙ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІ в”ҳГ в•Әв•Ј в•ӘШІв•ӘШҙв”ҳВҶв•ӘШ° в•ӘШҜв”ҳВ„в•ӘШІв”ҳГўв•Әв–’в•ӘШҜв•Әв–’\r\n            const merged = [...prev];\r\n            gradesData.grades.forEach(grade => {\r\n              if (!merged.find(g => g.id === grade.id)) {\r\n                merged.push(grade);\r\n              }\r\n            });\r\n            return merged;\r\n          });\r\n        }\r\n        if (gradesData?.averages) {\r\n          setSubjectAverages(gradesData.averages);\r\n        }\r\n      } else {\r\n        logger.error('Error fetching grades:', gradesResponse.status === 'rejected' ? gradesResponse.reason : gradesResponse.value.error);\r\n        if (!error) setError(\"в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІ\");\r\n      }\r\n\r\n      // в”ҳГ в•Әв•Јв•ӘШҜв”ҳВ„в•ӘШҙв•ӘШұ в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШІв•ӘШҜв•ӘШөв•ӘШұ\r\n      if (examsListResponse.status === 'fulfilled' && !examsListResponse.value.error) {\r\n        setAvailableExams(examsListResponse.value.data || []);\r\n      } else {\r\n        logger.warn('Error fetching available exams:', examsListResponse.status === 'rejected' ? examsListResponse.reason : examsListResponse.value.error);\r\n      }\r\n    } catch (err) {\r\n      logger.error('Error fetching data:', err);\r\n      setError(\"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ\");\r\n    } finally {\r\n      setIsLoading(false);\r\n    }\r\n  }, [userId, error]);\r\n\r\n  const handleAddGrade = async (e: React.FormEvent) => {\r\n    e.preventDefault();\r\n    setIsSubmitting(true);\r\n    setSubmitError(null);\r\n\r\n    // Validation\r\n    const gradeNum = parseFloat(newGrade.grade);\r\n    const maxGradeNum = parseFloat(newGrade.maxGrade);\r\n\r\n    if (isNaN(gradeNum) || gradeNum < 0) {\r\n      setSubmitError(\"в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҙв•ӘШҜв•ӘШ© в•ӘШӯв•ӘВ»в•ӘВ«в•ӘШҜв”ҳВ„ в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в•Әв•Ўв•ӘШөв”ҳГЁв•ӘШөв•ӘШұ\");\r\n      setIsSubmitting(false);\r\n      return;\r\n    }\r\n\r\n    if (isNaN(maxGradeNum) || maxGradeNum <= 0) {\r\n      setSubmitError(\"в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҙв•ӘШҜв•ӘШ© в•ӘШӯв•ӘВ»в•ӘВ«в•ӘШҜв”ҳВ„ в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в•Әв•Јв•Әв••в”ҳГ в”ҳГ« в•Әв•Ўв•ӘШөв”ҳГЁв•ӘШөв•ӘШұ\");\r\n      setIsSubmitting(false);\r\n      return;\r\n    }\r\n\r\n    if (gradeNum > maxGradeNum) {\r\n      setSubmitError(\"в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в”ҳВ„в•ӘШҜ в”ҳГЁв”ҳГ в”ҳГўв”ҳВҶ в•ӘШ«в”ҳВҶ в•ӘШІв”ҳГўв”ҳГӘв”ҳВҶ в•ӘШ«в”ҳГўв•ӘШ°в•Әв–’ в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в•ӘШҜв”ҳВ„в•Әв•Јв•Әв••в”ҳГ в”ҳГ«\");\r\n      setIsSubmitting(false);\r\n      return;\r\n    }\r\n\r\n    if (!newGrade.subject) {\r\n      setSubmitError(\"в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҙв•ӘШҜв•ӘШ© в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ\");\r\n      setIsSubmitting(false);\r\n      return;\r\n    }\r\n\r\n    try {\r\n      const { data, error: responseError } = await safeFetch<{ success: boolean }>(\r\n        '/api/grades',\r\n        {\r\n          method: 'POST',\r\n          headers: {\r\n            'Content-Type': 'application/json',\r\n          },\r\n          body: JSON.stringify({\r\n            userId,\r\n            subject: newGrade.subject,\r\n            grade: gradeNum,\r\n            maxGrade: maxGradeNum,\r\n            date: newGrade.date,\r\n            notes: newGrade.notes,\r\n            isOnline: newGrade.isOnline,\r\n            assignmentType: newGrade.assignmentType,\r\n            teacherId: newGrade.teacherId || undefined\r\n          }),\r\n        },\r\n        { success: false }\r\n      );\r\n\r\n      if (responseError || !data?.success) {\r\n        const errorMessage = responseError?.message || \"в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ\";\r\n        setSubmitError(errorMessage);\r\n        logger.error('Failed to add grade:', responseError);\r\n      } else {\r\n        // в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШІв•Әв•Јв”ҳГЁв”ҳГЁв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ в”ҳГӘв•Әв–‘в•ӘШҙ в”ҳГӘв•ӘШӯв•ӘВ«в”ҳВҒв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ в”ҳГӘв•Әв–‘в•ӘШҙ\r\n        setNewGrade({\r\n          subject: '',\r\n          grade: '',\r\n          maxGrade: '100',\r\n          date: new Date().toISOString().split('T')[0],\r\n          notes: '',\r\n          isOnline: false,\r\n          assignmentType: 'OTHER',\r\n          teacherId: ''\r\n        });\r\n        setShowAddGradeForm(false);\r\n        setSubmitError(null);\r\n        // в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҙв”ҳВ„в•ӘШ° в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ\r\n        await fetchData();\r\n      }\r\n    } catch (error) {\r\n      logger.error('Error adding grade:', error);\r\n      setSubmitError(\"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШІв”ҳГӘв”ҳГ©в•Әв•Ј\");\r\n    } finally {\r\n      setIsSubmitting(false);\r\n    }\r\n  };\r\n\r\n  const handleAddExamResult = async (e: React.FormEvent) => {\r\n    e.preventDefault();\r\n    setIsSubmitting(true);\r\n    setSubmitError(null);\r\n\r\n    // Validation\r\n    const scoreNum = parseFloat(newExamResult.score);\r\n\r\n    if (!newExamResult.examId) {\r\n      setSubmitError(\"в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҙв•ӘШҜв•ӘШ© в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ\");\r\n      setIsSubmitting(false);\r\n      return;\r\n    }\r\n\r\n    if (isNaN(scoreNum) || scoreNum < 0 || scoreNum > 100) {\r\n      setSubmitError(\"в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҙв•ӘШҜв•ӘШ© в•ӘШӯв•ӘВ»в•ӘВ«в•ӘШҜв”ҳВ„ в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в•Әв•Ўв•ӘШөв”ҳГЁв•ӘШөв•ӘШұ в•ӘШ°в”ҳГЁв”ҳВҶ 0 в”ҳГӘ 100\");\r\n      setIsSubmitting(false);\r\n      return;\r\n    }\r\n\r\n    try {\r\n      const { data, error: responseError } = await safeFetch<{ success: boolean; examResult: ExamResult }>(\r\n        '/api/exams/grades',\r\n        {\r\n          method: 'POST',\r\n          headers: {\r\n            'Content-Type': 'application/json',\r\n          },\r\n          body: JSON.stringify({\r\n            userId,\r\n            examId: newExamResult.examId,\r\n            score: scoreNum,\r\n            teacherId: newExamResult.teacherId || undefined,\r\n            isOnline: newExamResult.isOnline,\r\n            notes: newExamResult.notes\r\n          }),\r\n        },\r\n        { success: false, examResult: null as any }\r\n      );\r\n\r\n      if (responseError || !data?.success) {\r\n        const errorMessage = responseError?.message || \"в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в”ҳВҶв•ӘШІв”ҳГЁв•ӘШҙв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ\";\r\n        setSubmitError(errorMessage);\r\n        logger.error('Failed to add exam result:', responseError);\r\n      } else {\r\n        // в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШІв•Әв•Јв”ҳГЁв”ҳГЁв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ в”ҳГӘв•Әв–‘в•ӘШҙ в”ҳГӘв•ӘШӯв•ӘВ«в”ҳВҒв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ в”ҳГӘв•Әв–‘в•ӘШҙ\r\n        setNewExamResult({\r\n          examId: '',\r\n          score: '',\r\n          teacherId: '',\r\n          notes: '',\r\n          isOnline: false\r\n        });\r\n        setShowAddExamForm(false);\r\n        setSubmitError(null);\r\n        // в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҙв”ҳВ„в•ӘШ° в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ\r\n        await fetchData();\r\n      }\r\n    } catch (error) {\r\n      logger.error('Error adding exam result:', error);\r\n      setSubmitError(\"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШІв”ҳГӘв”ҳГ©в•Әв•Ј\");\r\n    } finally {\r\n      setIsSubmitting(false);\r\n    }\r\n  };\r\n\r\n  const formatDate = (dateString: string) => {\r\n    const date = new Date(dateString);\r\n    return date.toLocaleDateString('ar-EG', {\r\n      year: 'numeric',\r\n      month: 'short',\r\n      day: 'numeric'\r\n    });\r\n  };\r\n\r\n  const getGradeColor = useCallback((grade: number, maxGrade: number) => {\r\n    const percentage = (grade / maxGrade) * 100;\r\n    if (percentage >= 90) return 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200';\r\n    if (percentage >= 80) return 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200';\r\n    if (percentage >= 70) return 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200';\r\n    return 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200';\r\n  }, []);\r\n\r\n  const getAssignmentTypeLabel = useCallback((type: string) => {\r\n    const assignmentType = assignmentTypes.find(t => t.value === type);\r\n    return assignmentType ? assignmentType.label : type;\r\n  }, []);\r\n\r\n  // в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ° в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШөв•Әв•Ўв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШҜв•ӘШІ\r\n  const statistics = useMemo(() => {\r\n    if (userGrades.length === 0) return null;\r\n    \r\n    const totalGrades = userGrades.length;\r\n    const averageGrade = userGrades.reduce((sum, grade) => sum + (grade.grade / grade.maxGrade) * 100, 0) / totalGrades;\r\n    const maxGrade = Math.max(...userGrades.map(g => g.grade));\r\n    const minGrade = Math.min(...userGrades.map(g => g.grade));\r\n    \r\n    return { totalGrades, averageGrade, maxGrade, minGrade };\r\n  }, [userGrades]);\r\n\r\n  // в•ӘВ»в•ӘШҜв”ҳВ„в•ӘШұ в•ӘШөв•Әв–‘в”ҳВҒ в”ҳВҶв•ӘШІв”ҳГЁв•ӘШҙв•ӘШұ в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ\r\n  const handleDeleteExamResult = useCallback(async (resultId: string) => {\r\n    if (!confirm('в”ҳГ§в”ҳВ„ в•ӘШ«в”ҳВҶв•ӘШІ в”ҳГ в•ӘШІв•ӘШ«в”ҳГўв•ӘВ» в”ҳГ в”ҳВҶ в•ӘШөв•Әв–‘в”ҳВҒ в”ҳГ§в•Әв–‘в”ҳГ§ в•ӘШҜв”ҳВ„в”ҳВҶв•ӘШІв”ҳГЁв•ӘШҙв•ӘШұв•ӘШ§')) return;\r\n    \r\n    try {\r\n      const { error: deleteError } = await safeFetch(\r\n        `/api/exams/results/${resultId}`,\r\n        { method: 'DELETE' },\r\n        null\r\n      );\r\n\r\n      if (deleteError) {\r\n        logger.error('Error deleting exam result:', deleteError);\r\n        setError(\"в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШҜв”ҳВ„в”ҳВҶв•ӘШІв”ҳГЁв•ӘШҙв•ӘШұ\");\r\n      } else {\r\n        setExamResults(prev => prev.filter(r => r.id !== resultId));\r\n      }\r\n    } catch (err) {\r\n      logger.error('Error deleting exam result:', err);\r\n      setError(\"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШҜв”ҳВ„в”ҳВҶв•ӘШІв”ҳГЁв•ӘШҙв•ӘШұ\");\r\n    }\r\n  }, []);\r\n\r\n  if (isLoading) {\r\n    return (\r\n      <div className=\"flex flex-col justify-center items-center h-64 gap-4\" role=\"status\" aria-live=\"polite\">\r\n        <Loader2 className=\"h-12 w-12 animate-spin text-primary\" aria-hidden=\"true\" />\r\n        <p className=\"text-gray-600 dark:text-gray-400\">в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ...</p>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      <div className=\"flex justify-between items-center\">\r\n        <div>\r\n          <h2 className=\"text-2xl font-bold text-gray-800\">в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в”ҳГӘв•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІ</h2>\r\n          <p className=\"text-gray-600\">в•ӘШІв•ӘШІв•ӘШ°в•Әв•Ј в•ӘШ«в•ӘВ»в•ӘШҜв•ӘШ®в”ҳГў в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГўв•ӘШҜв•ӘВ»в”ҳГЁв”ҳГ в”ҳГЁ в”ҳГӘв•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІв”ҳГў в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘШҜв•ӘВ» в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ«в•ӘШІв”ҳВ„в”ҳВҒв•ӘШұ</p>\r\n        </div>\r\n        <div className=\"flex gap-2\">\r\n          <Button \r\n            onClick={() => setShowAddGradeForm(true)}\r\n            className=\"flex items-center gap-2\"\r\n          >\r\n            <PlusCircle className=\"h-4 w-4\" />\r\n            в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ\r\n          </Button>\r\n          <Button \r\n            onClick={() => setShowAddExamForm(true)}\r\n            variant=\"outline\"\r\n            className=\"flex items-center gap-2\"\r\n          >\r\n            <PlusCircle className=\"h-4 w-4\" />\r\n            в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в”ҳВҶв•ӘШІв”ҳГЁв•ӘШҙв•ӘШұ в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ\r\n          </Button>\r\n        </div>\r\n      </div>\r\n\r\n      <Tabs value={activeTab} onValueChange={setActiveTab} className=\"w-full\">\r\n        <TabsList className=\"grid w-full grid-cols-3\">\r\n          <TabsTrigger value=\"exams\">в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ</TabsTrigger>\r\n          <TabsTrigger value=\"grades\">в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІ</TabsTrigger>\r\n          <TabsTrigger value=\"analytics\">в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳВ„в”ҳГЁв”ҳВ„в•ӘШҜв•ӘШІ</TabsTrigger>\r\n        </TabsList>\r\n\r\n        <TabsContent value=\"exams\" className=\"space-y-4\">\r\n          {examResults.length === 0 ? (\r\n            <Card>\r\n              <CardContent className=\"flex flex-col items-center justify-center py-12\">\r\n                <BookOpen className=\"h-12 w-12 text-gray-400 mb-4\" />\r\n                <h3 className=\"text-lg font-medium text-gray-900 mb-2\">в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в”ҳГ в•Әв”Ӯв•ӘШҙв”ҳВ„в•ӘШұ</h3>\r\n                <p className=\"text-gray-500 mb-4\">в•ӘШҜв•ӘШ°в•ӘВ»в•ӘШ« в•ӘШ°в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в”ҳВҶв•ӘШІв•ӘШҜв•ӘШ®в•ӘШҙ в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІв”ҳГў в”ҳВ„в•ӘШІв•ӘШІв•ӘШ°в•Әв•Ј в•ӘШІв”ҳГ©в•ӘВ»в”ҳГ в”ҳГў</p>\r\n                <Button onClick={() => setShowAddExamForm(true)}>\r\n                  в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в”ҳВҶв•ӘШІв”ҳГЁв•ӘШҙв•ӘШұ в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ\r\n                </Button>\r\n              </CardContent>\r\n            </Card>\r\n          ) : (\r\n            <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4\">\r\n              {examResults.map((exam) => (\r\n                <Card key={exam.id} className=\"hover:shadow-md transition-shadow\">\r\n                  <CardHeader className=\"pb-3\">\r\n                    <div className=\"flex justify-between items-start\">\r\n                      <CardTitle className=\"text-lg\">{exam.exam.title}</CardTitle>\r\n                      <Badge className={getGradeColor(exam.score, 100)}>\r\n                        {exam.score}%\r\n                      </Badge>\r\n                    </div>\r\n                    <CardDescription className=\"flex items-center gap-2\">\r\n                      <BookOpen className=\"h-4 w-4\" />\r\n                      {exam.exam.subject} - в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВҶв•ӘШұ {exam.exam.year}\r\n                    </CardDescription>\r\n                  </CardHeader>\r\n                  <CardContent>\r\n                    <div className=\"space-y-2\">\r\n                      <div className=\"flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400\">\r\n                        <Calendar className=\"h-4 w-4\" />\r\n                        {formatDate(exam.takenAt)}\r\n                      </div>\r\n                      {exam.teacher && (\r\n                        <div className=\"flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400\">\r\n                          <User className=\"h-4 w-4\" />\r\n                          {exam.teacher.name}\r\n                        </div>\r\n                      )}\r\n                      <div className=\"flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400\">\r\n                        <Award className=\"h-4 w-4\" />\r\n                        {exam.exam.type === 'MIDTERM' ? 'в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ в”ҳВҶв•Әв•Ўв”ҳВҒв”ҳГЁ' : \r\n                         exam.exam.type === 'FINAL' ? 'в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ в”ҳВҶв”ҳГ§в•ӘШҜв•ӘШ®в”ҳГЁ' : \r\n                         exam.exam.type === 'QUIZ' ? 'в•ӘШҜв•ӘВ«в•ӘШІв•ӘШ°в•ӘШҜв•Әв–’ в”ҳГ©в•Әв•Ўв”ҳГЁв•Әв–’' : 'в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ'}\r\n                      </div>\r\n                      <div className=\"flex justify-end pt-2\">\r\n                        <Button\r\n                          variant=\"ghost\"\r\n                          size=\"sm\"\r\n                          onClick={() => handleDeleteExamResult(exam.id)}\r\n                          className=\"text-red-600 hover:text-red-700 hover:bg-red-50\"\r\n                          aria-label={`в•ӘШөв•Әв–‘в”ҳВҒ в”ҳВҶв•ӘШІв”ҳГЁв•ӘШҙв•ӘШұ ${exam.exam.title}`}\r\n                        >\r\n                          <Trash2 className=\"h-4 w-4\" />\r\n                        </Button>\r\n                      </div>\r\n                    </div>\r\n                  </CardContent>\r\n                </Card>\r\n              ))}\r\n            </div>\r\n          )}\r\n        </TabsContent>\r\n\r\n        <TabsContent value=\"grades\" className=\"space-y-4\">\r\n          {userGrades.length === 0 ? (\r\n            <Card>\r\n              <CardContent className=\"flex flex-col items-center justify-center py-12\">\r\n                <Award className=\"h-12 w-12 text-gray-400 mb-4\" />\r\n                <h3 className=\"text-lg font-medium text-gray-900 mb-2\">в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІ в”ҳГ в•Әв”Ӯв•ӘШҙв”ҳВ„в•ӘШұ</h3>\r\n                <p className=\"text-gray-500 mb-4\">в•ӘШҜв•ӘШ°в•ӘВ»в•ӘШ« в•ӘШ°в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІв”ҳГў в”ҳВ„в•ӘШІв•ӘШІв•ӘШ°в•Әв•Ј в•ӘШІв”ҳГ©в•ӘВ»в”ҳГ в”ҳГў в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГўв•ӘШҜв•ӘВ»в”ҳГЁв”ҳГ в”ҳГЁ</p>\r\n                <Button onClick={() => setShowAddGradeForm(true)}>\r\n                  в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ\r\n                </Button>\r\n              </CardContent>\r\n            </Card>\r\n          ) : (\r\n            <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4\">\r\n              {userGrades.map((grade) => (\r\n                <Card key={grade.id} className=\"hover:shadow-md transition-shadow\">\r\n                  <CardHeader className=\"pb-3\">\r\n                    <div className=\"flex justify-between items-start\">\r\n                      <CardTitle className=\"text-lg\">{grade.subject}</CardTitle>\r\n                      <Badge className={getGradeColor(grade.grade, grade.maxGrade)}>\r\n                        {grade.grade}/{grade.maxGrade}\r\n                      </Badge>\r\n                    </div>\r\n                    <CardDescription className=\"flex items-center gap-2\">\r\n                      {getAssignmentTypeLabel(grade.assignmentType)}\r\n                      {grade.isOnline && (\r\n                        <Badge variant=\"outline\">в•ӘШ«в”ҳГӘв”ҳВҶв”ҳВ„в•ӘШҜв”ҳГЁв”ҳВҶ</Badge>\r\n                      )}\r\n                    </CardDescription>\r\n                  </CardHeader>\r\n                  <CardContent>\r\n                    <div className=\"space-y-2\">\r\n                      <div className=\"flex items-center gap-2 text-sm text-gray-600\">\r\n                        <Calendar className=\"h-4 w-4\" />\r\n                        {formatDate(grade.date)}\r\n                      </div>\r\n                      {grade.teacher && (\r\n                        <div className=\"flex items-center gap-2 text-sm text-gray-600\">\r\n                          <User className=\"h-4 w-4\" />\r\n                          {grade.teacher.name}\r\n                        </div>\r\n                      )}\r\n                      {grade.notes && (\r\n                        <p className=\"text-sm text-gray-600 mt-2 line-clamp-2\">\r\n                          {grade.notes}\r\n                        </p>\r\n                      )}\r\n                    </div>\r\n                  </CardContent>\r\n                </Card>\r\n              ))}\r\n            </div>\r\n          )}\r\n        </TabsContent>\r\n\r\n        <TabsContent value=\"analytics\" className=\"space-y-4\">\r\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\r\n            <Card>\r\n              <CardHeader>\r\n                <CardTitle className=\"flex items-center gap-2\">\r\n                  <TrendingUp className=\"h-5 w-5\" />\r\n                  в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•– в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІ в•ӘШөв•Әв”Ӯв•ӘШ° в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ\r\n                </CardTitle>\r\n              </CardHeader>\r\n              <CardContent>\r\n                {subjectAverages.length === 0 ? (\r\n                  <p className=\"text-gray-500 text-center py-4\">в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в”ҳГўв•ӘШҜв”ҳВҒв”ҳГЁв•ӘШұ в”ҳВ„в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳВ„в”ҳГЁв”ҳВ„в•ӘШҜв•ӘШІ</p>\r\n                ) : (\r\n                  <div className=\"space-y-4\">\r\n                    {subjectAverages.map((average) => {\r\n                      const gradeValue = Number(average._avg.grade);\r\n                      const widthPercent = Math.min(100, gradeValue);\r\n                      const roundedValue = Math.round(gradeValue);\r\n                      const gradeColor = gradeValue >= 90 ? 'bg-green-600' :\r\n                                       gradeValue >= 80 ? 'bg-blue-600' :\r\n                                       gradeValue >= 70 ? 'bg-yellow-500' : 'bg-red-600';\r\n                      const ariaLabel = `в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•– ${average.subject}: ${gradeValue.toFixed(1)}%`;\r\n                      const ariaValueNow = roundedValue;\r\n                      const ariaValueMin = 0;\r\n                      const ariaValueMax = 100;\r\n                      \r\n                      return (\r\n                        <div key={average.subject} className=\"space-y-2\">\r\n                          <div className=\"flex justify-between\">\r\n                            <span className=\"font-medium\">{average.subject}</span>\r\n                            <span className=\"font-bold\">{gradeValue.toFixed(1)}%</span>\r\n                          </div>\r\n                          <div className=\"w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2.5\" title={ariaLabel}>\r\n                            <div \r\n                              className={`h-2.5 rounded-full transition-all duration-300 ${gradeColor}`}\r\n                              style={{ width: `${widthPercent}%` }}\r\n                              title={`${gradeValue.toFixed(1)}%`}\r\n                              role=\"progressbar\"\r\n                              aria-valuenow={ariaValueNow}\r\n                              aria-valuemin={ariaValueMin}\r\n                              aria-valuemax={ariaValueMax}\r\n                              aria-label={ariaLabel}\r\n                            ></div>\r\n                          </div>\r\n                        </div>\r\n                      );\r\n                    })}\r\n                  </div>\r\n                )}\r\n              </CardContent>\r\n            </Card>\r\n\r\n            <Card>\r\n              <CardHeader>\r\n                <CardTitle>в•ӘШӯв•ӘШөв•Әв•Ўв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШҜв•ӘШІ в•Әв•Јв•ӘШҜв”ҳГ в•ӘШұ</CardTitle>\r\n              </CardHeader>\r\n              <CardContent>\r\n                {!statistics ? (\r\n                  <p className=\"text-gray-500 dark:text-gray-400 text-center py-4\">в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в”ҳГўв•ӘШҜв”ҳВҒв”ҳГЁв•ӘШұ в”ҳВ„в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШөв•Әв•Ўв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШҜв•ӘШІ</p>\r\n                ) : (\r\n                  <div className=\"space-y-4\">\r\n                    <div className=\"grid grid-cols-2 gap-4\">\r\n                      <div className=\"bg-blue-50 dark:bg-blue-900/20 p-4 rounded-lg\">\r\n                        <p className=\"text-sm text-blue-800 dark:text-blue-200\">в•Әв•Јв•ӘВ»в•ӘВ» в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШҙв”ҳВ„в•ӘШұ</p>\r\n                        <p className=\"text-2xl font-bold text-blue-600 dark:text-blue-400\">{statistics.totalGrades}</p>\r\n                      </div>\r\n                      <div className=\"bg-green-50 dark:bg-green-900/20 p-4 rounded-lg\">\r\n                        <p className=\"text-sm text-green-800 dark:text-green-200\">в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•– в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•Әв•Јв•ӘШҜв”ҳГ </p>\r\n                        <p className=\"text-2xl font-bold text-green-600 dark:text-green-400\">\r\n                          {statistics.averageGrade.toFixed(1)}%\r\n                        </p>\r\n                      </div>\r\n                    </div>\r\n                    <div className=\"grid grid-cols-2 gap-4\">\r\n                      <div className=\"bg-purple-50 dark:bg-purple-900/20 p-4 rounded-lg\">\r\n                        <p className=\"text-sm text-purple-800 dark:text-purple-200\">в•ӘШ«в•Әв•Јв”ҳВ„в”ҳГ« в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ</p>\r\n                        <p className=\"text-2xl font-bold text-purple-600 dark:text-purple-400\">\r\n                          {statistics.maxGrade}\r\n                        </p>\r\n                      </div>\r\n                      <div className=\"bg-yellow-50 dark:bg-yellow-900/20 p-4 rounded-lg\">\r\n                        <p className=\"text-sm text-yellow-800 dark:text-yellow-200\">в•ӘШ«в”ҳГ©в”ҳВ„ в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ</p>\r\n                        <p className=\"text-2xl font-bold text-yellow-600 dark:text-yellow-400\">\r\n                          {statistics.minGrade}\r\n                        </p>\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                )}\r\n              </CardContent>\r\n            </Card>\r\n          </div>\r\n        </TabsContent>\r\n      </Tabs>\r\n\r\n      {/* в”ҳВҶв”ҳГ в”ҳГӘв•Әв–‘в•ӘШҙ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ */}\r\n      <Dialog open={showAddGradeForm} onOpenChange={setShowAddGradeForm}>\r\n        <DialogContent className=\"max-w-md max-h-[90vh] overflow-y-auto\">\r\n          <DialogHeader>\r\n            <DialogTitle>в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ</DialogTitle>\r\n            <DialogDescription>\r\n              в•ӘШ«в•ӘВ»в•ӘВ«в”ҳВ„ в”ҳГ в•Әв•Јв”ҳВ„в”ҳГӘв”ҳГ в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ\r\n            </DialogDescription>\r\n          </DialogHeader>\r\n          <form onSubmit={handleAddGrade} className=\"space-y-4\">\r\n                <div>\r\n                  <Label htmlFor=\"subject\">в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ</Label>\r\n                  <Select \r\n                    value={newGrade.subject} \r\n                    onValueChange={(value) => setNewGrade({...newGrade, subject: value})}\r\n                  >\r\n                    <SelectTrigger>\r\n                      <SelectValue placeholder=\"в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ\" />\r\n                    </SelectTrigger>\r\n                    <SelectContent>\r\n                      {subjects.map((subject) => (\r\n                        <SelectItem key={subject} value={subject}>\r\n                          {subject}\r\n                        </SelectItem>\r\n                      ))}\r\n                    </SelectContent>\r\n                  </Select>\r\n                </div>\r\n\r\n                <div className=\"grid grid-cols-2 gap-4\">\r\n                  <div>\r\n                    <Label htmlFor=\"grade\">в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ</Label>\r\n                    <Input\r\n                      id=\"grade\"\r\n                      type=\"number\"\r\n                      min=\"0\"\r\n                      value={newGrade.grade}\r\n                      onChange={(e) => setNewGrade({...newGrade, grade: e.target.value})}\r\n                      required\r\n                    />\r\n                  </div>\r\n                  <div>\r\n                    <Label htmlFor=\"maxGrade\">в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в•ӘШҜв”ҳВ„в•Әв•Јв•Әв••в”ҳГ в”ҳГ«</Label>\r\n                    <Input\r\n                      id=\"maxGrade\"\r\n                      type=\"number\"\r\n                      min=\"1\"\r\n                      value={newGrade.maxGrade}\r\n                      onChange={(e) => setNewGrade({...newGrade, maxGrade: e.target.value})}\r\n                      required\r\n                    />\r\n                  </div>\r\n                </div>\r\n\r\n                <div>\r\n                  <Label htmlFor=\"date\">в•ӘШҜв”ҳВ„в•ӘШІв•ӘШҜв•Әв–’в”ҳГЁв•ӘВ«</Label>\r\n                  <Input\r\n                    id=\"date\"\r\n                    type=\"date\"\r\n                    value={newGrade.date}\r\n                    onChange={(e) => setNewGrade({...newGrade, date: e.target.value})}\r\n                    required\r\n                  />\r\n                </div>\r\n\r\n                <div>\r\n                  <Label htmlFor=\"assignmentType\">в”ҳВҶв”ҳГӘв•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГӘв•ӘШҜв•ӘШҙв•ӘШ°</Label>\r\n                  <Select \r\n                    value={newGrade.assignmentType} \r\n                    onValueChange={(value) => setNewGrade({...newGrade, assignmentType: value})}\r\n                  >\r\n                    <SelectTrigger>\r\n                      <SelectValue />\r\n                    </SelectTrigger>\r\n                    <SelectContent>\r\n                      {assignmentTypes.map((type) => (\r\n                        <SelectItem key={type.value} value={type.value}>\r\n                          {type.label}\r\n                        </SelectItem>\r\n                      ))}\r\n                    </SelectContent>\r\n                  </Select>\r\n                </div>\r\n\r\n                <div>\r\n                  <Label htmlFor=\"teacher\">в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯ (в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’в”ҳГЁ)</Label>\r\n                  <Select \r\n                    value={newGrade.teacherId} \r\n                    onValueChange={(value) => setNewGrade({...newGrade, teacherId: value})}\r\n                  >\r\n                    <SelectTrigger>\r\n                      <SelectValue placeholder=\"в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯ\" />\r\n                    </SelectTrigger>\r\n                    <SelectContent>\r\n                      {teachers.map((teacher) => (\r\n                        <SelectItem key={teacher.id} value={teacher.id}>\r\n                          {teacher.name} ({teacher.subject})\r\n                        </SelectItem>\r\n                      ))}\r\n                    </SelectContent>\r\n                  </Select>\r\n                </div>\r\n\r\n                <div>\r\n                  <Label htmlFor=\"notes\">в”ҳГ в”ҳВ„в•ӘШҜв•ӘШөв•Әв••в•ӘШҜв•ӘШІ (в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’в”ҳГЁ)</Label>\r\n                  <Textarea\r\n                    id=\"notes\"\r\n                    value={newGrade.notes}\r\n                    onChange={(e) => setNewGrade({...newGrade, notes: e.target.value})}\r\n                    rows={3}\r\n                  />\r\n                </div>\r\n\r\n                <div className=\"flex items-center space-x-2\">\r\n                  <input\r\n                    type=\"checkbox\"\r\n                    id=\"gradeIsOnline\"\r\n                    checked={newGrade.isOnline}\r\n                    onChange={(e) => setNewGrade({...newGrade, isOnline: e.target.checked})}\r\n                    className=\"rounded\"\r\n                    aria-label=\"в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ в•ӘШ«в”ҳГӘв”ҳВҶв”ҳВ„в•ӘШҜв”ҳГЁв”ҳВҶ\"\r\n                  />\r\n                  <Label htmlFor=\"gradeIsOnline\">в•ӘШ«в”ҳГӘв”ҳВҶв”ҳВ„в•ӘШҜв”ҳГЁв”ҳВҶ</Label>\r\n                </div>\r\n\r\n            {submitError && (\r\n              <div className=\"bg-red-50 border border-red-200 rounded-lg p-3 flex items-center gap-2 text-red-700\">\r\n                <AlertCircle className=\"h-4 w-4 flex-shrink-0\" />\r\n                <p className=\"text-sm\">{submitError}</p>\r\n              </div>\r\n            )}\r\n            <DialogFooter>\r\n              <Button \r\n                type=\"button\" \r\n                variant=\"outline\" \r\n                onClick={() => {\r\n                  setShowAddGradeForm(false);\r\n                  setSubmitError(null);\r\n                }}\r\n                disabled={isSubmitting}\r\n              >\r\n                в•ӘШӯв”ҳВ„в•Әв•‘в•ӘШҜв•ӘШ©\r\n              </Button>\r\n              <Button type=\"submit\" disabled={isSubmitting}>\r\n                {isSubmitting ? (\r\n                  <>\r\n                    <Loader2 className=\"h-4 w-4 mr-2 animate-spin\" />\r\n                    в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШөв”ҳВҒв•Әв••...\r\n                  </>\r\n                ) : (\r\n                  \"в•ӘШөв”ҳВҒв•Әв••\"\r\n                )}\r\n              </Button>\r\n            </DialogFooter>\r\n          </form>\r\n        </DialogContent>\r\n      </Dialog>\r\n\r\n      {/* в”ҳВҶв”ҳГ в”ҳГӘв•Әв–‘в•ӘШҙ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в”ҳВҶв•ӘШІв”ҳГЁв•ӘШҙв•ӘШұ в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ */}\r\n      <Dialog open={showAddExamForm} onOpenChange={setShowAddExamForm}>\r\n        <DialogContent className=\"max-w-md max-h-[90vh] overflow-y-auto\">\r\n          <DialogHeader>\r\n            <DialogTitle>в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в”ҳВҶв•ӘШІв”ҳГЁв•ӘШҙв•ӘШұ в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ</DialogTitle>\r\n            <DialogDescription>\r\n              в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ в”ҳГӘв•ӘШ«в•ӘВ»в•ӘВ«в”ҳВ„ в•ӘШҜв”ҳВ„в”ҳВҶв•ӘШІв”ҳГЁв•ӘШҙв•ӘШұ\r\n            </DialogDescription>\r\n          </DialogHeader>\r\n          <form onSubmit={handleAddExamResult} className=\"space-y-4\">\r\n            <div>\r\n              <Label htmlFor=\"examId\">в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ <span className=\"text-red-500\">*</span></Label>\r\n              <Select \r\n                value={newExamResult.examId} \r\n                onValueChange={(value) => setNewExamResult({...newExamResult, examId: value})}\r\n                required\r\n              >\r\n                <SelectTrigger>\r\n                  <SelectValue placeholder=\"в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ\" />\r\n                </SelectTrigger>\r\n                <SelectContent>\r\n                  {availableExams.length === 0 ? (\r\n                    <SelectItem value=\"no-exams\" disabled>в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в”ҳГ в•ӘШІв•ӘШҜв•ӘШөв•ӘШұ</SelectItem>\r\n                  ) : (\r\n                    availableExams.map((exam) => (\r\n                      <SelectItem key={exam.id} value={exam.id}>\r\n                        {exam.title} - {exam.subject} ({exam.year})\r\n                      </SelectItem>\r\n                    ))\r\n                  )}\r\n                </SelectContent>\r\n              </Select>\r\n            </div>\r\n\r\n                <div>\r\n                  <Label htmlFor=\"score\">в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ</Label>\r\n                  <Input\r\n                    id=\"score\"\r\n                    type=\"number\"\r\n                    min=\"0\"\r\n                    max=\"100\"\r\n                    value={newExamResult.score}\r\n                    onChange={(e) => setNewExamResult({...newExamResult, score: e.target.value})}\r\n                    required\r\n                  />\r\n                </div>\r\n\r\n                <div>\r\n                  <Label htmlFor=\"teacher\">в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯ (в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’в”ҳГЁ)</Label>\r\n                  <Select \r\n                    value={newExamResult.teacherId} \r\n                    onValueChange={(value) => setNewExamResult({...newExamResult, teacherId: value})}\r\n                  >\r\n                    <SelectTrigger>\r\n                      <SelectValue placeholder=\"в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯ\" />\r\n                    </SelectTrigger>\r\n                    <SelectContent>\r\n                      {teachers.map((teacher) => (\r\n                        <SelectItem key={teacher.id} value={teacher.id}>\r\n                          {teacher.name} ({teacher.subject})\r\n                        </SelectItem>\r\n                      ))}\r\n                    </SelectContent>\r\n                  </Select>\r\n                </div>\r\n\r\n                <div>\r\n                  <Label htmlFor=\"notes\">в”ҳГ в”ҳВ„в•ӘШҜв•ӘШөв•Әв••в•ӘШҜв•ӘШІ (в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’в”ҳГЁ)</Label>\r\n                  <Textarea\r\n                    id=\"notes\"\r\n                    value={newExamResult.notes}\r\n                    onChange={(e) => setNewExamResult({...newExamResult, notes: e.target.value})}\r\n                    rows={3}\r\n                  />\r\n                </div>\r\n\r\n                <div className=\"flex items-center space-x-2\">\r\n                  <input\r\n                    type=\"checkbox\"\r\n                    id=\"examResultIsOnline\"\r\n                    checked={newExamResult.isOnline}\r\n                    onChange={(e) => setNewExamResult({...newExamResult, isOnline: e.target.checked})}\r\n                    className=\"rounded\"\r\n                    aria-label=\"в”ҳВҶв•ӘШІв”ҳГЁв•ӘШҙв•ӘШұ в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ в•ӘШ«в”ҳГӘв”ҳВҶв”ҳВ„в•ӘШҜв”ҳГЁв”ҳВҶ\"\r\n                  />\r\n                  <Label htmlFor=\"examResultIsOnline\">в•ӘШ«в”ҳГӘв”ҳВҶв”ҳВ„в•ӘШҜв”ҳГЁв”ҳВҶ</Label>\r\n                </div>\r\n\r\n            {submitError && (\r\n              <div className=\"bg-red-50 border border-red-200 rounded-lg p-3 flex items-center gap-2 text-red-700\">\r\n                <AlertCircle className=\"h-4 w-4 flex-shrink-0\" />\r\n                <p className=\"text-sm\">{submitError}</p>\r\n              </div>\r\n            )}\r\n            <DialogFooter>\r\n              <Button \r\n                type=\"button\" \r\n                variant=\"outline\" \r\n                onClick={() => {\r\n                  setShowAddExamForm(false);\r\n                  setSubmitError(null);\r\n                }}\r\n                disabled={isSubmitting}\r\n              >\r\n                в•ӘШӯв”ҳВ„в•Әв•‘в•ӘШҜв•ӘШ©\r\n              </Button>\r\n              <Button type=\"submit\" disabled={isSubmitting || availableExams.length === 0}>\r\n                {isSubmitting ? (\r\n                  <>\r\n                    <Loader2 className=\"h-4 w-4 mr-2 animate-spin\" />\r\n                    в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШөв”ҳВҒв•Әв••...\r\n                  </>\r\n                ) : (\r\n                  \"в•ӘШөв”ҳВҒв•Әв••\"\r\n                )}\r\n              </Button>\r\n            </DialogFooter>\r\n          </form>\r\n        </DialogContent>\r\n      </Dialog>\r\n      \r\n      {error && (\r\n        <div className=\"bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-lg p-4 flex items-center gap-2 text-yellow-800 dark:text-yellow-200\" role=\"alert\">\r\n          <AlertCircle className=\"h-5 w-5 flex-shrink-0\" aria-hidden=\"true\" />\r\n          <p>{error}</p>\r\n          <Button\r\n            variant=\"ghost\"\r\n            size=\"sm\"\r\n            onClick={() => setError(null)}\r\n            className=\"mr-auto text-yellow-800 dark:text-yellow-200 hover:bg-yellow-100 dark:hover:bg-yellow-900/40\"\r\n            aria-label=\"в•ӘШӯв•Әв•‘в”ҳВ„в•ӘШҜв”ҳГ© в•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ«в•Әв•–в•ӘШ«\"\r\n          >\r\n            ШёВЈЩҖ\r\n          </Button>\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(education)\\exams\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(education)\\library\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'userId' is assigned a value but never used. Allowed unused vars must match /^_/u.","line":30,"column":10,"nodeType":null,"messageId":"unusedVar","endLine":30,"endColumn":16}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\r\n\r\nimport { useEffect, useState } from \"react\";\r\nimport { toast } from \"sonner\";\r\n\r\nimport { ensureUser } from \"@/lib/user-utils\";\r\n\r\ntype Book = {\r\n  id: string;\r\n  title: string;\r\n  author: string;\r\n  description: string;\r\n  subject: string;\r\n  coverUrl?: string;\r\n  downloadUrl: string;\r\n  rating: number;\r\n  views: number;\r\n  downloads: number;\r\n  createdAt: string;\r\n  tags: string[];\r\n};\r\n\r\ntype LibraryCategory = {\r\n  id: string;\r\n  name: string;\r\n  icon: string;\r\n};\r\n\r\nexport default function LibraryPage() {\r\n  const [userId, setUserId] = useState<string | null>(null);\r\n  const [books, setBooks] = useState<Book[]>([]);\r\n  const [categories, setCategories] = useState<LibraryCategory[]>([]);\r\n  const [activeCategory, setActiveCategory] = useState<string>(\"all\");\r\n  const [searchTerm, setSearchTerm] = useState(\"\");\r\n  const [sortBy, setSortBy] = useState<\"newest\" | \"popular\" | \"rated\">(\"newest\");\r\n  const [showUploadModal, setShowUploadModal] = useState(false);\r\n  const [uploading, setUploading] = useState(false);\r\n  const [formData, setFormData] = useState({\r\n    title: \"\",\r\n    author: \"\",\r\n    description: \"\",\r\n    subjectId: \"\",\r\n    tags: [] as string[],\r\n    tagInput: \"\"\r\n  });\r\n  const [selectedFile, setSelectedFile] = useState<File | null>(null);\r\n  const [selectedCover, setSelectedCover] = useState<File | null>(null);\r\n\r\n  useEffect(() => {\r\n    ensureUser().then(setUserId);\r\n  }, []);\r\n\r\n  useEffect(() => {\r\n    // Load categories\r\n    const fetchCategories = async () => {\r\n      const res = await fetch(\"/api/library/categories\");\r\n      const data = await res.json();\r\n      setCategories(data);\r\n    };\r\n\r\n    // Load books\r\n    const fetchBooks = async () => {\r\n      const res = await fetch(\"/api/library/books\");\r\n      const data = await res.json();\r\n      setBooks(data);\r\n    };\r\n\r\n    fetchCategories();\r\n    fetchBooks();\r\n  }, []);\r\n\r\n  const handleAddTag = () => {\r\n    if (formData.tagInput.trim() && !formData.tags.includes(formData.tagInput.trim())) {\r\n      setFormData({\r\n        ...formData,\r\n        tags: [...formData.tags, formData.tagInput.trim()]\r\n      });\r\n      setFormData(prev => ({ ...prev, tagInput: \"\" }));\r\n    }\r\n  };\r\n\r\n  const handleRemoveTag = (tagToRemove: string) => {\r\n    setFormData({\r\n      ...formData,\r\n      tags: formData.tags.filter(tag => tag !== tagToRemove)\r\n    });\r\n  };\r\n\r\n  const handleFileChange = (e: React.ChangeEvent<HTMLInputElement>) => {\r\n    if (e.target.files && e.target.files[0]) {\r\n      setSelectedFile(e.target.files[0]);\r\n    }\r\n  };\r\n\r\n  const handleCoverChange = (e: React.ChangeEvent<HTMLInputElement>) => {\r\n    if (e.target.files && e.target.files[0]) {\r\n      setSelectedCover(e.target.files[0]);\r\n    }\r\n  };\r\n\r\n  const handleUpload = async (e: React.FormEvent) => {\r\n    e.preventDefault();\r\n    \r\n    if (!selectedFile || !formData.title || !formData.author || !formData.description || !formData.subjectId) {\r\n      toast.error(\"в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҙв•ӘШҜв•ӘШ© в”ҳГ в”ҳВ„в•ӘШ© в•ӘШҙв”ҳГ в”ҳГЁв•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШөв”ҳГ©в”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•–в”ҳВ„в”ҳГӘв•ӘШ°в•ӘШұ в”ҳГӘв•Әв–’в”ҳВҒв•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГ в”ҳВ„в”ҳВҒ\");\r\n      return;\r\n    }\r\n\r\n    setUploading(true);\r\n\r\n    try {\r\n      const formDataObj = new FormData();\r\n      formDataObj.append('title', formData.title);\r\n      formDataObj.append('author', formData.author);\r\n      formDataObj.append('description', formData.description);\r\n      formDataObj.append('subjectId', formData.subjectId);\r\n      formDataObj.append('tags', JSON.stringify(formData.tags));\r\n      formDataObj.append('bookFile', selectedFile);\r\n      \r\n      if (selectedCover) {\r\n        formDataObj.append('cover', selectedCover);\r\n      }\r\n\r\n      const response = await fetch('/api/library/upload', {\r\n        method: 'POST',\r\n        body: formDataObj,\r\n        headers: {\r\n          // We'll need to add authorization token here\r\n          'Authorization': `Bearer ${localStorage.getItem('auth-token') || ''}`\r\n        }\r\n      });\r\n\r\n      const result = await response.json();\r\n\r\n      if (response.ok) {\r\n        toast.success(\"в•ӘШІв”ҳГ  в•Әв–’в”ҳВҒв•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГўв•ӘШІв•ӘШҜв•ӘШ° в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө!\");\r\n        setShowUploadModal(false);\r\n        // Reset form\r\n        setFormData({\r\n          title: \"\",\r\n          author: \"\",\r\n          description: \"\",\r\n          subjectId: \"\",\r\n          tags: [],\r\n          tagInput: \"\"\r\n        });\r\n        setSelectedFile(null);\r\n        setSelectedCover(null);\r\n        // Refresh books list\r\n        const res = await fetch(\"/api/library/books\");\r\n        const data = await res.json();\r\n        setBooks(data);\r\n      } else {\r\n        toast.error(result.error || \"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•Әв–’в”ҳВҒв•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГўв•ӘШІв•ӘШҜв•ӘШ°\");\r\n      }\r\n    } catch (error) {\r\n      console.error(\"Upload error:\", error);\r\n      toast.error(\"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•Әв–’в”ҳВҒв•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГўв•ӘШІв•ӘШҜв•ӘШ°\");\r\n    } finally {\r\n      setUploading(false);\r\n    }\r\n  };\r\n\r\n  const filteredBooks = Array.isArray(books) ? books.filter(book => {\r\n    const matchesCategory = activeCategory === \"all\" || book.subject === activeCategory;\r\n    const matchesSearch = book.title.toLowerCase().includes(searchTerm.toLowerCase()) || \r\n                         book.author.toLowerCase().includes(searchTerm.toLowerCase()) ||\r\n                         book.description.toLowerCase().includes(searchTerm.toLowerCase()) ||\r\n                         book.tags.some(tag => tag.toLowerCase().includes(searchTerm.toLowerCase()));\r\n    return matchesCategory && matchesSearch;\r\n  }) : [];\r\n\r\n  // Sort books based on selected criteria\r\n  const sortedBooks = [...filteredBooks].sort((a, b) => {\r\n    if (sortBy === \"newest\") {\r\n      return new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime();\r\n    } else if (sortBy === \"popular\") {\r\n      return b.downloads - a.downloads;\r\n    } else { // rated\r\n      return b.rating - a.rating;\r\n    }\r\n  });\r\n\r\n  return (\r\n    <div className=\"px-4\">\r\n      <section className=\"mx-auto max-w-7xl py-8 space-y-6\">\r\n        <div className=\"flex flex-col md:flex-row justify-between items-start md:items-center gap-4\">\r\n          <div>\r\n            <h1 className=\"text-2xl md:text-3xl font-bold\">в•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв•ӘШІв•ӘШ°в•ӘШұ в•ӘШҜв”ҳВ„в•Әв–’в”ҳГ©в”ҳГ в”ҳГЁв•ӘШұ</h1>\r\n            <p className=\"text-muted-foreground\">в”ҳГӘв•Әв•Ўв”ҳГӘв”ҳВ„ в”ҳВ„в”ҳГ в•ӘШҙв”ҳГ в”ҳГӘв•Әв•Јв•ӘШұ в”ҳГӘв•ӘШҜв•Әв”Ӯв•Әв•Јв•ӘШұ в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГўв•ӘШІв•ӘШ° в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘШҜв•Әв–’в•ӘВ» в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Јв”ҳВ„в”ҳГЁв”ҳГ в”ҳГЁв•ӘШұ</p>\r\n          </div>\r\n          <button \r\n            onClick={() => setShowUploadModal(true)}\r\n            className=\"px-4 py-2 bg-primary text-primary-foreground rounded-md\"\r\n          >\r\n            в•Әв–’в”ҳВҒв•Әв•Ј в”ҳГўв•ӘШІв•ӘШҜв•ӘШ°\r\n          </button>\r\n        </div>\r\n\r\n        {/* Categories */}\r\n        <div className=\"rounded-lg border p-4\">\r\n          <h2 className=\"font-semibold mb-3\">в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Ўв”ҳВҶв”ҳГЁв”ҳВҒв•ӘШҜв•ӘШІ</h2>\r\n          <div className=\"flex flex-wrap gap-2\">\r\n            <button \r\n              className={`px-3 py-1.5 rounded-md text-sm ${activeCategory === \"all\" ? \"bg-primary text-primary-foreground\" : \"bg-muted\"}`}\r\n              onClick={() => setActiveCategory(\"all\")}\r\n            >\r\n              в•ӘШҜв”ҳВ„в”ҳГўв”ҳВ„\r\n            </button>\r\n            {categories.map((category) => (\r\n              <button\r\n                key={category.id}\r\n                className={`px-3 py-1.5 rounded-md text-sm flex items-center gap-1.5 ${activeCategory === category.id ? \"bg-primary text-primary-foreground\" : \"bg-muted\"}`}\r\n                onClick={() => setActiveCategory(category.id)}\r\n              >\r\n                <span>{category.icon}</span>\r\n                <span>{category.name}</span>\r\n              </button>\r\n            ))}\r\n          </div>\r\n        </div>\r\n\r\n        {/* Search and Sort */}\r\n        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\r\n          <div className=\"rounded-lg border p-4\">\r\n            <div className=\"relative\">\r\n              <input\r\n                type=\"text\"\r\n                placeholder=\"в•ӘШҜв•ӘШ°в•ӘШөв•ӘШі в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв•ӘШІв•ӘШ°в•ӘШұ...\"\r\n                className=\"w-full border rounded-md px-4 py-2 pl-10\"\r\n                value={searchTerm}\r\n                onChange={(e) => setSearchTerm(e.target.value)}\r\n              />\r\n              <svg\r\n                xmlns=\"http://www.w3.org/2000/svg\"\r\n                className=\"h-5 w-5 absolute left-3 top-2.5 text-muted-foreground\"\r\n                fill=\"none\"\r\n                viewBox=\"0 0 24 24\"\r\n                stroke=\"currentColor\"\r\n              >\r\n                <path\r\n                  strokeLinecap=\"round\"\r\n                  strokeLinejoin=\"round\"\r\n                  strokeWidth={2}\r\n                  d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\"\r\n                />\r\n              </svg>\r\n            </div>\r\n          </div>\r\n\r\n          <div className=\"rounded-lg border p-4\">\r\n            <div className=\"flex items-center gap-2\">\r\n              <span className=\"text-sm font-medium\">в•ӘШІв•Әв–’в•ӘШІв”ҳГЁв•ӘШ° в•ӘШөв•Әв”Ӯв•ӘШ°:</span>\r\n              <select\r\n                className=\"border rounded-md px-3 py-1.5 text-sm\"\r\n                value={sortBy}\r\n                onChange={(e) => setSortBy(e.target.value as any)}\r\n              >\r\n                <option value=\"newest\">в•ӘШҜв”ҳВ„в•ӘШ«в•ӘШөв•ӘВ»в•ӘШі</option>\r\n                <option value=\"popular\">в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГўв•ӘШів•Әв–’ в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„в•ӘШҜв”ҳГҜ</option>\r\n                <option value=\"rated\">в•ӘШҜв”ҳВ„в•ӘШ«в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШІв”ҳГ©в”ҳГЁв”ҳГЁв”ҳГ в•ӘШҜв”ҳГҜ</option>\r\n              </select>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        {/* Books Grid */}\r\n        {sortedBooks.length > 0 ? (\r\n          <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6\">\r\n            {sortedBooks.map((book) => (\r\n              <div key={book.id} className=\"rounded-lg border overflow-hidden transition-transform hover:scale-[1.02]\">\r\n                <div className=\"aspect-[3/4] bg-muted relative\">\r\n                  {book.coverUrl ? (\r\n                    <img \r\n                      src={book.coverUrl} \r\n                      alt={book.title} \r\n                      className=\"w-full h-full object-cover\"\r\n                    />\r\n                  ) : (\r\n                    <div className=\"w-full h-full flex items-center justify-center bg-gradient-to-br from-primary/20 to-primary/5\">\r\n                      <span className=\"text-4xl\">вүЎШ§ГҙШЈ</span>\r\n                    </div>\r\n                  )}\r\n                  <div className=\"absolute top-2 right-2 bg-black/70 text-white text-xs px-2 py-1 rounded\">\r\n                    {book.subject}\r\n                  </div>\r\n                </div>\r\n                <div className=\"p-4\">\r\n                  <h3 className=\"font-semibold line-clamp-1 mb-1\">{book.title}</h3>\r\n                  <p className=\"text-sm text-muted-foreground mb-2\">{book.author}</p>\r\n                  <p className=\"text-sm line-clamp-2 mb-3\">{book.description}</p>\r\n\r\n                  <div className=\"flex items-center justify-between mb-3\">\r\n                    <div className=\"flex items-center gap-1\">\r\n                      <svg xmlns=\"http://www.w3.org/2000/svg\" className=\"h-4 w-4 text-yellow-500\" viewBox=\"0 0 20 20\" fill=\"currentColor\">\r\n                        <path d=\"M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z\" />\r\n                      </svg>\r\n                      <span className=\"text-sm\">{book.rating.toFixed(1)}</span>\r\n                    </div>\r\n                    <div className=\"flex items-center gap-1 text-xs text-muted-foreground\">\r\n                      <svg xmlns=\"http://www.w3.org/2000/svg\" className=\"h-4 w-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\r\n                        <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10\" />\r\n                      </svg>\r\n                      <span>{book.downloads}</span>\r\n                    </div>\r\n                  </div>\r\n\r\n                  <div className=\"flex flex-wrap gap-1 mb-3\">\r\n                    {book.tags.slice(0, 3).map((tag, index) => (\r\n                      <span key={index} className=\"text-xs bg-muted px-2 py-0.5 rounded\">\r\n                        {tag}\r\n                      </span>\r\n                    ))}\r\n                    {book.tags.length > 3 && (\r\n                      <span className=\"text-xs bg-muted px-2 py-0.5 rounded\">\r\n                        +{book.tags.length - 3}\r\n                      </span>\r\n                    )}\r\n                  </div>\r\n\r\n                  <a \r\n                    href={book.downloadUrl} \r\n                    target=\"_blank\" \r\n                    rel=\"noopener noreferrer\"\r\n                    className=\"w-full block text-center px-3 py-2 bg-primary text-primary-foreground rounded-md text-sm font-medium\"\r\n                  >\r\n                    в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГўв•ӘШІв•ӘШҜв•ӘШ°\r\n                  </a>\r\n                </div>\r\n              </div>\r\n            ))}\r\n          </div>\r\n        ) : (\r\n          <div className=\"rounded-lg border p-12 text-center\">\r\n            <div className=\"text-5xl mb-4\">вүЎШ§ГҙШЈ</div>\r\n            <h3 className=\"text-lg font-medium mb-2\">в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в”ҳГўв•ӘШІв•ӘШ° в”ҳВҒв”ҳГЁ в”ҳГ§в•Әв–‘в•ӘШҜ в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Ўв”ҳВҶв”ҳГЁв”ҳВҒ</h3>\r\n            <p className=\"text-muted-foreground\">в•ӘШҙв•Әв–’в•ӘШ° в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Ўв”ҳВҶв”ҳГЁв”ҳВҒ в•ӘШ«в”ҳГӘ в”ҳГ в•Әв•Јв•ӘШҜв”ҳГЁв”ҳГЁв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШөв•ӘШі</p>\r\n          </div>\r\n        )}\r\n      </section>\r\n\r\n      {/* Upload Modal */}\r\n      {showUploadModal && (\r\n        <div className=\"fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4\">\r\n          <div className=\"bg-background rounded-lg max-w-2xl w-full max-h-[90vh] overflow-y-auto\">\r\n            <div className=\"p-6\">\r\n              <div className=\"flex justify-between items-center mb-4\">\r\n                <h2 className=\"text-xl font-bold\">в•Әв–’в”ҳВҒв•Әв•Ј в”ҳГўв•ӘШІв•ӘШҜв•ӘШ° в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»</h2>\r\n                <button \r\n                  onClick={() => setShowUploadModal(false)}\r\n                  className=\"text-gray-500 hover:text-gray-700\"\r\n                >\r\n                  <svg xmlns=\"http://www.w3.org/2000/svg\" className=\"h-6 w-6\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\r\n                    <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M6 18L18 6M6 6l12 12\" />\r\n                  </svg>\r\n                </button>\r\n              </div>\r\n\r\n              <form onSubmit={handleUpload}>\r\n                <div className=\"space-y-4\">\r\n                  <div>\r\n                    <label className=\"block text-sm font-medium mb-1\">в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГўв•ӘШІв•ӘШҜв•ӘШ°</label>\r\n                    <input\r\n                      type=\"text\"\r\n                      value={formData.title}\r\n                      onChange={(e) => setFormData({...formData, title: e.target.value})}\r\n                      className=\"w-full border rounded-md px-3 py-2\"\r\n                      required\r\n                    />\r\n                  </div>\r\n\r\n                  <div>\r\n                    <label className=\"block text-sm font-medium mb-1\">в•ӘШҜв”ҳВ„в”ҳГ в•ӘШ¬в”ҳВ„в”ҳВҒ</label>\r\n                    <input\r\n                      type=\"text\"\r\n                      value={formData.author}\r\n                      onChange={(e) => setFormData({...formData, author: e.target.value})}\r\n                      className=\"w-full border rounded-md px-3 py-2\"\r\n                      required\r\n                    />\r\n                  </div>\r\n\r\n                  <div>\r\n                    <label className=\"block text-sm font-medium mb-1\">в•ӘШҜв”ҳВ„в”ҳГӘв•Әв•Ўв”ҳВҒ</label>\r\n                    <textarea\r\n                      value={formData.description}\r\n                      onChange={(e) => setFormData({...formData, description: e.target.value})}\r\n                      className=\"w-full border rounded-md px-3 py-2\"\r\n                      rows={3}\r\n                      required\r\n                    />\r\n                  </div>\r\n\r\n                  <div>\r\n                    <label className=\"block text-sm font-medium mb-1\">в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Ўв”ҳВҶв”ҳГЁв”ҳВҒ</label>\r\n                    <select\r\n                      value={formData.subjectId}\r\n                      onChange={(e) => setFormData({...formData, subjectId: e.target.value})}\r\n                      className=\"w-full border rounded-md px-3 py-2\"\r\n                      required\r\n                    >\r\n                      <option value=\"\">в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Ўв”ҳВҶв”ҳГЁв”ҳВҒ</option>\r\n                      {categories.map(category => (\r\n                        <option key={category.id} value={category.id}>{category.name}</option>\r\n                      ))}\r\n                    </select>\r\n                  </div>\r\n\r\n                  <div>\r\n                    <label className=\"block text-sm font-medium mb-1\">в•ӘШҜв”ҳВ„в”ҳГӘв•Әв”Ӯв”ҳГӘв”ҳГ </label>\r\n                    <div className=\"flex gap-2\">\r\n                      <input\r\n                        type=\"text\"\r\n                        value={formData.tagInput}\r\n                        onChange={(e) => setFormData({...formData, tagInput: e.target.value})}\r\n                        className=\"flex-1 border rounded-md px-3 py-2\"\r\n                        placeholder=\"в•ӘШ«в•Әв•ўв”ҳВҒ в”ҳГӘв•Әв”Ӯв”ҳГ в”ҳГҜв•ӘШҜ в”ҳГӘв•ӘШҜв•Әв•ўв•Әв•‘в•Әв•– Enter\"\r\n                        onKeyPress={(e) => {\r\n                          if (e.key === 'Enter') {\r\n                            e.preventDefault();\r\n                            handleAddTag();\r\n                          }\r\n                        }}\r\n                      />\r\n                      <button \r\n                        type=\"button\" \r\n                        onClick={handleAddTag}\r\n                        className=\"px-3 py-2 bg-secondary text-secondary-foreground rounded-md\"\r\n                      >\r\n                        в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ\r\n                      </button>\r\n                    </div>\r\n                    \r\n                    <div className=\"mt-2 flex flex-wrap gap-2\">\r\n                      {formData.tags.map((tag, index) => (\r\n                        <div key={index} className=\"flex items-center bg-muted px-2 py-1 rounded\">\r\n                          <span>{tag}</span>\r\n                          <button \r\n                            type=\"button\" \r\n                            onClick={() => handleRemoveTag(tag)}\r\n                            className=\"ml-1 text-destructive\"\r\n                          >\r\n                            в”ңГ№\r\n                          </button>\r\n                        </div>\r\n                      ))}\r\n                    </div>\r\n                  </div>\r\n\r\n                  <div>\r\n                    <label className=\"block text-sm font-medium mb-1\">в”ҳГ в”ҳВ„в”ҳВҒ в•ӘШҜв”ҳВ„в”ҳГўв•ӘШІв•ӘШҜв•ӘШ°</label>\r\n                    <input\r\n                      type=\"file\"\r\n                      accept=\".pdf,.epub,.mobi,.djvu,.cbz,.cbr,.doc,.docx\"\r\n                      onChange={handleFileChange}\r\n                      className=\"w-full border rounded-md px-3 py-2\"\r\n                      required\r\n                    />\r\n                  </div>\r\n\r\n                  <div>\r\n                    <label className=\"block text-sm font-medium mb-1\">в•Әв•Ўв”ҳГӘв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в•Әв•‘в”ҳВ„в•ӘШҜв”ҳВҒ (в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’в”ҳГЁ)</label>\r\n                    <input\r\n                      type=\"file\"\r\n                      accept=\"image/*\"\r\n                      onChange={handleCoverChange}\r\n                      className=\"w-full border rounded-md px-3 py-2\"\r\n                    />\r\n                  </div>\r\n\r\n                  <div className=\"flex justify-end gap-3 pt-4\">\r\n                    <button\r\n                      type=\"button\"\r\n                      onClick={() => setShowUploadModal(false)}\r\n                      className=\"px-4 py-2 border rounded-md\"\r\n                    >\r\n                      в•ӘШӯв”ҳВ„в•Әв•‘в•ӘШҜв•ӘШ©\r\n                    </button>\r\n                    <button\r\n                      type=\"submit\"\r\n                      disabled={uploading}\r\n                      className=\"px-4 py-2 bg-primary text-primary-foreground rounded-md disabled:opacity-50\"\r\n                    >\r\n                      {uploading ? 'в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШҜв”ҳВ„в•Әв–’в”ҳВҒв•Әв•Ј...' : 'в•Әв–’в”ҳВҒв•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГўв•ӘШІв•ӘШҜв•ӘШ°'}\r\n                    </button>\r\n                  </div>\r\n                </div>\r\n              </form>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n}","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(education)\\resources\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(education)\\teacher-exams\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'result' is assigned a value but never used. Allowed unused vars must match /^_/u.","line":107,"column":9,"nodeType":null,"messageId":"unusedVar","endLine":107,"endColumn":15}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\r\n\r\nimport { useEffect, useState } from \"react\";\r\n\r\nimport { ensureUser } from \"@/lib/user-utils\";\r\n\r\ntype Teacher = { \r\n  id: string; \r\n  name: string; \r\n  subject: string; \r\n  onlineUrl?: string | null;\r\n};\r\n\r\ntype ExamResult = { \r\n  id: string; \r\n  score: number; \r\n  takenAt: string; \r\n  exam: { \r\n    id: string; \r\n    subject: string; \r\n    title: string; \r\n    year: number; \r\n  };\r\n  teacher?: Teacher;\r\n};\r\n\r\ntype UserGrade = {\r\n  id: string;\r\n  subject: string;\r\n  grade: number;\r\n  maxGrade: number;\r\n  date: string;\r\n  notes?: string;\r\n  isOnline: boolean;\r\n  assignmentType: string;\r\n  teacher?: Teacher;\r\n};\r\n\r\nexport default function TeacherExamsPage() {\r\n\tconst [userId, setUserId] = useState<string | null>(null);\r\n\tconst [teachers, setTeachers] = useState<Teacher[]>([]);\r\n\tconst [examResults, setExamResults] = useState<ExamResult[]>([]);\r\n\tconst [userGrades, setUserGrades] = useState<UserGrade[]>([]);\r\n\r\n\t// Form states for adding new exam with teacher\r\n\tconst [teacherId, setTeacherId] = useState(\"\");\r\n\tconst [subject, setSubject] = useState(\"\");\r\n\tconst [examTitle, setExamTitle] = useState(\"\");\r\n\tconst [examDate, setExamDate] = useState(\"\");\r\n\tconst [score, setScore] = useState(0);\r\n\tconst [maxScore, setMaxScore] = useState(100);\r\n\tconst [isOnline, setIsOnline] = useState(false);\r\n\tconst [notes, setNotes] = useState(\"\");\r\n\tconst [assignmentType, setAssignmentType] = useState(\"OTHER\");\r\n\r\n\tuseEffect(() => {\r\n\t\tensureUser().then(setUserId);\r\n\t}, []);\r\n\r\n\tuseEffect(() => {\r\n\t\t(async () => {\r\n\t\t\tconst ts = await fetch(\"/api/teachers\").then((r) => r.json());\r\n\t\t\tsetTeachers(ts);\r\n\t\t})();\r\n\t}, []);\r\n\r\n\tuseEffect(() => {\r\n\t\tif (!userId) return;\r\n\t\t(async () => {\r\n\t\t\tconst results = await fetch(`/api/exams/results?userId=${userId}`).then((r) => r.json());\r\n\t\t\tsetExamResults(results);\r\n\r\n\t\t\tconst grades = await fetch(`/api/grades?userId=${userId}`).then((r) => r.json());\r\n\t\t\tsetUserGrades(grades);\r\n\t\t})();\r\n\t}, [userId]);\r\n\r\n\tasync function addTeacherExam(e: React.FormEvent) {\r\n\t\te.preventDefault();\r\n\t\tif (!userId || !teacherId || !subject || !examTitle || !examDate) return;\r\n\r\n\t\t// First create the exam\r\n\t\tconst examRes = await fetch(\"/api/exams\", {\r\n\t\t\tmethod: \"POST\",\r\n\t\t\theaders: { \"Content-Type\": \"application/json\" },\r\n\t\t\tbody: JSON.stringify({ \r\n\t\t\t\tsubject, \r\n\t\t\t\ttitle: examTitle, \r\n\t\t\t\tyear: new Date(examDate).getFullYear(),\r\n\t\t\t\ttype: \"OTHER\"\r\n\t\t\t}),\r\n\t\t});\r\n\t\tconst exam = await examRes.json();\r\n\r\n\t\t// Then create the exam result with teacher\r\n\t\tconst resultRes = await fetch(\"/api/exams/results\", {\r\n\t\t\tmethod: \"POST\",\r\n\t\t\theaders: { \"Content-Type\": \"application/json\" },\r\n\t\t\tbody: JSON.stringify({ \r\n\t\t\t\tuserId, \r\n\t\t\t\texamId: exam.id, \r\n\t\t\t\tscore: Number(score), \r\n\t\t\t\ttakenAt: examDate,\r\n\t\t\t\tteacherId\r\n\t\t\t}),\r\n\t\t});\r\n\t\tconst result = await resultRes.json();\r\n\r\n\t\t// Also add as a user grade\r\n\t\tawait fetch(\"/api/grades\", {\r\n\t\t\tmethod: \"POST\",\r\n\t\t\theaders: { \"Content-Type\": \"application/json\" },\r\n\t\t\tbody: JSON.stringify({\r\n\t\t\t\tuserId,\r\n\t\t\t\tsubject,\r\n\t\t\t\tgrade: Number(score),\r\n\t\t\t\tmaxGrade: Number(maxScore),\r\n\t\t\t\tdate: examDate,\r\n\t\t\t\tnotes,\r\n\t\t\t\tisOnline,\r\n\t\t\t\tassignmentType,\r\n\t\t\t\tteacherId\r\n\t\t\t}),\r\n\t\t});\r\n\r\n\t\t// Refresh data\r\n\t\tconst updatedResults = await fetch(`/api/exams/results?userId=${userId}`).then((r) => r.json());\r\n\t\tsetExamResults(updatedResults);\r\n\r\n\t\tconst updatedGrades = await fetch(`/api/grades?userId=${userId}`).then((r) => r.json());\r\n\t\tsetUserGrades(updatedGrades);\r\n\r\n\t\t// Reset form\r\n\t\tsetTeacherId(\"\");\r\n\t\tsetSubject(\"\");\r\n\t\tsetExamTitle(\"\");\r\n\t\tsetExamDate(\"\");\r\n\t\tsetScore(0);\r\n\t\tsetMaxScore(100);\r\n\t\tsetIsOnline(false);\r\n\t\tsetNotes(\"\");\r\n\t\tsetAssignmentType(\"OTHER\");\r\n\t}\r\n\r\n\tasync function deleteExamResult(id: string) {\r\n\t\tawait fetch(`/api/exams/results/${id}`, { method: \"DELETE\" });\r\n\t\tsetExamResults((r) => r.filter((x) => x.id !== id));\r\n\t}\r\n\r\n\tasync function deleteGrade(id: string) {\r\n\t\tawait fetch(`/api/grades/${id}`, { method: \"DELETE\" });\r\n\t\tsetUserGrades((g) => g.filter((x) => x.id !== id));\r\n\t}\r\n\r\n\treturn (\r\n\t\t\t\t\t<div className=\"px-4\">\r\n\t\t\t\t<section className=\"mx-auto max-w-7xl py-8 space-y-6\">\r\n\t\t\t\t<h1 className=\"text-2xl md:text-3xl font-bold\">в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в”ҳГӘв•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯв”ҳГЁв”ҳВҶ</h1>\r\n\r\n\t\t\t\t<div className=\"rounded-lg border p-4\">\r\n\t\t\t\t\t<h2 className=\"font-semibold mb-2\">в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ» в”ҳГ в•Әв•Ј в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯ</h2>\r\n\t\t\t\t\t<form className=\"grid md:grid-cols-2 gap-3\" onSubmit={addTeacherExam}>\r\n\t\t\t\t\t\t<select \r\n\t\t\t\t\t\t\tclassName=\"border rounded-md px-3 py-2 text-sm\" \r\n\t\t\t\t\t\t\taria-label=\"в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯ\" \r\n\t\t\t\t\t\t\tvalue={teacherId} \r\n\t\t\t\t\t\t\tonChange={(e) => setTeacherId(e.target.value)}\r\n\t\t\t\t\t\t>\r\n\t\t\t\t\t\t\t<option value=\"\">в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯ</option>\r\n\t\t\t\t\t\t\t{teachers.map((t) => (\r\n\t\t\t\t\t\t\t\t<option key={t.id} value={t.id}>{t.subject} - {t.name}</option>\r\n\t\t\t\t\t\t\t))}\r\n\t\t\t\t\t\t</select>\r\n\r\n\t\t\t\t\t\t<select \r\n\t\t\t\t\t\t\tclassName=\"border rounded-md px-3 py-2 text-sm\" \r\n\t\t\t\t\t\t\taria-label=\"в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ\" \r\n\t\t\t\t\t\t\tvalue={subject} \r\n\t\t\t\t\t\t\tonChange={(e) => setSubject(e.target.value)}\r\n\t\t\t\t\t\t>\r\n\t\t\t\t\t\t\t<option value=\"\">в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ</option>\r\n\t\t\t\t\t\t\t<option value=\"MATH\">в•Әв–’в”ҳГЁв•ӘШҜв•Әв•ўв”ҳГЁв•ӘШҜв•ӘШІ</option>\r\n\t\t\t\t\t\t\t<option value=\"PHYSICS\">в”ҳВҒв”ҳГЁв•Әв–“в”ҳГЁв•ӘШҜв•ӘШ©</option>\r\n\t\t\t\t\t\t\t<option value=\"CHEMISTRY\">в”ҳГўв”ҳГЁв”ҳГ в”ҳГЁв•ӘШҜв•ӘШ©</option>\r\n\t\t\t\t\t\t\t<option value=\"ARABIC\">в”ҳВ„в•Әв•‘в•ӘШұ в•Әв•Јв•Әв–’в•ӘШ°в”ҳГЁв•ӘШұ</option>\r\n\t\t\t\t\t\t\t<option value=\"ENGLISH\">в”ҳВ„в•Әв•‘в•ӘШұ в•ӘШӯв”ҳВҶв•ӘШҙв”ҳВ„в”ҳГЁв•Әв–“в”ҳГЁв•ӘШұ</option>\r\n\t\t\t\t\t\t</select>\r\n\r\n\t\t\t\t\t\t<input \r\n\t\t\t\t\t\t\tclassName=\"border rounded-md px-3 py-2 text-sm\" \r\n\t\t\t\t\t\t\tplaceholder=\"в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ\" \r\n\t\t\t\t\t\t\taria-label=\"в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ\" \r\n\t\t\t\t\t\t\tvalue={examTitle} \r\n\t\t\t\t\t\t\tonChange={(e) => setExamTitle(e.target.value)} \r\n\t\t\t\t\t\t/>\r\n\r\n\t\t\t\t\t\t<input \r\n\t\t\t\t\t\t\ttype=\"date\" \r\n\t\t\t\t\t\t\tclassName=\"border rounded-md px-3 py-2 text-sm\" \r\n\t\t\t\t\t\t\taria-lab