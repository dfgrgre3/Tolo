n\tconst getIcon = (type: string) => {\r\n\t\tswitch (type) {\r\n\t\t\tcase \"article\":\r\n\t\t\t\treturn <BookOpen className=\"h-4 w-4\" />;\r\n\t\t\tcase \"video\":\r\n\t\t\t\treturn <Video className=\"h-4 w-4\" />;\r\n\t\t\tcase \"guide\":\r\n\t\t\t\treturn <MessageCircle className=\"h-4 w-4\" />;\r\n\t\t\tdefault:\r\n\t\t\t\treturn <HelpCircle className=\"h-4 w-4\" />;\r\n\t\t}\r\n\t};\r\n\r\n\tif (helpItems.length === 0) return null;\r\n\r\n\treturn (\r\n\t\t<DropdownMenu open={isOpen} onOpenChange={setIsOpen}>\r\n\t\t\t<DropdownMenuTrigger asChild>\r\n\t\t\t\t<Button\r\n\t\t\t\t\tvariant=\"ghost\"\r\n\t\t\t\t\tsize=\"icon\"\r\n\t\t\t\t\tclassName=\"h-9 w-9 hover:bg-primary/10 dark:hover:bg-primary/15\"\r\n\t\t\t\t\taria-label=\"в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘВ»в•ӘШұ в•Әв”Ӯв”ҳГЁв•ӘШҜв”ҳГ©в”ҳГЁв•ӘШұ\"\r\n\t\t\t\t\ttitle=\"в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘВ»в•ӘШұ\"\r\n\t\t\t\t>\r\n\t\t\t\t\t<HelpCircle className=\"h-4 w-4\" />\r\n\t\t\t\t</Button>\r\n\t\t\t</DropdownMenuTrigger>\r\n\t\t\t<DropdownMenuContent align=\"end\" className=\"w-80 p-0\" sideOffset={8}>\r\n\t\t\t\t<div className=\"flex items-center justify-between px-4 py-3 border-b\">\r\n\t\t\t\t\t<div className=\"flex items-center gap-2\">\r\n\t\t\t\t\t\t<HelpCircle className=\"h-4 w-4 text-primary\" />\r\n\t\t\t\t\t\t<span className=\"font-semibold text-sm\">в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘВ»в•ӘШұ</span>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t\t<Button\r\n\t\t\t\t\t\tvariant=\"ghost\"\r\n\t\t\t\t\t\tsize=\"icon\"\r\n\t\t\t\t\t\tclassName=\"h-6 w-6\"\r\n\t\t\t\t\t\tonClick={() => setIsOpen(false)}\r\n\t\t\t\t\t>\r\n\t\t\t\t\t\t<X className=\"h-3 w-3\" />\r\n\t\t\t\t\t</Button>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div className=\"p-2 space-y-1\">\r\n\t\t\t\t\t<AnimatePresence>\r\n\t\t\t\t\t\t{helpItems.map((item, index) => (\r\n\t\t\t\t\t\t\t<motion.a\r\n\t\t\t\t\t\t\t\tkey={item.id}\r\n\t\t\t\t\t\t\t\thref={item.url || \"#\"}\r\n\t\t\t\t\t\t\t\ttarget={item.url?.startsWith(\"http\") ? \"_blank\" : undefined}\r\n\t\t\t\t\t\t\t\trel={item.u