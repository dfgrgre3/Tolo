             initial={{ scale: 0 }}\r\n                animate={{ scale: 1 }}\r\n                exit={{ scale: 0 }}\r\n                className=\"absolute -top-0.5 -right-0.5 w-2 h-2 bg-primary rounded-full\"\r\n              />\r\n            )}\r\n          </AnimatePresence>\r\n\r\n          {showLabel && (\r\n            <span className=\"mr-2 text-sm\">\r\n              {state.isEnabled ? \"в”ҳГ в•Әв–’в”ҳГўв”ҳЩ‘в•Әв–“\" : \"в•ӘШІв•Әв–’в”ҳГўв”ҳГЁв•Әв–“\"}\r\n            </span>\r\n          )}\r\n        </Button>\r\n      </DropdownMenuTrigger>\r\n\r\n      <DropdownMenuContent align=\"end\" className=\"w-64\">\r\n        <DropdownMenuLabel className=\"flex items-center justify-between\">\r\n          <span>в”ҳГӘв•Әв•ўв•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШІв•Әв–’в”ҳГўв”ҳГЁв•Әв–“</span>\r\n          <Button\r\n            variant=\"ghost\"\r\n            size=\"sm\"\r\n            className=\"h-7 px-2 text-xs\"\r\n            onClick={actions.toggle}\r\n          >\r\n            {state.isEnabled ? (\r\n              <>\r\n                <EyeOff className=\"h-3 w-3 ml-1\" />\r\n                в•ӘШӯв”ҳГЁв”ҳГ©в•ӘШҜв”ҳВҒ\r\n              </>\r\n            ) : (\r\n              <>\r\n                <Eye className=\"h-3 w-3 ml-1\" />\r\n                в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„\r\n              </>\r\n            )}\r\n          </Button>\r\n        </DropdownMenuLabel>\r\n\r\n        <DropdownMenuSeparator />\r\n\r\n        {/* Focus mode options */}\r\n        <DropdownMenuCheckboxItem\r\n          checked={state.hideNotifications}\r\n          onCheckedChange={actions.setHideNotifications}\r\n          disabled={!state.isEnabled}\r\n        >\r\n          <BellOff className=\"h-4 w-4 ml-2\" />\r\n          в•ӘШӯв•ӘВ«в”ҳВҒв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШӯв•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ\r\n        </DropdownMenuCheckboxItem>\r\n\r\n        <DropdownMenuCheckboxItem\r\n          checked={state.hideSearch}\r\n          onCheckedChange={actions.setHideSearch}\r\n          disabled={