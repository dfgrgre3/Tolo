ils';\nimport { toast } from 'sonner';\nimport { useAuth } from '@/contexts/auth-context';\nimport { DeleteAccountDialog } from '../components';\nimport { useRouter } from 'next/navigation';\n\nexport default function SecurityPage() {\n  const { logout, user } = useAuth();\n  const router = useRouter();\n  const [isChangingPassword, setIsChangingPassword] = useState(false);\n  const [passwordData, setPasswordData] = useState({\n    currentPassword: '',\n    newPassword: '',\n    confirmPassword: '',\n  });\n  const [isLoading, setIsLoading] = useState(false);\n\n  // Security Logs State\n  const [recentLogs, setRecentLogs] = useState<any[]>([]);\n  const [isLoadingLogs, setIsLoadingLogs] = useState(true);\n\n  const EVENT_LABELS: Record<string, string> = {\n    LOGIN_SUCCESS: 'в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳВҶв•ӘШҜв•ӘШҙв•ӘШө',\n    LOGIN_FAILED: 'в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳВҒв•ӘШҜв•Әв”Өв”ҳВ„в•ӘШұ',\n    LOGOUT: 'в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘВ«в•Әв–’в”ҳГӘв•ӘШҙ',\n    REGISTER: 'в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ° в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»',\n    PASSWORD_CHANGE: 'в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’',\n    MAGIC_LINK_REQUESTED: 'в•Әв•–в”ҳВ„в•ӘШ° в•Әв–’в•ӘШҜв•ӘШ°в•Әв•– в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„',\n    DEVICE_TRUST_CHANGE: 'в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШів”ҳГ©в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШҙв”ҳГ§в•ӘШҜв•Әв–“',\n    SUSPICIOUS_ACTIVITY: 'в”ҳВҶв•Әв”Өв•ӘШҜв•Әв•– в”ҳГ в•Әв”Өв•ӘШ°в”ҳГӘв”ҳГ§',\n  };\n\n  useEffect(() => {\n    const fetchRecentLogs = async () => {\n      try {\n        const res = await fetch('/api/auth/security-logs?limit=3');\n        if (!res.ok) throw new Error();\n        const data = await res.json();\n        setRecentLogs(data.logs || []);\n      } catch (err) {\n        console.error('Failed to fetch logs');\n      } finally {\n        setIsLoadingLogs(false);\n      }\n    };\n    fetchRecentLogs();\n  }, []);\n\n  const handlePasswordChange = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (passwordData.newPassword !== passwordData.confirmPassword) {\n      toast.error('в”ҳГўв”ҳВ„в”ҳГ в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШІв•Әв•–в•ӘШҜв•ӘШ°в”ҳГ©в•ӘШұ');\n      return;\n    }\n\n    setIsLoading(true);\n    try {\n      const response = await fetch('/api/auth/change-password', {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({\n          currentPassword: passwordData.currentPassword,\n          newPassword: passwordData.newPassword,\n        }),\n      });\n\n      if (!response.ok) {\n        const error = await response.json();\n        throw new Error(error.error || 'в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’');\n      }\n\n      toast.success('в•ӘШІв”ҳГ  в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө');\n      setIsChangingPassword(false);\n      setPasswordData({ currentPassword: '', newPassword: '', confirmPassword: '' });\n    } catch (error: any) {\n      toast.error(error.message);\n    } finally {\n      setIsLoading(false);\n    }\n  };\n\n  const handleDeleteAccount = async () => {\n    if (!user?.id) return;\n\n    try {\n      const res = await fetch(`/api/users/${user.id}`, {\n        method: \"DELETE\",\n        headers: { \"Content-Type\": \"application/json\" },\n        credentials: \"include\",\n      });\n\n      if (res.ok) {\n        toast.success(\"в•ӘШІв”ҳГ  в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШҜв”ҳВ„в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ° в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө\");\n        localStorage.clear();\n        sessionStorage.clear();\n        setTimeout(() => {\n          router.push(\"/\");\n        }, 1000);\n      } else {\n        const errorData = await res.json().catch(() => ({ error: \"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв•Јв•Әв–’в”ҳГӘв”ҳВҒ\" }));\n        toast.error(errorData.error || \"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШҜв”ҳВ„в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°\");\n      }\n    } catch (error) {\n      console.error(\"Error deleting account:\", error);\n      toast.error(\"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШҜв”ҳВ„в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°\");\n    }\n  };\n\n  return (\n    <div className=\"max-w-4xl mx-auto space-y-8\">\n      {/* Header */}\n      <div>\n        <h1 className=\"text-2xl font-bold text-white flex items-center gap-3\">\n          <Shield className=\"h-7 w-7 text-indigo-400\" />\n          в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ в•ӘШҜв”ҳВҶ\n        </h1>\n        <p className=\"text-sm text-slate-400 mt-1\">в•ӘШӯв•ӘВ»в•ӘШҜв•Әв–’в•ӘШұ в”ҳГӘв•ӘШөв”ҳГ в•ӘШҜв”ҳГЁв•ӘШұ в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°в”ҳГў в”ҳГӘв•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в”ҳГўв”ҳВ„в”ҳГ в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’</p>\n      </div>\n\n      {/* Password Section */}\n      <section className=\"rounded-2xl bg-white/5 border border-white/10 overflow-hidden\">\n        <div className=\"p-6\">\n          <div className=\"flex items-center justify-between mb-6\">\n            <div className=\"flex items-center gap-4\">\n              <div className=\"h-12 w-12 rounded-xl bg-indigo-500/10 flex items-center justify-center\">\n                <Key className=\"h-6 w-6 text-indigo-400\" />\n              </div>\n              <div>\n                <h3 className=\"font-semibold text-white\">в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’</h3>\n                <p className=\"text-sm text-slate-400\">в•ӘШӘв•ӘВ«в•Әв–’ в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’: в”ҳГ в”ҳВҶв•Әв–‘ 3 в•ӘШ«в•Әв”Өв”ҳГ§в•Әв–’</p>\n              </div>\n            </div>\n            <button\n              onClick={() => setIsChangingPassword(!isChangingPassword)}\n              className=\"px-4 py-2 rounded-xl bg-white/5 hover:bg-white/10 text-white transition-colors\"\n            >\n              {isChangingPassword ? 'в•ӘШӯв”ҳВ„в•Әв•‘в•ӘШҜв•ӘШ©' : 'в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі'}\n            </button>\n          </div>\n\n          {isChangingPassword && (\n            <motion.form\n              initial={{ height: 0, opacity: 0 }}\n              animate={{ height: 'auto', opacity: 1 }}\n              onSubmit={handlePasswordChange}\n              className=\"space-y-4 border-t border-white/10 pt-6\"\n            >\n              <div className=\"grid gap-4\">\n                <div className=\"space-y-2\">\n                  <label className=\"text-sm text-slate-300\">в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШұ</label>\n                  <input\n                    type=\"password\"\n                    required\n                    value={passwordData.currentPassword}\n                    onChange={(e) => setPasswordData({ ...passwordData, currentPassword: e.target.value })}\n                    className=\"w-full p-3 rounded-xl bg-white/5 border border-white/10 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500/50\"\n                  />\n                </div>\n                <div className=\"grid sm:grid-cols-2 gap-4\">\n                  <div className=\"space-y-2\">\n                    <label className=\"text-sm text-slate-300\">в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ</label>\n                    <input\n                      type=\"password\"\n                      required\n                      value={passwordData.newPassword}\n                      onChange={(e) => setPasswordData({ ...passwordData, newPassword: e.target.value })}\n                      className=\"w-full p-3 rounded-xl bg-white/5 border border-white/10 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500/50\"\n                    />\n                  </div>\n                  <div className=\"space-y-2\">\n                    <label className=\"text-sm text-slate-300\">в•ӘШІв•ӘШ«в”ҳГўв”ҳГЁв•ӘВ» в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ</label>\n                    <input\n                      type=\"password\"\n                      required\n                      value={passwordData.confirmPassword}\n                      onChange={(e) => setPasswordData({ ...passwordData, confirmPassword: e.target.value })}\n                      className=\"w-full p-3 rounded-xl bg-white/5 border border-white/10 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500/50\"\n                    />\n                  </div>\n                </div>\n              </div>\n              <button\n                type=\"submit\"\n                disabled={isLoading}\n                className=\"w-full sm:w-auto px-6 py-2 rounded-xl bg-indigo-500 hover:bg-indigo-600 text-white transition-colors flex items-center justify-center gap-2\"\n              >\n                {isLoading && <Loader2 className=\"h-4 w-4 animate-spin\" />}\n                в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’\n              </button>\n            </motion.form>\n          )}\n        </div>\n      </section>\n\n      {/* Two-Factor Authentication */}\n      <section className=\"rounded-2xl bg-white/5 border border-white/10 p-6\">\n        <div className=\"flex items-center justify-between\">\n          <div className=\"flex items-center gap-4\">\n            <div className=\"h-12 w-12 rounded-xl bg-green-500/10 flex items-center justify-center\">\n              <Shield className=\"h-6 w-6 text-green-400\" />\n            </div>\n            <div>\n              <h3 className=\"font-semibold text-white\">в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Ўв•ӘШҜв•ӘВ»в”ҳГ©в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШів”ҳВҶв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШұ (2FA)</h3>\n              <p className=\"text-sm text-slate-400\">в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•Әв•–в•ӘШ°в”ҳГ©в•ӘШұ в•ӘШөв”ҳГ в•ӘШҜв”ҳГЁв•ӘШұ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв”ҳГЁв•ӘШұ в”ҳВ„в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°в”ҳГў</p>\n            </div>\n          </div>\n          <button className=\"px-4 py-2 rounded-xl bg-green-500/20 text-green-400 hover:bg-green-500/30 transition-colors\">\n            в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„\n          </button>\n        </div>\n      </section>\n\n      {/* Active Sessions */}\n      <section className=\"rounded-2xl bg-white/5 border border-white/10 overflow-hidden\">\n        <div className=\"p-4 border-b border-white/10\">\n          <h3 className=\"font-semibold text-white flex items-center gap-2\">\n            <Smartphone className=\"h-5 w-5 text-indigo-400\" />\n            в•ӘШҜв”ҳВ„в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Өв•Әв•–в•ӘШұ\n          </h3>\n        </div>\n        <div className=\"p-6 space-y-4\">\n          <div className=\"flex items-center justify-between\">\n            <div className=\"flex items-center gap-4\">\n              <div className=\"h-10 w-10 rounded-lg bg-white/5 flex items-center justify-center\">\n                <Monitor className=\"h-5 w-5 text-slate-400\" />\n              </div>\n              <div>\n                <p className=\"text-sm font-medium text-white\">Windows ШёВҖШӘ Chrome</p>\n                <p className=\"text-xs text-slate-500\">в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв”ҳГ§в•Әв–’в•ӘШұв•ӘГ® в”ҳГ в•Әв•Ўв•Әв–’ ШёВҖШӘ в”ҳВҶв•Әв”Өв•Әв•– в•ӘШҜв”ҳВ„в•ӘШӘв”ҳВҶ</p>\n              </div>\n            </div>\n            <span className=\"px-2 py-1 rounded text-[10px] bg-green-500/20 text-green-400 uppercase font-bold\">в”ҳГ§в•Әв–‘в•ӘШҜ в•ӘШҜв”ҳВ„в•ӘШҙв”ҳГ§в•ӘШҜв•Әв–“</span>\n          </div>\n          \n          <button \n            onClick={() => logout(true)}\n            className=\"w-full mt-4 flex items-center justify-center gap-2 p-3 rounded-xl border border-red-500/30 text-red-400 hover:bg-red-500/10 transition-colors\"\n          >\n            <LogOut className=\"h-4 w-4\" />\n            в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ«в•Әв–’в”ҳГӘв•ӘШҙ в”ҳГ в”ҳВҶ в•ӘШҙв”ҳГ в”ҳГЁв•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШ«в•ӘШҙв”ҳГ§в•Әв–“в•ӘШұ\n          </button>\n        </div>\n      </section>\n\n      {/* Security Log Summary */}\n      <section className=\"rounded-2xl bg-white/5 border border-white/10 p-6\">\n        <div className=\"flex items-center justify-between mb-4\">\n          <h3 className=\"font-semibold text-white flex items-center gap-2\">\n            <History className=\"h-5 w-5 text-indigo-400\" />\n            в•Әв”Ӯв•ӘШҙв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Өв•ӘШҜв•Әв•–в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ в”ҳВҶв”ҳГЁв•ӘШұ\n          </h3>\n          <Link href=\"/settings/security/logs\" className=\"text-sm text-indigo-400 hover:underline\">в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в”ҳГўв”ҳВ„</Link>\n        </div>\n        <div className=\"space-y-4\">\n          {isLoadingLogs ? (\n            <div className=\"flex items-center justify-center py-4\">\n              <Loader2 className=\"h-5 w-5 text-indigo-500 animate-spin\" />\n            </div>\n          ) : recentLogs.length > 0 ? (\n            recentLogs.map((log) => (\n              <div key={log.id} className=\"flex items-center justify-between text-sm\">\n                <div className=\"flex items-center gap-2\">\n                  {log.eventType.includes('SUCCESS') || log.eventType === 'REGISTER' ? (\n                    <CheckCircle2 className=\"h-4 w-4 text-green-400\" />\n                  ) : log.eventType.includes('FAILED') || log.eventType.includes('SUSPICIOUS') ? (\n                    <AlertTriangle className=\"h-4 w-4 text-red-400\" />\n                  ) : (\n                    <Shield className=\"h-4 w-4 text-indigo-400\" />\n                  )}\n                  <span className=\"text-slate-300\">\n                    {EVENT_LABELS[log.eventType] || log.eventType}\n                  </span>\n                </div>\n                <span className=\"text-slate-500\">\n                  {formatDistanceToNow(new Date(log.createdAt), { addSuffix: true, locale: ar })}\n                </span>\n              </div>\n            ))\n          ) : (\n            <p className=\"text-center text-xs text-slate-500 py-2\">в”ҳВ„в•ӘШҜ в”ҳГЁв”ҳГӘв•ӘШҙв•ӘВ» в”ҳВҶв•Әв”Өв•ӘШҜв•Әв•–в•ӘШҜв•ӘШІ в”ҳГ в•Әв”Ӯв•ӘШҙв”ҳВ„в•ӘШұ в•ӘШөв•ӘШІв”ҳГ« в•ӘШҜв”ҳВ„в•ӘШӘв”ҳВҶ</p>\n          )}\n        </div>\n      </section>\n\n      {/* Danger Zone - Delete Account */}\n      <section className=\"rounded-2xl bg-red-500/5 border border-red-500/20 overflow-hidden\">\n        <div className=\"p-4 border-b border-red-500/20 bg-red-500/10\">\n          <h3 className=\"font-semibold text-red-400 flex items-center gap-2\">\n            <AlertTriangle className=\"h-5 w-5\" />\n            в”ҳГ в”ҳВҶв•Әв•–в”ҳГ©в•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ«в•Әв•–в•Әв–’\n          </h3>\n        </div>\n        <div className=\"p-6\">\n          <div className=\"flex items-start justify-between gap-4\">\n            <div>\n              <h4 className=\"font-medium text-white\">в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШҜв”ҳВ„в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ° в”ҳВҶв”ҳГ§в•ӘШҜв•ӘШ®в”ҳГЁв•ӘШҜв”ҳГҜ</h4>\n              <p className=\"text-sm text-slate-400 mt-1\">\n                в•Әв”Ӯв”ҳГЁв•ӘШІв”ҳГ  в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°в”ҳГў в”ҳГӘв•ӘШҙв”ҳГ в”ҳГЁв•Әв•Ј в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІв”ҳГў в•ӘШ°в•Әв”Өв”ҳГўв”ҳВ„ в•ӘВ»в•ӘШҜв•ӘШ®в”ҳГ . в”ҳГ§в•Әв–‘в•ӘШҜ в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШҙв•Әв–’в•ӘШҜв•ӘШ© в”ҳВ„в•ӘШҜ в”ҳГЁв”ҳГ в”ҳГўв”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШІв•Әв–’в•ӘШҜв•ӘШҙв•Әв•Ј в•Әв•Јв”ҳВҶв”ҳГ§.\n              </p>\n            </div>\n            <DeleteAccountDialog onConfirm={handleDeleteAccount} />\n          </div>\n        </div>\n      </section>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\tasks\\components\\TaskAnalytics.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\tasks\\components\\TaskForm.tsx","messages":[],"suppressedMessages":[],"errorCoun