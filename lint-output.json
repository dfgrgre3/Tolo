hite/5'}`}\r\n                            >\r\n                                {PATH_OPTIONS.map((path: string) => (\r\n                                    <option key={path} value={path} className=\"bg-slate-900 text-gray-200\">{path}</option>\r\n                                ))}\r\n                            </select>\r\n                            <div className=\"absolute top-1/2 right-2 transform -translate-y-1/2 pointer-events-none text-gray-400\">\r\n                                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\" strokeLinecap=\"round\" strokeLinejoin=\"round\"><polyline points=\"6 9 12 15 18 9\"></polyline></svg>\r\n                            </div>\r\n                        </div>\r\n                        \r\n                        {/* 2. Refresh Button */}\r\n                        <button \r\n                            onClick={() => loadData(pathFilter)} // Refresh data for the current path\r\n                            disabled={isLoading}\r\n                            className={`p-2 rounded-full transition-all duration-300 flex items-center justify-center border border-white/10\r\n                                ${\r\n                                    isLoading \r\n                                        ? 'bg-white/5 cursor-not-allowed text-gray-500' \r\n                                        : 'bg-white/5 text-primary hover:bg-white/10 hover:shadow-[0_0_10px_rgba(124,58,237,0.2)]'\r\n                                }`\r\n                            }\r\n                            title=\"в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ\"\r\n                        >\r\n                            <RefreshCw className={`h-5 w-5 ${isLoading ? 'animate-spin' : ''}`} />\r\n                        </button>\r\n                    </div>\r\n\r\n                </div>\r\n                \r\n                {/* --- Main Card Container --- */}\r\n                <div className=\"relative z-10\">\r\n                    {cardContent}\r\n                </div>\r\n            </div>\r\n        </div>\r\n    );\r\n}\r\n\r\n// Applying React.memo is the performance enhancement for this purely presentational component.\r\nexport const AnalyticsSection = React.memo(AnalyticsSectionComponent);\r\n\r\n// The default export is the memoized version.\r\nexport default AnalyticsSection;\r\n\r\n\r\n\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\components\\home\\sections\\ExamsSection.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'AnimatePresence' is defined but never used. Allowed unused vars must match /^_/u.","line":5,"column":18,"nodeType":null,"messageId":"unusedVar","endLine":5,"endColumn":33},{"ruleId":"react/no-unescaped-entities","severity":1,"message":"`\"` can be escaped with `&quot;`, `&ldquo;`, `&#34;`, `&rdquo;`.","line":239,"column":98,"nodeType":"JSXText","messageId":"unescapedEntityAlts","suggestions":[{"messageId":"replaceWithAlt","data":{"alt":"&quot;"},"fix":{"range":[13416,13554],"text":"\r\n                        в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•Әв”Ӯв”ҳВ„в•ӘШҜв•ӘШөв”ҳГў (в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ) в”ҳГӘв•ӘШҜв•Әв”Ӯв•ӘШІв•Әв•Јв•ӘВ» в”ҳВ„в”ҳГ в”ҳГӘв•ӘШҜв•ӘШҙв”ҳГ§в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШҜв•ӘШІ. в”ҳГўв”ҳВ„ в•ӘШҜв”ҳВҶв•ӘШІв•Әв•Ўв•ӘШҜв•Әв–’ в”ҳГЁв”ҳГ©в•Әв–’в•ӘШ°в”ҳГў в”ҳГ в”ҳВҶ в”ҳВҶв”ҳГЁв”ҳВ„ в•Әв–’в•ӘШІв•ӘШ°в•ӘШұ &quot;в•ӘШҜв”ҳВ„в•ӘШ°в•Әв•–в”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•Әв•–в”ҳГӘв•Әв–’в”ҳГЁ\".\r\n                    "},"desc":"Replace with `&quot;`."},{"messageId":"replaceWithAlt","data":{"alt":"&ldquo;"},"fix":{"range":[13416,13554],"text":"\r\n                        в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•Әв”Ӯв”ҳВ„в•ӘШҜв•ӘШөв”ҳГў (в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ) в”ҳГӘв•ӘШҜв•Әв”Ӯв•ӘШІв•Әв•Јв•ӘВ» в”ҳВ„в”ҳГ в”ҳГӘв•ӘШҜв•ӘШҙв”ҳГ§в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШҜв•ӘШІ. в”ҳГўв”ҳВ„ в•ӘШҜв”ҳВҶв•ӘШІв•Әв•Ўв•ӘШҜв•Әв