dy<{\r\n        messages?: { role: string; content: string }[];\r\n        provider?: string;\r\n        userId?: string;\r\n      }>(req, {\r\n        maxSize: 10240, // 10KB max for chat messages\r\n        required: true,\r\n      });\r\n\r\n      if (!bodyResult.success) {\r\n        return bodyResult.error;\r\n      }\r\n\r\n      const { messages, provider, userId } = bodyResult.data;\r\n\r\n      // Try to get userId from token if not provided\r\n      let actualUserId = userId;\r\n      if (!actualUserId) {\r\n        // Auth removed\r\n      }\r\n\r\n      // в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘВ» в”ҳГ в”ҳГ©в•ӘВ»в”ҳГ  в•ӘШҜв”ҳВ„в•ӘВ«в•ӘВ»в”ҳГ в•ӘШұ\r\n      const selectedProvider = provider === 'openai' ? AI_PROVIDERS.OPENAI : AI_PROVIDERS.GEMINI;\r\n\r\n      if (!validateApiKey(selectedProvider === AI_PROVIDERS.OPENAI ? 'OPENAI' : 'GEMINI')) {\r\n        const response = NextResponse.json(\r\n          { error: `в”ҳГ в”ҳВҒв•ӘШІв•ӘШҜв•ӘШө API в”ҳВ„в”ҳВҖ ${selectedProvider.name} в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в”ҳГ§в”ҳГЁв•ӘШ«`, code: 'API_KEY_MISSING' },\r\n          { status: 500 }\r\n        );\r\n        return addSecurityHeaders(response);\r\n      }\r\n\r\n      if (!messages || !Array.isArray(messages)) {\r\n        const response = NextResponse.json(\r\n          { error: \"в•ӘШҜв”ҳВ„в•Әв–’в•Әв”Ӯв•ӘШҜв•ӘШ®в”ҳВ„ в•Әв•‘в”ҳГЁв•Әв–’ в•Әв•Ўв•ӘШҜв”ҳВ„в•ӘШөв•ӘШұ\", code: 'INVALID_MESSAGES' },\r\n          { status: 400 }\r\n        );\r\n        return addSecurityHeaders(response);\r\n      }\r\n\r\n      // Analyze sentiment of the last user message\r\n      let sentiment = null;\r\n      let sentimentAwareContext = \"\";\r\n\r\n      if (actualUserId && messages.length > 0) {\r\n        const lastUserMessage = messages.filter((m) => m.role === 'user').pop();\r\n        if (lastUserMessage) {\r\n          try {\r\n            sentiment = await analyzeSentiment(lastUserMessage.content, actualUserId, 'chat');\r\n\r\n            // Add sentiment-aware context\r\n            if (sentiment.sentiment === 'frustrated' || sentiment.sentiment === 'tired') {\r\n              sentimentAwareContext = `в”ҳГ в”ҳВ„в•ӘШҜв•ӘШөв•Әв••в•ӘШұ в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ: в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в”ҳГЁв•ӘШ°в•ӘВ»в”ҳГӘ ${sentiment.sentiment === 'frustrated' ? 'в”ҳГ в•ӘШөв•ӘШ°в•Әв•–в•ӘШҜв”ҳГҜ' : 'в”ҳГ в•ӘШІв•Әв•Јв•ӘШ°в•ӘШҜв”ҳГҜ'}. в”ҳГЁв•ӘШҙв•ӘШ° в•ӘШ«в”ҳВҶ в•ӘШІв”ҳГўв”ҳГӘв”ҳВҶ в•ӘШ«в”ҳГўв•ӘШів•Әв–’ в•ӘШІв”ҳВҒв”ҳГ§в”ҳГ в•ӘШҜв”ҳГҜ в”ҳГӘв•ӘШІв”ҳГ©в•ӘВ»в”ҳГЁв”ҳГ  в•ӘВ»в•Әв•Јв”ҳГ  в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв”ҳГЁ. `;\r\n              if (sentiment.suggestions && sentiment.suggestions.length > 0) {\r\n                sentimentAwareContext += `в•ӘШҜв”ҳГ©в•ӘШІв•Әв–’в•ӘШҜв•ӘШөв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв•Јв”ҳГ : ${sentiment.suggestions.join(', ')}. `;\r\n              }\r\n            }\r\n\r\n            // Save chat message with sentiment\r\n            await prisma.aiChatMessage.create({\r\n              data: {\r\n                userId: actualUserId,\r\n                role: 'user',\r\n                content: lastUserMessage.content,\r\n                sentiment: sentiment.sentiment,\r\n                metadata: JSON.stringify({\r\n                  score: sentiment.score,\r\n                  confidence: sentiment.confidence,\r\n                  emotions: sentiment.emotions\r\n                })\r\n              }\r\n            });\r\n          } catch (error) {\r\n            logger.error('Error analyzing sentiment:', error);\r\n          }\r\n        }\r\n      }\r\n\r\n      // в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в”ҳВҶв•Әв••в•ӘШҜв”ҳГ  в”ҳВ„в•ӘШІв•Әв•Јв•Әв–’в”ҳГЁв”ҳВҒ в•Әв”Өв•ӘВ«в•Әв•Ўв”ҳГЁв•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘВ» в”ҳГ в•Әв•Ј в•ӘШІв•ӘШөв”ҳВ„в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Өв•ӘШҜв•Әв•Јв•Әв–’\r\n      const systemMessage = {\r\n        role: \"system\",\r\n        content: `${sentimentAwareContext}в•ӘШ«в”ҳВҶв•ӘШІ в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘВ» в•Әв–‘в”ҳГўв•ӘШҜв•ӘШ© в•ӘШҜв•Әв•Ўв•Әв•–в”ҳВҶв•ӘШҜв•Әв•Јв”ҳГЁ в”ҳГ в•ӘШІв•ӘВ«в•Әв•Ўв•Әв•Ў в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Јв”ҳВ„в”ҳГЁв”ҳГ  в”ҳГӘв•ӘШҜв”ҳВ„в•ӘШӯв•Әв–’в•Әв”Өв•ӘШҜв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГўв•ӘШҜв•ӘВ»в”ҳГЁв”ҳГ в”ҳГЁ в”ҳВ„в”ҳГ в”ҳВҶв•Әв•Ўв•ӘШұ в•ӘШів”ҳВҶв•ӘШҜв”ҳГӘв”ҳГЁ. в”ҳГ в”ҳГ§в”ҳГ в•ӘШІв”ҳГў в”ҳГ§в”ҳГЁ в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в•Әв•–в”ҳВ„в•ӘШҜв•ӘШ° в”ҳВҒв”ҳГЁ в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв•ӘШІв”ҳГ§в”ҳГ  в”ҳГӘв•ӘШҜв”ҳВ„в•ӘШӯв•ӘШҙв•ӘШҜв•ӘШ°в•ӘШұ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШ«в•Әв”Ӯв•ӘШ®в”ҳВ„в•ӘШІв”ҳГ§в”ҳГ  в•ӘШ°в•Әв•–в•Әв–’в”ҳГЁв”ҳГ©в•ӘШұ в”ҳГӘв•ӘШҜв•Әв•ўв•ӘШөв•ӘШұ в”ҳГӘв”ҳГ в”ҳВҒв”ҳГЁв•ӘВ»в•ӘШұ. в”ҳГЁв•ӘШҙв•ӘШ° в•ӘШ«в”ҳВҶ в•ӘШІв”ҳГўв”ҳГӘв”ҳВҶ в•ӘШӯв•ӘШҙв•ӘШҜв•ӘШ°в•ӘШҜв•ӘШІв”ҳГў в•ӘВ»в”ҳГ©в”ҳГЁв”ҳГ©в•ӘШұ в”ҳГӘв”ҳГ в•ӘШІв”ҳВҶв•ӘШҜв•Әв”Ӯв•ӘШ°в•ӘШұ в”ҳГ в•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГӘв”ҳГ« в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Јв”ҳВ„в”ҳГЁв”ҳГ в”ҳГЁ в”ҳВ„в”ҳВ„в•Әв•–в•ӘШҜв”ҳВ„в•ӘШ°. в•ӘШӯв•Әв–‘в•ӘШҜ в”ҳВ„в”ҳГ  в•ӘШІв”ҳГўв”ҳВҶ в”ҳГ в•ӘШІв•ӘШ«в”ҳГўв•ӘВ»в•ӘШҜв”ҳГҜ в”ҳГ в”ҳВҶ в•ӘШӯв•ӘШҙв•ӘШҜв•ӘШ°в•ӘШұ в•Әв”Ӯв•ӘШ¬в•ӘШҜв”ҳВ„ в”ҳГ в•ӘШҜв•ӘГ® в”ҳВҒв”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШ«в”ҳВҒв•Әв•ўв”ҳВ„ в•ӘШ«в”ҳВҶ в•ӘШІв•Әв•Јв•ӘШІв•Әв–’в”ҳВҒ в•ӘШ°в•Әв–‘в”ҳВ„в”ҳГў в•ӘШ°в•ӘВ»в”ҳВ„в•ӘШҜв”ҳГҜ в”ҳГ в”ҳВҶ в•ӘШІв”ҳГ©в•ӘВ»в”ҳГЁв”ҳГ  в”ҳГ в•Әв•Јв”ҳВ„в”ҳГӘв”ҳГ в•ӘШҜв•ӘШІ в•ӘВ«в•ӘШҜв•Әв•–в•ӘШ®в•ӘШұ. в”ҳГўв”ҳВҶ в•ӘВ»в•ӘШҜв•ӘШ®в”ҳГ в•ӘШҜв”ҳГҜ в•ӘВ»в•ӘШҜв•Әв•Јв”ҳГ в•ӘШҜв”ҳГҜ в”ҳГӘв”ҳГ в•Әв”Өв•ӘШҙв•Әв•Јв•ӘШҜв”ҳГҜв•ӘГ® в•ӘВ«в•ӘШҜв•Әв•Ўв•ӘШұ в•ӘШӯв•Әв–‘в•ӘШҜ в”ҳГўв•ӘШҜв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в”ҳГЁв•ӘШ°в•ӘВ»в”ҳГӘ в”ҳГ в•ӘШөв•ӘШ°в•Әв•–в•ӘШҜв”ҳГҜ в•ӘШ«в”ҳГӘ в”ҳГ в•ӘШІв•Әв•Јв•ӘШ°в•ӘШҜв”ҳГҜ.`\r\n      };\r\n\r\n      let aiMessage = \"\";\r\n\r\n      if (selectedProvider === AI_PROVIDERS.OPENAI) {\r\n        // в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в•ӘШҜв”ҳГ  OpenAI API\r\n        const response = await fetch(selectedProvider.baseUrl, {\r\n          method: \"POST\",\r\n          headers: {\r\n            \"Content-Type\": \"application/json\",\r\n            \"Authorization\": `Bearer ${selectedProvider.apiKey}`\r\n          },\r\n          body: JSON.stringify({\r\n            model: selectedProvider.model,\r\n            messages: [systemMessage, ...messages],\r\n            temperature: 0.7,\r\n            max_tokens: 1000\r\n          })\r\n        });\r\n\r\n        if (!response.ok) {\r\n          const errorData = await response.json();\r\n          logger.error(\"Error from OpenAI:\", errorData);\r\n          const errorResponse = NextResponse.json({\r\n            message: \"в•Әв•Јв•Әв–‘в•Әв–’в•ӘШҜв”ҳГҜв•ӘГ® в”ҳГЁв”ҳГӘв•ӘШҜв•ӘШҙв”ҳГ§ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘВ» в•ӘШҜв”ҳВ„в•Әв–‘в”ҳГўв”ҳГЁ в•ӘШ°в•Әв•Јв•Әв•ў в•ӘШҜв”ҳВ„в•Әв•Ўв•Әв•Јв”ҳГӘв•ӘШ°в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШІв”ҳГ©в”ҳВҶв”ҳГЁв•ӘШұ в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШҜв”ҳГҜ. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ« в”ҳВ„в•ӘШҜв•ӘШөв”ҳГ©в•ӘШҜв”ҳГҜ в•ӘШ«в”ҳГӘ в•ӘШҜв”ҳВ„в•ӘШІв”ҳГӘв•ӘШҜв•Әв•Ўв”ҳВ„ в”ҳГ в•Әв•Ј в”ҳВҒв•Әв–’в”ҳГЁв”ҳГ© в•ӘШҜв”ҳВ„в•ӘВ»в•Әв•Јв”ҳГ .\",\r\n            code: 'AI_SERVICE_ERROR'\r\n          }, { status: 500 });\r\n          return addSecurityHeaders(errorResponse);\r\n        }\r\n\r\n        const data = await response.json();\r\n        aiMessage = data.choices[0].message.content;\r\n      } else {\r\n        // в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в•ӘШҜв”ҳГ  Google Gemini API\r\n        const geminiMessages = [\r\n          systemMessage,\r\n          ...messages\r\n        ].map(msg => ({\r\n          role: msg.role === \"user\" ? \"user\" : \"model\",\r\n          parts: [{ text: msg.content }]\r\n        }));\r\n\r\n        const response = await fetch(`${selectedProvider.baseUrl}${selectedProvider.model}:generateContent?key=${selectedProvider.apiKey}`, {\r\n          method: \"POST\",\r\n          headers: {\r\n            \"Content-Type\": \"application/json\",\r\n          },\r\n          body: JSON.stringify({\r\n            contents: geminiMessages,\r\n            generationConfig: {\r\n              temperature: 0.7,\r\n              topK: 40,\r\n              topP: 0.95,\r\n              maxOutputTokens: 1000,\r\n            },\r\n          })\r\n        });\r\n\r\n        if (!response.ok) {\r\n          const errorData = await response.json();\r\n          logger.error(\"Error from Gemini:\", errorData);\r\n          const errorResponse = NextResponse.json({\r\n            message: \"в•Әв•Јв•Әв–‘в•Әв–’в•ӘШҜв”ҳГҜв•ӘГ® в”ҳГЁв”ҳГӘв•ӘШҜв•ӘШҙв”ҳГ§ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘВ» в•ӘШҜв”ҳВ„в•Әв–‘в”ҳГўв”ҳГЁ в•ӘШ°в•Әв•Јв•Әв•ў в•ӘШҜв”ҳВ„в•Әв•Ўв•Әв•Јв”ҳГӘв•ӘШ°в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШІв”ҳГ©в”ҳВҶв”ҳГЁв•ӘШұ в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШҜв”ҳГҜ. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ« в”ҳВ„в•ӘШҜв•ӘШөв”ҳГ©в•ӘШҜв”ҳГҜ в•ӘШ«в”ҳГӘ в•ӘШҜв”ҳВ„в•ӘШІв”ҳГӘв•ӘШҜв•Әв•Ўв”ҳВ„ в”ҳГ в•Әв•Ј в”ҳВҒв•Әв–’в”ҳГЁв”ҳГ© в•ӘШҜв”ҳВ„в•ӘВ»в•Әв•Јв”ҳГ .\",\r\n            code: 'AI_SERVICE_ERROR'\r\n          }, { status: 500 });\r\n          return addSecurityHeaders(errorResponse);\r\n        }\r\n\r\n        const data = await response.json();\r\n        aiMessage = data.candidates[0].content.parts[0].text;\r\n      }\r\n\r\n      // Save assistant message if userId exists\r\n      if (actualUserId) {\r\n        await prisma.aiChatMessage.create({\r\n          data: {\r\n            userId: actualUserId,\r\n            role: 'assistant',\r\n            content: aiMessage,\r\n            metadata: JSON.stringify({\r\n              provider: selectedProvider.name,\r\n              sentiment: sentiment?.sentiment || null\r\n            })\r\n          }\r\n        });\r\n      }\r\n\r\n      return createSuccessResponse({\r\n        message: aiMessage,\r\n        sentiment: sentiment ? {\r\n          sentiment: sentiment.sentiment,\r\n          score: sentiment.score,\r\n          suggestions: sentiment.suggestions\r\n        } : null\r\n      });\r\n    } catch (error) {\r\n      logger.error(\"Error in AI chat API:\", error);\r\n      return createStandardErrorResponse(\r\n        error,\r\n        \"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в”ҳВҒв”ҳГЁ в”ҳГ в•Әв•Јв•ӘШҜв”ҳВ„в•ӘШҙв•ӘШұ в•Әв•–в”ҳВ„в•ӘШ°в”ҳГў\"\r\n      );\r\n    }\r\n  });\r\n}","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\api\\ai\\content\\route.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\api\\ai\\exam\\route.ts","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'getDefaultProvider' is defined but never used. Allowed unused vars must match /^_/u.","line":4,"column":24,"nodeType":null,"messageId":"unusedVar","endLine":4,"endColumn":42}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"ЩҠв•—в”җimport { NextRequest, NextResponse } from \"next/server\";\r\nimport { randomUUID } from \"crypto\";\r\nimport { prisma } from '@/lib/db';\r\nimport { AI_PROVIDERS, getDefaultProvider, validateApiKey } from \"@/lib/ai-config\";\r\nimport { opsWrapper } from \"@/lib/middleware/ops-middleware\";\r\n\r\nimport { logger } from '@/lib/logger';\r\n\r\nexport async function POST(request: NextRequest) {\r\n  return opsWrapper(request, async (req) => {\r\n    try {\r\n      const { subject, year, lesson, difficulty, questionCount, provider } = await req.json();\r\n\r\n      if (!subject || !year || !lesson) {\r\n        return NextResponse.json(\r\n          { error: \"в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬в–’в•Әв•–в”¬Шҙв•Әв•–в”¬ШҜв•Әв•–в•ӘГ® в•Әв•–в”Ңв•ӣв•Әв••в•ҰВҶв•Әв••в”ҳв•ӣв•Әв••в”ҳв•Јв•Әв•–в”¬в–’ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬ШҜв•Әв•–в”¬В»в•Әв•–в”¬Шұ в•Әв••в•ҰВҶв•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬в”Ӯв•Әв••ШёВҖШЁв•Әв•–в”¬Шұ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬В»в•Әв•–в”¬в–’в•Әв•–в”¬ШҜв•Әв•–в”¬в”Ӯв•Әв••в”ҳв•Јв•Әв•–в”¬Шұ в•Әв••в•ҰВҶв•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬В»в•Әв•–в”¬в–’в•Әв•–в”¬в”Ӯ\" },\r\n          { status: 400 }\r\n        );\r\n      }\r\n\r\n      // в•Әв•–в”Ңв•ӣв•Әв•–в”¬Шөв•Әв•–в”¬В»в•Әв••в”ҳв•Јв•Әв•–в”¬В» в•Әв•–в”¬в•Јв•Әв•–в”¬В»в•Әв•–в”¬В» в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Ш«в•Әв•–в”¬в”Ӯв•Әв•–в”¬Ш®в•Әв••ШёВҖШҰв•Әв•–в”¬Шұ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬ШҜв•Әв••в”ҳв•ӣв•Әв•–в”Ңв•ӣв•Әв•–в”¬в–’в•Әв•–в”¬ШҜв•Әв•–в”¬в•ўв•Әв••в”ҳв•Ј в•Әв•–в”¬Шӯв•Әв•–в”¬в–‘в•Әв•–в”¬ШҜ в•Әв••ШёВҖШҰв•Әв••ШёВҖШ® в•Әв••в”ҳв•Јв•Әв•–в”Ңв•ӣв•Әв••ШёВҖШ® в•Әв•–в”Ңв•ӣв•Әв•–в”¬Шөв•Әв•–в”¬В»в•Әв••в”ҳв•Јв•Әв•–в”¬В»в•Әв••ШёВҖШ©\r\n      const numQuestions = questionCount || 10;\r\n\r\n      // в•Әв•–в”Ңв•ӣв•Әв•–в”¬Шөв•Әв•–в”¬В»в•Әв••в”ҳв•Јв•Әв•–в”¬В» в•Әв••ШёВҖШ®в•Әв••ШёВҖШЈв•Әв•–в”¬В»в•Әв••ШёВҖШ® в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬В«в•Әв•–в”¬В»в•Әв••ШёВҖШ®в•Әв•–в”¬Шұ\r\n      const selectedProvider = provider === 'openai' ? AI_PROVIDERS.OPENAI : AI_PROVIDERS.GEMINI;\r\n\r\n      if (!validateApiKey(selectedProvider === AI_PROVIDERS.OPENAI ? 'OPENAI' : 'GEMINI')) {\r\n        return NextResponse.json(\r\n          { error: `в•Әв••ШёВҖШ®в•Әв••в”ҳв•ӣв•Әв•–в”Ңв•ӣв•Әв•–в”¬ШҜв•Әв•–в”¬Шө API в•Әв••ШёВҖШҰв•Әв••ШёГ©Шҙ ${selectedProvider.name} в•Әв•–в•ӘШӨв•Әв••в”ҳв•Јв•Әв•–в”¬в–’ в•Әв••ШёВҖШ®в•Әв••ШёВҖШ©в•Әв••в”ҳв•Јв•Әв•–в”¬Ш«` },\r\n          { status: 500 }\r\n        );\r\n      }\r\n\r\n      // в•Әв•–в”¬Шӯв•Әв••ШёВҖШЁв•Әв•–в”¬в”Өв•Әв•–в”¬ШҜв•Әв•–в•ӘГ® в•Әв•–в”¬в–’в•Әв•–в”¬в”Ӯв•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Шұ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШЁв•Әв•–в”¬в••в•Әв•–в”¬ШҜв•Әв••ШёВҖШ® в•Әв••ШёВҖШҰв•Әв•–в”Ңв•ӣв•Әв••в•ҰВҶв•Әв•–в”¬Шҙв•Әв••в”ҳв•Јв•Әв••ШёВҖШ© в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬в–‘в•Әв••в•һЩ’в•Әв•–в”¬ШҜв•Әв•–в•ӘГ® в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬ШҜв•Әв•–в”¬в•Ўв•Әв•–в”¬в•–в•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв•–в”¬в•Јв•Әв••в”ҳв•Ј в•Әв••ШёВҖШҰв•Әв•–в”¬Шӯв•Әв••ШёВҖШЁв•Әв•–в”¬в”Өв•Әв•–в”¬ШҜв•Әв•–в•ӘГ® в•Әв•–в”¬ШҜв•Әв••ШёВҖШ®в•Әв•–в”Ңв•ӣв•Әв•–в”¬Шөв•Әв•–в”¬ШҜв•Әв••ШёВҖШЁ\r\n      const systemPrompt = `в•Әв•–в”¬Ш«в•Әв••ШёВҖШЁв•Әв•–в”Ңв•ӣ в•Әв••ШёВҖШ®в•Әв•–в”¬в”Ӯв•Әв•–в”¬ШҜв•Әв•–в”¬в•Јв•Әв•–в”¬В» в•Әв•–в”¬в–‘в•Әв••в•һЩ’в•Әв•–в”¬ШҜв•Әв•–в•ӘГ® в•Әв•–в”¬ШҜв•Әв•–в”¬в•Ўв•Әв•–в”¬в•–в•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв•–в”¬в•Јв•Әв••в”ҳв•Ј в•Әв••ШёВҖШ®в•Әв•–в”Ңв•ӣв•Әв•–в”¬В«в•Әв•–в”¬в•Ўв•Әв•–в”¬в•Ў в•Әв••в”ҳв•ӣв•Әв••в”ҳв•Ј в•Әв•–в”¬Шӯв•Әв••ШёВҖШЁв•Әв•–в”¬в”Өв•Әв•–в”¬ШҜв•Әв•–в•ӘГ® в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬ШҜв•Әв••ШёВҖШ®в•Әв•–в”Ңв•ӣв•Әв•–в”¬Шөв•Әв•–в”¬ШҜв•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”Ңв•ӣв•Әв•–в”¬в•Јв•Әв••ШёВҖШҰв•Әв••в”ҳв•Јв•Әв••ШёВҖШ®в•Әв••в”ҳв•Јв•Әв•–в”¬Шұ в•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв••ШёВҖШЁв•Әв•–в”¬в•Ўв•Әв•–в”¬Шұ в•Әв•–в”¬Шів•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв••в•ҰВҶв•Әв••в”ҳв•Ј. \r\n    в•Әв••ШёВҖШ®в•Әв••ШёВҖШ©в•Әв••ШёВҖШ®в•Әв•–в”Ңв•ӣв•Әв••в•һЩ’ в•Әв••ШёВҖШ©в•Әв••в”ҳв•Ј в•Әв•–в”¬Шӯв•Әв••ШёВҖШЁв•Әв•–в”¬в”Өв•Әв•–в”¬ШҜв•Әв•–в•ӘГ® в•Әв•–в”¬ШҜв•Әв••ШёВҖШ®в•Әв•–в”Ңв•ӣв•Әв•–в”¬Шөв•Әв•–в”¬ШҜв•Әв••ШёВҖШЁ в•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬ШҜв•Әв•–в”¬В»в•Әв•–в”¬Шұ ${subject} в•Әв••ШёВҖШҰв•Әв••ШёВҖШҰв•Әв•–в”¬в”Ӯв•Әв••ШёВҖШЁв•Әв•–в”¬Шұ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬В»в•Әв•–в”¬в–’в•Әв•–в”¬ШҜв•Әв•–в”¬в”Ӯв•Әв••в”ҳв•Јв•Әв•–в”¬Шұ ${year}в•Әв•–в”јЩ’ focusing в•Әв•–в”¬в•Јв•Әв••ШёВҖШҰв•Әв••ШёВҖв–‘ в•Әв•–в”¬В»в•Әв•–в”¬в–’в•Әв•–в”¬в”Ӯ ${lesson}.\r\n    ${difficulty ? `в•Әв••ШёВҖШ®в•Әв•–в”¬в”Ӯв•Әв•–в”Ңв•ӣв•Әв••в•ҰВҶв•Әв••ШёВҖв–‘ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬в•Ўв•Әв•–в”¬в•Јв•Әв••в•ҰВҶв•Әв•–в”¬Ш°в•Әв•–в”¬Шұ: ${difficulty}` : ''}\r\n    в•Әв••ШёВҖШЈв•Әв••ШёВҖШ® в•Әв•–в”¬Ш°в•Әв•–в”¬Шӯв•Әв••ШёВҖШЁв•Әв•–в”¬в”Өв•Әв•–в”¬ШҜв•Әв•–в•ӘГ® ${numQuestions} в•Әв•–в”¬Ш«в•Әв•–в”¬в”Ӯв•Әв•–в”¬Ш®в•Әв••ШёВҖШҰв•Әв•–в”¬Шұ в•Әв••ШёВҖШ®в•Әв•–в”Ңв•ӣв•Әв••ШёВҖШЁв•Әв••в•ҰВҶв•Әв•–в”¬в•Јв•Әв•–в”¬Шұ (в•Әв•–в”¬ШҜв•Әв•–в”¬В«в•Әв•–в”Ңв•ӣв•Әв••в”ҳв•Јв•Әв•–в”¬ШҜв•Әв•–в”¬в–’ в•Әв••ШёВҖШ®в•Әв••ШёВҖШЁ в•Әв••ШёВҖШ®в•Әв•–в”Ңв•ӣв•Әв•–в”¬в•Јв•Әв•–в”¬В»в•Әв•–в”¬В»в•Әв•–в”јЩ’ в•Әв•–в”¬в•Ўв•Әв•–в”¬Шө в•Әв•–в”¬Ш«в•Әв••в•ҰВҶ в•Әв•–в”¬В«в•Әв•–в”¬в•–в•Әв•–в”¬Ш«в•Әв•–в”јЩ’ в•Әв•–в”¬Шӯв•Әв•–в”¬Шҙв•Әв•–в”¬ШҜв•Әв•–в”¬Ш°в•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ в•Әв••ШёВҖШЈв•Әв•–в”¬в•Ўв•Әв••в”ҳв•Јв•Әв•–в”¬в–’в•Әв•–в”¬Шұ).\r\n    в•Әв••ШёВҖШҰв•Әв••в•һЩ’в•Әв••ШёВҖШҰ в•Әв•–в”¬в”Ӯв•Әв•–в”¬Ш¬в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”јЩ’ в•Әв••ШёВҖШЈв•Әв••ШёВҖШ® в•Әв•–в”¬Ш°в•Әв•–в”Ңв•ӣв•Әв••в•ҰВҶв•Әв••в”ҳв•ӣв•Әв••в”ҳв•Јв•Әв•–в”¬в–’:\r\n    1. в•Әв••ШёВҖШЁв•Әв•–в”¬в•Ў в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬в”Ӯв•Әв•–в”¬Ш¬в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰ\r\n    2. в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬В«в•Әв••в”ҳв•Јв•Әв•–в”¬ШҜв•Әв•–в”¬в–’в•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ (в•Әв••ШёВҖШҰв•Әв•–в”¬Ш«в•Әв•–в”¬в”Ӯв•Әв•–в”¬Ш®в•Әв••ШёВҖШҰв•Әв•–в”¬Шұ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬ШҜв•Әв•–в”¬В«в•Әв•–в”Ңв•ӣв•Әв••в”ҳв•Јв•Әв•–в”¬ШҜв•Әв•–в”¬в–’ в•Әв••ШёВҖШ®в•Әв••ШёВҖШЁ в•Әв••ШёВҖШ®в•Әв•–в”Ңв•ӣв•Әв•–в”¬в•Јв•Әв•–в”¬В»в•Әв•–в”¬В»)\r\n    3. в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Шӯв•Әв•–в”¬Шҙв•Әв•–в”¬ШҜв•Әв•–в”¬Ш°в•Әв•–в”¬Шұ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬в•Ўв•Әв•–в”¬Шөв•Әв••в”ҳв•Јв•Әв•–в”¬Шөв•Әв•–в”¬Шұ\r\n    4. в•Әв•–в”¬в”Өв•Әв•–в”¬в–’в•Әв•–в”¬Шө в•Әв••ШёВҖШ®в•Әв••в•ҰВҶв•Әв•–в”¬Шҙв•Әв•–в”¬в–“ в•Әв••ШёВҖШҰв•Әв••ШёВҖШҰв•Әв•–в”¬Шӯв•Әв•–в”¬Шҙв•Әв•–в”¬ШҜв•Әв•–в”¬Ш°в•Әв•–в”¬Шұ\r\n\r\n    в•Әв••в”ҳв•Јв•Әв•–в”¬Шҙв•Әв•–в”¬Ш° в•Әв•–в”¬Ш«в•Әв••ШёВҖШЁ в•Әв•–в”Ңв•ӣв•Әв••в•һЩ’в•Әв••в•ҰВҶв•Әв••ШёВҖШЁ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Ш«в•Әв•–в”¬в”Ӯв•Әв•–в”¬Ш®в•Әв••ШёВҖШҰв•Әв•–в”¬Шұ в•Әв••ШёВҖШ®в•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв•–в”¬в”Ӯв•Әв•–в”¬Ш°в•Әв•–в”¬Шұ в•Әв••ШёВҖШҰв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬в”Ӯв•Әв•–в”Ңв•ӣв•Әв••в•ҰВҶв•Әв••ШёВҖв–‘ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬В»в•Әв•–в”¬в–’в•Әв•–в”¬ШҜв•Әв•–в”¬в”Ӯв•Әв••в”ҳв•Ј в•Әв••в•ҰВҶв•Әв•–в”Ңв•ӣв•Әв•–в•ӘШӨв•Әв•–в”¬в•–в•Әв••в”ҳв•Ј в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв••в”ҳв•ӣв•Әв•–в”¬ШҜв•Әв••ШёВҖШ©в•Әв••в”ҳв•Јв•Әв••ШёВҖШ® в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬в–’в•Әв•–в”¬Ш®в•Әв••в”ҳв•Јв•Әв•–в”¬в”Ӯв•Әв••в”ҳв•Јв•Әв•–в”¬Шұ в•Әв••ШёВҖШҰв•Әв••ШёВҖШҰв•Әв•–в”¬В»в•Әв•–в”¬в–’в•Әв•–в”¬в”Ӯ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬Шөв•Әв•–в”¬В»в•Әв•–в”¬В».\r\n    в•Әв••ШёВҖШЈв•Әв••ШёВҖШ® в•Әв•–в”¬Ш°в•Әв•–в”Ңв•ӣв•Әв••ШёВҖШЁв•Әв•–в”¬в”Ӯв•Әв••в”ҳв•Јв•Әв••ШёВҖШЈ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Шӯв•Әв•–в”¬Шҙв•Әв•–в”¬ШҜв•Әв•–в”¬Ш°в•Әв•–в”¬Шұ в•Әв••в•һЩ’в•Әв••ШёГ©Шҙ JSON в•Әв••ШёВҖШ®в•Әв•–в”¬в•Ј в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬в•Ўв•Әв••в”ҳв•ӣв•Әв••в•ҰВҶв•Әв••в”ҳв•ӣв•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”Ңв•ӣв•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••в”ҳв•Јв•Әв•–в”¬Шұ:\r\n    {\r\n      \"questions\": [\r\n        {\r\n          \"question\": \"в•Әв••ШёВҖШЁв•Әв•–в”¬в•Ў в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬в”Ӯв•Әв•–в”¬Ш¬в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰ\",\r\n          \"type\": \"multiple_choice|true_false|short_answer\",\r\n          \"options\": [\"в•Әв•–в”¬В«в•Әв••в”ҳв•Јв•Әв•–в”¬ШҜв•Әв•–в”¬в–’ 1\", \"в•Әв•–в”¬В«в•Әв••в”ҳв•Јв•Әв•–в”¬ШҜв•Әв•–в”¬в–’ 2\", \"в•Әв•–в”¬В«в•Әв••в”ҳв•Јв•Әв•–в”¬ШҜв•Әв•–в”¬в–’ 3\", \"в•Әв•–в”¬В«в•Әв••в”ҳв•Јв•Әв•–в”¬ШҜв•Әв•–в”¬в–’ 4\"],\r\n          \"correctAnswer\": \"в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Шӯв•Әв•–в”¬Шҙв•Әв•–в”¬ШҜв•Әв•–в”¬Ш°в•Әв•–в”¬Шұ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬в•Ўв•Әв•–в”¬Шөв•Әв••в”ҳв•Јв•Әв•–в”¬Шөв•Әв•–в”¬Шұ\",\r\n          \"explanation\": \"в•Әв•–в”¬в”Өв•Әв•–в”¬в–’в•Әв•–в”¬Шө в•Әв••ШёВҖШ®в•Әв••в•ҰВҶв•Әв•–в”¬Шҙв•Әв•–в”¬в–“ в•Әв••ШёВҖШҰв•Әв••ШёВҖШҰв•Әв•–в”¬Шӯв•Әв•–в”¬Шҙв•Әв•–в”¬ШҜв•Әв•–в”¬Ш°в•Әв•–в”¬Шұ\"\r\n        }\r\n      ]\r\n    }`;\r\n\r\n      let examContent = \"\";\r\n\r\n      if (selectedProvider === AI_PROVIDERS.OPENAI) {\r\n        // в•Әв•–в”¬ШҜв•Әв•–в”¬в”Ӯв•Әв•–в”Ңв•ӣв•Әв•–в”¬В«в•Әв•–в”¬В»в•Әв•–в”¬ШҜв•Әв••ШёВҖШ® OpenAI API\r\n        const response = await fetch(selectedProvider.baseUrl, {\r\n          method: \"POST\",\r\n          headers: {\r\n            \"Content-Type\": \"application/json\",\r\n            \"Authorization\": `Bearer ${selectedProvider.apiKey}`\r\n          },\r\n          body: JSON.stringify({\r\n            model: selectedProvider.model,\r\n            messages: [{ role: \"system\", content: systemPrompt }],\r\n            temperature: 0.7,\r\n            max_tokens: 4000\r\n          })\r\n        });\r\n\r\n        if (!response.ok) {\r\n          const errorData = await response.json();\r\n          logger.error(\"Error from OpenAI:\", errorData);\r\n          return NextResponse.json({\r\n            error: \"в•Әв•–в”¬в•Јв•Әв•–в”¬в–‘в•Әв•–в”¬в–’в•Әв•–в”¬ШҜв•Әв••ШёВҖв•Јв•Әв•–в”јЩ’ в•Әв••в”ҳв•Јв•Әв••в•ҰВҶв•Әв•–в”¬ШҜв•Әв•–в”¬Шҙв•Әв••ШёВҖШ© в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШЁв•Әв•–в”¬в••в•Әв•–в”¬ШҜв•Әв••ШёВҖШ® в•Әв•–в”¬Ш°в•Әв•–в”¬в•Јв•Әв•–в”¬в•ў в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬в•Ўв•Әв•–в”¬в•Јв•Әв••в•ҰВҶв•Әв•–в”¬Ш°в•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”Ңв•ӣв•Әв••ШёВҖШЈв•Әв••ШёВҖШЁв•Әв••в”ҳв•Јв•Әв•–в”¬Шұ в•Әв••в”ҳв•ӣв•Әв••в”ҳв•Ј в•Әв•–в”¬Шӯв•Әв••ШёВҖШЁв•Әв•–в”¬в”Өв•Әв•–в”¬ШҜв•Әв•–в•ӘГ® в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬ШҜв•Әв••ШёВҖШ®в•Әв•–в”Ңв•ӣв•Әв•–в”¬Шөв•Әв•–в”¬ШҜв•Әв••ШёВҖШЁ в•Әв•–в”¬Шөв•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••в”ҳв•Јв•Әв•–в”¬ШҜв•Әв••ШёВҖв•Ј. в•Әв••в”ҳв•Јв•Әв•–в”¬в–’в•Әв•–в”¬Шҙв•Әв••ШёВҖв–‘ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬Шөв•Әв•–в”¬ШҜв•Әв••в•ҰВҶв•Әв••ШёВҖШҰв•Әв•–в”¬Шұ в•Әв••ШёВҖШ®в•Әв•–в”¬в–’в•Әв•–в”¬Шұ в•Әв•–в”¬Ш«в•Әв•–в”¬В«в•Әв•–в”¬в–’в•Әв••ШёВҖв–‘ в•Әв••ШёВҖШҰв•Әв•–в”¬ШҜв•Әв•–в”¬Шөв•Әв••ШёВҖШЈв•Әв•–в”¬ШҜв•Әв••ШёВҖв•Ј.\"\r\n          }, { status: 500 });\r\n        }\r\n\r\n        const data = await response.json();\r\n        examContent = data.choices[0].message.content;\r\n      } else {\r\n        // в•Әв•–в”¬ШҜв•Әв•–в”¬в”Ӯв•Әв•–в”Ңв•ӣв•Әв•–в”¬В«в•Әв•–в”¬В»в•Әв•–в”¬ШҜв•Әв••ШёВҖШ® Google Gemini API\r\n        const response = await fetch(`${selectedProvider.baseUrl}${selectedProvider.model}:generateContent?key=${selectedProvider.apiKey}`, {\r\n          method: \"POST\",\r\n          headers: {\r\n            \"Content-Type\": \"application/json\",\r\n          },\r\n          body: JSON.stringify({\r\n            contents: [{\r\n              role: \"user\",\r\n              parts: [{ text: systemPrompt }]\r\n            }],\r\n            generationConfig: {\r\n              temperature: 0.7,\r\n              topK: 40,\r\n              topP: 0.95,\r\n              maxOutputTokens: 4000,\r\n            },\r\n          })\r\n        });\r\n\r\n        if (!response.ok) {\r\n          const errorData = await response.json();\r\n          logger.error(\"Error from Gemini:\", errorData);\r\n          return NextResponse.json({\r\n            error: \"в•Әв•–в”¬в•Јв•Әв•–в”¬в–‘в•Әв•–в”¬в–’в•Әв•–в”¬ШҜв•Әв••ШёВҖв•Јв•Әв•–в”јЩ’ в•Әв••в”ҳв•Јв•Әв••в•ҰВҶв•Әв•–в”¬ШҜв•Әв•–в”¬Шҙв•Әв••ШёВҖШ© в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШЁв•Әв•–в”¬в••в•Әв•–в”¬ШҜв•Әв••ШёВҖШ® в•Әв•–в”¬Ш°в•Әв•–в”¬в•Јв•Әв•–в”¬в•ў в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬в•Ўв•Әв•–в”¬в•Јв•Әв••в•ҰВҶв•Әв•–в”¬Ш°в•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”Ңв•ӣв•Әв••ШёВҖШЈв•Әв••ШёВҖШЁв•Әв••в”ҳв•Јв•Әв•–в”¬Шұ в•Әв••в”ҳв•ӣв•Әв••в”ҳв•Ј в•Әв•–в”¬Шӯв•Әв••ШёВҖШЁв•Әв•–в”¬в”Өв•Әв•–в”¬ШҜв•Әв•–в•ӘГ® в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬ШҜв•Әв••ШёВҖШ®в•Әв•–в”Ңв•ӣв•Әв•–в”¬Шөв•Әв•–в”¬ШҜв•Әв••ШёВҖШЁ в•Әв•–в”¬Шөв•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••в”ҳв•Јв•Әв•–в”¬ШҜв•Әв••ШёВҖв•Ј. в•Әв••в”ҳв•Јв•Әв•–в”¬в–’в•Әв•–в”¬Шҙв•Әв••ШёВҖв–‘ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬Шөв•Әв•–в”¬ШҜв•Әв••в•ҰВҶв•Әв••ШёВҖШҰв•Әв•–в”¬Шұ в•Әв••ШёВҖШ®в•Әв•–в”¬в–’в•Әв•–в”¬Шұ в•Әв•–в”¬Ш«в•Әв•–в”¬В«в•Әв•–в”¬в–’в•Әв••ШёВҖв–‘ в•Әв••ШёВҖШҰв•Әв•–в”¬ШҜв•Әв•–в”¬Шөв•Әв••ШёВҖШЈв•Әв•–в”¬ШҜв•Әв••ШёВҖв•Ј.\"\r\n          }, { status: 500 });\r\n        }\r\n\r\n        const data = await response.json();\r\n        examContent = data.candidates[0].content.parts[0].text;\r\n      }\r\n\r\n      // в•Әв••ШёВҖШ®в•Әв•–в”¬Шөв•Әв•–в”¬ШҜв•Әв••в•ҰВҶв•Әв••ШёВҖШҰв•Әв•–в”¬Шұ в•Әв•–в”Ңв•ӣв•Әв•–в”¬Шөв•Әв••ШёВҖШҰв•Әв••в”ҳв•Јв•Әв••ШёВҖШҰ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬Шөв•Әв•–в”Ңв•ӣв•Әв••в•ҰВҶв•Әв••ШёВҖв–‘ в•Әв••в•һЩ’в•Әв••ШёГ©Шҙ JSON\r\n      try {\r\n        const examData = JSON.parse(examContent);\r\n\r\n        // в•Әв•–в”¬Шөв•Әв••в”ҳв•ӣв•Әв•–в”¬в•• в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬ШҜв•Әв••ШёВҖШ®в•Әв•–в”Ңв•ӣв•Әв•–в”¬Шөв•Әв•–в”¬ШҜв•Әв••ШёВҖШЁ в•Әв••в”ҳв•ӣв•Әв••в”ҳв•Ј в•Әв••ШёВҖШЈв•Әв•–в”¬ШҜв•Әв•–в”¬в•Јв•Әв•–в”¬В»в•Әв•–в”¬Шұ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Ш°в•Әв••в”ҳв•Јв•Әв•–в”¬ШҜв•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ\r\n        const exam = await prisma.exam.create({\r\n          data: {\r\n            id: randomUUID(),\r\n            subjectId: subject, // subject here is likely the ID from the req.json()\r\n            title: `в•Әв•–в”¬ШҜв•Әв••ШёВҖШ®в•Әв•–в”Ңв•ӣв•Әв•–в”¬Шөв•Әв•–в”¬ШҜв•Әв••ШёВҖШЁ ${subject} - ${year} - ${lesson}`,\r\n            year: parseInt(year),\r\n            url: \"\", // в•Әв•–в”¬в”Ӯв•Әв••в”ҳв•Јв•Әв•–в”Ңв•ӣв•Әв••ШёВҖШ® в•Әв•–в”Ңв•ӣв•Әв•–в”¬Шөв•Әв•–в”¬В»в•Әв••в”ҳв•Јв•Әв•–в”¬Шів•Әв••ШёВҖШ© в•Әв••ШёВҖШҰв•Әв•–в”¬ШҜв•Әв•–в”¬Шөв•Әв••ШёВҖШЈв•Әв•–в”¬ШҜв•Әв••ШёВҖв•Ј в•Әв•–в”¬в•Јв•Әв••ШёВҖШЁв•Әв•–в”¬В» в•Әв•–в”¬Шӯв•Әв••ШёВҖШЁв•Әв•–в”¬в”Өв•Әв•–в”¬ШҜв•Әв•–в•ӘГ® в•Әв••в•ҰВҶв•Әв•–в”¬ШҜв•Әв•–в”¬Шҙв•Әв••ШёВҖШ©в•Әв•–в”¬Шұ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬ШҜв•Әв••ШёВҖШ®в•Әв•–в”Ңв•ӣв•Әв•–в”¬Шөв•Әв•–в”¬ШҜв•Әв••ШёВҖШЁ\r\n          }\r\n        });\r\n\r\n        return NextResponse.json({\r\n          examId: exam.id,\r\n          questions: examData.questions,\r\n          provider: selectedProvider.name\r\n        });\r\n      } catch (parseError) {\r\n        logger.error(\"Error parsing exam JSON:\", parseError);\r\n\r\n        // в•Әв•–в”¬Шӯв•Әв•–в”¬в–‘в•Әв•–в”¬ШҜ в•Әв••в”ҳв•ӣв•Әв•–в”¬в”Өв•Әв••ШёВҖШҰ в•Әв•–в”Ңв•ӣв•Әв•–в”¬Шөв•Әв••ШёВҖШҰв•Әв••в”ҳв•Јв•Әв••ШёВҖШҰ JSONв•Әв•–в”јЩ’ в•Әв••ШёВҖШЈв•Әв••ШёВҖШ® в•Әв•–в”¬Ш°в•Әв•–в”¬Шӯв•Әв•–в”¬в–’в•Әв•–в”¬Шҙв•Әв•–в”¬ШҜв•Әв•–в”¬в•Ј в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬Шөв•Әв•–в”Ңв•ӣв•Әв••в•ҰВҶв•Әв••ШёВҖв–‘ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬В«в•Әв•–в”¬ШҜв•Әв••ШёВҖШ®\r\n        return NextResponse.json({\r\n          examContent,\r\n          provider: selectedProvider.name\r\n        });\r\n      }\r\n    } catch (error) {\r\n      logger.error(\"Error in AI exam generation API:\", error);\r\n      return NextResponse.json(\r\n        { error: \"в•Әв•–в”¬Шөв•Әв•–в”¬В»в•Әв•–в”¬Ші в•Әв•–в”¬В«в•Әв•–в”¬в•–в•Әв•–в”¬Ш« в•Әв••в”ҳв•ӣв•Әв••в”ҳв•Ј в•Әв••ШёВҖШ®в•Әв•–в”¬в•Јв•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Шҙв•Әв•–в”¬Шұ в•Әв•–в”¬в•–в•Әв••ШёВҖШҰв•Әв•–в”¬Ш°в•Әв••в•һЩ’\" },\r\n        { status: 500 }\r\n      );\r\n    }\r\n  });\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\api\\ai\\recommendations\\route.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\api\\ai\\recommendations\\track\\route.ts","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'token' is assigned a value but never used. Allowed unused vars must match /^_/u.","line":19,"column":15,"nodeType":null,"messageId":"unusedVar","endLine":19,"endColumn":20}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { NextRequest, NextResponse } from \"next/server\";\r\nimport { trackInteraction } from \"@/lib/ai/ml-recommendations\";\r\nimport { logger } from '@/lib/logger';\r\n\r\n/**\r\n * POST /api/ai/recommendations/track\r\n * Track user interactions for ML learning\r\n */\r\nexport async function POST(request: NextRequest) {\r\n    try {\r\n        const authHeader = request.headers.get('authorization');\r\n        if (!authHeader?.startsWith('Bearer ')) {\r\n            return NextResponse.json(\r\n                { error: 'Missing or invalid authorization header' },\r\n                { status: 401 }\r\n            );\r\n        }\r\n\r\n        const token = authHeader.substring(7);\r\n        const user: any = { userId: 'default-user' };\r\n\r\n        if (!user || !user.userId) {\r\n            return NextResponse.json(\r\n                { error: 'Invalid or expired token' },\r\n                { status: 401 }\r\n            );\r\n        }\r\n\r\n        const body = await request.json();\r\n        const { type, itemType, itemId, metadata } = body;\r\n\r\n        // Validate required fields\r\n        if (!type || !itemType || !itemId) {\r\n            return NextResponse.json(\r\n                { error: 'Missing required fields: type, itemType, itemId' },\r\n                { status: 400 }\r\n            );\r\n        }\r\n\r\n        // Validate interaction type\r\n        const validTypes = ['view', 'click', 'complete', 'like', 'dislike', 'bookmark'];\r\n        if (!validTypes.includes(type)) {\r\n            return NextResponse.json(\r\n                { error: 'Invalid interaction type. Must be one of: ' + validTypes.join(', ') },\r\n                { status: 400 }\r\n            );\r\n        }\r\n\r\n        // Validate item type\r\n        const validItemTypes = ['resource', 'course', 'exam', 'content', 'teacher'];\r\n        if (!validItemTypes.includes(itemType)) {\r\n            return NextResponse.json(\r\n                { error: 'Invalid item type. Must be one of: ' + validItemTypes.join(', ') },\r\n                { status: 400 }\r\n            );\r\n        }\r\n\r\n        // Track the interaction\r\n        await trackInteraction(user.userId, type, itemType, itemId, metadata);\r\n\r\n        logger.debug(`Interaction tracked: ${type} on ${itemType}:${itemId} by user ${user.userId}`);\r\n\r\n        return NextResponse.json({\r\n            success: true,\r\n            message: 'Interaction tracked successfully'\r\n        });\r\n\r\n    } catch (error) {\r\n        logger.error('Error tracking interaction:', error);\r\n        return NextResponse.json(\r\n            { error: 'Failed to track interaction' },\r\n            { status: 500 }\r\n        );\r\n    }\r\n}","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\api\\ai\\sentiment\\route.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\api\\ai\\teachers\\route.ts","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'getDefaultProvider' is defined but never used. Allowed unused vars must match /^_/u.","line":3,"column":24,"nodeType":null,"messageId":"unusedVar","endLine":3,"endColumn":42}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"ЩҠв•—в”җimport { NextRequest, NextResponse } from \"next/server\";\r\nimport { prisma } from '@/lib/db';\r\nimport { AI_PROVIDERS, getDefaultProvider, validateApiKey } from \"@/lib/ai-config\";\r\nimport { opsWrapper } from \"@/lib/middleware/ops-middleware\";\r\n\r\nimport { logger } from '@/lib/logger';\r\n\r\n// в•Әв••в•ҰВҶв•Әв•–в”¬ШҜв•Әв•–в”¬Шҙв•Әв••ШёВҖШ©в•Әв•–в”¬Шұ в•Әв•–в”¬Ш°в•Әв•–в”¬в–’в•Әв••ШёВҖШ®в•Әв•–в”¬Шҙв•Әв•–в”¬Шұ в•Әв•–в”Ңв•ӣв•Әв•–в”¬в•–в•Әв•–в”¬Ш°в•Әв••в”ҳв•Јв•Әв••ШёВҖШЈв•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••в”ҳв•Јв•Әв••в•ҰВҶв•Әв•–в”Ңв•ӣв•Әв••в”ҳв•Јв•Әв•–в”¬Ш° в•Әв••ШёВҖШҰв•Әв••ШёВҖШҰв•Әв•–в”¬Ш°в•Әв•–в”¬Шөв•Әв•–в”¬Ші в•Әв•–в”¬в•Јв•Әв••ШёВҖШЁ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШЈв•Әв••ШёВҖШЁв•Әв••в•ҰВҶв•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”Ңв•ӣв•Әв•–в”¬в•Јв•Әв••ШёВҖШҰв•Әв••в”ҳв•Јв•Әв••ШёВҖШ®в•Әв••в”ҳв•Јв•Әв•–в”¬Шұ\r\nconst YOUTUBE_API_KEY = process.env.YOUTUBE_API_KEY;\r\nconst YOUTUBE_SEARCH_URL = \"https://www.googleapis.com/youtube/v3/search\";\r\n\r\nexport async function POST(request: NextRequest) {\r\n  return opsWrapper(request, async (req) => {\r\n    try {\r\n      const { subject, keywords, platform, provider } = await req.json();\r\n\r\n      if (!subject) {\r\n        return NextResponse.json(\r\n          { error: \"в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬в–’в•Әв•–в”¬Шҙв•Әв•–в”¬ШҜв•Әв•–в•ӘГ® в•Әв•–в”Ңв•ӣв•Әв••в•ҰВҶв•Әв••в”ҳв•ӣв•Әв••в”ҳв•Јв•Әв•–в”¬в–’ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬ШҜв•Әв•–в”¬В»в•Әв•–в”¬Шұ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬В»в•Әв•–в”¬в–’в•Әв•–в”¬ШҜв•Әв•–в”¬в”Ӯв•Әв••в”ҳв•Јв•Әв•–в”¬Шұ\" },\r\n          { status: 400 }\r\n        );\r\n      }\r\n\r\n      // в•Әв•–в”Ңв•ӣв•Әв•–в”¬Шөв•Әв•–в”¬В»в•Әв••в”ҳв•Јв•Әв•–в”¬В» в•Әв••ШёВҖШ®в•Әв••ШёВҖШЈв•Әв•–в”¬В»в•Әв••ШёВҖШ® в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬В«в•Әв•–в”¬В»в•Әв••ШёВҖШ®в•Әв•–в”¬Шұ\r\n      const selectedProvider = provider === 'openai' ? AI_PROVIDERS.OPENAI : AI_PROVIDERS.GEMINI;\r\n\r\n      // в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”Ңв•ӣв•Әв•–в”¬Шөв•Әв••ШёВҖШЈв•Әв••ШёВҖШЈ в•Әв••ШёВҖШ®в•Әв••ШёВҖШЁ в•Әв••ШёВҖШ®в•Әв••в”ҳв•ӣв•Әв•–в”Ңв•ӣв•Әв•–в”¬ШҜв•Әв•–в”¬Шө API\r\n      if (!validateApiKey(selectedProvider === AI_PROVIDERS.OPENAI ? 'OPENAI' : 'GEMINI')) {\r\n        logger.error(`API key for ${selectedProvider.name} is not configured`);\r\n        return NextResponse.json(\r\n          { error: `в•Әв••ШёВҖШ®в•Әв••в”ҳв•ӣв•Әв•–в”Ңв•ӣв•Әв•–в”¬ШҜв•Әв•–в”¬Шө API в•Әв••ШёВҖШҰв•Әв••ШёГ©Шҙ ${selectedProvider.name} в•Әв•–в•ӘШӨв•Әв••в”ҳв•Јв•Әв•–в”¬в–’ в•Әв••ШёВҖШ®в•Әв••ШёВҖШ©в•Әв••в”ҳв•Јв•Әв•–в”¬Ш«. в•Әв••в”ҳв•Јв•Әв•–в”¬в–’в•Әв•–в”¬Шҙв•Әв••ШёВҖв–‘ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”Ңв•ӣв•Әв••в•ҰВҶв•Әв•–в”¬ШҜв•Әв•–в”¬в•Ўв•Әв••ШёВҖШҰ в•Әв••ШёВҖШ®в•Әв•–в”¬в•Ј в•Әв••в”ҳв•ӣв•Әв•–в”¬в–’в•Әв••в”ҳв•Јв•Әв••ШёВҖШЈ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬В»в•Әв•–в”¬в•Јв•Әв••ШёВҖШ® в•Әв••ШёВҖШҰв•Әв•–в”¬Шӯв•Әв•–в”¬в•ўв•Әв•–в”¬ШҜв•Әв••в”ҳв•ӣв•Әв•–в”¬Шұ в•Әв••ШёВҖШ®в•Әв••в”ҳв•ӣв•Әв•–в”Ңв•ӣв•Әв•–в”¬ШҜв•Әв•–в”¬Шө API в•Әв•–в”¬в•Ўв•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Шө.` },\r\n          { status: 500 }\r\n        );\r\n      }\r\n\r\n      // в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”Ңв•ӣв•Әв•–в”¬Шөв•Әв••ШёВҖШЈв•Әв••ШёВҖШЈ в•Әв••ШёВҖШ®в•Әв••ШёВҖШЁ в•Әв••ШёВҖШ®в•Әв••в”ҳв•ӣв•Әв•–в”Ңв•ӣв•Әв•–в”¬ШҜв•Әв•–в”¬Шө YouTube API в•Әв•–в”¬Шӯв•Әв•–в”¬в–‘в•Әв•–в”¬ШҜ в•Әв••в•һЩ’в•Әв•–в”¬ШҜв•Әв••ШёВҖШЁ в•Әв••ШёВҖШ®в•Әв•–в”¬в•–в•Әв••ШёВҖШҰв•Әв••в•ҰВҶв•Әв•–в”¬Ш°в•Әв••ШёВҖв•Јв•Әв•–в”¬ШҜ\r\n      if ((!platform || platform.toLowerCase().includes(\"youtube\") || platform.toLowerCase().includes(\"в•Әв••в”ҳв•Јв•Әв••в•ҰВҶв•Әв•–в”Ңв•ӣв•Әв••в”ҳв•Јв•Әв••в•ҰВҶв•Әв•–в”¬Ш°\")) && !YOUTUBE_API_KEY) {\r\n        logger.error(\"YouTube API key is not configured\");\r\n        return NextResponse.json(\r\n          { error: \"в•Әв••ШёВҖШ®в•Әв••в”ҳв•ӣв•Әв•–в”Ңв•ӣв•Әв•–в”¬ШҜв•Әв•–в”¬Шө YouTube API в•Әв•–в•ӘШӨв•Әв••в”ҳв•Јв•Әв•–в”¬в–’ в•Әв••ШёВҖШ®в•Әв••ШёВҖШ©в•Әв••в”ҳв•Јв•Әв•–в”¬Ш«. в•Әв••в”ҳв•Јв•Әв•–в”¬в–’в•Әв•–в”¬Шҙв•Әв••ШёВҖв–‘ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”Ңв•ӣв•Әв••в•ҰВҶв•Әв•–в”¬ШҜв•Әв•–в”¬в•Ўв•Әв••ШёВҖШҰ в•Әв••ШёВҖШ®в•Әв•–в”¬в•Ј в•Әв••в”ҳв•ӣв•Әв•–в”¬в–’в•Әв••в”ҳв•Јв•Әв••ШёВҖШЈ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬В»в•Әв•–в”¬в•Јв•Әв••ШёВҖШ®.\" },\r\n          { status: 500 }\r\n        );\r\n      }\r\n\r\n      // в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Ш°в•Әв•–в”¬Шөв•Әв•–в”¬Ші в•Әв••в”ҳв•ӣв•Әв••в”ҳв•Ј в•Әв••ШёВҖШЈв•Әв•–в”¬ШҜв•Әв•–в”¬в•Јв•Әв•–в”¬В»в•Әв•–в”¬Шұ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Ш°в•Әв••в”ҳв•Јв•Әв•–в”¬ШҜв•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬Шөв•Әв••ШёВҖШҰв•Әв••в”ҳв•Јв•Әв•–в”¬Шұ в•Әв•–в”¬Ш«в•Әв••в•ҰВҶв•Әв••ШёВҖШҰв•Әв•–в”¬ШҜв•Әв••ШёВҖв•Ј\r\n      let localTeachers: unknown[] = [];\r\n      try {\r\n        localTeachers = await prisma.teacher.findMany({\r\n          where: {\r\n            subjectId: subject as string,\r\n          },\r\n          include: {\r\n            subject: true\r\n          }\r\n        });\r\n      } catch (dbError) {\r\n        logger.error(\"Error fetching teachers from database:\", dbError);\r\n        // в•Әв•–в”¬ШҜв•Әв•–в”¬в”Ӯв•Әв•–в”Ңв•ӣв•Әв••ШёВҖШ®в•Әв•–в”¬в–’ в•Әв•–в”¬Шөв•Әв•–в”Ңв•ӣв•Әв••ШёВҖв–‘ в•Әв••ШёВҖШҰв•Әв••в•ҰВҶ в•Әв••в”ҳв•ӣв•Әв•–в”¬в”Өв•Әв••ШёВҖШҰ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Ш°в•Әв•–в”¬Шөв•Әв•–в”¬Ші в•Әв••в”ҳв•ӣв•Әв••в”ҳв•Ј в•Әв••ШёВҖШЈв•Әв•–в”¬ШҜв•Әв•–в”¬в•Јв•Әв•–в”¬В»в•Әв•–в”¬Шұ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Ш°в•Әв••в”ҳв•Јв•Әв•–в”¬ШҜв•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ\r\n      }\r\n\r\n      // в•Әв•–в”¬Шӯв•Әв••ШёВҖШЁв•Әв•–в”¬в”Өв•Әв•–в”¬ШҜв•Әв•–в•ӘГ® в•Әв•–в”¬в–’в•Әв•–в”¬в”Ӯв•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Шұ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШЁв•Әв•–в”¬в••в•Әв•–в”¬ШҜв•Әв••ШёВҖШ® в•Әв••ШёВҖШҰв•Әв•–в”Ңв•ӣв•Әв••в•ҰВҶв•Әв•–в”¬Шҙв•Әв••в”ҳв•Јв•Әв••ШёВҖШ© в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬в–‘в•Әв••в•һЩ’в•Әв•–в”¬ШҜв•Әв•–в•ӘГ® в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬ШҜв•Әв•–в”¬в•Ўв•Әв•–в”¬в•–в•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв•–в”¬в•Јв