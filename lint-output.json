 { Button } from \"@/components/ui/button\";\r\nimport { Switch } from \"@/components/ui/switch\";\r\nimport { Label } from \"@/components/ui/label\";\r\nimport { Input } from \"@/components/ui/input\";\r\nimport { Badge } from \"@/components/ui/badge\";\r\nimport { toast } from 'sonner';\r\nimport { Shield, MapPin, AlertTriangle, CheckCircle2, X, Plus, Trash2, Globe, Lock } from \"lucide-react\";\r\nimport { Separator } from \"@/components/ui/separator\";\r\n\r\nimport { logger } from '@/lib/logger';\r\n\r\ninterface AdvancedProtectionProps {\r\n  userId: string;\r\n}\r\n\r\ninterface IPWhitelistEntry {\r\n  id: string;\r\n  ip: string;\r\n  label?: string;\r\n  createdAt: string;\r\n}\r\n\r\nexport default function AdvancedProtection({ userId }: AdvancedProtectionProps) {\r\n  const [recaptchaEnabled, setRecaptchaEnabled] = useState(false);\r\n  const [geographicSecurityEnabled, setGeographicSecurityEnabled] = useState(false);\r\n  const [suspiciousActivityDetection, setSuspiciousActivityDetection] = useState(true);\r\n  const [ipWhitelistEnabled, setIpWhitelistEnabled] = useState(false);\r\n  const [ipWhitelist, setIpWhitelist] = useState<IPWhitelistEntry[]>([]);\r\n  const [newIp, setNewIp] = useState('');\r\n  const [newIpLabel, setNewIpLabel] = useState('');\r\n  const [currentLocation, setCurrentLocation] = useState<string>('');\r\n\r\n  useEffect(() => {\r\n    loadProtectionSettings();\r\n    loadIPWhitelist();\r\n    detectCurrentLocation();\r\n  }, [userId]);\r\n\r\n  const loadProtectionSettings = async () => {\r\n    try {\r\n      // Token is in httpOnly cookie - no need to send Authorization header\r\n      const response = await fetch('/api/auth/security/protection', {\r\n        credentials: 'include',\r\n      });\r\n\r\n      if (response.ok) {\r\n        const data = await response.json();\r\n        setRecaptchaEnabled(data.recaptchaEnabled || false);\r\n        setGeographicSecurityEnabled(data.geographicSecurityEnabled || false);\r\n        setSuspiciousActivityDetection(data.suspiciousActivityDetection !== false);\r\n        setIpWhitelistEnabled(data.ipWhitelistEnabled || false);\r\n      }\r\n    } catch (error) {\r\n      logger.error('Error loading protection settings:', error);\r\n    }\r\n  };\r\n\r\n  const loadIPWhitelist = async () => {\r\n    try {\r\n      // Token is in httpOnly cookie - no need to send Authorization header\r\n      const response = await fetch('/api/auth/security/ip-whitelist', {\r\n        credentials: 'include',\r\n      });\r\n\r\n      if (response.ok) {\r\n        const data = await response.json();\r\n        setIpWhitelist(data.ips || []);\r\n      }\r\n    } catch (error) {\r\n      logger.error('Error loading IP whitelist:', error);\r\n    }\r\n  };\r\n\r\n  const detectCurrentLocation = async () => {\r\n    try {\r\n      // Use a geolocation service or IP-based location detection\r\n      const response = await fetch('https://ipapi.co/json/');\r\n      if (response.ok) {\r\n        const data = await response.json();\r\n        setCurrentLocation(`${data.city || ''}, ${data.country_name || ''}`);\r\n      }\r\n    } catch (error) {\r\n      logger.error('Error detecting location:', error);\r\n    }\r\n  };\r\n\r\n  const handleSaveProtectionSettings = async () => {\r\n    try {\r\n      // Token is in httpOnly cookie - no need to send Authorization header\r\n      const response = await fetch('/api/auth/security/protection', {\r\n        method: 'POST',\r\n        headers: {\r\n          'Content-Type': 'application/json',\r\n        },\r\n        credentials: 'include',\r\n        body: JSON.stringify({\r\n          recaptchaEnabled,\r\n          geographicSecurityEnabled,\r\n          suspiciousActivityDetection,\r\n          ipWhitelistEnabled,\r\n        }),\r\n      });\r\n\r\n      if (response.ok) {\r\n        toast.success('в•ӘШІв”ҳГ  в•ӘШөв”ҳВҒв•Әв•• в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШөв”ҳГ в•ӘШҜв”ҳГЁв•ӘШұ');\r\n      } else {\r\n        toast.error('в”ҳВҒв•Әв”Өв”ҳВ„ в”ҳВҒв”ҳГЁ в•ӘШөв”ҳВҒв•Әв•• в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ');\r\n      }\r\n    } catch (error) {\r\n      logger.error('Error saving protection settings:', error);\r\n      toast.error('в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШөв”ҳВҒв•Әв•• в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ');\r\n    }\r\n  };\r\n\r\n  const handleAddIP = async () => {\r\n    if (!newIp) {\r\n      toast.error('в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҙв•ӘШҜв•ӘШ© в•ӘШӯв•ӘВ»в•ӘВ«в•ӘШҜв”ҳВ„ в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ IP');\r\n      return;\r\n    }\r\n\r\n    // Basic IP validation\r\n    const ipRegex = /^(?:(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.){3}(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$/;\r\n    if (!ipRegex.test(newIp)) {\r\n      toast.error('в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ IP в•Әв•‘в”ҳГЁв•Әв–’ в•Әв•Ўв•ӘШөв”ҳГЁв•ӘШө');\r\n      return;\r\n    }\r\n\r\n    try {\r\n      // Token is in httpOnly cookie - no need to send Authorization header\r\n      const response = await fetch('/api/auth/security/ip-whitelist', {\r\n        method: 'POST',\r\n        headers: {\r\n          'Content-Type': 'application/json',\r\n        },\r\n        credentials: 'include',\r\n        body: JSON.stringify({\r\n          ip: newIp,\r\n          label: newIpLabel || 'в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ IP',\r\n        }),\r\n      });\r\n\r\n      if (response.ok) {\r\n        const data = await response.json();\r\n        setIpWhitelist([...ipWhitelist, data.ip]);\r\n        setNewIp('');\r\n        setNewIpLabel('');\r\n        toast.success('в•ӘШІв”ҳГ  в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ IP в•ӘШӯв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•Әв•ўв•ӘШҜв•ӘШ©');\r\n      } else {\r\n        toast.error('в”ҳВҒв•Әв”Өв”ҳВ„ в”ҳВҒв”ҳГЁ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ IP');\r\n      }\r\n    } catch (error) {\r\n      logger.error('Error adding IP:', error);\r\n      toast.error('в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ IP');\r\n    }\r\n  };\r\n\r\n  const handleRemoveIP = async (ipId: string) => {\r\n    try {\r\n      // Token is in httpOnly cookie - no need to send Authorization header\r\n      const response = await fetch(`/api/auth/security/ip-whitelist/${ipId}`, {\r\n        method: 'DELETE',\r\n        credentials: 'include',\r\n      });\r\n\r\n      if (response.ok) {\r\n        setIpWhitelist(ipWhitelist.filter(ip => ip.id !== ipId));\r\n        toast.success('в•ӘШІв”ҳГ  в•ӘШӯв•Әв–“в•ӘШҜв”ҳВ„в•ӘШұ в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ IP в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•Әв•ўв•ӘШҜв•ӘШ©');\r\n      } else {\r\n        toast.error('в”ҳВҒв•Әв”Өв”ҳВ„ в”ҳВҒв”ҳГЁ в•ӘШӯв•Әв–“в•ӘШҜв”ҳВ„в•ӘШұ в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ IP');\r\n      }\r\n    } catch (error) {\r\n      logger.error('Error removing IP:', error);\r\n      toast.error('в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШӯв•Әв–“в•ӘШҜв”ҳВ„в•ӘШұ в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ IP');\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      {/* Google reCAPTCHA */}\r\n      <Card>\r\n        <CardHeader>\r\n          <CardTitle className=\"flex items-center gap-2\">\r\n            <Shield className=\"h-5 w-5\" />\r\n            Google reCAPTCHA\r\n          </CardTitle>\r\n          <CardDescription>\r\n            в•ӘШөв”ҳГ в•ӘШҜв”ҳГЁв•ӘШұ в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°в”ҳГў в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в•Әв–’в”ҳГӘв•ӘШ°в”ҳГӘв•ӘШІв•ӘШҜв•ӘШІ в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГ§в•ӘШҙв”ҳГ в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШІв”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГЁв•ӘШұ\r\n          </CardDescription>\r\n        </CardHeader>\r\n        <CardContent className=\"space-y-4\">\r\n          <div className=\"flex items-center justify-between p-4 rounded-lg border\">\r\n            <div className=\"flex items-center gap-3\">\r\n              <Globe className=\"h-5 w-5 text-muted-foreground\" />\r\n              <div>\r\n                <Label className=\"text-base\">в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„ reCAPTCHA</Label>\r\n                <p className=\"text-sm text-muted-foreground\">\r\n                  в”ҳГЁв•ӘШІв•Әв•–в”ҳВ„в•ӘШ° в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в”ҳГ в”ҳВҶ reCAPTCHA в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„\r\n                </p>\r\n              </div>\r\n            </div>\r\n            <Switch\r\n              checked={recaptchaEnabled}\r\n              onCheckedChange={setRecaptchaEnabled}\r\n            />\r\n          </div>\r\n\r\n          {recaptchaEnabled && (\r\n            <div className=\"p-4 rounded-lg border bg-blue-50 dark:bg-blue-900/20\">\r\n              <div className=\"text-sm text-center py-4\">в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө</div>\r\n            </div>\r\n          )}\r\n        </CardContent>\r\n      </Card>\r\n\r\n      {/* Geographic Security */}\r\n      <Card>\r\n        <CardHeader>\r\n          <CardTitle className=\"flex items-center gap-2\">\r\n            <MapPin className=\"h-5 w-5\" />\r\n            в•ӘШ«в”ҳГ в•ӘШҜв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв”ҳГ©в•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШҙв•Әв•‘в•Әв–’в•ӘШҜв”ҳВҒв”ҳГЁ\r\n          </CardTitle>\r\n          <CardDescription>\r\n            в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв”ҳГ©в•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШҙв•Әв•‘в•Әв–’в•ӘШҜв”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв”ҳГ в”ҳГӘв•ӘШө в”ҳВ„в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„\r\n          </CardDescription>\r\n        </CardHeader>\r\n        <CardContent className=\"space-y-4\">\r\n          <div className=\"flex items-center justify-between p-4 rounded-lg border\">\r\n            <div className=\"flex items-center gap-3\">\r\n              <MapPin className=\"h-5 w-5 text-muted-foreground\" />\r\n              <div>\r\n                <Label className=\"text-base\">в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„ в•ӘШ«в”ҳГ в•ӘШҜв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв”ҳГ©в•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШҙв•Әв•‘в•Әв–’в•ӘШҜв”ҳВҒв”ҳГЁ</Label>\r\n                <p className=\"text-sm text-muted-foreground\">\r\n                  {currentLocation && `в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв”ҳГ©в•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁ: ${currentLocation}`}\r\n                </p>\r\n              </div>\r\n            </div>\r\n            <Switch\r\n              checked={geographicSecurityEnabled}\r\n              onCheckedChange={setGeographicSecurityEnabled}\r\n            />\r\n          </div>\r\n\r\n          {geographicSecurityEnabled && (\r\n            <div className=\"p-4 rounded-lg border bg-yellow-50 dark:bg-yellow-900/20\">\r\n              <div className=\"flex items-start gap-3\">\r\n                <AlertTriangle className=\"h-5 w-5 text-yellow-600 mt-0.5\" />\r\n                <div className=\"text-sm text-yellow-800 dark:text-yellow-200\">\r\n                  <p className=\"font-medium mb-1\">в•ӘШІв”ҳВҶв•ӘШ°в”ҳГЁв”ҳГ§:</p>\r\n                  <p>в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„ в”ҳГ§в•Әв–‘в”ҳГ§ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГЁв•Әв–“в•ӘШұв•ӘГ® в•Әв”Ӯв”ҳГЁв•ӘШІв”ҳГ  в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„ в•ӘШІв”ҳВҶв•ӘШ°в”ҳГЁв”ҳГ§ в•Әв•Јв”ҳВҶв•ӘВ» в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳГ в”ҳВҶ в”ҳГ в”ҳГӘв”ҳГ©в•Әв•Ј в•ӘШҙв•Әв•‘в•Әв–’в•ӘШҜв”ҳВҒв”ҳГЁ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ» в•ӘШ«в”ҳГӘ в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв•Јв•ӘШІв•ӘШҜв•ӘВ».</p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          )}\r\n        </CardContent>\r\n      </Card>\r\n\r\n      {/* Suspicious Activity Detection */}\r\n      <Card>\r\n        <CardHeader>\r\n          <CardTitle className=\"flex items-center gap-2\">\r\n            <AlertTriangle className=\"h-5 w-5\" />\r\n            в”ҳГўв•Әв”Өв”ҳВҒ в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Өв•ӘШҜв•Әв•– в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Өв•ӘШ°в”ҳГӘв”ҳГ§\r\n          </CardTitle>\r\n          <CardDescription>\r\n            в”ҳГ в•Әв–’в•ӘШҜв”ҳГ©в•ӘШ°в•ӘШұ в”ҳГӘв•ӘШҜв”ҳГўв•ӘШІв•Әв”Өв•ӘШҜв”ҳВҒ в•ӘШҜв”ҳВ„в•ӘШ«в”ҳВҶв•Әв”Өв•Әв•–в•ӘШұ в•Әв•‘в”ҳГЁв•Әв–’ в•ӘШҜв”ҳВ„в•Әв•Јв•ӘШҜв•ӘВ»в”ҳГЁв•ӘШұ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°в”ҳГў\r\n          </CardDescription>\r\n        </CardHeader>\r\n        <CardContent className=\"space-y-4\">\r\n          <div className=\"flex items-center justify-between p-4 rounded-lg border\">\r\n            <div className=\"flex items-center gap-3\">\r\n              <AlertTriangle className=\"h-5 w-5 text-muted-foreground\" />\r\n              <div>\r\n                <Label className=\"text-base\">в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„ в”ҳГўв•Әв”Өв”ҳВҒ в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Өв•ӘШҜв•Әв•– в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Өв•ӘШ°в”ҳГӘв”ҳГ§</Label>\r\n                <p className=\"text-sm text-muted-foreground\">\r\n                  в•Әв”Ӯв”ҳГЁв•ӘШІв”ҳГ  в•ӘШҜв”ҳГўв•ӘШІв•Әв”Өв•ӘШҜв”ҳВҒ в”ҳГӘв•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„ в•ӘШІв”ҳВҶв•ӘШ°в”ҳГЁв”ҳГ§в•ӘШҜв•ӘШІ в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШҜв”ҳГўв•ӘШІв•Әв”Өв•ӘШҜв”ҳВҒ в”ҳВҶв•Әв”Өв•ӘШҜв•Әв•– в•Әв•‘в”ҳГЁв•Әв–’ в•Әв•Јв•ӘШҜв•ӘВ»в”ҳГЁ\r\n                </p>\r\n              </div>\r\n            </div>\r\n            <Switch\r\n              checked={suspiciousActivityDetection}\r\n              onCheckedChange={setSuspiciousActivityDetection}\r\n            />\r\n          </div>\r\n\r\n          {suspiciousActivityDetection && (\r\n            <div className=\"p-4 rounded-lg border bg-blue-50 dark:bg-blue-900/20\">\r\n              <h3 className=\"font-medium mb-2\">в”ҳГ в•ӘШҜ в”ҳГЁв•ӘШІв”ҳГ  в”ҳГ в•Әв–’в•ӘШҜв”ҳГ©в•ӘШ°в•ӘШІв”ҳГ§:</h3>\r\n              <ul className=\"text-sm space-y-1 text-muted-foreground list-disc list-inside\">\r\n                <li>в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШҜв•ӘШІ в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳГ в•ӘШІв•Әв•Јв•ӘВ»в•ӘВ»в•ӘШұ в”ҳВҒв•ӘШҜв•Әв”Өв”ҳВ„в•ӘШұ</li>\r\n                <li>в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳГ в”ҳВҶ в”ҳГ в”ҳГӘв•ӘШҜв”ҳГ©в•Әв•Ј в•ӘШҙв•Әв•‘в•Әв–’в•ӘШҜв”ҳВҒв”ҳГЁв•ӘШұ в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв•Јв•ӘШІв•ӘШҜв•ӘВ»в•ӘШұ</li>\r\n                <li>в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳГ в”ҳВҶ в•ӘШ«в•ӘШҙв”ҳГ§в•Әв–“в•ӘШұ в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв•Јв•Әв–’в”ҳГӘв”ҳВҒв•ӘШұ</li>\r\n                <li>в•ӘШ«в”ҳВҶв•Әв”Өв•Әв•–в•ӘШұ в•Әв•‘в”ҳГЁв•Әв–’ в•Әв•Јв•ӘШҜв•ӘВ»в”ҳГЁв•ӘШұ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°</li>\r\n              </ul>\r\n            </div>\r\n          )}\r\n        </CardContent>\r\n      </Card>\r\n\r\n      {/* IP Whitelisting */}\r\n      <Card>\r\n        <CardHeader>\r\n          <CardTitle className=\"flex items-center gap-2\">\r\n            <Lock className=\"h-5 w-5\" />\r\n            IP Whitelisting\r\n          </CardTitle>\r\n          <CardDescription>\r\n            в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘВ» в•Әв•Јв”ҳВҶв•ӘШҜв”ҳГӘв”ҳГЁв”ҳВҶ IP в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв”ҳГ в”ҳГӘв•ӘШө в”ҳВ„в”ҳГ§в•ӘШҜ в•ӘШ°в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в•ӘШӯв”ҳВ„в”ҳГ« в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°в”ҳГў\r\n          </CardDescription>\r\n        </CardHeader>\r\n        <CardContent className=\"space-y-4\">\r\n          <div className=\"flex items-center justify-between p-4 rounded-lg border\">\r\n            <div className=\"flex items-center gap-3\">\r\n              <Lock className=\"h-5 w-5 text-muted-foreground\" />\r\n              <div>\r\n                <Label className=\"text-base\">в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„ IP Whitelisting</Label>\r\n                <p className=\"text-sm text-muted-foreground\">\r\n                  в•Әв”Ӯв”ҳГЁв•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳГ в•ӘШҜв•ӘШө в•ӘШ°в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳВҒв”ҳГ©в•Әв•– в”ҳГ в”ҳВҶ в•Әв•Јв”ҳВҶв•ӘШҜв”ҳГӘв”ҳГЁв”ҳВҶ IP в•ӘШҜв”ҳВ„в”ҳГ в•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ\r\n                </p>\r\n              </div>\r\n            </div>\r\n            <Switch\r\n              checked={ipWhitelistEnabled}\r\n              onCheckedChange={setIpWhitelistEnabled}\r\n            />\r\n          </div>\r\n\r\n          {ipWhitelistEnabled && (\r\n            <div className=\"space-y-4\">\r\n              <div className=\"p-4 rounded-lg border bg-yellow-50 dark:bg-yellow-900/20\">\r\n                <div className=\"flex items-start gap-3\">\r\n                  <AlertTriangle className=\"h-5 w-5 text-yellow-600 mt-0.5\" />\r\n                  <div className=\"text-sm text-yellow-800 dark:text-yellow-200\">\r\n                    <p className=\"font-medium mb-1\">в•ӘШІв•ӘШөв•Әв–‘в”ҳГЁв•Әв–’:</p>\r\n                    <p>в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„ в”ҳГ§в•Әв–‘в”ҳГ§ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГЁв•Әв–“в•ӘШұв•ӘГ® в•Әв”Ӯв”ҳГЁв•ӘШІв”ҳГ  в•ӘШөв•Әв••в•Әв–’ в•ӘШҙв”ҳГ в”ҳГЁв•Әв•Ј в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШҜв•ӘШІ в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳГ в”ҳВҶ в•Әв•Јв”ҳВҶв•ӘШҜв”ҳГӘв”ҳГЁв”ҳВҶ IP в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в”ҳГӘв•ӘШҙв”ҳГӘв•ӘВ»в•ӘШұ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•Әв•ўв•ӘШҜв•ӘШ©. в•ӘШІв•ӘШ«в”ҳГўв•ӘВ» в”ҳГ в”ҳВҶ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ IP в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁ в”ҳГ©в•ӘШ°в”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„.</p>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n\r\n              <div className=\"space-y-2\">\r\n                <div className=\"flex gap-2\">\r\n                  <Input\r\n                    placeholder=\"в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ IP (в”ҳГ в•ӘШів•ӘШҜв”ҳВ„: 192.168.1.1)\"\r\n                    value={newIp}\r\n                    onChange={(e) => setNewIp(e.target.value)}\r\n                    className=\"flex-1\"\r\n                  />\r\n                  <Input\r\n                    placeholder=\"в•ӘШІв•Әв”Ӯв”ҳГ в”ҳГЁв•ӘШұ (в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’в”ҳГЁ)\"\r\n                    value={newIpLabel}\r\n                    onChange={(e) => setNewIpLabel(e.target.value)}\r\n                    className=\"w-40\"\r\n                  />\r\n                  <Button onClick={handleAddIP}>\r\n                    <Plus className=\"h-4 w-4 ml-2\" />\r\n                    в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ\r\n                  </Button>\r\n                </div>\r\n              </div>\r\n\r\n              <Separator />\r\n\r\n              <div className=\"space-y-2\">\r\n                <h3 className=\"font-medium\">в•Әв•Јв”ҳВҶв•ӘШҜв”ҳГӘв”ҳГЁв”ҳВҶ IP в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв”ҳГ в”ҳГӘв•ӘШөв•ӘШұ:</h3>\r\n                {ipWhitelist.length > 0 ? (\r\n                  <div className=\"space-y-2\">\r\n                    {ipWhitelist.map((ip) => (\r\n                      <div\r\n                        key={ip.id}\r\n                        className=\"flex items-center justify-between p-3 rounded-lg border\"\r\n                      >\r\n                        <div>\r\n                          <div className=\"flex items-center gap-2\">\r\n                            <span className=\"font-medium\">{ip.ip}</span>\r\n                            {ip.label && (\r\n                              <Badge variant=\"outline\">{ip.label}</Badge>\r\n                            )}\r\n                          </div>\r\n                          <p className=\"text-xs text-muted-foreground\">\r\n                            в•ӘШ«в•Әв•ўв”ҳГЁв”ҳВҒ в”ҳВҒв”ҳГЁ: {new Date(ip.createdAt).toLocaleDateString('ar-EG')}\r\n                          </p>\r\n                        </div>\r\n                        <Button\r\n                          variant=\"destructive\"\r\n                          size=\"sm\"\r\n                          onClick={() => handleRemoveIP(ip.id)}\r\n                        >\r\n                          <Trash2 className=\"h-4 w-4\" />\r\n                        </Button>\r\n                      </div>\r\n                    ))}\r\n                  </div>\r\n                ) : (\r\n                  <p className=\"text-sm text-muted-foreground text-center py-4\">\r\n                    в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в•Әв•Јв”ҳВҶв•ӘШҜв”ҳГӘв”ҳГЁв”ҳВҶ IP в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•Әв•ўв•ӘШҜв•ӘШ©\r\n                  </p>\r\n                )}\r\n              </div>\r\n            </div>\r\n          )}\r\n        </CardContent>\r\n      </Card>\r\n\r\n      <div className=\"flex justify-end\">\r\n        <Button onClick={handleSaveProtectionSettings}>\r\n          в•ӘШөв”ҳВҒв•Әв•• в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ\r\n        </Button>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\profile\\components\\PasswordManagement.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Separator' is defined but never used. Allowed unused vars must match /^_/u.","line":12,"column":10,"nodeType":null,"messageId":"unusedVar","endLine":12,"endColumn":19},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'userId' is defined but never used. Allowed unused args must match /^_/u.","line":32,"column":46,"nodeType":null,"messageId":"unusedVar","endLine":32,"endColumn":52},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'count' is assigned a value but never used. Allowed unused vars must match /^_/u.","line":114,"column":22,"nodeType":null,"messageId":"unusedVar","endLine":114,"endColumn":27}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\r\n\r\nimport { useState } from 'react';\r\nimport { Card, CardContent, CardDescription, CardHeader, CardTitle } from \"@/components/ui/card\";\r\nimport { Button } from \"@/components/ui/button\";\r\nimport { Input } from \"@/components/ui/input\";\r\nimport { Label } from \"@/components/ui/label\";\r\nimport { Progress } from \"@/components/ui/progress\";\r\nimport { Badge } from \"@/components/ui/badge\";\r\nimport { toast } from 'sonner';\r\nimport { Key, AlertTriangle, CheckCircle2, Eye, EyeOff, Shield, RefreshCw } from \"lucide-react\";\r\nimport { Separator } from \"@/components/ui/separator\";\r\n\r\nconst getPasswordStrengthDisplay = (password: string) => ({\r\n  score: password.length > 8 ? 100 : 0,\r\n  label: password.length > 8 ? 'в”ҳГ©в”ҳГӘв”ҳГЁв•ӘШұ' : 'в•Әв•ўв•Әв•Јв”ҳГЁв”ҳВҒв•ӘШұ',\r\n  color: password.length > 8 ? 'bg-green-500' : 'bg-red-500',\r\n  checks: {\r\n    minLength: password.length >= 8,\r\n    hasUpper: /[A-Z]/.test(password),\r\n    hasLower: /[a-z]/.test(password),\r\n    hasNumber: /\\d/.test(password),\r\n    hasSpecial: /[^A-Za-z0-9]/.test(password)\r\n  }\r\n});\r\nimport { logger } from '@/lib/logger';\r\n\r\ninterface PasswordManagementProps {\r\n  userId: string;\r\n}\r\n\r\nexport default function PasswordManagement({ userId }: PasswordManagementProps) {\r\n  const [currentPassword, setCurrentPassword] = useState('');\r\n  const [newPassword, setNewPassword] = useState('');\r\n  const [confirmPassword, setConfirmPassword] = useState('');\r\n  const [showCurrentPassword, setShowCurrentPassword] = useState(false);\r\n  const [showNewPassword, setShowNewPassword] = useState(false);\r\n  const [showConfirmPassword, setShowConfirmPassword] = useState(false);\r\n  const [isChanging, setIsChanging] = useState(false);\r\n  const [isCheckingLeak, setIsCheckingLeak] = useState(false);\r\n  const [isLeaked, setIsLeaked] = useState<boolean | null>(null);\r\n  const [checkPassword, setCheckPassword] = useState('');\r\n\r\n  const passwordStrength = getPasswordStrengthDisplay(newPassword);\r\n\r\n  const handleChangePassword = async () => {\r\n    if (!currentPassword || !newPassword || !confirmPassword) {\r\n      toast.error('в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҙв•ӘШҜв•ӘШ© в”ҳГ в”ҳВ„в•ӘШ© в•ӘШҙв”ҳГ в”ҳГЁв•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШөв”ҳГ©в”ҳГӘв”ҳВ„');\r\n      return;\r\n    }\r\n\r\n    if (newPassword !== confirmPassword) {\r\n      toast.error('в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ в”ҳГӘв•ӘШІв•ӘШ«в”ҳГўв”ҳГЁв•ӘВ»в”ҳГ§в•ӘШҜ в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШІв•Әв•–в•ӘШҜв•ӘШ°в”ҳГ©в”ҳГЁв”ҳВҶ');\r\n      return;\r\n    }\r\n\r\n    if (passwordStrength.score < 40) {\r\n      toast.error('в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•Әв•ўв•Әв•Јв”ҳГЁв”ҳВҒв•ӘШұ в•ӘШҙв•ӘВ»в•ӘШҜв”ҳГҜ. в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҙв•ӘШҜв•ӘШ© в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘШ«в”ҳГ©в”ҳГӘв”ҳГ«');\r\n      return;\r\n    }\r\n\r\n    try {\r\n      setIsChanging(true);\r\n      // Token is in httpOnly cookie - no need to send Authorization header\r\n      \r\n      const response = await fetch('/api/auth/change-password', {\r\n        method: 'POST',\r\n        headers: {\r\n          'Content-Type': 'application/json',\r\n        },\r\n        credentials: 'include',\r\n        body: JSON.stringify({\r\n          currentPassword,\r\n          newPassword,\r\n        }),\r\n      });\r\n\r\n      if (response.ok) {\r\n        toast.success('в•ӘШІв”ҳГ  в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө');\r\n        setCurrentPassword('');\r\n        setNewPassword('');\r\n        setConfirmPassword('');\r\n      } else {\r\n        const error = await response.json();\r\n        toast.error(error.error || 'в”ҳВҒв•Әв”Өв”ҳВ„ в”ҳВҒв”ҳГЁ в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’');\r\n      }\r\n    } catch (error) {\r\n      logger.error('Error changing password:', error);\r\n      toast.error('в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’');\r\n    } finally {\r\n      setIsChanging(false);\r\n    }\r\n  };\r\n\r\n  const handleCheckLeakedPassword = async () => {\r\n    if (!checkPassword) {\r\n      toast.error('в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҙв•ӘШҜв•ӘШ© в•ӘШӯв•ӘВ»в•ӘВ«в•ӘШҜв”ҳВ„ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в”ҳВ„в”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ©');\r\n      return;\r\n    }\r\n\r\n    try {\r\n      setIsCheckingLeak(true);\r\n      \r\n      // Use Have I Been Pwned API (k-anonymity)\r\n      const passwordHash = await sha256(checkPassword);\r\n      const hashPrefix = passwordHash.substring(0, 5);\r\n      const hashSuffix = passwordHash.substring(5);\r\n\r\n      const response = await fetch(`https://api.pwnedpasswords.com/range/${hashPrefix}`);\r\n      const data = await response.text();\r\n      \r\n      const hashes = data.split('\\n');\r\n      const found = hashes.some(line => {\r\n        const [hash, count] = line.split(':');\r\n        return hash.toLowerCase() === hashSuffix.toLowerCase();\r\n      });\r\n\r\n      setIsLeaked(found);\r\n      \r\n      if (found) {\r\n        toast.error('ШёШЈШЁЩҠв••ВҸ в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•Әв•Јв•ӘШів”ҳГӘв•Әв–’ в•Әв•Јв”ҳВ„в”ҳГ« в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в”ҳВҒв”ҳГЁ в”ҳГ©в•ӘШҜв•Әв•Јв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•Әв–’в•ӘШ°в•ӘШұ. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в•ӘШҜв”ҳГ  в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ«.');\r\n      } else {\r\n        toast.success('ШёВЈГҙ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘШӘв”ҳГ в”ҳВҶв•ӘШұ в”ҳГӘв”ҳВ„в”ҳГ  в”ҳГЁв•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•Әв•Јв•ӘШів”ҳГӘв•Әв–’ в•Әв•Јв”ҳВ„в”ҳГЁв”ҳГ§в•ӘШҜ в”ҳВҒв”ҳГЁ в”ҳГ©в”ҳГӘв•ӘШҜв•Әв•Јв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•Әв–’в•ӘШ°в•ӘШұ');\r\n      }\r\n    } catch (error) {\r\n      logger.error('Error checking leaked password:', error);\r\n      toast.error('в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в”ҳГ в”ҳВҶ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’');\r\n    } finally {\r\n      setIsCheckingLeak(false);\r\n    }\r\n  };\r\n\r\n  const sha256 = async (message: string): Promise<string> => {\r\n    const msgBuffer = new TextEncoder().encode(message);\r\n    const hashBuffer = await crypto.subtle.digest('SHA-256', msgBuffer);\r\n    const hashArray = Array.from(new Uint8Array(hashBuffer));\r\n    return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');\r\n  };\r\n\r\n  const getPasswordSuggestions = () => {\r\n    const suggestions: string[] = [];\r\n    \r\n    if (newPassword.length < 8) {\r\n      suggestions.push('в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ©в”ҳВ„ 8 в•ӘШ«в•ӘШөв•Әв–’в”ҳВҒ');\r\n    }\r\n    if (!passwordStrength.checks.hasUpper) {\r\n      suggestions.push('в•ӘШ«в•Әв•ўв”ҳВҒ в•ӘШөв•Әв–’в”ҳВҒ в”ҳГўв•ӘШ°в”ҳГЁв•Әв–’ в”ҳГӘв•ӘШҜв•ӘШөв•ӘВ» в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ©в”ҳВ„');\r\n    }\r\n    if (!passwordStrength.checks.hasLower) {\r\n      suggestions.push('в•ӘШ«в•Әв•ўв”ҳВҒ в•ӘШөв•Әв–’в”ҳВҒ в•Әв•Ўв•Әв•‘в”ҳГЁв•Әв–’ в”ҳГӘв•ӘШҜв•ӘШөв•ӘВ» в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ©в”ҳВ„');\r\n    }\r\n    if (!passwordStrength.checks.hasNumber) {\r\n      suggestions.push('в•ӘШ«в•Әв•ўв”ҳВҒ в•Әв–’в”ҳГ©в”ҳГ  в”ҳГӘв•ӘШҜв•ӘШөв•ӘВ» в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ©в”ҳВ„');\r\n    }\r\n    if (!passwordStrength.checks.hasSpecial) {\r\n      suggestions.push('в•ӘШ«в•Әв•ўв”ҳВҒ в•Әв–’в”ҳГ в•Әв–“ в•ӘВ«в•ӘШҜв•Әв•Ў (!@#$%^&*)');\r\n    }\r\n    if (newPassword.length < 12) {\r\n      suggestions.push('в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  12 в•ӘШөв•Әв–’в”ҳВҒ в•ӘШ«в”ҳГӘ в•ӘШ«в”ҳГўв•ӘШів•Әв–’ в”ҳВ„в”ҳВ„в•ӘШ«в”ҳГ в•ӘШҜв”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШ«в”ҳВҒв•Әв•ўв”ҳВ„');\r\n    }\r\n\r\n    return suggestions;\r\n  };\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      {/* Change Password */}\r\n      <Card>\r\n        <CardHeader>\r\n          <CardTitle className=\"flex items-center gap-2\">\r\n            <Key className=\"h-5 w-5\" />\r\n            в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’\r\n          </CardTitle>\r\n          <CardDescription>\r\n            в”ҳГ©в”ҳГ  в•ӘШ°в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘШ°в•ӘШҜв”ҳВҶв•ӘШІв•Әв••в•ӘШҜв”ҳГ  в”ҳВ„в”ҳВ„в•ӘШөв”ҳВҒв•ӘШҜв•Әв•• в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШ«в”ҳГ в•ӘШҜв”ҳВҶ в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°в”ҳГў\r\n          </CardDescription>\r\n        </CardHeader>\r\n        <CardContent className=\"space-y-4\">\r\n          <div className=\"space-y-2\">\r\n            <Label htmlFor=\"current-password\">в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШұ</Label>\r\n            <div className=\"relative\">\r\n              <Input\r\n                id=\"current-password\"\r\n                type={showCurrentPassword ? 'text' : 'password'}\r\n                value={currentPassword}\r\n                onChange={(e) => setCurrentPassword(e.target.value)}\r\n                placeholder=\"в•ӘШ«в•ӘВ»в•ӘВ«в”ҳВ„ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШұ\"\r\n              />\r\n              <Button\r\n                type=\"button\"\r\n                variant=\"ghost\"\r\n                size=\"sm\"\r\n                className=\"absolute left-2 top-1/2 -translate-y-1/2 h-8 w-8 p-0\"\r\n                onClick={() => setShowCurrentPassword(!showCurrentPassword)}\r\n              >\r\n                {showCurrentPassword ? (\r\n                  <EyeOff className=\"h-4 w-4\" />\r\n                ) : (\r\n                  <Eye className=\"h-4 w-4\" />\r\n                )}\r\n              </Button>\r\n            </div>\r\n          </div>\r\n\r\n          <div className=\"space-y-2\">\r\n            <Label htmlFor=\"new-password\">в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ</Label>\r\n            <div className=\"relative\">\r\n              <Input\r\n                id=\"new-password\"\r\n                type={showNewPassword ? 'text' : 'password'}\r\n                value={newPassword}\r\n                onChange={(e) => setNewPassword(e.target.value)}\r\n                placeholder=\"в•ӘШ«в•ӘВ»в•ӘВ«в”ҳВ„ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ\"\r\n              />\r\n              <Button\r\n                type=\"button\"\r\n                variant=\"ghost\"\r\n                size=\"sm\"\r\n                className=\"absolute left-2 top-1/2 -translate-y-1/2 h-8 w-8 p-0\"\r\n                onClick={() => setShowNewPassword(!showNewPassword)}\r\n              >\r\n                {showNewPassword ? (\r\n                  <EyeOff className=\"h-4 w-4\" />\r\n                ) : (\r\n                  <Eye className=\"h-4 w-4\" />\r\n                )}\r\n              </Button>\r\n            </div>\r\n          </div>\r\n\r\n          {/* Password Strength Indicator */}\r\n          {newPassword && (\r\n            <div className=\"space-y-2\">\r\n              <div className=\"flex items-center justify-between\">\r\n                <Label>в”ҳГ©в”ҳГӘв•ӘШұ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’</Label>\r\n                <Badge className={passwordStrength.color}>\r\n                  {passwordStrength.label}\r\n                </Badge>\r\n              </div>\r\n              <Progress value={passwordStrength.score} className=\"h-2\" />\r\n              \r\n              <div className=\"grid grid-cols-2 gap-2 text-sm\">\r\n                <div className={`flex items-center gap-2 ${passwordStrength.checks.minLength ? 'text-green-600' : 'text-gray-400'}`}>\r\n                  {passwordStrength.checks.minLength ? (\r\n                    <CheckCircle2 className=\"h-4 w-4\" />\r\n                  ) : (\r\n                    <AlertTriangle className=\"h-4 w-4\" />\r\n                  )}\r\n                  <span>8 в•ӘШ«в•ӘШөв•Әв–’в”ҳВҒ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ©в”ҳВ„</span>\r\n                </div>\r\n                <div className={`flex items-center gap-2 ${passwordStrength.checks.hasUpper ? 'text-green-600' : 'text-gray-400'}`}>\r\n                  {passwordStrength.checks.hasUpper ? (\r\n                    <CheckCircle2 className=\"h-4 w-4\" />\r\n                  ) : (\r\n                    <AlertTriangle className=\"h-4 w-4\" />\r\n                  )}\r\n                  <span>в•ӘШөв•Әв–’в”ҳВҒ в”ҳГўв•ӘШ°в”ҳГЁв•Әв–’</span>\r\n                </div>\r\n                <div className={`flex items-center gap-2 ${passwordStrength.checks.hasLower ? 'text-green-600' : 'text-gray-400'}`}>\r\n                  {passwordStrength.checks.hasLower ? (\r\n                    <CheckCircle2 className=\"h-4 w-4\" />\r\n                  ) : (\r\n                    <AlertTriangle className=\"h-4 w-4\" />\r\n                  )}\r\n                  <span>в•ӘШөв•Әв–’в”ҳВҒ в•Әв•Ўв•Әв•‘в”ҳГЁв•Әв–’</span>\r\n                </div>\r\n                <div className={`flex items-center gap-2 ${passwordStrength.checks.hasNumber ? 'text-green-600' : 'text-gray-400'}`}>\r\n                  {passwordStrength.checks.hasNumber ? (\r\n                    <CheckCircle2 className=\"h-4 w-4\" />\r\n                  ) : (\r\n                    <AlertTriangle className=\"h-4 w-4\" />\r\n                  )}\r\n                  <span>в•Әв–’в”ҳГ©в”ҳГ </span>\r\n                </div>\r\n                <div className={`flex items-center gap-2 ${passwordStrength.checks.hasSpecial ? 'text-green-600' : 'text-gray-400'}`}>\r\n                  {passwordStrength.checks.hasSpecial ? (\r\n                    <CheckCircle2 className=\"h-4 w-4\" />\r\n                  ) : (\r\n                    <AlertTriangle className=\"h-4 w-4\" />\r\n                  )}\r\n                  <span>в•Әв–’в”ҳГ в•Әв–“ в•ӘВ«в•ӘШҜв•Әв•Ў</span>\r\n                </div>\r\n              </div>\r\n\r\n              {getPasswordSuggestions().length > 0 && (\r\n                <div className=\"p-3 rounded-lg bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200\">\r\n                  <h4 className=\"font-medium text-sm mb-2\">в•ӘШҜв”ҳГ©в•ӘШІв•Әв–’в•ӘШҜв•ӘШөв•ӘШҜв•ӘШІ в”ҳВ„в•ӘШІв•ӘШөв•Әв”Ӯв”ҳГЁв”ҳВҶ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’:</h4>\r\n                  <ul className=\"text-sm space-y-1 list-disc list-inside text-muted-foreground\">\r\n                    {getPasswordSuggestions().map((suggestion, index) 