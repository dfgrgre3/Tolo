n\r\n    в•Әв••ШёВҖШЈв•Әв••ШёВҖШ® в•Әв•–в”¬Ш°в•Әв•–в”Ңв•ӣв•Әв••в•ҰВҶв•Әв••в”ҳв•ӣв•Әв••в”ҳв•Јв•Әв•–в”¬в–’ в•Әв••ШёВҖШЈв•Әв•–в”¬ШҜв•Әв•–в”¬Ш®в•Әв••ШёВҖШ®в•Әв•–в”¬Шұ в•Әв••ШёВҖШ®в•Әв••ШёВҖШЁ 5-10 в•Әв••ШёВҖШ®в•Әв•–в”¬В»в•Әв•–в”¬в–’в•Әв•–в”¬в”Ӯв•Әв••в”ҳв•Јв•Әв••ШёВҖШЁ в•Әв•–в”¬Ш«в•Әв••в•ҰВҶ в•Әв••ШёВҖШЈв•Әв••ШёВҖШЁв•Әв••в•ҰВҶв•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ в•Әв•–в”Ңв•ӣв•Әв•–в”¬в•Јв•Әв••ШёВҖШҰв•Әв••в”ҳв•Јв•Әв••ШёВҖШ®в•Әв••в”ҳв•Јв•Әв•–в”¬Шұ в•Әв••ШёВҖШ®в•Әв•–в”¬в•Ўв•Әв•–в”¬в–’в•Әв••в”ҳв•Јв•Әв•–в”¬Шұ в•Әв••ШёВҖШ®в•Әв•–в”¬в•Јв•Әв••ШёВҖШҰв•Әв••в•ҰВҶв•Әв••ШёВҖШ®в•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣв•Әв••ШёВҖШ©в•Әв••ШёВҖШ® в•Әв••в•һЩ’в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”Ңв•ӣв•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••в”ҳв•Ј:\r\n    1. в•Әв•–в”¬ШҜв•Әв•–в”¬в”Ӯв•Әв••ШёВҖШ® в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬В»в•Әв•–в”¬в–’в•Әв•–в”¬в”Ӯ в•Әв•–в”¬Ш«в•Әв••в•ҰВҶ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШЈв•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв•–в”¬Шұ\r\n    2. в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬ШҜв•Әв•–в”¬В»в•Әв•–в”¬Шұ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”Ңв•ӣв•Әв••в”ҳв•Ј в•Әв••в”ҳв•Јв•Әв•–в”¬В»в•Әв•–в”¬в–’в•Әв•–в”¬в”Ӯв•Әв••ШёВҖШ©в•Әв•–в”¬ШҜ\r\n    3. в•Әв•–в”¬в–’в•Әв•–в”¬ШҜв•Әв•–в”¬Ш°в•Әв•–в”¬в•– в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШЈв•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв•–в”¬Шұ в•Әв•–в”¬Ш«в•Әв••в•ҰВҶ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв••ШёВҖШҰв•Әв••в”ҳв•ӣ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬в”Өв•Әв•–в”¬В«в•Әв•–в”¬в•Ўв•Әв••в”ҳв•Ј\r\n    4. в•Әв••в•ҰВҶв•Әв•–в”¬в•Ўв•Әв••в”ҳв•ӣ в•Әв••ШёВҖШ®в•Әв••в•ҰВҶв•Әв•–в”¬Шҙв•Әв•–в”¬в–“ в•Әв••ШёВҖШҰв•Әв•–в”¬Ш«в•Әв•–в”¬в”Ӯв•Әв••ШёВҖШҰв•Әв••в•ҰВҶв•Әв•–в”¬Ш° в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”Ңв•ӣв•Әв•–в”¬В»в•Әв•–в”¬в–’в•Әв••в”ҳв•Јв•Әв•–в”¬в”Ӯ в•Әв••в•ҰВҶв•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬Шөв•Әв•–в”Ңв•ӣв•Әв••в•ҰВҶв•Әв••ШёВҖв–‘\r\n    5. в•Әв•–в”Ңв•ӣв•Әв••ШёВҖШЈв•Әв••в”ҳв•Јв•Әв••в”ҳв•Јв•Әв••ШёВҖШ® в•Әв•–в”Ңв•ӣв•Әв••ШёВҖШЈв•Әв•–в”¬в–’в•Әв••в”ҳв•Јв•Әв•–в”¬Ш°в•Әв••в”ҳв•Ј (в•Әв••ШёВҖШ®в•Әв••ШёВҖШЁ 1 в•Әв•–в”¬Шӯв•Әв••ШёВҖШҰв•Әв••ШёВҖв–‘ 5)\r\n\r\n    в•Әв••в”ҳв•Јв•Әв•–в”¬Шҙв•Әв•–в”¬Ш° в•Әв•–в”¬Ш«в•Әв••ШёВҖШЁ в•Әв•–в”Ңв•ӣв•Әв••в•һЩ’в•Әв••в•ҰВҶв•Әв••ШёВҖШЁ в•Әв•–в”¬Шҙв•Әв••ШёВҖШ®в•Әв••в”ҳв•Јв•Әв•–в”¬в•Ј в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬в–’в•Әв••в•ҰВҶв•Әв•–в”¬ШҜв•Әв•–в”¬Ш°в•Әв•–в”¬в•– в•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬в•Ўв•Әв•–в”¬ШҜв•Әв•–в”¬В»в•Әв•–в”¬в–’ в•Әв••ШёВҖШ®в•Әв•–в”¬в•Ўв•Әв•–в”¬в–’в•Әв••в”ҳв•Јв•Әв•–в”¬Шұ в•Әв•–в”¬Шөв•Әв••ШёВҖШЈв•Әв••в”ҳв•Јв•Әв••ШёВҖШЈв•Әв••в”ҳв•Јв•Әв•–в”¬Шұ в•Әв••в•ҰВҶв•Әв••ШёВҖШ®в•Әв••в•ҰВҶв•Әв•–в”¬Шів•Әв••в•ҰВҶв•Әв••ШёВҖШЈв•Әв•–в”¬Шұ.\r\n    в•Әв••ШёВҖШЈв•Әв••ШёВҖШ® в•Әв•–в”¬Ш°в•Әв•–в”Ңв•ӣв•Әв••ШёВҖШЁв•Әв•–в”¬в”Ӯв•Әв••в”ҳв•Јв•Әв••ШёВҖШЈ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Шӯв•Әв•–в”¬Шҙв•Әв•–в”¬ШҜв•Әв•–в”¬Ш°в•Әв•–в”¬Шұ в•Әв••в•һЩ’в•Әв••ШёГ©Шҙ JSON в•Әв••ШёВҖШ®в•Әв•–в”¬в•Ј в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬в•Ўв•Әв••в”ҳв•ӣв•Әв••в•ҰВҶв•Әв••в”ҳв•ӣв•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”Ңв•ӣв•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••в”ҳв•Јв•Әв•–в”¬Шұ:\r\n    {\r\n      \"teachers\": [\r\n        {\r\n          \"name\": \"в•Әв•–в”¬ШҜв•Әв•–в”¬в”Ӯв•Әв••ШёВҖШ® в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬В»в•Әв•–в”¬в–’в•Әв•–в”¬в”Ӯ в•Әв•–в”¬Ш«в•Әв••в•ҰВҶ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШЈв•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв•–в”¬Шұ\",\r\n          \"subject\": \"в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬ШҜв•Әв•–в”¬В»в•Әв•–в”¬Шұ\",\r\n          \"url\": \"в•Әв•–в”¬в–’в•Әв•–в”¬ШҜв•Әв•–в”¬Ш°в•Әв•–в”¬в•– в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШЈв•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв•–в”¬Шұ в•Әв•–в”¬Ш«в•Әв••в•ҰВҶ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв••ШёВҖШҰв•Әв••в”ҳв•ӣ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬в”Өв•Әв•–в”¬В«в•Әв•–в”¬в•Ўв•Әв••в”ҳв•Ј\",\r\n          \"description\": \"в•Әв••в•ҰВҶв•Әв•–в”¬в•Ўв•Әв••в”ҳв•ӣ в•Әв••ШёВҖШ®в•Әв••в•ҰВҶв•Әв•–в”¬Шҙв•Әв•–в”¬в–“\",\r\n          \"rating\": 4.5\r\n        }\r\n      ]\r\n    }`;\r\n\r\n      let aiTeachers: any[] = [];\r\n      let youtubeResults: any[] = [];\r\n\r\n      // в•Әв•–в”¬Шӯв•Әв•–в”¬в–‘в•Әв•–в”¬ШҜ в•Әв••в•һЩ’в•Әв•–в”¬ШҜв•Әв••ШёВҖШЁ в•Әв•–в”¬в•–в•Әв••ШёВҖШҰв•Әв•–в”¬Ш° в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Ш°в•Әв•–в”¬Шөв•Әв•–в”¬Ші в•Әв••в”ҳв•Јв•Әв•–в”¬в”Өв•Әв••ШёВҖШ®в•Әв••ШёВҖШҰ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••в”ҳв•Јв•Әв••в•ҰВҶв•Әв•–в”Ңв•ӣв•Әв••в”ҳв•Јв•Әв•–в”¬Ш°в•Әв•–в”јЩ’ в•Әв••ШёВҖШЈв•Әв••ШёВҖШ® в•Әв•–в”¬Ш°в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Ш°в•Әв•–в”¬Шөв•Әв•–в”¬Ші в•Әв••ШёВҖШ©в•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв••в•һЩ’ в•Әв•–в”¬Ш«в•Әв••в”ҳв•Јв•Әв•–в”¬в•ўв•Әв•–в”¬ШҜв•Әв••ШёВҖв•Ј\r\n      if (!platform || platform.toLowerCase().includes(\"youtube\") || platform.toLowerCase().includes(\"в•Әв••в”ҳв•Јв•Әв••в•ҰВҶв•Әв•–в”Ңв•ӣв•Әв••в”ҳв•Јв•Әв••в•ҰВҶв•Әв•–в”¬Ш°\")) {\r\n        const searchQuery = `${subject} в•Әв••ШёВҖШ®в•Әв•–в”¬В»в•Әв•–в”¬в–’в•Әв•–в”¬в”Ӯ в•Әв••ШёВҖШ®в•Әв•–в”¬в•Ўв•Әв•–в”¬в–’в•Әв••в”ҳв•Ј ${keywords || \"\"}`;\r\n\r\n        try {\r\n          const youtubeResponse = await fetch(\r\n            `${YOUTUBE_SEARCH_URL}?part=snippet&q=${encodeURIComponent(searchQuery)}&type=channel&key=${YOUTUBE_API_KEY}&maxResults=5`\r\n          );\r\n\r\n          if (youtubeResponse.ok) {\r\n            const youtubeData = await youtubeResponse.json();\r\n            if (youtubeData.items && Array.isArray(youtubeData.items)) {\r\n              youtubeResults = youtubeData.items.map((item: any) => ({\r\n                name: item.snippet.channelTitle,\r\n                url: `https://www.youtube.com/channel/${item.snippet.channelId}`,\r\n                description: item.snippet.description,\r\n                thumbnail: item.snippet.thumbnails.default.url\r\n              }));\r\n            }\r\n          }\r\n        } catch (error) {\r\n          logger.error(\"Error searching YouTube:\", error);\r\n        }\r\n      }\r\n\r\n      // в•Әв••ШёВҖШ®в•Әв•–в”¬в•Јв•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Шҙв•Әв•–в”¬Шұ в•Әв•–в”¬ШҜв•Әв•–в”¬в”Ӯв•Әв•–в”Ңв•ӣв•Әв•–в”¬Шҙв•Әв•–в”¬ШҜв•Әв•–в”¬Ш°в•Әв•–в”¬Шұ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬в–‘в•Әв••в•һЩ’в•Әв•–в”¬ШҜв•Әв•–в•ӘГ® в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬ШҜв•Әв•–в”¬в•Ўв•Әв•–в”¬в•–в•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв•–в”¬в•Јв•Әв••в”ҳв•Ј\r\n      try {\r\n        if (selectedProvider === AI_PROVIDERS.OPENAI) {\r\n          // в•Әв•–в”¬ШҜв•Әв•–в”¬в”Ӯв•Әв•–в”Ңв•ӣв•Әв•–в”¬В«в•Әв•–в”¬В»в•Әв•–в”¬ШҜв•Әв••ШёВҖШ® OpenAI API\r\n          const response = await fetch(selectedProvider.baseUrl, {\r\n            method: \"POST\",\r\n            headers: {\r\n              \"Content-Type\": \"application/json\",\r\n              \"Authorization\": `Bearer ${selectedProvider.apiKey}`\r\n            },\r\n            body: JSON.stringify({\r\n              model: selectedProvider.model,\r\n              messages: [{ role: \"system\", content: systemPrompt }],\r\n              temperature: 0.7,\r\n              max_tokens: 4000\r\n            })\r\n          });\r\n\r\n          if (response.ok) {\r\n            const data = await response.json();\r\n            const teachersContent = data.choices[0].message.content;\r\n\r\n            try {\r\n              const teachersData = JSON.parse(teachersContent);\r\n              aiTeachers = teachersData.teachers || [];\r\n\r\n              // в•Әв•–в”¬Шөв•Әв••в”ҳв•ӣв•Әв•–в”¬в•• в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬В»в•Әв•–в”¬в–’в•Әв•–в”¬в”Ӯв•Әв••в”ҳв•Јв•Әв••ШёВҖШЁ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Шҙв•Әв•–в”¬В»в•Әв•–в”¬В» в•Әв••в”ҳв•ӣв•Әв••в”ҳв•Ј в•Әв••ШёВҖШЈв•Әв•–в”¬ШҜв•Әв•–в”¬в•Јв•Әв•–в”¬В»в•Әв•–в”¬Шұ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Ш°в•Әв••в”ҳв•Јв•Әв•–в”¬ШҜв•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ\r\n              for (const teacher of aiTeachers) {\r\n                try {\r\n                  await prisma.teacher.upsert({\r\n                    where: {\r\n                      // в•Әв•–в”¬ШҜв•Әв•–в”¬в”Ӯв•Әв•–в”Ңв•ӣв•Әв•–в”¬В«в•Әв•–в”¬В»в•Әв•–в”¬ШҜв•Әв••ШёВҖШ® в•Әв•–в”¬ШҜв•Әв•–в”¬в”Ӯв•Әв••ШёВҖШ® в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬В»в•Әв•–в”¬в–’в•Әв•–в”¬в”Ӯ в•Әв••в•ҰВҶв•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬ШҜв•Әв•–в”¬В»в•Әв•–в”¬Шұ в•Әв••в•һЩ’в•Әв••ШёВҖШ®в•Әв••в”ҳв•ӣв•Әв•–в”Ңв•ӣв•Әв•–в”¬ШҜв•Әв•–в”¬Шө в•Әв••в”ҳв•ӣв•Әв•–в”¬в–’в•Әв••в”ҳв•Јв•Әв•–в”¬В»\r\n                      name_subject: {\r\n                        name: teacher.name,\r\n                        subjectId: teacher.subjectId || teacher.subject\r\n                      }\r\n                    },\r\n                    update: {\r\n                      onlineUrl: teacher.url,\r\n                      rating: teacher.rating,\r\n                      notes: teacher.description\r\n                    },\r\n                    create: {\r\n                      name: teacher.name,\r\n                      subjectId: teacher.subjectId || teacher.subject,\r\n                      onlineUrl: teacher.url,\r\n                      rating: teacher.rating,\r\n                      notes: teacher.description\r\n                    }\r\n                  });\r\n                } catch (dbError) {\r\n                  logger.error(\"Error saving teacher to database:\", dbError);\r\n                }\r\n              }\r\n            } catch (parseError) {\r\n              logger.error(\"Error parsing teachers JSON:\", parseError);\r\n            }\r\n          }\r\n        }\r\n      } catch (aiError) {\r\n        logger.error(\"Error with AI provider:\", aiError);\r\n        // в•Әв•–в”¬ШҜв•Әв•–в”¬в”Ӯв•Әв•–в”Ңв•ӣв•Әв••ШёВҖШ®в•Әв•–в”¬в–’ в•Әв•–в”¬Шөв•Әв•–в”Ңв•ӣв•Әв••ШёВҖв–‘ в•Әв••ШёВҖШҰв•Әв••в•ҰВҶ в•Әв••в”ҳв•ӣв•Әв•–в”¬в”Өв•Әв••ШёВҖШҰ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬в–‘в•Әв••в•һЩ’в•Әв•–в”¬ШҜв•Әв•–в•ӘГ® в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬ШҜв•Әв•–в”¬в•Ўв•Әв•–в”¬в•–в•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв•–в”¬в•Јв•Әв••в”ҳв•Ј\r\n      }\r\n\r\n      // в•Әв•–в”¬В»в•Әв••ШёВҖШ®в•Әв•–в”¬Шҙ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШЁв•Әв•–в”Ңв•ӣв•Әв•–в”¬ШҜв•Әв•–в”¬Ш®в•Әв•–в”¬Шҙ в•Әв••ШёВҖШ®в•Әв••ШёВҖШЁ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬в•Ўв•Әв•–в”¬ШҜв•Әв•–в”¬В»в•Әв•–в”¬в–’ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬В«в•Әв•–в”Ңв•ӣв•Әв••ШёВҖШҰв•Әв••в”ҳв•ӣв•Әв•–в”¬Шұ\r\n      // в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”Ңв•ӣв•Әв•–в”¬Ш«в•Әв••в•һЩ’в•Әв•–в”¬В» в•Әв••ШёВҖШ®в•Әв••ШёВҖШЁ в•Әв•–в”¬Ш«в•Әв••ШёВҖШЁ в•Әв•–в”¬Шҙв•Әв••ШёВҖШ®в•Әв••в”ҳв•Јв•Әв•–в”¬в•Ј в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬в•Ўв•Әв••в”ҳв•ӣв•Әв••в•ҰВҶв•Әв••в”ҳв•ӣв•Әв•–в”¬ШҜв•Әв•–в”Ңв•ӣ в•Әв••ШёВҖШ®в•Әв••в•ҰВҶв•Әв•–в”¬Шҙв•Әв••в•ҰВҶв•Әв•–в”¬В»в•Әв•–в”¬Шұ\r\n      const result = {\r\n        localTeachers: localTeachers || [],\r\n        aiTeachers: aiTeachers || [],\r\n        youtubeResults: youtubeResults || [],\r\n        message: \"в•Әв•–в”Ңв•ӣв•Әв••ШёВҖШ® в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬в•Јв•Әв•–в”¬Шів•Әв••в•ҰВҶв•Әв•–в”¬в–’ в•Әв•–в”¬в•Јв•Әв••ШёВҖШҰв•Әв••ШёВҖв–‘ в•Әв••ШёВҖШЈв•Әв•–в”¬ШҜв•Әв•–в”¬Ш®в•Әв••ШёВҖШ®в•Әв•–в”¬Шұ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв••ШёВҖШ®в•Әв•–в”¬В»в•Әв•–в”¬в–’в•Әв•–в”¬в”Ӯв•Әв••в”ҳв•Јв•Әв••ШёВҖШЁ в•Әв•–в”¬Ш°в•Әв••ШёВҖШЁв•Әв•–в”¬Шҙв•Әв•–в”¬ШҜв•Әв•–в”¬Шө\",\r\n        provider: selectedProvider.name\r\n      };\r\n\r\n      return NextResponse.json(result);\r\n    } catch (error) {\r\n      logger.error(\"Error in AI teachers search API:\", error);\r\n      let errorMessage = \"в•Әв•–в”¬Шөв•Әв•–в”¬В»в•Әв•–в”¬Ші в•Әв•–в”¬В«в•Әв•–в”¬в•–в•Әв•–в”¬Ш« в•Әв••в”ҳв•ӣв•Әв••в”ҳв•Ј в•Әв••ШёВҖШ®в•Әв•–в”¬в•Јв•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Шҙв•Әв•–в”¬Шұ в•Әв•–в”¬в•–в•Әв••ШёВҖШҰв•Әв•–в”¬Ш°в•Әв••в•һЩ’\";\r\n\r\n      // в•Әв•–в”Ңв•ӣв•Әв•–в”¬Шөв•Әв•–в”¬В»в•Әв••в”ҳв•Јв•Әв•–в”¬В» в•Әв•–в”¬в–’в•Әв•–в”¬в”Ӯв•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬Шұ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬В«в•Әв•–в”¬в•–в•Әв•–в”¬Ш« в•Әв•–в”¬Ш°в•Әв••ШёВҖШЁв•Әв•–в”¬ШҜв•Әв•–в•ӘГ®в•Әв••ШёВҖв•Ј в•Әв•–в”¬в•Јв•Әв••ШёВҖШҰв•Әв••ШёВҖв–‘ в•Әв••ШёВҖШЁв•Әв••в•ҰВҶв•Әв•–в”¬в•Ј в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”¬В«в•Әв•–в”¬в•–в•Әв•–в”¬Ш«\r\n      if (error instanceof Error) {\r\n        if (error.message.includes(\"API key\")) {\r\n          errorMessage = \"в•Әв••ШёВҖШ®в•Әв••в”ҳв•ӣв•Әв•–в”Ңв•ӣв•Әв•–в”¬ШҜв•Әв•–в”¬Шө API в•Әв••ШёВҖШҰв•Әв••ШёГ©Шҙ Google Gemini в•Әв•–в•ӘШӨв•Әв••в”ҳв•Јв•Әв•–в”¬в–’ в•Әв••ШёВҖШ®в•Әв••ШёВҖШ©в•Әв••в”ҳв•Јв•Әв•–в”¬Ш«. в•Әв••в”ҳв•Јв•Әв•–в”¬в–’в•Әв•–в”¬Шҙв•Әв••ШёВҖв–‘ в•Әв•–в”¬ШҜв•Әв••ШёВҖШҰв•Әв•–в”Ңв•ӣв•Әв••в•ҰВҶв•Әв•–в”¬ШҜв•Әв•–в”¬в•Ўв•Әв••ШёВҖШҰ в•Әв••ШёВҖШ®в•Әв•–в”¬в•Ј в•Әв••в”ҳв•ӣв•Әв•