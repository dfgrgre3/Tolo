п»ҝ[{"filePath":"D:\\thanawy\\src\\app\\(auth)\\forgot-password\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'error' is defined but never used. Allowed unused caught errors must match /^_/u.","line":53,"column":14,"nodeType":null,"messageId":"unusedVar","endLine":53,"endColumn":19}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\n\nimport { useState } from 'react';\nimport { useForm } from 'react-hook-form';\nimport { zodResolver } from '@hookform/resolvers/zod';\nimport { z } from 'zod';\nimport { Mail, Loader2, AlertCircle, CheckCircle2, ArrowRight, ArrowLeft } from 'lucide-react';\nimport Link from 'next/link';\nimport { motion, AnimatePresence } from 'framer-motion';\n\nconst forgotPasswordSchema = z.object({\n  email: z.string().email('Please enter a valid email address'),\n});\n\ntype ForgotPasswordValues = z.infer<typeof forgotPasswordSchema>;\n\nexport default function ForgotPasswordPage() {\n  const [status, setStatus] = useState<{ type: 'error' | 'success'; message: string } | null>(null);\n  const [isLoading, setIsLoading] = useState(false);\n\n  const {\n    register,\n    handleSubmit,\n    formState: { errors },\n  } = useForm<ForgotPasswordValues>({\n    resolver: zodResolver(forgotPasswordSchema),\n  });\n\n  const onSubmit = async (data: ForgotPasswordValues) => {\n    setIsLoading(true);\n    setStatus(null);\n\n    try {\n      const response = await fetch('/api/auth/forgot-password', {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify(data),\n      });\n\n      const result = await response.json();\n\n      if (response.ok) {\n        setStatus({\n          type: 'success',\n          message: result.message || 'If an account exists, a reset link has been sent.',\n        });\n      } else {\n        setStatus({\n          type: 'error',\n          message: result.error || 'Something went wrong. Please try again.',\n        });\n      }\n    } catch (error) {\n      setStatus({\n        type: 'error',\n        message: 'Network error. Please check your connection.',\n      });\n    }\n\n    setIsLoading(false);\n  };\n\n  return (\n    <motion.div\n      initial={{ opacity: 0, y: 20 }}\n      animate={{ opacity: 1, y: 0 }}\n      transition={{ duration: 0.4 }}\n    >\n      <div className=\"mb-8\">\n        <h2 className=\"text-2xl font-bold text-white mb-2\">Forgot Password?</h2>\n        <p className=\"text-gray-400 text-sm\">No worries, enter your email and we&apos;ll send you a reset link.</p>\n      </div>\n\n      <AnimatePresence>\n        {status && (\n          <motion.div \n            initial={{ opacity: 0, height: 0 }}\n            animate={{ opacity: 1, height: 'auto' }}\n            exit={{ opacity: 0, height: 0 }}\n            className={`mb-6 p-4 rounded-xl flex items-center gap-3 border ${\n              status.type === 'error' \n                ? 'bg-red-500/10 border-red-500/20 text-red-500' \n                : 'bg-green-500/10 border-green-500/20 text-green-400'\n            }`}\n          >\n            {status.type === 'error' ? (\n              <AlertCircle className=\"w-5 h-5 flex-shrink-0\" />\n            ) : (\n              <CheckCircle2 className=\"w-5 h-5 flex-shrink-0\" />\n            )}\n            <p className=\"text-sm font-medium\">{status.message}</p>\n          </motion.div>\n        )}\n      </AnimatePresence>\n\n      <form onSubmit={handleSubmit(onSubmit)} className=\"space-y-6\">\n        <div className=\"space-y-2\">\n          <label htmlFor=\"forgot-email\" className=\"text-sm font-medium text-gray-300 ml-1\">Email Address</label>\n          <div className=\"relative group\">\n            <div className=\"absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none\">\n              <Mail className=\"h-5 w-5 text-gray-500 group-focus-within:text-blue-500 transition-colors\" />\n            </div>\n            <input\n              id=\"forgot-email\"\n              {...register('email')}\n              type=\"email\"\n              disabled={isLoading || status?.type === 'success'}\n              className=\"w-full pl-11 pr-4 py-3 bg-gray-950/50 border border-gray-800 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all outline-none text-white placeholder-gray-600 disabled:opacity-50\"\n              placeholder=\"you@example.com\"\n            />\n          </div>\n          {errors.email && (\n            <p className=\"text-xs text-red-400 ml-1 mt-1 font-medium\">{errors.email.message}</p>\n          )}\n        </div>\n\n        <button\n          type=\"submit\"\n          disabled={isLoading || status?.type === 'success'}\n          className=\"w-full py-3.5 px-4 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 text-white rounded-xl font-semibold shadow-lg shadow-blue-500/25 hover:shadow-blue-500/40 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:ring-offset-gray-900 transition-all disabled:opacity-70 disabled:cursor-not-allowed group flex justify-center items-center gap-2\"\n        >\n          {isLoading ? (\n            <><Loader2 className=\"w-5 h-5 animate-spin\" /> Sending...</>\n          ) : (\n            <>Send reset link <ArrowRight className=\"w-4 h-4 group-hover:translate-x-1 transition-transform\" /></>\n          )}\n        </button>\n      </form>\n\n      <div className=\"mt-8 text-center\">\n        <Link href=\"/login\" className=\"inline-flex items-center gap-2 text-sm font-medium text-gray-400 hover:text-white transition-colors\">\n          <ArrowLeft className=\"w-4 h-4\" /> Back to login\n        </Link>\n      </div>\n    </motion.div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(auth)\\layout.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(auth)\\login\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'error' is defined but never used. Allowed unused caught errors must match /^_/u.","line":135,"column":14,"nodeType":null,"messageId":"unusedVar","endLine":135,"endColumn":19}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\n\nimport { useCallback, useEffect, useMemo, useState } from 'react';\nimport { useForm } from 'react-hook-form';\nimport { zodResolver } from '@hookform/resolvers/zod';\nimport { z } from 'zod';\nimport { useRouter, useSearchParams } from 'next/navigation';\nimport { Mail, Lock, Loader2, AlertCircle, ArrowRight, Eye, EyeOff, Github, Chrome, Wand2 } from 'lucide-react';\nimport Link from 'next/link';\nimport { motion, AnimatePresence } from 'framer-motion';\nimport { useAuth } from '@/contexts/auth-context';\nimport {\n  DEFAULT_AUTHENTICATED_ROUTE,\n  sanitizeRedirectPath,\n} from '@/lib/auth/navigation';\n\nconst loginSchema = z.object({\n  email: z.string().trim().email('в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШӯв•ӘВ»в•ӘВ«в•ӘШҜв”ҳВ„ в•ӘШ°в•Әв–’в”ҳГЁв•ӘВ» в•ӘШӯв”ҳВ„в”ҳГўв•ӘШІв•Әв–’в”ҳГӘв”ҳВҶв”ҳГЁ в•Әв•Ўв•ӘШөв”ҳГЁв•ӘШө'),\n  password: z.string().min(1, 'в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в”ҳГ в•Әв•–в”ҳВ„в”ҳГӘв•ӘШ°в•ӘШұ'),\n  rememberMe: z.boolean().optional(),\n});\n\ntype LoginFormValues = z.infer<typeof loginSchema>;\n\nexport default function LoginPage() {\n  const router = useRouter();\n  const searchParams = useSearchParams();\n  const { login, isAuthenticated, isLoading: isAuthLoading } = useAuth();\n  const [errorStatus, setErrorStatus] = useState<string | null>(null);\n  const [isSubmitting, setIsSubmitting] = useState(false);\n  const [showPassword, setShowPassword] = useState(false);\n  const [loginMode, setLoginMode] = useState<'password' | 'magic-link'>('password');\n  const [requires2FA, setRequires2FA] = useState(false);\n  const [userId2FA, setUserId2FA] = useState<string | null>(null);\n  const [twoFactorCode, setTwoFactorCode] = useState('');\n  const { verify2FA } = useAuth();\n\n  const redirectUrl = useMemo(\n    () => sanitizeRedirectPath(searchParams.get('redirect'), DEFAULT_AUTHENTICATED_ROUTE),\n    [searchParams]\n  );\n\n  const {\n    register,\n    handleSubmit,\n    getValues,\n    formState: { errors },\n  } = useForm<LoginFormValues>({\n    resolver: zodResolver(loginSchema),\n    defaultValues: { rememberMe: false },\n  });\n\n  const redirectAfterLogin = useCallback((target: string) => {\n    router.replace(target);\n    router.refresh();\n  }, [router]);\n\n  useEffect(() => {\n    if (!isAuthLoading && isAuthenticated) {\n      redirectAfterLogin(redirectUrl);\n    }\n  }, [isAuthLoading, isAuthenticated, redirectAfterLogin, redirectUrl]);\n\n  const onSubmit = async (data: LoginFormValues) => {\n    if (isAuthLoading || isAuthenticated) return;\n    setIsSubmitting(true);\n    setErrorStatus(null);\n\n    try {\n      const result = await login(\n        data.email.trim().toLowerCase(),\n        data.password,\n        data.rememberMe ?? false\n      );\n\n      if (result.success) {\n        if (result.requires2FA) {\n          setRequires2FA(true);\n          setUserId2FA(result.userId || null);\n          return;\n        }\n        redirectAfterLogin(redirectUrl);\n        return;\n      }\n      setErrorStatus(result.error || 'в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ«.');\n    } finally {\n      setIsSubmitting(false);\n    }\n  };\n\n  const onVerify2FA = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!userId2FA || twoFactorCode.length < 6) return;\n    \n    setIsSubmitting(true);\n    setErrorStatus(null);\n    try {\n      const result = await verify2FA(userId2FA, twoFactorCode, getValues('rememberMe'));\n      if (result.success) {\n        redirectAfterLogin(redirectUrl);\n        return;\n      }\n      setErrorStatus(result.error || 'в•Әв–’в”ҳГ в•Әв–“ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в•Әв•‘в”ҳГЁв•Әв–’ в•Әв•Ўв•ӘШөв”ҳГЁв•ӘШө');\n    } finally {\n      setIsSubmitting(false);\n    }\n  };\n\n  const handleSocialLogin = (provider: string) => {\n    window.location.href = `/api/auth/oauth/${provider}`;\n  };\n\n  const handleMagicLinkRequest = async () => {\n    const email = getValues('email');\n    if (!email || !email.includes('@')) {\n      setErrorStatus('в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШӯв•ӘВ»в•ӘВ«в•ӘШҜв”ҳВ„ в•ӘШ°в•Әв–’в”ҳГЁв•ӘВ» в•ӘШӯв”ҳВ„в”ҳГўв•ӘШІв•Әв–’в”ҳГӘв”ҳВҶв”ҳГЁ в•Әв•Ўв•ӘШөв”ҳГЁв•ӘШө в•ӘШ«в”ҳГӘв”ҳВ„в•ӘШҜв”ҳГҜ');\n      return;\n    }\n\n    setIsSubmitting(true);\n    setErrorStatus(null);\n    try {\n      const response = await fetch('/api/auth/magic-link/request', {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({ email }),\n      });\n      const data = await response.json();\n      \n      if (response.ok) {\n        alert('в•ӘШІв”ҳВҒв”ҳГ©в•ӘВ» в•ӘШ°в•Әв–’в”ҳГЁв•ӘВ»в”ҳГў в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВ„в”ҳГўв•ӘШІв•Әв–’в”ҳГӘв”ҳВҶв”ҳГЁ! в•ӘШ«в•Әв–’в•Әв”Ӯв”ҳВ„в”ҳВҶв•ӘШҜ в”ҳВ„в”ҳГў в•Әв–’в•ӘШҜв•ӘШ°в•Әв•– в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв”Ӯв•ӘШөв•Әв–’в”ҳГЁ.');\n      } else {\n        setErrorStatus(data.error || 'в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҜв•ӘШ°в•Әв•–');\n      }\n    } catch (error) {\n      setErrorStatus('в•ӘВ«в•Әв•–в•ӘШ« в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„ в•ӘШ°в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШҜв•ӘВ»в”ҳГ ');\n    } finally {\n      setIsSubmitting(false);\n    }\n  };\n\n  if (isAuthLoading || isAuthenticated) {\n    return (\n      <div className=\"flex min-h-[400px] flex-col items-center justify-center space-y-4 text-center\">\n        <div className=\"relative\">\n          <div className=\"h-16 w-16 animate-spin rounded-full border-4 border-blue-500/20 border-t-blue-500\"></div>\n          <div className=\"absolute inset-0 flex items-center justify-center\">\n            <div className=\"h-8 w-8 animate-pulse rounded-full bg-blue-500/20\"></div>\n          </div>\n        </div>\n        <p className=\"animate-pulse text-sm font-medium text-blue-400\">в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в”ҳГ в”ҳВҶ в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШІв”ҳГў...</p>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"relative w-full max-w-md mx-auto\">\n      {/* Decorative background elements */}\n      <div className=\"absolute -top-24 -left-20 h-64 w-64 rounded-full bg-blue-600/10 blur-3xl\" />\n      <div className=\"absolute -bottom-24 -right-20 h-64 w-64 rounded-full bg-indigo-600/10 blur-3xl\" />\n\n      <motion.div\n        initial={{ opacity: 0, y: 20 }}\n        animate={{ opacity: 1, y: 0 }}\n        transition={{ duration: 0.5, ease: \"easeOut\" }}\n        className=\"relative overflow-hidden rounded-3xl border border-white/10 bg-gray-950/40 p-8 backdrop-blur-xl shadow-2xl\"\n      >\n        <div className=\"mb-8 text-right\">\n          <h2 className=\"text-3xl font-bold tracking-tight text-white mb-2\">в”ҳГ в•Әв–’в•ӘШөв•ӘШ°в•ӘШҜв”ҳГҜ в•ӘШ°в”ҳГў в”ҳГ в•ӘШҙв•ӘВ»в•ӘВ»в•ӘШҜв”ҳГҜ</h2>\n          <p className=\"text-gray-400\">в•Әв”Ӯв•ӘШҙв”ҳВ„ в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„в”ҳГў в”ҳВ„в•ӘШІв”ҳГўв”ҳГ в”ҳВ„ в•Әв–’в•ӘШөв”ҳВ„в•ӘШІв”ҳГў в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Јв”ҳВ„в”ҳГЁв”ҳГ в”ҳГЁв•ӘШұ</p>\n        </div>\n\n        {/* Social Logins */}\n        <div className=\"mb-8 grid grid-cols-2 gap-4\">\n          <button\n            onClick={() => handleSocialLogin('google')}\n            className=\"flex items-center justify-center gap-2 rounded-2xl border border-white/5 bg-white/5 py-3 transition-all hover:bg-white/10 hover:border-white/10 active:scale-95\"\n          >\n            <Chrome className=\"h-5 w-5 text-red-400\" />\n            <span className=\"text-sm font-medium text-white\">Google</span>\n          </button>\n          <button\n            onClick={() => handleSocialLogin('github')}\n            className=\"flex items-center justify-center gap-2 rounded-2xl border border-white/5 bg-white/5 py-3 transition-all hover:bg-white/10 hover:border-white/10 active:scale-95\"\n          >\n            <Github className=\"h-5 w-5 text-white\" />\n            <span className=\"text-sm font-medium text-white\">Github</span>\n          </button>\n        </div>\n\n        <div className=\"relative mb-8 flex items-center justify-center\">\n          <div className=\"absolute inset-0 flex items-center\">\n            <div className=\"w-full border-t border-white/5\"></div>\n          </div>\n          <span className=\"relative bg-gray-950 px-4 text-xs font-medium uppercase tracking-wider text-gray-500\">в•ӘШ«в”ҳГӘ в•Әв•Јв•ӘШ°в•Әв–’ в•ӘШҜв”ҳВ„в•ӘШ°в•Әв–’в”ҳГЁв•ӘВ»</span>\n        </div>\n\n        <AnimatePresence mode=\"wait\">\n          {errorStatus && (\n            <motion.div\n              initial={{ opacity: 0, scale: 0.95, x: 0 }}\n              animate={{ opacity: 1, scale: 1, x: [0, -10, 10, -10, 10, 0] }}\n              exit={{ opacity: 0, scale: 0.95 }}\n              transition={{ duration: 0.4 }}\n              className=\"mb-6 flex items-center gap-3 rounded-2xl border border-red-500/20 bg-red-500/10 p-4 text-red-500\"\n            >\n              <AlertCircle className=\"h-5 w-5 flex-shrink-0\" />\n              <p className=\"text-sm font-medium\">{errorStatus}</p>\n            </motion.div>\n          )}\n        </AnimatePresence>\n\n        <div className=\"space-y-6\">\n          {!requires2FA ? (\n            <>\n              <div className=\"space-y-2\">\n                <label className=\"mr-1 text-sm font-medium text-gray-300\">в•ӘШҜв”ҳВ„в•ӘШ°в•Әв–’в”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВ„в”ҳГўв•ӘШІв•Әв–’в”ҳГӘв”ҳВҶв”ҳГЁ</label>\n                <div className=\"group relative\">\n                  <input\n                    {...register('email')}\n                    type=\"email\"\n                    className=\"w-full rounded-2xl border border-white/5 bg-white/5 py-3.5 pr-11 pl-4 text-white outline-none transition-all placeholder:text-gray-600 focus:border-blue-500/50 focus:ring-4 focus:ring-blue-500/10 disabled:opacity-50\"\n                    placeholder=\"name@example.com\"\n                    dir=\"rtl\"\n                  />\n                  <Mail className=\"absolute right-4 top-1/2 -translate-y-1/2 h-5 w-5 text-gray-500 transition-colors group-focus-within:text-blue-500\" />\n                </div>\n                {errors.email && <p className=\"mr-1 mt-1 text-xs font-medium text-red-400\">{errors.email.message}</p>}\n              </div>\n\n              <AnimatePresence>\n                {loginMode === 'password' && (\n                  <motion.div\n                    initial={{ opacity: 0, height: 0 }}\n                    animate={{ opacity: 1, height: 'auto' }}\n                    exit={{ opacity: 0, height: 0 }}\n                    className=\"space-y-2\"\n                  >\n                    <div className=\"mr-1 flex items-center justify-between\">\n                      <label className=\"text-sm font-medium text-gray-300\">в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’</label>\n                      <Link href=\"/forgot-password\" className=\"text-xs font-medium text-blue-400 hover:text-blue-300 transition-colors\">в”ҳВҶв•Әв”Ӯв”ҳГЁв•ӘШІ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’в•ӘШ§</Link>\n                    </div>\n                    <div className=\"group relative\">\n                      <input\n                        {...register('password')}\n                        type={showPassword ? 'text' : 'password'}\n                        className=\"w-full rounded-2xl border border-white/5 bg-white/5 py-3.5 pr-11 pl-12 text-white outline-none transition-all placeholder:text-gray-600 focus:border-blue-500/50 focus:ring-4 focus:ring-blue-500/10 disabled:opacity-50\"\n                        placeholder=\"ШёВҖШӘШёВҖШӘШёВҖШӘШёВҖШӘШёВҖШӘШёВҖШӘШёВҖШӘШёВҖШӘ\"\n                        dir=\"rtl\"\n                      />\n                      <Lock className=\"absolute right-4 top-1/2 -translate-y-1/2 h-5 w-5 text-gray-500 transition-colors group-focus-within:text-blue-500\" />\n                      <button\n                        type=\"button\"\n                        onClick={() => setShowPassword(!showPassword)}\n                        className=\"absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 hover:text-white transition-colors\"\n                      >\n                        {showPassword ? <EyeOff className=\"h-5 w-5\" /> : <Eye className=\"h-5 w-5\" />}\n                      </button>\n                    </div>\n                    {errors.password && <p className=\"mr-1 mt-1 text-xs font-medium text-red-400\">{errors.password.message}</p>}\n                  </motion.div>\n                )}\n              </AnimatePresence>\n\n              <div className=\"flex items-center justify-between mr-1\">\n                <div className=\"flex items-center gap-2 cursor-pointer group\">\n                  <input\n                    {...register('rememberMe')}\n                    type=\"checkbox\"\n                    id=\"rememberMe\"\n                    className=\"h-4 w-4 rounded border-white/10 bg-white/5 text-blue-500 focus:ring-blue-500/20\"\n                  />\n                  <label htmlFor=\"rememberMe\" className=\"text-xs text-gray-400 group-hover:text-gray-300 transition-colors cursor-pointer\">в•ӘШІв•Әв–‘в”ҳГўв•Әв–’в”ҳВҶв”ҳГЁ в”ҳВ„в”ҳГ в•ӘВ»в•ӘШұ 7 в•ӘШ«в”ҳГЁв•ӘШҜв”ҳГ </label>\n                </div>\n                \n                <button\n                  type=\"button\"\n                  onClick={() => setLoginMode(loginMode === 'password' ? 'magic-link' : 'pas