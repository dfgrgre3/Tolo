lassName=\"flex items-start justify-between gap-2 mb-1\">\r\n                      <h4 className=\"font-semibold text-base\">\r\n                        {activity.title}\r\n                      </h4>\r\n                      <Badge className={activityBadgeColors[activity.type]}>\r\n                        {activityLabels[activity.type]}\r\n                      </Badge>\r\n                    </div>\r\n                    <p className=\"text-sm text-muted-foreground line-clamp-2\">\r\n                      {activity.description}\r\n                    </p>\r\n                    <div className=\"flex items-center gap-3 mt-2\">\r\n                      <div className=\"flex items-center gap-1 text-xs text-muted-foreground\">\r\n                        <Clock className=\"h-3 w-3\" />\r\n                        <span>\r\n                          {new Date(activity.timestamp).toLocaleDateString(\"ar-EG\", {\r\n                            year: \"numeric\",\r\n                            month: \"long\",\r\n                            day: \"numeric\",\r\n                            hour: \"2-digit\",\r\n                            minute: \"2-digit\",\r\n                          })}\r\n                        </span>\r\n                      </div>\r\n                      {activity.xp && (\r\n                        <Badge variant=\"outline\" className=\"text-xs\">\r\n                          +{activity.xp} XP\r\n                        </Badge>\r\n                      )}\r\n                    </div>\r\n                  </div>\r\n                </motion.div>\r\n              );\r\n            })}\r\n          </div>\r\n        </CardContent>\r\n      </Card>\r\n    </motion.div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\profile\\components\\SecurityLogs.tsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'loadSecurityEvents'. Either include it or remove the dependency array.","line":66,"column":6,"nodeType":"ArrayExpression","endLine":66,"endColumn":22,"suggestions":[{"desc":"Update the dependencies array to be: [userId, filter, loadSecurityEvents]","fix":{"range":[3321,3337],"text":"[userId, filter, loadSecurityEvents]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\r\n\r\nimport { useState, useEffect } from 'react';\r\nimport { Card, CardContent, CardDescription, CardHeader, CardTitle } from \"@/components/ui/card\";\r\nimport { Badge } from \"@/components/ui/badge\";\r\nimport { Button } from \"@/components/ui/button\";\r\nimport { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from \"@/components/ui/select\";\r\nimport { Input } from \"@/components/ui/input\";\r\nimport { AlertTriangle, CheckCircle2, XCircle, Shield, Lock, Key, Mail, Bell } from \"lucide-react\";\r\nimport { Separator } from \"@/components/ui/separator\";\r\n\r\nimport { logger } from '@/lib/logger';\r\n\r\ninterface SecurityEvent {\r\n  id: string;\r\n  eventType: string;\r\n  ip: string;\r\n  userAgent: string;\r\n  deviceInfo?: any;\r\n  location?: string;\r\n  metadata?: any;\r\n  createdAt: string;\r\n  riskLevel?: 'low' | 'medium' | 'high' | 'critical';\r\n}\r\n\r\ninterface SecurityLogsProps {\r\n  userId: string;\r\n}\r\n\r\nconst eventTypeLabels: Record<string, { label: string; color: string; icon: any }> = {\r\n  LOGIN_SUCCESS: { label: 'в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳВҶв•ӘШҜв•ӘШҙв•ӘШө', color: 'bg-green-100 text-green-800', icon: CheckCircle2 },\r\n  LOGIN_FAILED: { label: 'в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳВҒв•ӘШҜв•Әв”Өв”ҳВ„в•ӘШұ', color: 'bg-red-100 text-red-800', icon: XCircle },\r\n  LOGIN_NEW_DEVICE: { label: 'в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳГ в”ҳВҶ в•ӘШҙв”ҳГ§в•ӘШҜв•Әв–“ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»', color: 'bg-yellow-100 text-yellow-800', icon: AlertTriangle },\r\n  LOGOUT: { label: 'в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘВ«в•Әв–’в”ҳГӘв•ӘШҙ', color: 'bg-blue-100 text-blue-800', icon: Key },\r\n  LOGOUT_ALL: { label: 'в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘВ«в•Әв–’в”ҳГӘв•ӘШҙ в”ҳГ в”ҳВҶ в•ӘШҙв”ҳГ в”ҳГЁв•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШ«в•ӘШҙв”ҳГ§в•Әв–“в•ӘШұ', color: 'bg-blue-100 text-blue-800', icon: Key },\r\n  PASSWORD_CHANGED: { label: 'в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’', color: 'bg-purple-100 text-purple-800', icon: Lock },\r\n  PASSWORD_RESET_REQUESTED: { label: 'в•Әв•–в”ҳВ„в•ӘШ° в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШІв•Әв•Јв”ҳГЁв”ҳГЁв”ҳВҶ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’', color: 'bg-orange-100 text-orange-800', icon: Mail },\r\n  TWO_FACTOR_ENABLED: { label: 'в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Ўв•ӘШҜв•ӘВ»в”ҳГ©в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШів”ҳВҶв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШұ', color: 'bg-green-100 text-green-800', icon: Shield },\r\n  TWO_FACTOR_DISABLED: { label: 'в•ӘШІв•Әв•Јв•Әв•–в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Ўв•ӘШҜв•ӘВ»в”ҳГ©в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШів”ҳВҶв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШұ', color: 'bg-red-100 text-red-800', icon: Shield },\r\n  TWO_FACTOR_SUCCESS: { label: 'в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Ўв•ӘШҜв•ӘВ»в”ҳГ©в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШів”ҳВҶв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШұ в”ҳВҶв•ӘШҜв•ӘШҙв•ӘШөв•ӘШұ', color: 'bg-green-100 text-green-800', icon: CheckCircle2 },\r\n  TWO_FACTOR_FAILED: { label: 'в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Ўв•ӘШҜв•ӘВ»в”ҳГ©в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШів”ҳВҶв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШұ', color: 'bg-red-100 text-red-800', icon: XCircle },\r\n  SECURITY_ALERT: { label: 'в•ӘШІв”ҳВҶв•ӘШ°в”ҳГЁв”ҳГ§ в•ӘШ«в”ҳГ в”ҳВҶв”ҳГЁ', color: 'bg-red-100 text-red-800', icon: AlertTriangle },\r\n  SUSPICIOUS_ACTIVITY: { label: 'в”ҳВҶв•Әв”Өв•ӘШҜв•Әв•– в”ҳГ в•Әв”Өв•ӘШ°в”ҳГӘв”ҳГ§', color: 'bg-red-100 text-red-800', icon: AlertTriangle },\r\n  IP_WHITELIST_ADDED: { label: 'в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ IP в”ҳВ„в”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•Әв•ўв•ӘШҜв•ӘШ©', color: 'bg-blue-100 text-blue-800', icon: Shield },\r\n  IP_WHITELIST_REMOVED: { label: 'в•ӘШӯв•Әв–“в•ӘШҜв”ҳВ„в•ӘШұ IP в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•Әв•ўв•ӘШҜв•ӘШ©', color: 'bg-orange-100 text-orange-800', icon: Shield },\r\n};\r\n\r\nexport default function SecurityLogs({ userId }: SecurityLogsProps) {\r\n  const [events, setEvents] = useState<SecurityEvent[]>([]);\r\n  const [loading, setLoading] = useState(true);\r\n  const [filter, setFilter] = useState<string>('all');\r\n  const [searchQuery, setSearchQuery] = useState('');\r\n  const [hasNotifications, setHasNotifications] = useState(false);\r\n\r\n  useEffect(() => {\r\n    loadSecurityEvents();\r\n    checkForNewAlerts();\r\n    \r\n    // Setup polling for new security alerts\r\n    const interval = setInterval(() => {\r\n      checkForNewAlerts();\r\n      loadSecurityEvents();\r\n    }, 30000); // Check every 30 seconds\r\n    \r\n    return () => clearInterval(interval);\r\n  }, [userId, filter]);\r\n\r\n  const loadSecurityEvents = async () => {\r\n    try {\r\n      setLoading(true);\r\n      // Token is in httpOnly cookie - no need to send Authorization header\r\n      \r\n      const params = new URLSearchParams();\r\n      if (filter !== 'all') {\r\n        params.append('eventType', filter);\r\n      }\r\n      params.append('limit', '50');\r\n\r\n      const response = await fetch(`/api/auth/security-logs?${params.toString()}`, {\r\n        credentials: 'include',\r\n      });\r\n\r\n      if (response.ok) {\r\n        const data = await response.json();\r\n        setEvents(data.logs || []);\r\n      } else {\r\n        logger.error('Failed to load security events');\r\n      }\r\n    } catch (error) {\r\n      logger.error('Error loading security events:', error);\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  };\r\n\r\n  const checkForNewAlerts = async () => {\r\n    try {\r\n      // Token is in httpOnly cookie - no need to send Authorization header\r\n      const response = await fetch('/api/auth/security-logs?eventType=SECURITY_ALERT&limit=1', {\r\n        credentials: 'include',\r\n      });\r\n\r\n      if (response.ok) {\r\n        const data = await response.json();\r\n        const recentAlerts = data.logs?.filter((log: SecurityEvent) => {\r\n          const alertTime = new Date(log.createdAt).getTime();\r\n          const fiveMinutesAgo = Date.now() - 5 * 60 * 1000;\r\n          return alertTime > fiveMinutesAgo;\r\n        });\r\n        \r\n        if (recentAlerts && recentAlerts.length > 0) {\r\n          setHasNotifications(true);\r\n          // Show browser notification if permission granted\r\n          if (Notification.permission === 'granted') {\r\n            new Notification('в•ӘШІв”ҳВҶв•ӘШ°в”ҳГЁв”ҳГ§ в•ӘШ«в”ҳГ в”ҳВҶв”ҳГЁ', {\r\n              body: 'в•ӘШІв”ҳГ  в•ӘШҜв”ҳГўв•ӘШІв•Әв”Өв•ӘШҜв”ҳВҒ в”ҳВҶв•Әв”Өв•ӘШҜв•Әв•– в•ӘШ«в”ҳГ в”ҳВҶв”ҳГЁ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ» в”ҳВҒв”ҳГЁ в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°в”ҳГў',\r\n              icon: '/icon-192x192.png',\r\n            });\r\n          }\r\n        }\r\n      }\r\n    } catch (error) {\r\n      logger.error('Error checking for alerts:', error);\r\n    }\r\n  };\r\n\r\n  const requestNotificationPermission = async () => {\r\n    if ('Notification' in window && Notification.permission === 'default') {\r\n      await Notification.requestPermission();\r\n    }\r\n  };\r\n\r\n  useEffect(() => {\r\n    requestNotificationPermission();\r\n  }, []);\r\n\r\n  const filteredEvents = events.filter(event => {\r\n    if (searchQuery) {\r\n      const query = searchQuery.toLowerCase();\r\n      return (\r\n        event.ip.toLowerCase().includes(query) ||\r\n        event.location?.toLowerCase().includes(query) ||\r\n        event.eventType.toLowerCase().includes(query) ||\r\n        eventTypeLabels[event.eventType]?.label.toLowerCase().includes(query)\r\n      );\r\n    }\r\n    return true;\r\n  });\r\n\r\n  const formatDate = (dateString: string) => {\r\n    return new Date(dateString).toLocaleString('ar-EG', {\r\n      year: 'numeric',\r\n      month: 'long',\r\n      day: 'numeric',\r\n      hour: '2-digit',\r\n      minute: '2-digit',\r\n    });\r\n  };\r\n\r\n  const getRiskLevelBadge = (riskLevel?: string) => {\r\n    if (!riskLevel) return null;\r\n    \r\n    const colors: Record<string, string> = {\r\n      low: 'bg-green-100 text-green-800',\r\n      medium: 'bg-yellow-100 text-yellow-800',\r\n      high: 'bg-orange-100 text-orange-800',\r\n      critical: 'bg-red-100 text-red-800',\r\n    };\r\n\r\n    const labels: Record<string, string> = {\r\n      low: 'в”ҳГ в”ҳВҶв•ӘВ«в”ҳВҒв•Әв•ў',\r\n      medium: 'в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•–',\r\n      high: 'в•Әв•Јв•ӘШҜв”ҳВ„в”ҳГЁ',\r\n      critical: 'в•ӘШөв•Әв–’в•ӘШҙ',\r\n    };\r\n\r\n    return (\r\n      <Badge className={colors[riskLevel] || 'bg-gray-100 text-gray-800'}>\r\n        {labels[riskLevel] || riskLevel}\r\n      </Badge>\r\n    );\r\n  };\r\n\r\n  if (loading) {\r\n    return (\r\n      <div className=\"flex justify-center items-center p-8\">\r\n        <div className=\"animate-spin rounded-full h-8 w-8 border-b-2 border-primary\"></div>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      <Card>\r\n        <CardHeader>\r\n          <div className=\"flex justify-between items-center\">\r\n            <div>\r\n              <CardTitle className=\"flex items-center gap-2\">\r\n                <Bell className=\"h-5 w-5\" />\r\n                в•ӘШҜв”ҳВ„в•Әв”Ӯв•ӘШҙв”ҳВ„в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ в”ҳВҶв”ҳГЁв•ӘШұ\r\n                {hasNotifications && (\r\n                  <Badge className=\"bg-red-500 text-white animate-pulse\">\r\n                    в•ӘШІв”ҳВҶв•ӘШ°в”ҳГЁв”ҳГ§в•ӘШҜв•ӘШІ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ\r\n                  </Badge>\r\n                )}\r\n              </CardTitle>\r\n              <CardDescription>\r\n                в•Әв”Ӯв•ӘШҙв”ҳВ„ в•Әв”Өв•ӘШҜв”ҳГ в”ҳВ„ в”ҳВ„в•ӘШҙв”ҳГ в”ҳГЁв•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШ«в•ӘШөв•ӘВ»в•ӘШҜв•ӘШі в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ в”ҳВҶв”ҳГЁв•ӘШұ в”ҳВҒв”ҳГЁ в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°в”ҳГў. в”ҳГЁв•ӘШІв”ҳГ  в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҙв”ҳГ в”ҳГЁв•Әв•Ј в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШҜв•ӘШІ в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„в•ӘГ® в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’в•ӘШҜв•ӘШІ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’в•ӘГ® в”ҳГӘв•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„/в•ӘШӯв”ҳВ„в•Әв•‘в•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Ўв•ӘШҜв•ӘВ»в”ҳГ©в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШів”ҳВҶв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШұ.\r\n              </CardDescription>\r\n            </div>\r\n          </div>\r\n        </CardHeader>\r\n        <CardContent className=\"space-y-4\">\r\n          <div className=\"flex gap-4 flex-wrap\">\r\n            <div className=\"flex-1 min-w-[200px]\">\r\n              <Input\r\n                placeholder=\"в•ӘШ°в•ӘШөв•ӘШі в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•Әв”Ӯв•ӘШҙв”ҳВ„в•ӘШҜв•ӘШІ...\"\r\n                value={searchQuery}\r\n                onChange={(e) => setSearchQuery(e.target.value)}\r\n              />\r\n            </div>\r\n            <Select value={filter} onValueChange={setFilter}>\r\n              <SelectTrigger className=\"w-[200px]\">\r\n                <SelectValue placeholder=\"в•ӘШІв•Әв•Ўв”ҳВҒв”ҳГЁв•ӘШұ в•ӘШөв•Әв”Ӯв•ӘШ° в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГӘв•Әв•Ј\" />\r\n              </SelectTrigger>\r\n              <SelectContent>\r\n                <SelectItem value=\"all\">в•ӘШҙв”ҳГ в”ҳГЁв•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШ«в•ӘШөв•ӘВ»в•ӘШҜв•ӘШі</SelectItem>\r\n                <SelectItem value=\"LOGIN_SUCCESS\">в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„в•ӘШҜв•ӘШІ в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳВҶв•ӘШҜв•ӘШҙв•ӘШөв•ӘШұ</SelectItem>\r\n                <SelectItem value=\"LOGIN_FAILED\">в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШҜв•ӘШІ в”ҳВҒв•ӘШҜв•Әв”Өв”ҳВ„в•ӘШұ</SelectItem>\r\n                <SelectItem value=\"LOGIN_NEW_DEVICE\">в•ӘШ«в•ӘШҙв”ҳГ§в•Әв–“в•ӘШұ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ</SelectItem>\r\n                <SelectItem value=\"TWO_FACTOR_ENABLED\">в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„ 2FA</SelectItem>\r\n                <SelectItem value=\"TWO_FACTOR_DISABLED\">в•ӘШІв•Әв•Јв•Әв•–в”ҳГЁв”ҳВ„ 2FA</SelectItem>\r\n                <SelectItem value=\"PASSWORD_CHANGED\">в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’</SelectItem>\r\n                <SelectItem value=\"SECURITY_ALERT\">в•ӘШІв”ҳВҶв•ӘШ°в”ҳГЁв”ҳГ§в•ӘШҜв•ӘШІ в•ӘШ«в”ҳГ в”ҳВҶв”ҳГЁв•ӘШұ</SelectItem>\r\n                <SelectItem value=\"SUSPICIOUS_ACTIVITY\">в”ҳВҶв•Әв”Өв•ӘШҜв•Әв•– в”ҳГ в•Әв”Өв•ӘШ°в”ҳГӘв”ҳГ§</SelectItem>\r\n              </SelectContent>\r\n            </Select>\r\n          </div>\r\n\r\n          <Separator />\r\n\r\n          <div className=\"space-y-3\">\r\n            {filteredEvents.length > 0 ? (\r\n              filteredEvents.map((event) => {\r\n                const eventType = eventTypeLabels[event.eventType] || {\r\n                  label: event.eventType,\r\n                  color: 'bg-gray-100 text-gray-800',\r\n                  icon: Shield,\r\n                };\r\n                const Icon = eventType.icon;\r\n\r\n                return (\r\n                  <div\r\n                    key={event.id}\r\n                    className=\"p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors\"\r\n                  >\r\n                    <div className=\"flex items-start justify-between gap-4\">\r\n                      <div className=\"flex items-start gap-3 flex-1\">\r\n                        <div className={`p-2 rounded-lg ${eventType.color.replace('text-', 'bg-').replace('bg-', 'bg-').split(' ')[0]}/10`}>\r\n                          <Icon className={`h-5 w-5 ${eventType.color.split(' ')[1] || 'text-gray-800'}`} />\r\n                        </div>\r\n                        <div className=\"flex-1 space-y-2\">\r\n                          <div className=\"flex items-center gap-2 flex-wrap\">\r\n                            <Badge className={eventType.color}>\r\n                              {eventType.lab