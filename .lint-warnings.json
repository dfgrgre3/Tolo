nimport { opsWrapper } from \"@/lib/middleware/ops-middleware\";\r\nimport { successResponse, withAuth, handleApiError, badRequestResponse, forbiddenResponse, notFoundResponse } from '@/lib/api-utils';\r\nimport { z } from \"zod\";\r\n\r\nconst blogPostSchema = z.object({\r\n  title: z.string().min(1, \"в•ӘШҜв”ҳВ„в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ в”ҳГ в•Әв•–в”ҳВ„в”ҳГӘв•ӘШ°\"),\r\n  content: z.string().min(1, \"в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШІв”ҳГӘв”ҳГ« в”ҳГ в•Әв•–в”ҳВ„в”ҳГӘв•ӘШ°\"),\r\n  categoryId: z.string().min(1, \"в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Ўв”ҳВҶв”ҳГЁв”ҳВҒ в”ҳГ в•Әв•–в”ҳВ„в”ҳГӘв•ӘШ°\"),\r\n  slug: z.string().min(1, \"в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҜв•ӘШ°в•Әв•– в”ҳГ в•Әв•–в”ҳВ„в”ҳГӘв•ӘШ°\"),\r\n  excerpt: z.string().optional(),\r\n  image: z.string().optional(),\r\n  published: z.boolean().default(false),\r\n});\r\n\r\nexport async function GET(request: NextRequest) {\r\n  return opsWrapper(request, async (req) => {\r\n    return withAuth(req, async (authUser) => {\r\n      if (authUser.userRole !== \"ADMIN\") {\r\n        return forbiddenResponse(\"в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв”Ӯв”ҳГ в”ҳГӘв•ӘШө в”ҳВ„в”ҳГў в•ӘШ°в•ӘШҜв”ҳВ„в”ҳГӘв•Әв•Ўв”ҳГӘв”ҳВ„ в•ӘШӯв”ҳВ„в”ҳГ« в”ҳВ„в”ҳГӘв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГўв”ҳГ \");\r\n      }\r\n\r\n      try {\r\n        const searchParams = req.nextUrl.searchParams;\r\n        const page = parseInt(searchParams.get(\"page\") || \"1\");\r\n        const limit = parseInt(searchParams.get(\"limit\") || \"10\");\r\n        const search = searchParams.get(\"search\") || \"\";\r\n\r\n        const skip = (page - 1) * limit;\r\n\r\n        const where = search\r\n          ? { title: { contains: search, mode: \"insensitive\" as const } }\r\n          : {};\r\n\r\n        const [posts, total] = await Promise.all([\r\n          prisma.blogPost.findMany({\r\n            where,\r\n            skip,\r\n            take: limit,\r\n            orderBy: { createdAt: \"desc\" },\r\n            include: {\r\n              author: {\r\n                select: { id: true, name: true },\r\n              },\r\n              category: {\r\n                select: { id: true, name: true },\r\n              },\r\n            },\r\n          }),\r\n          prisma.blogPost.count({ where }),\r\n        ]);\r\n\r\n        return successResponse({\r\n          posts,\r\n          pagination: {\r\n            page,\r\n            limit,\r\n            total,\r\n            totalPages: Math.ceil(total / limit),\r\n          },\r\n        });\r\n      } catch (error) {\r\n        return handleApiError(error);\r\n      }\r\n    });\r\n  });\r\n}\r\n\r\nexport async function POST(request: NextRequest) {\r\n  return opsWrapper(request, async (req) => {\r\n    return withAuth(req, async (authUser) => {\r\n      if (authUser.userRole !== \"ADMIN\") {\r\n        return forbiddenResponse(\"в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв”Ӯв”ҳГ в”ҳГӘв•ӘШө в”ҳВ„в”ҳГў в•ӘШ°в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в”ҳГ в”ҳГ©в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІ\");\r\n      }\r\n\r\n      try {\r\n        const body = await req.json();\r\n        const validation = blogPostSchema.safeParse(body);\r\n\r\n        if (!validation.success) {\r\n          return badRequestResponse(validation.error.errors[0].message);\r\n        }\r\n\r\n        const data = validation.data;\r\n\r\n        const post = await prisma.blogPost.create({\r\n          data: {\r\n            ...data,\r\n            authorId: authUser.userId,\r\n          },\r\n        });\r\n\r\n        return successResponse(post, \"в•ӘШІв”ҳГ  в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ©в•ӘШҜв”ҳВ„ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө\", 201);\r\n      } catch (error) {\r\n        return handleApiError(error);\r\n      }\r\n    });\r\n  });\r\n}\r\n\r\n// PATCH /api/admin/blog - Update blog post\r\nexport async function PATCH(request: NextRequest) {\r\n  return opsWrapper(request, async (req) => {\r\n    return withAuth(req, async (authUser) => {\r\n      if (authUser.userRole !== \"ADMIN\") {\r\n        return forbiddenResponse(\"в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв”Ӯв”ҳГ в”ҳГӘв•ӘШө в”ҳВ„в”ҳГў в•ӘШ°в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в”ҳГ в”ҳГ©в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІ\");\r\n      }\r\n\r\n      try {\r\n        const body = await req.json();\r\n        const { id, ...data } = body;\r\n\r\n        if (!id) {\r\n          return badRequestResponse(\"в”ҳГ в•Әв•Јв•Әв–’в”ҳВҒ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ©в•ӘШҜв”ҳВ„ в”ҳГ в•Әв•–в”ҳВ„в”ҳГӘв•ӘШ°\");\r\n        }\r\n\r\n        const post = await prisma.blogPost.update({\r\n          where: { id },\r\n          data,\r\n        });\r\n\r\n        return successResponse(post, \"в•ӘШІв”ҳГ  в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ©в•ӘШҜв”ҳВ„ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө\");\r\n      } catch (error) {\r\n        return handleApiError(error);\r\n      }\r\n    });\r\n  });\r\n}\r\n\r\nexport async function DELETE(request: NextRequest) {\r\n  return opsWrapper(request, async (req) => {\r\n    return withAuth(req, async (authUser) => {\r\n      if (authUser.userRole !== \"ADMIN\") {\r\n        return forbiddenResponse(\"в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв”Ӯв”ҳГ в”ҳГӘв•ӘШө в”ҳВ„в”ҳГў в•ӘШ°в•ӘШөв•Әв–‘в”ҳВҒ в”ҳГ в”ҳГ©в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІ\");\r\n      }\r\n\r\n      try {\r\n        const body = await req.json();\r\n        const { id } = body;\r\n\r\n        if (!id) {\r\n          return badRequestResponse(\"в”ҳГ в•Әв•Јв•Әв–’в”ҳВҒ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ©в•ӘШҜв”ҳВ„ в”ҳГ в•Әв•–в”ҳВ„в”ҳГӘв•ӘШ°\");\r\n        }\r\n\r\n        await prisma.blogPost.delete({\r\n          where: { id },\r\n        });\r\n\r\n        return successResponse({ success: true }, \"в•ӘШІв”ҳГ  в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ©в•ӘШҜв”ҳВ„ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө\");\r\n      } catch (error) {\r\n        return handleApiError(error);\r\n      }\r\n    });\r\n  });\r\n}\r\n\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\api\\admin\\books\\route.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\a