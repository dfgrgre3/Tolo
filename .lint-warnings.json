r\n                    onClick={() => handleRemoveIP(ip.id)}>\r\n                    \r\n                          <Trash2 className=\"h-4 w-4\" />\r\n                        </Button>\r\n                      </div>\r\n                )}\r\n                  </div> :\r\n\r\n              <p className=\"text-sm text-muted-foreground text-center py-4\">\r\n                    в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в•Әв•Јв”ҳВҶв•ӘШҜв”ҳГӘв”ҳГЁв”ҳВҶ IP в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•Әв•ўв•ӘШҜв•ӘШ©\r\n                  </p>\r\n              }\r\n              </div>\r\n            </div>\r\n          }\r\n        </CardContent>\r\n      </Card>\r\n\r\n      <div className=\"flex justify-end\">\r\n        <Button onClick={handleSaveProtectionSettings}>\r\n          в•ӘШөв”ҳВҒв•Әв•• в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ\r\n        </Button>\r\n      </div>\r\n    </div>);\r\n\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\profile\\components\\PasswordManagement.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\profile\\components\\ProfileLevel.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\profile\\components\\RecentAchievements.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\profile\\components\\RecentActivity.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src