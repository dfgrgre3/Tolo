-vars","severity":1,"message":"'Input' is defined but never used. Allowed unused vars must match /^_/u.","line":10,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":10,"endColumn":15,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"Input"},"fix":{"range":[400,448],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Badge' is defined but never used. Allowed unused vars must match /^_/u.","line":11,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":11,"endColumn":15,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"Badge"},"fix":{"range":[448,496],"text":""},"desc":"Remove unused import declaration."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":15,"fixableErrorCount":0,"fixableWarningCount":0,"source":"ЩҠв•—в”җ\r\n\"use client\";\r\n\r\nimport React, { useState } from 'react';\r\nimport { Search, User, Star, GraduationCap, BookOpen, MapPin, Clock, TrendingUp, Zap, Target, Shield, Award, Users, Briefcase, ExternalLink, Filter, X, Loader2, Youtube } from 'lucide-react';\r\n\r\nimport { logger } from '@/lib/logger';\r\nimport { safeFetch } from \"@/lib/safe-client-utils\";\r\nimport { Button } from '@/components/ui/button';\r\nimport { Input } from '@/components/ui/input';\r\nimport { Badge } from '@/components/ui/badge';\r\n\r\ninterface Teacher {\r\n  name: string;\r\n  subject: string;\r\n  url?: string;\r\n  description?: string;\r\n  rating?: number;\r\n  thumbnail?: string;\r\n}\r\n\r\ninterface TeacherSearchProps {\r\n  subjects: string[];\r\n  platforms?: string[];\r\n  className?: string;\r\n}\r\n\r\nexport default function TeacherSearch({\r\n  subjects,\r\n  platforms = ['в”ҳГЁв”ҳГӘв•ӘШІв”ҳГЁв”ҳГӘв•ӘШ°', 'в”ҳГ в”ҳВҶв•Әв•Ўв•ӘШұ в•ӘВ»в•Әв–’в”ҳГӘв•Әв”Ӯ', 'в”ҳГ в”ҳВҶв•Әв•Ўв•ӘШұ в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯв•ӘШІв”ҳГЁ', 'в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ«'],\r\n  className = \"\"\r\n}: TeacherSearchProps) {\r\n  const [selectedSubject, setSelectedSubject] = useState('');\r\n  const [keywords, setKeywords] = useState('');\r\n  const [selectedPlatform, setSelectedPlatform] = useState('');\r\n  const [isSearching, setIsSearching] = useState(false);\r\n  const [teachers, setTeachers] = useState<{\r\n    localTeachers: Teacher[];\r\n    aiTeachers: Teacher[];\r\n    youtubeResults: Teacher[];\r\n  } | null>(null);\r\n  const [error, setError] = useState('');\r\n\r\n  const handleSubmit = async (e: React.FormEvent) => {\r\n    e.preventDefault();\r\n    if (!selectedSubject) {\r\n      setError('в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҙв•ӘШҜв•ӘШ© в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ');\r\n      return;\r\n    }\r\n\r\n    setIsSearching(true);\r\n    setError('');\r\n    setTeachers(null);\r\n\r\n    try {\r\n      const response = await fetch('/api/ai/teachers', {\r\n        method: 'POST',\r\n        headers: {\r\n          'Content-Type': 'application/json'\r\n        },\r\n        body: JSON.stringify({\r\n          subject: selectedSubject,\r\n          keywords: keywords || undefined,\r\n          platform: selectedPlatform || undefined,\r\n          provider: 'gemini' // в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в•ӘШҜв”ҳГ  Gemini в”ҳГўв•ӘВ«в”ҳГЁв•ӘШҜв•Әв–’ в•ӘШҜв”ҳВҒв•ӘШІв•Әв–’в•ӘШҜв•Әв•ўв”ҳГЁ\r\n        })\r\n      });\r\n\r\n      if (!response.ok) {\r\n        let errorMessage = 'в”ҳВҒв•Әв”Өв”ҳВ„в•ӘШІ в•Әв•Јв”ҳГ в”ҳВ„в”ҳГЁв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШөв•ӘШі в•Әв•Јв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯв”ҳГЁв”ҳВҶ';\r\n\r\n        try {\r\n          const errorData = await response.json();\r\n          if (errorData && errorData.error) {\r\n            errorMessage = errorData.error;\r\n          }\r\n        } catch (e) {\r\n          logger.error('Error parsing error response:', e);\r\n          // в•ӘШӯв•Әв–‘в•ӘШҜ в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШІв•ӘШөв”ҳВ„в”ҳГЁв”ҳВ„ в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘШҙв•ӘШҜв•ӘШ°в•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ«в•Әв•–в•ӘШ«в•ӘГ® в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„в•ӘШұ в•Әв•Јв•ӘШҜв”ҳГ в•ӘШұ в•ӘШ°в”ҳВҶв•ӘШҜв•ӘШ©в”ҳГҜ в•Әв•Јв”ҳВ„в”ҳГ« в•Әв–’в”ҳГ в•Әв–“ в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ\r\n          if (response.status === 401) {\r\n            errorMessage = 'в”ҳГ в•Әв”Өв”ҳГўв”ҳВ„в•ӘШұ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Ўв•ӘШҜв•ӘВ»в”ҳГ©в•ӘШұ. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ«.';\r\n          } else if (response.status === 403) {\r\n            errorMessage = 'в”ҳГ в”ҳВҒв•ӘШІв•ӘШҜв•ӘШө API в”ҳВ„в”ҳВҖ Google Gemini в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в”ҳГ§в”ҳГЁв•ӘШ«. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в•ӘШІв”ҳГӘв•ӘШҜв•Әв•Ўв”ҳВ„ в”ҳГ в•Әв•Ј в”ҳВҒв•Әв–’в”ҳГЁв”ҳГ© в•ӘШҜв”ҳВ„в•ӘВ»в•Әв•Јв”ҳГ .';\r\n          } else if (response.status === 500) {\r\n            errorMessage = 'в”ҳГ в•Әв”Өв”ҳГўв”ҳВ„в•ӘШұ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШҜв•ӘВ»в”ҳГ . в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ« в”ҳВ„в•ӘШҜв•ӘШөв”ҳГ©в•ӘШҜв”ҳГҜ.';\r\n          } else if (response.status === 429) {\r\n            errorMessage = 'в•ӘШІв”ҳГ  в•ӘШІв•ӘШҙв•ӘШҜв”ҳГӘв•Әв–“ в•ӘШөв•ӘВ» в•ӘШҜв”ҳВ„в•Әв•–в”ҳВ„в•ӘШ°в•ӘШҜв•ӘШІ. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ« в•ӘШ°в•Әв•Јв•ӘВ» в”ҳГ©в”ҳВ„в”ҳГЁв”ҳВ„.';\r\n          }\r\n        }\r\n\r\n        // в”ҳВ„в•ӘШҜ в•ӘШІв•Әв–’в”ҳГ в”ҳГЁ в•ӘШҜв”ҳВ„в•ӘВ«в•Әв•–в•ӘШ« в”ҳГ§в”ҳВҶв•ӘШҜв•ӘГ® в•ӘШ°в”ҳВ„ в”ҳГ©в”ҳГ  в•ӘШ°в•ӘШІв•Әв•Јв”ҳГЁв”ҳГЁв”ҳВҶв”ҳГ§ в”ҳГ в•ӘШ°в•ӘШҜв•Әв”Өв•Әв–’в•ӘШұ\r\n        setError(errorMessage);\r\n        setIsSearching(false);\r\n        return;\r\n      }\r\n\r\n      let data;\r\n      try {\r\n        data = await response.json();\r\n\r\n        // в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в”ҳГ в”ҳВҶ в•ӘШ«в”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШІв•ӘШөв•ӘШІв”ҳГӘв”ҳГЁ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•ӘШөв”ҳГ©в”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•–в”ҳВ„в”ҳГӘв•ӘШ°в•ӘШұ\r\n        if (!data || typeof data !== 'object') {\r\n          throw new Error('в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•Әв•‘в”ҳГЁв•Әв–’ в•Әв•Ўв•ӘШҜв”ҳВ„в•ӘШөв•ӘШұ в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШҜв•ӘВ»в”ҳГ ');\r\n        }\r\n\r\n        // в•ӘШҜв”ҳВ„в•ӘШІв•ӘШ«в”ҳГўв•ӘВ» в”ҳГ в”ҳВҶ в”ҳГӘв•ӘШҙв”ҳГӘв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШөв”ҳГ©в”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•ӘШҜв•Әв”Ӯв”ҳГЁв•ӘШұ\r\n        if (!data.localTeachers || !data.aiTeachers || !data.youtubeResults) {\r\n          // в•ӘШӯв•Әв–‘в•ӘШҜ в”ҳГўв•ӘШҜв”ҳВҶв•ӘШІ в”ҳГ§в”ҳВҶв•ӘШҜв”ҳГў в•ӘШөв”ҳГ©в”ҳГӘв”ҳВ„ в”ҳГ в”ҳВҒв”ҳГ©в”ҳГӘв•ӘВ»в•ӘШұв•ӘГ® в”ҳГ©в”ҳГ  в•ӘШ°в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ®в”ҳГ§в•ӘШҜ\r\n          data.localTeachers = data.localTeachers || [];\r\n          data.aiTeachers = data.aiTeachers || [];\r\n          data.youtubeResults = data.youtubeResults || [];\r\n        }\r\n\r\n        setTeachers(data);\r\n      } catch (parseError) {\r\n        logger.error('Error parsing response data:', parseError);\r\n        setError('в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в”ҳВҒв”ҳГЁ в•ӘШІв•ӘШөв”ҳВ„в”ҳГЁв”ҳВ„ в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘШҙв•ӘШҜв•ӘШ°в•ӘШұ. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ«.');\r\n        setIsSearching(false);\r\n        return;\r\n      }\r\n    } catch (err) {\r\n      logger.error('Error searching teachers:', err);\r\n      let errorMessage = 'в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв•Јв•Әв–’в”ҳГӘв”ҳВҒ';\r\n\r\n      if (err instanceof Error) {\r\n        errorMessage = err.message;\r\n\r\n        // в•ӘШІв•ӘШөв•Әв”Ӯв”ҳГЁв”ҳВҶ в•Әв–’в•Әв”Ӯв•ӘШҜв•ӘШ®в”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ«в•Әв•–в•ӘШ« в•ӘШҜв”ҳВ„в•Әв”Өв•ӘШҜв•ӘШ®в•Әв•Јв•ӘШұ\r\n        if (errorMessage.includes('API key') || errorMessage.includes('в”ҳГ в”ҳВҒв•ӘШІв•ӘШҜв•ӘШө API')) {\r\n          errorMessage = 'в”ҳГ в”ҳВҒв•ӘШІв•ӘШҜв•ӘШө API в”ҳВ„в”ҳВҖ Google Gemini в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в”ҳГ§в”ҳГЁв•ӘШ«. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в•ӘШІв”ҳГӘв•ӘШҜв•Әв•Ўв”ҳВ„ в”ҳГ в•Әв•Ј в”ҳВҒв•Әв–’в”ҳГЁв”ҳГ© в•ӘШҜв”ҳВ„в•ӘВ»в•Әв•Јв”ҳГ  в”ҳВ„в•ӘШөв”ҳВ„ в”ҳГ§в•Әв–‘в”ҳГ§ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Өв”ҳГўв”ҳВ„в•ӘШұ.';\r\n        } else if (errorMessage.includes('fetch')) {\r\n          errorMessage = 'в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„ в•ӘШ°в•ӘВ«в•ӘВ»в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•Әв–‘в”ҳГўв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШҜв•Әв•Ўв•Әв•–в”ҳВҶв•ӘШҜв•Әв•Јв”ҳГЁ. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в”ҳГ в”ҳВҶ в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШІв•Әв–’в”ҳВҶв•ӘШІ в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ«.';\r\n        }\r\n      }\r\n\r\n      setError(errorMessage);\r\n    } finally {\r\n      setIsSearching(false);\r\n    }\r\n  };\r\n\r\n  const renderStars = (rating?: number) => {\r\n    if (!rating) return null;\r\n\r\n    return (\r\n      <div className=\"flex items-center gap-1\">\r\n        {[...Array(5)].map((_, i) =>\r\n        <Star\r\n          key={i}\r\n          className={`h-4 w-4 ${\r\n          i < Math.floor(rating) ? 'text-yellow-400 fill-yellow-400' : 'text-gray-300'}`\r\n          } />\r\n\r\n        )}\r\n        <span className=\"text-sm text-gray-600 ml-1\">{rating.toFixed(1)}</span>\r\n      </div>);\r\n\r\n  };\r\n\r\n  const renderTeacherCard = (teacher: Teacher, source: string) =>\r\n  <div key={`${teacher.name}-${source}`} className=\"border border-gray-200 rounded-lg p-4 hover:shadow-md transition-shadow\">\r\n      <div className=\"flex items-start gap-4\">\r\n        {teacher.thumbnail ?\r\n      <img\r\n        src={teacher.thumbnail}\r\n        alt={teacher.name}\r\n        className=\"w-16 h-16 rounded-lg object-cover\" /> :\r\n\r\n\r\n      <div className=\"w-16 h-16 rounded-lg bg-blue-100 flex items-center justify-center\">\r\n            <User className=\"h-8 w-8 text-blue-600\" />\r\n          </div>\r\n      }\r\n\r\n        <div className=\"flex-1\">\r\n          <div className=\"flex items-start justify-between\">\r\n            <div>\r\n              <h3 className=\"font-bold text-gray-800\">{teacher.name}</h3>\r\n              <div className=\"flex items-center gap-2 mt-1\">\r\n                <span className=\"inline-flex items-center gap-1 px-2 py-1 bg-blue-100 text-blue-800 text-xs font-medium rounded-full\">\r\n                  <BookOpen className=\"h-3 w-3\" />\r\n                  {teacher.subject}\r\n                </span>\r\n                {source === 'youtube' &&\r\n              <span className=\"inline-flex items-center gap-1 px-2 py-1 bg-red-100 text-red-800 text-xs font-medium rounded-full\">\r\n                    <Youtube className=\"h-3 w-3\" />\r\n                    в”ҳГЁв”ҳГӘв•ӘШІв”ҳГЁв”ҳГӘв•ӘШ°\r\n                  </span>\r\n              }\r\n                {source === 'ai' &&\r\n              <span className=\"inline-flex items-center gap-1 px-2 py-1 bg-green-100 text-green-800 text-xs font-medium rounded-full\">\r\n                    Gemini 2.0 Flash\r\n                  </span>\r\n              }\r\n              </div>\r\n            </div>\r\n\r\n            {teacher.url &&\r\n          <a\r\n            href={teacher.url}\r\n            target=\"_blank\"\r\n            rel=\"noopener noreferrer\"\r\n            className=\"text-blue-500 hover:text-blue-700\">\r\n            \r\n                <ExternalLink className=\"h-5 w-5\" />\r\n              </a>\r\n          }\r\n          </div>\r\n\r\n          {teacher.description &&\r\n        <p className=\"text-gray-600 text-sm mt-2 line-clamp-2\">{teacher.description}</p>\r\n        }\r\n\r\n          <div className=\"mt-3\">\r\n            {renderStars(teacher.rating)}\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>;\r\n\r\n\r\n  return (\r\n    <div className={`bg-white rounded-xl shadow-lg p-6 ${className}`}>\r\n      <div className=\"flex items-center gap-3 mb-6\">\r\n        <div className=\"p-2 bg-blue-100 rounded-lg\">\r\n          <Search className=\"h-6 w-6 text-blue-600\" />\r\n        </