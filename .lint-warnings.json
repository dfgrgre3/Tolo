  const digitsOnly = value.replace(/\\D/g, '');\r\n  if (digitsOnly.length > 0 && !digitsOnly.startsWith('01')) {\r\n    return digitsOnly.substring(0, 11);\r\n  }\r\n  return digitsOnly.substring(0, 11);\r\n};\r\n\r\nconst handlePhoneInput = (e: React.KeyboardEvent<HTMLInputElement>) => {\r\n  if ([46, 8, 9, 27, 13, 37, 38, 39, 40, 35, 36].includes(e.keyCode)) return;\r\n  if ((e.shiftKey || (e.keyCode < 48 || e.keyCode > 57)) && (e.keyCode < 96 || e.keyCode > 105)) {\r\n    e.preventDefault();\r\n  }\r\n};\r\n\r\nconst COUNTRIES = [\r\n  { code: 'EG', name: 'в”ҳГ в•Әв•Ўв•Әв–’', phoneCode: '+20' },\r\n  { code: 'SA', name: 'в•ӘШҜв”ҳВ„в•Әв”Ӯв•Әв•Јв”ҳГӘв•ӘВ»в”ҳГЁв•ӘШұ', phoneCode: '+966' },\r\n  { code: 'AE', name: 'в•ӘШҜв”ҳВ„в•ӘШӯв”ҳГ в•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ', phoneCode: '+971' },\r\n  { code: 'KW', name: 'в•ӘШҜв”ҳВ„в”ҳГўв”ҳГӘв”ҳГЁв•ӘШІ', phoneCode: '+965' },\r\n  { code: 'QA', name: 'в”ҳГ©в•Әв•–в•Әв–’', phoneCode: '+974' },\r\n  { code: 'OM', name: 'в•Әв•Јв”ҳГ в•ӘШҜв”ҳВҶ', phoneCode: '+968' },\r\n  { code: 'BH', name: 'в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШөв•Әв–’в”ҳГЁв”ҳВҶ', phoneCode: '+973' },\r\n  { code: 'JO', name: 'в•ӘШҜв”ҳВ„в•ӘШ«в•Әв–’в•ӘВ»в”ҳВҶ', phoneCode: '+962' },\r\n];\r\n\r\nconst registerSchema = z.object({\r\n  username: z.string().min(3, 'в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв”ҳГ  в”ҳГЁв•ӘШҙв•ӘШ° в•ӘШ«в”ҳВҶ в”ҳГЁв”ҳГўв”ҳГӘв”ҳВҶ 3 в•ӘШ«в•ӘШөв•Әв–’в”ҳВҒ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ©в”ҳВ„').regex(/^[^\\s@]+$/, 'в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в”ҳВ„в•ӘШҜ в”ҳГЁв”ҳГ в”ҳГўв”ҳВҶ в•ӘШ«в”ҳВҶ в”ҳГЁв•ӘШөв•ӘШІв”ҳГӘв”ҳГЁ в•Әв•Јв”ҳВ„в”ҳГ« в”ҳГ в•Әв”Ӯв•ӘШҜв”ҳВҒв•ӘШҜв•ӘШІ в•ӘШ«в”ҳГӘ в•Әв–’в”ҳГ в•Әв–“ @'),\r\n  email: z.string().email('в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШӯв•ӘВ»в•ӘВ«в•ӘШҜв”ҳВ„ в•ӘШ°в•Әв–’в”ҳГЁв•ӘВ» в•ӘШӯв”ҳВ„в”ҳГўв•ӘШІв•Әв–’в”ҳГӘв”ҳВҶв”ҳГЁ в•Әв•Ўв•ӘШөв”ҳГЁв•ӘШө'),\r\n  password: z.string().min(8, 'в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в”ҳГЁв•ӘШҙв•ӘШ° в•ӘШ«в”ҳВҶ в•ӘШІв”ҳГўв”ҳГӘв”ҳВҶ 8 в•ӘШ«в•ӘШөв•Әв–’в”ҳВҒ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ©в”ҳВ„')\r\n    .regex(/[A-Z]/, 'в”ҳГЁв•ӘШҙв•ӘШ° в•ӘШ«в”ҳВҶ в•ӘШІв•ӘШөв•ӘШІв”ҳГӘв”ҳГЁ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШөв•Әв–’в”ҳВҒ в”ҳГўв•ӘШ°в”ҳГЁв•Әв–’ в”ҳГӘв•ӘШҜв•ӘШөв•ӘВ»')\r\n    .regex(/[a-z]/, 'в”ҳГЁв•ӘШҙв•ӘШ° в•ӘШ«в”ҳВҶ в•ӘШІв•ӘШөв•ӘШІв”ҳГӘв”ҳГЁ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШөв•Әв–’в”ҳВҒ в•Әв•Ўв•Әв•‘в”ҳГЁв•Әв–’ в”ҳГӘв•ӘШҜв•ӘШөв•ӘВ»')\r\n    .regex(/[0-9]/, 'в”ҳГЁв•ӘШҙв•ӘШ° в•ӘШ«в”ҳВҶ в•ӘШІв•ӘШөв•ӘШІв”ҳГӘв”ҳГЁ в•Әв•Јв”ҳВ„в”ҳГ« в•Әв–’в”ҳГ©в”ҳГ  в”ҳГӘв•ӘШҜв•ӘШөв•ӘВ»')\r\n    .regex(/[^A-Za-z0-9]/, 'в”ҳГЁв•ӘШҙв•ӘШ° в•ӘШ«в”ҳВҶ в•ӘШІв•ӘШөв•ӘШІв”ҳГӘв”ҳГЁ в•Әв•Јв”ҳВ„в”ҳГ« в•Әв–’в”ҳГ в•Әв–“ в•ӘВ«в•ӘШҜв•Әв•Ў в”ҳГӘв•ӘШҜв•ӘШөв•ӘВ»'),\r\n  confirmPassword: z.string(),\r\n  phone: z.string().refine((val) => {\r\n    if (!val) return true;\r\n    const egyptianPattern = /^(010|011|012|015)\\d{8}$/;\r\n    return egyptianPattern.test(val);\r\n  }, 'в•Әв–’в”ҳГ©в”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ§в•ӘШҜв•ӘШІв”ҳВҒ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Ўв•Әв–’в”ҳГЁ в”ҳГЁв•ӘШҙв•ӘШ° в•ӘШ«в”ҳВҶ в”ҳГЁв•ӘШ°в•ӘВ»в•ӘШ« в•ӘШ°в”ҳВҖ 010в•ӘГ® 011в•ӘГ® 012в•ӘГ® в•ӘШ«в”ҳГӘ 015 в”ҳГӘв”ҳГЁв•ӘШІв”ҳГўв”ҳГӘв”ҳВҶ в”ҳГ в”ҳВҶ 11 в•Әв–’в”ҳГ©в”ҳГ в”ҳГҜв•ӘШҜ'),\r\n  alternativePhone: z.string().optional().refine((val) => {\r\n    if (!val) return true;\r\n    const egyptianPattern = /^(010|011|012|015)\\d{8}$/;\r\n    return egyptianPattern.test(val);\r\n  }, 'в•Әв–’в”ҳГ©в”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ§в•ӘШҜв•ӘШІв”ҳВҒ в•ӘШҜв”ҳВ„в•ӘШ°в•ӘВ»в”ҳГЁв”ҳВ„ в”ҳГЁв•ӘШҙв•ӘШ° в•ӘШ«в”ҳВҶ в”ҳГЁв”ҳГўв”ҳГӘв”ҳВҶ в•Әв–’в”ҳГ©в”ҳГ  в”ҳГ§в•ӘШҜв•ӘШІв”ҳВҒ в”ҳГ в•Әв•Ўв•Әв–’в”ҳГЁ в•Әв•Ўв•ӘШҜв”ҳВ„в•ӘШө'),\r\n  country: z.string().min(2, 'в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв”ҳВ„в•ӘШұ в”ҳГ в•Әв•–в”ҳВ„в”ҳГӘв•ӘШ°в•ӘШұ'),\r\n  dateOfBirth: z.string().min(1, 'в•ӘШІв•ӘШҜв•Әв–’в”ҳГЁв•ӘВ« в•ӘШҜв”ҳВ„в”ҳГ в”ҳГЁв”ҳВ„в•ӘШҜв•ӘВ» в”ҳГ в•Әв•–в”ҳВ„в”ҳГӘв•ӘШ°'),\r\n  role: z.enum(['STUDENT', 'TEACHER']),\r\n  gradeLevel: z.string().optional(),\r\n  educationType: z.string().optional(),\r\n  interestedSubjects: z.array(z.string()).optional(),\r\n  subjectsTaught: z.array(z.string()).optional(),\r\n  acceptTerms: z.boolean().refine(val => val === true, 'в”ҳГЁв•ӘШҙв•ӘШ° в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘШҜв”ҳВҒв”ҳГ©в•ӘШұ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•Әв”Өв•Әв–’в”ҳГӘв•Әв•–'),\r\n}).refine((data) => data.password === data.confirmPassword, {\r\n  message: 'в”ҳГўв”ҳВ„в”ҳГ в•ӘШІв•ӘШҜ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШІв•Әв•–в•ӘШҜв•ӘШ°в”ҳГ©в•ӘШІв”ҳГЁв”ҳВҶ',\r\n  path: ['confirmPassword'],\r\n});\r\n\r\ntype RegisterFormValues = z.infer<typeof registerSchema>;\r\n\r\nconst STUDENT_GRADES = ['в•ӘШ«в”ҳГӘв”ҳВ„в”ҳГ« в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в”ҳГЁ', 'в•ӘШів•ӘШҜв”ҳВҶв”ҳГЁв•ӘШұ в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в”ҳГЁ', 'в•ӘШів•ӘШҜв”ҳВ„в•ӘШів•ӘШұ в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в”ҳГЁ', 'в•ӘШ«в”ҳГӘв”ҳВ„в”ҳГ« в•ӘШів•ӘШҜв”ҳВҶв”ҳГӘв”ҳГЁ', 'в•ӘШів•ӘШҜв”ҳВҶв”ҳГЁв•ӘШұ в•ӘШів•ӘШҜв”ҳВҶв”ҳГӘв”ҳГЁ', 'в•ӘШів•ӘШҜв”ҳВ„в•ӘШів•ӘШұ в•ӘШів•ӘШҜв”ҳВҶв”ҳГӘв”ҳГЁ'];\r\nconst EDUCATION_TYPES = ['в•Әв•Јв•ӘШҜв”ҳГ ', 'в•ӘШ«в•Әв–“в”ҳГ§в•Әв–’в”ҳГЁ', 'в•ӘВ»в”ҳГӘв”ҳВ„в”ҳГЁ', 'IG', 'American', 'в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ«'];\r\nconst SUBJECTS = ['в•Әв–’в”ҳГЁв•ӘШҜв•Әв•ўв”ҳГЁв•ӘШҜв•ӘШІ', 'в”ҳВҒв”ҳГЁв•Әв–“в”ҳГЁв•ӘШҜв•ӘШ©', 'в”ҳГўв”ҳГЁв”ҳГ в”ҳГЁв•ӘШҜв•ӘШ©', 'в•ӘШ°в•Әв–’в”ҳГ в•ӘШҙв•ӘШұ', 'в•ӘШӯв”ҳВҶв•ӘШҙв”ҳВ„в”ҳГЁв•Әв–“в”ҳГЁ', 'в•ӘШІв•Әв•Ўв”ҳГ в”ҳГЁв”ҳГ ', 'в”ҳВ„в•Әв•‘в•ӘШұ в•Әв•Јв•Әв–’в•ӘШ°в”ҳГЁв•ӘШұ', 'в•ӘШ«в•ӘШөв”ҳГЁв•ӘШҜв•ӘШ©', 'в•ӘШІв•ӘШҜв•Әв–’в”ҳГЁв•ӘВ«', 'в•ӘШҙв•Әв•‘в•Әв–’в•ӘШҜв”ҳВҒв”ҳГЁв•ӘШҜ'];\r\n\r\nfunction RegisterForm() {\r\n  const router = useRouter();\r\n  const searchParams = useSearchParams();\r\n  const { register: registerUser, isAuthenticated, isLoading: isAuthLoading } = useAuth();\r\n  const [step, setStep] = useState(1);\r\n  const [isLoading, setIsLoading] = useState(false);\r\n  const [showPassword, setShowPassword] = useState(false);\r\n  const [showConfirmPassword, setShowConfirmPassword] = useState(false);\r\n  const [selectedCountry, setSelectedCountry] = useState('EG');\r\n\r\n  const redirectUrl = useMemo(\r\n    () => sanitizeRedirectPath(searchParams.get('redirect'), DEFAULT_AUTHENTICATED_ROUTE),\r\n    [searchParams]\r\n  );\r\n  const loginUrl = `/login?redirect=${encodeURIComponent(redirectUrl)}`;\r\n\r\n  const { register, handleSubmit, control, getValues, setValue, trigger, formState: { errors } } = useForm<RegisterFormValues>({\r\n    resolver: zodResolver(registerSchema),\r\n    defaultValues: { \r\n      role: 'STUDENT', \r\n      interestedSubjects: [], \r\n      subjectsTaught: [], \r\n      acceptTerms: false,\r\n      country: 'в”ҳГ в•Әв•Ўв•Әв–’'\r\n    },\r\n  });\r\n\r\n  const handlePhoneChange = (field: 'phone' | 'alternativePhone') => (e: React.ChangeEvent<HTMLInputElement>) => {\r\n    setValue(field, formatPhoneNumber(e.target.value), { shouldValidate: true });\r\n  };\r\n\r\n  const handleCountryChange = (e: React.ChangeEvent<HTMLSelectElement>) => {\r\n    const countryCode = e.target.value;\r\n    const country = COUNTRIES.find(c => c.code === countryCode);\r\n    if (country) {\r\n      setValue('country', country.name, { shouldValidate: true });\r\n      setSelectedCountry(countryCode);\r\n    }\r\n  };\r\n\r\n  const roleValue = useWatch({ control, name: 'role' });\r\n  const interestedSubjects = useWatch({ control, name: 'interestedSubjects', defaultValue: [] }) || [];\r\n\r\n  const redirectAfterRegister = useCallback((target: string) => {\r\n    router.replace(target);\r\n    router.refresh();\r\n  }, [router]);\r\n\r\n  useEffect(() => {\r\n    if (!isAuthLoading && isAuthenticated) {\r\n      redirectAfterRegister(redirectUrl);\r\n    }\r\n  }, [isAuthLoading, isAuthenticated, redirectAfterRegister, redirectUrl]);\r\n\r\n  const handleNextStep = async () => {\r\n    let fieldsToValidate: any[] = [];\r\n    if (step === 1) fieldsToValidate = ['role'];\r\n    if (step === 2) fieldsToValidate = ['username', 'email', 'password', 'confirmPassword', 'phone', 'country', 'dateOfBirth'];\r\n\r\n    const isValid = await trigger(fieldsToValidate as any);\r\n\r\n    if (isValid) {\r\n      setStep(prev => prev + 1);\r\n      window.scrollTo({ top: 0, behavior: 'smooth' });\r\n    } else {\r\n      toast.error('в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШІв•Әв•Ўв•ӘШөв”ҳГЁв•ӘШө в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ«в•Әв•–в•ӘШҜв•ӘШ© в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШөв”ҳГ в•Әв–’в•ӘШҜв•ӘШ©');\r\n    }\r\n  };\r\n\r\n  const toggleArrayItem = (field: 'interestedSubjects' | 'subjectsTaught', value: string) => {\r\n    const currentList = getValues(field) || [];\r\n    setValue(\r\n      field,\r\n      currentList.includes(value)\r\n        ? currentList.filter(item => item !== value)\r\n        : [...currentList, value]\r\n    );\r\n  };\r\n\r\n  const onSubmit = async (data: RegisterFormValues) => {\r\n    setIsLoading(true);\r\n\r\n    try {\r\n      const result = await registerUser({\r\n        email: data.email,\r\n        password: data.password,\r\n        username: data.username,\r\n        role: data.role,\r\n        country: data.country,\r\n        dateOfBirth: data.dateOfBirth ? new Date(data.dateOfBirth).toISOString() : null,\r\n        phone: data.phone,\r\n        alternativePhone: data.alternativePhone,\r\n        gradeLevel: data.gradeLevel,\r\n        educationType: data.educationType,\r\n        interestedSubjects: data.interestedSubjects,\r\n        subjectsTaught: data.subjectsTaught,\r\n      });\r\n\r\n      if (result.success) {\r\n        toast.success(result.message || 'в•ӘШІв”ҳГ  в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в”ҳГ в”ҳГ в”ҳВ„в”ҳГўв•ӘШІв”ҳГў в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШҜв•Әв•Ўв•ӘШұ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө!');\r\n        if (result.autoLoggedIn) {\r\n          redirectAfterRegister(redirectUrl);\r\n          return;\r\n        }\r\n        setTimeout(() => router.push(loginUrl), 2000);\r\n      } else {\r\n        toast.error(result.error || 'в”ҳВҒв•Әв”Өв”ҳВ„ в”ҳВҒв”ҳГЁ в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ»в•Әв•Јв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в”ҳГ§в”ҳГӘв”ҳГЁв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ');\r\n      }\r\n    } catch (err) {\r\n      toast.error('в•ӘШөв•ӘВ»в•ӘШі в•Әв•Јв•ӘШҜв•Әв–’в•Әв•ў в”ҳВҒв”ҳВҶв”ҳГЁ в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШІв”ҳГӘв”ҳГ©в•Әв•Ј');\r\n    } finally {\r\n      setIsLoading(false);\r\n    }\r\n  };\r\n\r\n  if (isAuthLoading) {\r\n    return (\r\n      <div className=\"flex min-h-screen items-center justify-center bg-black\">\r\n        <motion.div \r\n          animate={{ rotate: 360 }}\r\n          transition={{ duration: 2, repeat: Infinity, ease: \"linear\" }}\r\n          className=\"h-12 w-12 border-2 border-primary border-t-transparent rounded-full shadow-[0_0_15px_rgba(var(--primary),0.2)]\" \r\n        />\r\n      </div>\r\n    );\r\n  }\r\n\r\n  return (\r\n    <div className=\"relative min-h-screen w-full flex flex-col items-center py-12 px-4 bg-black overflow-hidden\" dir=\"rtl\">\r\n      {/* Background Decor */}\r\n      <div className=\"absolute top-[-5%] left-[-5%] w-[600px] h-[600px] bg-primary/10 blur-[130px] rounded-full\" />\r\n      <div className=\"absolute bottom-[-5%] right-[-5%] w-[500px] h-[500px] bg-blue-600/5 blur-[130px] rounded-full\" />\r\n      <div className=\"absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-10 pointer-events-none\" />\r\n\r\n      <div className=\"relative w-full max-w-2xl\">\r\n        <motion.div \r\n          initial={{ opacity: 0, y: 20 }}\r\n          animate={{ opacity: 1, y: 0 }}\r\n          className=\"mb-12 text-center space-y-4\"\r\n        >\r\n          <div className=\"mx-auto w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center mb-6 shadow-xl\">\r\n            <Wand2 className=\"w-8 h-8 text-primary\" />\r\n          </div>\r\n          <h2 className=\"text-4xl md:text-5xl font-black text-white tracking-tight leading-tight\">\r\n            в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© <span className=\"text-transparent bg-clip-text bg-gradient-to-r from-primary to-blue-400\">в•ӘШҜв”ҳВ„в”ҳГ§в”ҳГӘв”ҳГЁв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•Әв•–в”ҳГӘв•Әв–’в”ҳГЁв•ӘШұ</span>\r\n          </h2>\r\n          <p className=\"text-gray-400 font-medium\">в•ӘШҜв•ӘШ°в•ӘВ»в•ӘШ« в•Әв–’в•ӘШөв”ҳВ„в•ӘШұ в•Әв•Ўв”ҳВҶв•ӘШҜв•Әв•Јв•ӘШұ в•ӘШ°в•Әв•–в”ҳВ„в”ҳГў в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Јв”ҳВ„в”ҳГЁв”ҳГ в”ҳГЁ в”ҳВҒв”ҳГЁ в”ҳГ в”ҳВҶв•Әв•Ўв•ӘШұ в•ӘШІв”ҳГӘв”ҳВ„в”ҳГӘ</p>\r\n        </motion.div>\r\n\r\n        {/* Improved Stepper */}\r\n        <div className=\"mb-16 flex items-center justify-center gap-6\">\r\n          {[1, 2, 3].map((i) => (\r\n            <div key={i} className=\"flex items-center\">\r\n              <div className=\"relative flex flex-col items-center\">\r\n                <motion.div \r\n                  animate={{ \r\n                    scale: step === i ? 1.1 : 1,\r\n                    backgroundColor: step >= i ? 'var(--primary-rgb)' : 'rgba(255,255,255,0.05)'\r\n                  }}\r\n                  className={`flex h-12 w-12 items-center justify-center rounded-2xl border-2 transition-all shadow-lg ${step >= i ? 'border-primary bg-primary text-black' : 'border-white/5 bg-white/5 text-gray-500'}`}\r\n                >\r\n                  {step > i ? <Check className=\"h-5 w-5\" /> : <span className=\"text-lg font-black\">{i}</span>}\r\n                </motion.div>\r\n                <span className={`absolute -bottom-8 text-[9px] font-black uppercase tracking-[0.2em] whitespace-nowrap transition-colors ${step >= i ? 'text-primary' : 'text-gray-600'}`}>\r\n                  {i === 1 ? 'в”ҳВҶв”ҳВҖв”ҳГӘв•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГ§в”ҳГӘв”ҳГЁв”ҳВҖв•ӘШұ' : i === 2 ? 'в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв”ҳВҖв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГӘв•ӘШҜв”ҳГ©в”ҳВҖв•Әв•Ј' : 'в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв”ҳВҖв•ӘШҜв•Әв–’'}\r\n                </span>\r\n              </div>\r\n              {i < 3 && (\r\n                <div className=\"mx-2 h-0.5 w-8 rounded-full bg-white/5 relative overflow-hidden\">\r\n                   <motion.div \r\n                     initial={{ width: 0 }}\r\n                     animate={{ width: step > i ? '100%' : '0%' }}\r\n                     className=\"absolute inset-0 bg-primary\"\r\n                   />\r\n                </div>\r\n              )}\r\n            </div>\r\n          ))}\r\n        </div>\r\n\r\n        <motion.div\r\n          layout\r\n          initial={{ opacity: 0, scale: 0.98 }}\r\n          animate={{ opacity: 1, scale: 1 }}\r\n          transition={{ duration: 0.4 }}\r\n          className=\"relative overflow-hidden rounded-[2.5rem] border border-white/10 bg-white/5 p-8 md:p-12 backdrop-blur-2xl shadow-2xl\"\r\n        >\r\n          <div className=\"absolute inset-0 border border-white/5 pointer-events-none rounded-[2.5rem]\" />\r\n\r\n          <form onSubmit={handleSubmit(onSubmit)} className=\"space-y-8\">\r\n            <AnimatePresence mode=\"wait\">\r\n              {step === 1 && (\r\n                <motion.div \r\n                  key=\"step1\"\r\n                  initial={{ opacity: 0, x: 20 }}\r\n                  animate={{ opacity: 1, x: 0 }}\r\n                  exit={{ opacity: 0, x: -20 }}\r\n                  className=\"space-y-8\"\r\n                >\r\n                  <div className=\"text-center space-y-2 mb-8\">\r\n                    <Shield className=\"mx-auto text-primary/40\" size={32} />\r\n                    <h3 className=\"text-xl font-black text-white\">в”ҳГ в”ҳВҶ в•ӘШ«в”ҳВҶв•ӘШІ в”ҳВҒв”ҳГЁ в”ҳГ§в•Әв–‘в•ӘШҜ в•ӘШҜв”ҳВ„в•Әв•Јв•ӘШҜв”ҳВ„в”ҳГ в•ӘШ§</h3>\r\n                    <p className=\"text-gray-500 text-sm\">в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘВ»в”ҳГӘв•Әв–’в”ҳГў в”ҳВ„в”ҳВҶв•ӘВ«в•Әв•Ўв•Әв•Ў в”ҳВ„в”ҳГў в•ӘШҜв”ҳВ„в•ӘШІв•ӘШҙв•Әв–’в•ӘШ°в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ в•ӘШів”ҳВ„</p>\r\n                  </div>\r\n\r\n                  <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-6\">\r\n                    {[\r\n                      { id: 'STUDENT', label: 'в•Әв•–в•ӘШҜв”ҳВ„в•ӘШ° в”ҳГ в•Әв•‘в•ӘШҜв”ҳГ в•Әв–’', icon: GraduationCap, desc: 'в”ҳВ„в”ҳВ„в”ҳГ в•Әв–‘в•ӘШҜв”ҳГўв•Әв–’в•ӘШұв•ӘГ® в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҒв”ҳГӘв”ҳГ© в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•ӘШҜв”ҳВҒв•Әв”Ӯв•ӘШұ' },\r\n                      { id: 'TEACHER', label: 'в”ҳГ в•Әв•Јв”ҳВ„в”ҳГ  в•ӘВ«в•ӘШ°в”ҳГЁв•Әв–’', icon: Briefcase, desc: 'в”ҳВ„в”ҳГ в•Әв”Өв•ӘШҜв•Әв–’в”ҳГўв•ӘШұ в•ӘШҜв”ҳВ„в•Әв•Јв”ҳВ„в”ҳГ  в”ҳГӘв•ӘШ°в”ҳВҶв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШ«в•ӘШ°в•Әв•–в•ӘШҜв”ҳВ„' },\r\n                    ].map(({ id, label, icon: Icon, desc }) => {\r\n                      const active = roleValue === id;\r\n                      return (\r\n                        <label key={id} className={`group cursor-pointer rounded-[2rem] border-2 p-8 transition-all relative overflow-hidden ${active ? 'border-primary bg-primary/10 shadow-[0_0_20px_rgba(var(--primary),0.1)]' : 'border-white/5 bg-white/5 hover:border-white/10'}`}>\r\n                          <input type=\"radio\" value={id} {...register('role')} className=\"hidden\" />\r\n                          <div className=\"flex flex-col items-center gap-4 text-center\">\r\n                            <motion.div \r\n                              animate={{ scale: active ? 1.1 : 1 }}\r\n                              className={`rounded-2xl p-5 ${active ? 'bg-primary text-black' : 'bg-white/5 text-gray-500 group-hover:bg-white/10'}`}\r\n                            >\r\n                              <Icon size={32} />\r\n                            </motion.div>\r\n                            <div className=\"space-y-1\">\r\n                              <span className={`block font-black text-lg ${active ? 'text-white' : 'text-gray-400'}`}>{label}</span>\r\n                              <span className=\"block text-[10px] text-gray-600 font-bold uppercase tracking-widest\">{desc}</span>\r\n                            </div>\r\n                          </div>\r\n                        </label>\r\n                      );\r\n                    })}\r\n                  </div>\r\n                  \r\n                  <motion.div whileHover={{ scale: 1.01 }} whileTap={{ scale: 0.99 }} className=\"pt-4\">\r\n                    <Button type=\"button\" onClick={handleNextStep} className=\"h-16 w-full rounded-2xl bg-primary font-black text-black group\