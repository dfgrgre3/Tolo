nter gap-1 px-2\">\r\n                <span className=\"text-sm font-medium\">\r\n                  {currentPage + 1}\r\n                </span>\r\n                <span className=\"text-sm text-muted-foreground\">/</span>\r\n                <span className=\"text-sm text-muted-foreground\">\r\n                  {table.getPageCount()}\r\n                </span>\r\n              </div>\r\n\r\n              <Button\r\n                variant=\"outline\"\r\n                size=\"sm\"\r\n                className=\"h-9 rounded-lg\"\r\n                onClick={() => table.nextPage()}\r\n                disabled={!table.getCanNextPage()}\r\n              >\r\n                в•ӘШҜв”ҳВ„в•ӘШІв•ӘШҜв”ҳВ„в”ҳГЁ\r\n                <ChevronLeft className=\"h-4 w-4 mr-1\" />\r\n              </Button>\r\n              <Button\r\n                variant=\"outline\"\r\n                size=\"icon\"\r\n                className=\"h-9 w-9 rounded-lg hidden sm:flex\"\r\n                onClick={() => table.setPageIndex(table.getPageCount() - 1)}\r\n                disabled={!table.getCanNextPage()}\r\n              >\r\n                <ChevronsLeft className=\"h-4 w-4\" />\r\n              </Button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\components\\admin\\ui\\impersonation-banner.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\components\\admin\\ui\\index.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\components\\admin\\ui\\loading-skeleton.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarni