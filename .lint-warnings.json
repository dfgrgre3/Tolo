uth-context\";\r\nimport { logger } from \"@/lib/logger\";\r\nimport { Button } from \"@/components/ui/button\";\r\nimport { cn } from \"@/lib/utils\";\r\nimport {\r\n  CourseCard,\r\n  CoursesEmptyState,\r\n  CoursesFilter,\r\n  CoursesHero,\r\n  CoursesLoadingSkeleton,\r\n  FeaturedCourses,\r\n  type CourseCardProps,\r\n} from \"./components\";\r\n\r\nconst PAGE_SIZE = 12;\r\n\r\ntype SortOption = \"newest\" | \"popular\" | \"rated\" | \"price-low\" | \"price-high\" | \"duration-short\" | \"duration-long\";\r\ntype CourseLevelFilter = \"all\" | \"BEGINNER\" | \"INTERMEDIATE\" | \"ADVANCED\";\r\n\r\ntype Course = CourseCardProps & {\r\n  createdAt: string;\r\n  categoryId?: string;\r\n  categoryName?: string;\r\n  duration: number;\r\n  enrolledCount: number;\r\n  rating: number;\r\n  price: number;\r\n  tags: string[];\r\n  lessonsCount?: number;\r\n  isWishlisted?: boolean;\r\n};\r\n\r\ntype CourseCategory = {\r\n  id: string;\r\n  name: string;\r\n  icon: string;\r\n  count?: number;\r\n};\r\n\r\ntype CoursesApiResponse = {\r\n  courses?: Course[];\r\n  subjects?: Course[];\r\n  categories?: CourseCategory[];\r\n};\r\n\r\nfunction normalizeLevel(level: Course[\"level\"]): Exclude<CourseLevelFilter, \"all\"> {\r\n  switch (level) {\r\n    case \"BEGINNER\":\r\n    case \"EASY\":\r\n      return \"BEGINNER\";\r\n    case \"ADVANCED\":\r\n    case \"HARD\":\r\n    case \"EXPERT\":\r\n      return \"ADVANCED\";\r\n    case \"INTERMEDIATE\":\r\n    case \"MEDIUM\":\r\n    default:\r\n      return \"INTERMEDIATE\";\r\n  }\r\n}\r\n\r\nfunction toTimestamp(value: string): number {\r\n  const date = new Date(value);\r\n  return Number.isNaN(date.getTime()) ? 0 : date.getTime();\r\n}\r\n\r\nexport default function CoursesPage({\r\n  params,\r\n  searchParams,\r\n}: {\r\n  params: Promise<{ slug?: string }>;\r\n  searchParams: Promise<{ [key: string]: string | string[] | undefined }>;\r\n}) {\r\n  const { user, isLoading: authLoading, fetchWithAuth } = useAuth();\r\n  const router = useRouter();\r\n\r\n  const [courses, setCourses] = useState<Course[]>([]);\r\n  const [categories, setCategories] = useState<CourseCategory[]>([]);\r\n  const [activeCategory, setActiveCategory] = useState(\"all\");\r\n  const [searchTerm, setSearchTerm] = useState(\"\");\r\n  const [sortBy, setSortBy] = useState<SortOption>(\"newest\");\r\n  const [levelFilter, setLevelFilter] = useState<CourseLevelFilter>(\"all\");\r\n  const [showEnrolledOnly, setShowEnrolledOnly] = useState(false);\r\n  const [loading, setLoading] = useState(true);\r\n  const [fetchError, setFetchError] = useState<string | null>(null);\r\n  const [enrollingId, setEnrollingId] = useState<string | null>(null);\r\n  const [visibleCount, setVisibleCount] = useState(PAGE_SIZE);\r\n  const [refreshKey, setRefreshKey] = useState(0);\r\n  const [wishlistIds, setWishlistIds] = useState<Set<string>>(new Set());\r\n\r\n  const resetFilters = () => {\r\n    setActiveCategory(\"all\");\r\n    setSearchTerm(\"\");\r\n    setSortBy(\"newest\");\r\n    setLevelFilter(\"all\");\r\n    setShowEnrolledOnly(false);\r\n    setVisibleCount(PAGE_SIZE);\r\n  };\r\n\r\n  const hasActiveFilters =\r\n    activeCategory !== \"all\" ||\r\n    searchTerm.trim() !== \"\" ||\r\n    levelFilter !== \"all\" ||\r\n    showEnrolledOnly;\r\n\r\n  useEffect(() => {\r\n    if (authLoading) return;\r\n\r\n    const controller = new AbortController();\r\n\r\n    const fetchCourses = async () => {\r\n      try {\r\n        setLoading(true);\r\n        setFetchError(null);\r\n\r\n        const response = await fetchWithAuth(\"/api/courses\", {\r\n          cache: \"no-store\",\r\n          signal: controller.signal,\r\n        });\r\n\r\n        if (!response.ok) throw new Error(`Failed to fetch courses (${response.status})`);\r\n\r\n        const data = (await response.json()) as CoursesApiResponse;\r\n        const fetchedCourses = Array.isArray(data.courses)\r\n          ? data.courses\r\n          : Array.isArray(data.subjects)\r\n            ? data.subjects\r\n            : [];\r\n        const fetchedCategories = Array.isArray(data.categories) ? data.categories : [];\r\n\r\n        setCourses(fetchedCourses);\r\n        setCategories(fetchedCategories);\r\n      } catch (error) {\r\n        if (controller.signal.aborted) return;\r\n        logger.error(\"Error fetching courses:\", error);\r\n\r\n        let errorMessage = \"в•ӘШІв•Әв•Јв•Әв–‘в•Әв–’ в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШҜв•ӘШІ в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШҜв”ҳГҜ.\";\r\n        let toastMessage = \"в•ӘШІв•Әв•Јв•Әв–‘в•Әв–’ в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШҜв•ӘШІ\";\r\n\r\n        if (error instanceof TypeError && error.message.includes('fetch')) {\r\n          errorMessage = \"в”ҳВ„в•ӘШҜ в”ҳГЁв”ҳГ в”ҳГўв”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„ в•ӘШ°в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШҜв•ӘВ»в”ҳГ . в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в”ҳГ в”ҳВҶ в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„в”ҳГў в•ӘШ°в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШІв•Әв–’в”ҳВҶв•ӘШІ.\";\r\n          toastMessage = \"в”ҳГ в•Әв”Өв”ҳГўв”ҳВ„в•ӘШұ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„ в•ӘШ°в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШҜв•ӘВ»в”ҳГ \";\r\n        } else if (error instanceof Error && error.message.includes('500')) {\r\n          errorMessage = \"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘВ»в•ӘШҜв•ӘВ«в”ҳВ„в”ҳГЁ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШҜв•ӘВ»в”ҳГ .\";\r\n          toastMessage = \"в•ӘВ«в•Әв•–в•ӘШ« в•ӘВ»в•ӘШҜв•ӘВ«в”ҳВ„в”ҳГЁ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШҜв•ӘВ»в”ҳГ \";\r\n        } else if (error instanceof Error && error.message.includes('403')) {\r\n          errorMessage = \"в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв•Ўв•Әв–’в•ӘШө в”ҳВ„в”ҳГў в•ӘШ°в•ӘШҜв”ҳВ„в”ҳГӘв•Әв•Ўв”ҳГӘв”ҳВ„ в•ӘШӯв”ҳВ„в”ҳГ« в”ҳГ§в•Әв–‘в”ҳГ§ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ.\";\r\n          toastMessage = \"в”ҳГӘв•Әв•Ўв”ҳГӘв”ҳВ„ в”ҳГ в•ӘШөв•Әв••в”ҳГӘв•Әв–’\";\r\n        }\r\n\r\n        setCourses([]);\r\n        setCategories([]);\r\n        setFetchError(errorMessage);\r\n        toast.error(toastMessage);\r\n      } finally {\r\n        if (!controller.signal.aborted) setLoading(false);\r\n      }\r\n    };\r\n\r\n    void fetchCourses();\r\n    return () => controller.abort();\r\n  }, [authLoading, refreshKey, user?.id, fetchWithAuth]);\r\n\r\n  useEffect(() => {\r\n    setVisibleCount(PAGE_SIZE);\r\n  }, [activeCategory, searchTerm, sortBy, levelFilter, showEnrolledOnly]);\r\n\r\n  const filteredCourses = useMemo(() => {\r\n    const normalizedSearch = searchTerm.trim().toLowerCase();\r\n\r\n    return courses.filter((course) => {\r\n      if (showEnrolledOnly && !course.enrolled) return false;\r\n\r\n      const matchesCategory =\r\n        activeCategory === \"all\" ||\r\n        course.categoryId === activeCategory ||\r\n        course.subject === activeCategory;\r\n\r\n      const matchesLevel = levelFilter === \"all\" || normalizeLevel(course.level) === levelFilter;\r\n\r\n      if (!normalizedSearch) return matchesCategory && matchesLevel;\r\n\r\n      const matchesSearch =\r\n        course.title.toLowerCase().includes(normalizedSearch) ||\r\n        course.instructor.toLowerCase().includes(normalizedSearch) ||\r\n        course.description.toLowerCase().includes(normalizedSearch) ||\r\n        course.tags.some(tag => tag.toLowerCase().includes(normalizedSearch));\r\n\r\n      return matchesCategory && matchesSearch && matchesLevel;\r\n    });\r\n  }, [courses, activeCategory, searchTerm, levelFilter, showEnrolledOnly]);\r\n\r\n  const sortedCourses = useMemo(() => {\r\n    return [...filteredCourses].sort((left, right) => {\r\n      switch (sortBy) {\r\n        case \"newest\":\r\n          return toTimestamp(right.createdAt) - toTimestamp(left.createdAt);\r\n        case \"popular\":\r\n          return (right.enrolledCount || 0) - (left.enrolledCount || 0);\r\n        case \"rated\":\r\n          return (right.rating || 0) - (left.rating || 0);\r\n        case \"price-low\":\r\n          return (left.price || 0) - (right.price || 0);\r\n        case \"price-high\":\r\n          return (right.price || 0) - (left.price || 0);\r\n        case \"duration-short\":\r\n          return (left.duration || 0) - (right.duration || 0);\r\n        case \"duration-long\":\r\n          return (right.duration || 0) - (left.duration || 0);\r\n        default:\r\n          return 0;\r\n      }\r\n    });\r\n  }, [filteredCourses, sortBy]);\r\n\r\n  const featuredCourses = useMemo(() => {\r\n    // Priority 1: Courses manually marked as featured in database\r\n    // Priority 2: Fallback to highest rated courses\r\n    const allFeatured = courses.filter(c => (c as any).isFeatured);\r\n    \r\n    if (allFeatured.length > 0) {\r\n      return allFeatured.slice(0, 6);\r\n    }\r\n\r\n    const source = showEnrolledOnly ? courses.filter((course) => course.enrolled) : courses;\r\n    return [...source]\r\n      .sort((a, b) => (b.rating || 0) - (a.rating || 0))\r\n      .slice(0, 5);\r\n  }, [courses, showEnrolledOnly]);\r\n\r\n  const stats = useMemo(() => {\r\n    const enrolledCoursesCount = courses.filter((course) => course.enrolled).length;\r\n    const freeCoursesCount = courses.filter((course) => (course.price || 0) === 0).length;\r\n    const totalLessons = courses.reduce((acc, course) => acc + (course.lessonsCount || 0), 0);\r\n    const avgRating = courses.length > 0\r\n      ? courses.reduce((sum, course) => sum + (course.rating || 0), 0) / courses.length\r\n      : 0;\r\n\r\n    return {\r\n      totalCourses: courses.length,\r\n      totalStudents: courses.reduce((acc, course) => acc + (course.enrolledCount || 0), 0),\r\n      enrolledCoursesCount,\r\n      freeCoursesCount,\r\n      totalInstructors: new Set(courses.map(c => c.instructor)).size,\r\n      totalLessons,\r\n      avgRating: parseFloat(avgRating.toFixed(1)),\r\n    };\r\n  }, [courses]);\r\n\r\n  const handleEnroll = async (courseId: string) => {\r\n    if (!user) {\r\n      toast.error(\"в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в•ӘШ«в”ҳГӘв”ҳВ„в•ӘШҜв”ҳГҜ\");\r\n      router.push(\"/login?redirect=/courses\");\r\n      return;\r\n    }\r\n    setEnrollingId(courseId);\r\n    try {\r\n      const res = await fetch(`/api/courses/${courseId}/enroll`, { method: \"POST\" });\r\n      if (res.ok) {\r\n        const data = await res.json();\r\n        if (data.requiresPayment) {\r\n          router.push(`/courses/${courseId}/checkout`);\r\n          return;\r\n        }\r\n        toast.success(\"в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө!\");\r\n        setRefreshKey(k => k + 1);\r\n      } else {\r\n        toast.error(\"в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„\");\r\n      }\r\n    } catch (err) {\r\n      toast.error(\"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„\");\r\n    } finally {\r\n      setEnrollingId(null);\r\n    }\r\n  };\r\n\r\n  const handleUnenroll = async (courseId: string) => {\r\n    setEnrollingId(courseId);\r\n    try {\r\n      const res = await fetch(`/api/courses/${courseId}/enroll`, { method: \"DELETE\" });\r\n      if (res.ok) {\r\n        toast.success(\"в•ӘШІв”ҳГ  в•ӘШӯв”ҳВ„в•Әв•‘в•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„\");\r\n        setRefreshKey(k => k + 1);\r\n      }\r\n    } finally {\r\n      setEnrollingId(null);\r\n    }\r\n  };\r\n\r\n  const toggleWishlist = (courseId: string) => {\r\n    setWishlistIds(prev => {\r\n      const newSet = new Set(prev);\r\n      if (newSet.has(courseId)) {\r\n        newSet.delete(courseId);\r\n      } else {\r\n        newSet.add(courseId);\r\n      }\r\n      return newSet;\r\n    });\r\n  };\r\n\r\n  const visibleCourses = sortedCourses.slice(0, visibleCount);\r\n  const canLoadMore = visibleCount < sortedCourses.length;\r\n\r\n  if (loading) return <CoursesLoadingSkeleton />;\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-gray-50 dark:bg-[#0B0D14]\" dir=\"rtl\">\r\n      {/* Ambient background */}\r\n      <div className=\"fixed inset-0 pointer-events-none -z-10\">\r\n        <div className=\"absolute top-0 right-0 w-[600px] h-[600px] bg-primary/[0.02] blur-[150px] rounded-full\" />\r\n        <div className=\"absolute bottom-0 left-0 w-[500px] h-[500px] bg-violet-500/[0.02] blur-[130px] rounded-full\" />\r\n      </div>\r\n\r\n      <div className=\"mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8 space-y-10\">\r\n        {/* Hero Section */}\r\n        <CoursesHero\r\n          totalCourses={stats.totalCourses}\r\n          totalStudents={stats.totalStudents}\r\n          totalInstructors={stats.totalInstructors}\r\n          avgRating={stats.avgRating}\r\n        />\r\n\r\n        {/* Quick Stats - compact row */}\r\n        <div className=\"grid grid-cols-2 md:grid-cols-5 gap-3\">\r\n          {[\r\n            { label: \"в•ӘШӯв•ӘШҙв”ҳГ в•ӘШҜв”ҳВ„в”ҳГЁ в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШҜв•ӘШІ\", val: stats.totalCourses, icon: BookOpen, color: \"text-blue-500\", bg: \"bg-blue-500/10\" },\r\n            { label: \"в•ӘШӯв•ӘШҙв”ҳГ в•ӘШҜв”ҳВ„в”ҳГЁ в•ӘШҜв”ҳВ„в•Әв•–в”ҳВ„в•ӘШҜв•ӘШ°\", val: stats.totalStudents, icon: Users, color: \"text-violet-500\", bg: \"bg-violet-500/10\" },\r\n            { label: \"в•ӘВ»в”ҳГӘв•Әв–’в•ӘШҜв•ӘШІв”ҳГў в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Өв•Әв•–в•ӘШұ\", val: stats.enrolledCoursesCount, icon: BookCheck, color: \"text-emerald-500\", bg: \"bg-emerald-500/10\" },\r\n            { label: \"в•ӘВ»в”ҳГӘв•Әв–’в•ӘШҜв•ӘШІ в”ҳГ в•ӘШҙв•ӘШҜв”ҳВҶв”ҳГЁв•ӘШұ\", val: stats.freeCoursesCount, icon: Sparkles, color: \"text-amber-500\", bg: \"bg-amber-500/10\" },\r\n            { label: \"в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•– в•ӘШҜв”ҳВ„в•ӘШІв”ҳГ©в”ҳГЁв”ҳГЁв”ҳГ \", val: stats.avgRating, icon: Star, color: \"text-yellow-500\", bg: \"bg-yellow-500/10\" },\r\n          ].map((stat, i) => (\r\n            <motion.div\r\n              key={i}\r\n              initial={{ opacity: 0, y: 12 }}\r\n              animate={{ opacity: 1, y: 0 }}\r\n              transition={{ delay: i * 0.05 }}\r\n              className=\"flex items-center gap-3 rounded-xl border border-gray-200 dark:border-white/[0.06] bg-white dark:bg-gray-900/80 p-4 transition-all hover:border-gray-300 dark:hover:border-white/10\"\r\n            >\r\n              <div className={cn(\"flex h-10 w-10 shrink-0 items-center justify-center rounded-xl\", stat.bg)}>\r\n                <stat.icon className={cn(\"h-5 w-5\", stat.color)} />\r\n              </div>\r\n              <div className=\"min-w-0\">\r\n                <p className=\"text-[10px] font-bold uppercase tracking-wider text-gray-500 truncate\">{stat.label}</p>\r\n                <p className=\"text-xl font-black text-gray-900 dark:text-white\" suppressHydrationWarning>\r\n                  {typeof stat.val === 'number' && stat.val >= 1000\r\n                    ? `${(stat.val / 1000).toFixed(1)}K`\r\n                    : stat.val}\r\n                </p>\r\n              </div>\r\n            </motion.div>\r\n          ))}\r\n        </div>\r\n\r\n        {/* Featured Courses */}\r\n        {!loading && featuredCourses.length > 0 && (\r\n          <FeaturedCourses\r\n            courses={featuredCourses}\r\n            onEnroll={handleEnroll}\r\n            onUnenroll={handleUnenroll}\r\n            enrollingId={enrollingId}\r\n          />\r\n        )}\r\n\r\n        {/* Main Content */}\r\n        <div className=\"space-y-8\">\r\n          {/* Tab Switcher */}\r\n          <div className=\"flex flex-col md:flex-row items-center justify-between gap-6\">\r\n            <div className=\"flex items-center gap-2 p-1 rounded-xl bg-gray-100 dark:bg-white/5\">\r\n              <button\r\n                onClick={() => setShowEnrolledOnly(false)}\r\n                className={cn(\r\n                  \"flex items-center gap-2 rounded-lg px-5 py-2.5 text-sm font-bold transition-all\",\r\n                  !showEnrolledOnly\r\n                    ? \"bg-white dark:bg-gray-800 text-gray-900 dark:text-white shadow-sm\"\r\n                    : \"text-gray-500 hover:text-gray-700 dark:hover:text-gray-300\"\r\n                )}\r\n              >\r\n                <LayoutGrid className=\"h-4 w-4\" />\r\n                <span>в•ӘШҙв”ҳГ в”ҳГЁв•Әв•Ј в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШҜв•ӘШІ</span>\r\n              </button>\r\n              <button\r\n                onClick={() => setShowEnrolledOnly(true)}\r\n                className={cn(\r\n                  \"flex items-center gap-2 rounded-lg px-5 py-2.5 text-sm font-bold transition-all\",\r\n                  showEnrolledOnly\r\n                    ? \"bg-white dark:bg-gray-800 text-gray-900 dark:text-white shadow-sm\"\r\n                    : \"text-gray-500 hover:text-gray-700 dark:hover:text-gray-300\"\r\n                )}\r\n              >\r\n                <BookCheck className=\"h-4 w-4\" />\r\n                <span>в•ӘВ»в”ҳГӘв•Әв–’в•ӘШҜв•ӘШІв”ҳГЁ</span>\r\n                {stats.enrolledCoursesCount > 0 && (\r\n                  <span className=\"flex h-5 min-w-5 items-center justify-center rounded-full bg-primary/10 px-1.5 text-[10px] font-bold text-primary\">\r\n                    {stats.enrolledCoursesCount}\r\n                  </span>\r\n                )}\r\n              </button>\r\n            </div>\r\n\r\n            <div className=\"flex items-center gap-3\">\r\n              <div className=\"hidden md:flex items-center gap-1.5 text-xs text-gray-400\">\r\n                <TrendingUp className=\"h-3.5 w-3.5\" />\r\n                <span>в”ҳГ в•ӘШөв•ӘВ»в•ӘШів•ӘШұ в•ӘШ°в•ӘШҜв•Әв”Ӯв•ӘШІв”ҳГ в•Әв–’в•ӘШҜв•Әв–’</span>\r\n              </div>\r\n              <div className=\"flex gap-1.5\">\r\n                <button\r\n                  className=\"flex h-9 w-9 items-center justify-center rounded-lg border border-gray-200 dark:border-white/10 bg-white dark:bg-gray-900/80 text-gray-500 hover:text-gray-700 dark:hover:text-white transition-colors\"\r\n                  onClick={() => window.print()}\r\n                  title=\"в•ӘШІв•Әв•Ўв•ӘВ»в”ҳГЁв•Әв–’\"\r\n                >\r\n                  <Download className=\"h-4 w-4\" />\r\n                </button>\r\n                <button\r\n                  className=\"flex h-9 w-9 items-center justify-center rounded-lg border border-gray-200 dark:border-white/10 bg-white dark:bg-gray-900/80 text-gray-500 hover:text-gray-700 dark:hover:text-white transition-colors\"\r\n                  onClick={() =>\r\n                    navigator.share\r\n                      ? navigator.share({\r\n                          title: \"Thanawy - в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Јв”ҳВ„в”ҳГЁв”ҳГ в”ҳГЁв•ӘШұ\",\r\n                          text: \"в•ӘШҜв”ҳГўв•ӘШІв•Әв”Өв”ҳВҒ в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Јв”ҳВ„в”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ«в•ӘШІв”ҳВ„в”ҳВҒв•ӘШұ в•Әв•Јв”ҳВ„в”ҳГ« в”ҳГ в”ҳВҶв•Әв•Ўв•ӘШұ Thanawy\",\r\n                          url: window.location.href,\r\n                        })\r\n                      : null\r\n                  }\r\n                  title=\"в”ҳГ в•Әв”Өв•ӘШҜв•Әв–’в”ҳГўв•ӘШұ\"\r\n                >\r\n                  <Share2 className=\"h-4 w-4\" />\r\n                </button>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          {/* Filters */}\r\n          <CoursesFilter\r\n            categories={categories}\r\n            activeCategory={activeCategory}\r\n            setActiveCategory={setActiveCategory}\r\n            searchTerm={searchTerm}\r\n            setSearchTerm={setSearchTerm}\r\n            sortBy={sortBy}\r\n            setSortBy={setSortBy}\r\n            levelFilter={levelFilter}\r\n            setLevelFilter={setLevelFilter}\r\n            resultsCount={sortedCourses.length}\r\n            hasActiveFilters={hasActiveFilters}\r\n            onResetFilters={resetFilters}\r\n          />\r\n\r\n          {/* Results info */}\r\n          {sortedCourses.length > 0 && (\r\n            <div className=\"flex items-center justify-between\">\r\n              <p className=\"text-sm text-gray-500\">\r\n                в•Әв•Јв•Әв–’в•Әв•ў <span className=\"font-bold text-gray-700 dark:text-white\">{Math.min(visibleCount, sortedCourses.length)}</span> в”ҳГ в”ҳВҶ{\" \"}\r\n                <span className=\"font-bold text-gray-700 dark:text-white\">{sortedCourses.length}</span> в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ\r\n              </p>\r\n              {hasActiveFilters && (\r\n                <button\r\n                  onClick={resetFilters}\r\n                  className=\"text-xs font-medium text-primary hover:underline\"\r\n                >\r\n                  в•ӘШӯв•Әв–“в•ӘШҜв”ҳВ„в•ӘШұ в•ӘШҙв”ҳГ в”ҳГЁв•Әв•Ј в•ӘШҜв”ҳВ„в”ҳВҒв”ҳВ„в•ӘШҜв•ӘШІв•Әв–’\r\n                </button>\r\n              )}\r\n            </div>\r\n          )}\r\n\r\n          {/* Course Grid */}\r\n          {sortedCourses.length === 0 && !loading ? (\r\n            <CoursesEmptyState />\r\n          ) : (\r\n            <>\r\n              <div className=\"grid gap-5 sm:grid-cols-2 lg:grid-cols-3\">\r\n                <AnimatePresence mode=\"popLayout\">\r\n                  {visibleCourses.map((course, index) => (\r\n                    <CourseCard\r\n                      key={course.id}\r\n                      {...course}\r\n                      index={index}\r\n                      isProcessing={enrollingId === course.id}\r\n                      isWishlisted={wishlistIds.has(course.id)}\r\n                      onEnroll={() => handleEnroll(course.id)}\r\n                      onUnenroll={() => handleUnenroll(course.id)}\r\n                      onWishlistToggle={() => toggleWishlist(course.id)}\r\n                    />\r\n                  ))}\r\n                </AnimatePresence>\r\n              </div>\r\n\r\n              {/* Load More */}\r\n              {canLoadMore && (\r\n                <div className=\"flex justify-center pt-4\">\r\n                  <Button\r\n                    onClick={() => setVisibleCount((v) => v + PAGE_SIZE)}\r\n                    variant=\"outline\"\r\n                    className=\"gap-2 rounded-xl border-gray-200 dark:border-white/10 px-8 py-3 text-sm font-bold hover:bg-gray-50 dark:hover:bg-white/5\"\r\n                  >\r\n                    <ArrowDown className=\"h-4 w-4\" />\r\n                    <span>в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в”ҳГ в•Әв–“в”ҳГЁв•ӘВ» ({sortedCourses.length - visibleCount} в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ в”ҳГ в•ӘШІв•ӘШ°в”ҳГ©в”ҳГЁв•ӘШұ)</span>\r\n                  </Button>\r\n                </div>\r\n              )}\r\n            </>\r\n          )}\r\n        </div>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(education)\\exams\\components\\ExamGrades.tsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'fetchData'. Either include it or remove the dependency array.","line":118,"column":6,"nodeType":"ArrayExpression","endLine":118,"endColumn":14,"suggestions":[{"desc":"Update the dependencies array to be: [fetchData, userId]","fix":{"range":[3505,3513],"text":"[fetchData, userId]"}}]},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useCallback has a missing dependency: 'assignmentTypes'. Either include it or remove the dependency array.","line":363,"column":6,"nodeType":"ArrayExpression","endLine":363,"endColumn":8,"suggestions":[{"desc":"Update the dependencies array to be: [assignmentTypes]","fix":{"range":[11615,11617],"text":"[assignmentTypes]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"ЩҠв•—в”җ\"use client\";\r\n\r\nimport React, { useState, useEffect, useCallback, useMemo } from 'react';\r\nimport { Card, CardContent, CardDescription, CardHeader, CardTitle } from \"@/components/ui/card\";\r\nimport { Button } from '@/components/ui/button';\r\nimport { Input } from '@/components/ui/input';\r\nimport { Label } from '@/components/ui/label';\r\nimport { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';\r\nimport { Textarea } from '@/components/ui/textarea';\r\nimport { Badge } from \"@/components/ui/badge\";\r\nimport { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';\r\nimport { Dialog, DialogContent, DialogDescription, DialogFooter, DialogHeader, DialogTitle } from '@/components/ui/dialog';\r\nimport { Calendar, BookOpen, User, Award, TrendingUp, PlusCircle, AlertCircle, Loader2, Trash2 } from 'lucide-react';\r\nimport { logger } from '@/lib/logger';\r\nimport { safeFetch } from \"@/lib/safe-client-utils\";\r\n\r\ninterface Exam {\r\n  id: string;\r\n  title: string;\r\n  subject: string;\r\n  year: number;\r\n  type?: string;\r\n}\r\n\r\ninterface ExamsResponse {\r\n  exams: Exam[];\r\n}\r\n\r\ninterface ExamResult {\r\n  id: string;\r\n  exam: Exam;\r\n  score: number;\r\n  takenAt: string;\r\n  teacherId?: string;\r\n  teacher?: {\r\n    id: string;\r\n    name: string;\r\n  };\r\n}\r\n\r\ninterface UserGrade {\r\n  id: string;\r\n  subject: string;\r\n  grade: number;\r\n  maxGrade: number;\r\n  date: string;\r\n  notes?: string;\r\n  isOnline: boolean;\r\n  assignmentType: string;\r\n  teacherId?: string;\r\n  teacher?: {\r\n    id: string;\r\n    name: string;\r\n  };\r\n  examResultId?: string;\r\n}\r\n\r\ninterface SubjectAverage {\r\n  subject: string;\r\n  _avg: {\r\n    grade: number;\r\n  };\r\n}\r\n\r\ninterface ExamGradesProps {\r\n  userId: string;\r\n  subjects: string[];\r\n  teachers?: {id: string;name: string;subject: string;}[];\r\n}\r\n\r\nexport default function ExamGrades({ userId, subjects, teachers = [] }: ExamGradesProps) {\r\n  const [activeTab, setActiveTab] = useState('exams');\r\n  const [examResults, setExamResults] = useState<ExamResult[]>([]);\r\n  const [userGrades, setUserGrades] = useState<UserGrade[]>([]);\r\n  const [subjectAverages, setSubjectAverages] = useState<SubjectAverage[]>([]);\r\n  const [availableExams, setAvailableExams] = useState<Exam[]>([]);\r\n  const [isLoading, setIsLoading] = useState(true);\r\n  const [isSubmitting, setIsSubmitting] = useState(false);\r\n  const [showAddGradeForm, setShowAddGradeForm] = useState(false);\r\n  const [showAddExamForm, setShowAddExamForm] = useState(false);\r\n  const [error, setError] = useState<string | null>(null);\r\n  const [submitError, setSubmitError] = useState<string | null>(null);\r\n\r\n  // в”ҳВҶв”ҳГ в”ҳГӘв•Әв–‘в•ӘШҙ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ\r\n  const [newGrade, setNewGrade] = useState({\r\n    subject: '',\r\n    grade: '',\r\n    maxGrade: '100',\r\n    date: new Date().toISOString().split('T')[0],\r\n    notes: '',\r\n    isOnline: false,\r\n    assignmentType: 'OTHER',\r\n    teacherId: ''\r\n  });\r\n\r\n  // в”ҳВҶв”ҳГ в”ҳГӘв•Әв–‘в•ӘШҙ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в”ҳВҶв•ӘШІв”ҳГЁв•ӘШҙв•ӘШұ в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ\r\n  const [newExamResult, setNewExamResult] = useState({\r\n    examId: '',\r\n    score: '',\r\n    teacherId: '',\r\n    notes: '',\r\n    isOnline: false\r\n  });\r\n\r\n  // в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ в•ӘШ«в”ҳВҶв”ҳГӘв•ӘШҜв•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГӘв•ӘШҜв•ӘШҙв•ӘШ°в•ӘШҜв•ӘШІ\r\n  const assignmentTypes = [\r\n  { value: 'EXAM', label: 'в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ' },\r\n  { value: 'QUIZ', label: 'в•ӘШҜв•ӘВ«в•ӘШІв•ӘШ°в•ӘШҜв•Әв–’ в”ҳГ©в•Әв•Ўв”ҳГЁв•Әв–’' },\r\n  { value: 'HOMEWORK', label: 'в”ҳГӘв•ӘШҜв•ӘШҙв•ӘШ° в”ҳГ в”ҳВҶв•Әв–“в”ҳВ„в”ҳГЁ' },\r\n  { value: 'PROJECT', label: 'в”ҳГ в•Әв”Өв•Әв–’в”ҳГӘв•Әв•Ј' },\r\n  { value: 'PARTICIPATION', label: 'в”ҳГ в•Әв”Өв•ӘШҜв•Әв–’в”ҳГўв•ӘШұ' },\r\n  { value: 'OTHER', label: 'в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ«' }];\r\n\r\n\r\n  // в•ӘШҙв”ҳВ„в•ӘШ° в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶ\r\n  useEffect(() => {\r\n    fetchData();\r\n  }, [userId]);\r\n\r\n  const fetchData = useCallback(async () => {\r\n    if (!userId) return;\r\n\r\n    setIsLoading(true);\r\n    setError(null);\r\n\r\n    try {\r\n      // в•ӘШҙв”ҳВ„в•ӘШ° в”ҳВҶв•ӘШІв•ӘШҜв•ӘШ®в•ӘШҙ в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в”ҳГӘв•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІ в”ҳВҒв”ҳГЁ в”ҳВҶв”ҳВҒв•Әв”Ӯ в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГ©в•ӘШІ\r\n      const [examsResponse, gradesResponse, examsListResponse] = await Promise.allSettled([\r\n      safeFetch<{exams: ExamResult[];grades: UserGrade[];}>(\r\n        `/api/exams/grades?userId=${userId}`,\r\n        undefined,\r\n        { exams: [], grades: [] }\r\n      ),\r\n      safeFetch<{grades: UserGrade[];averages: SubjectAverage[];}>(\r\n        `/api/grades?userId=${userId}`,\r\n        undefined,\r\n        { grades: [], averages: [] }\r\n      ),\r\n      safeFetch<ExamsResponse>(\r\n        \"/api/exams\",\r\n        undefined,\r\n        { exams: [] }\r\n      )]\r\n      );\r\n\r\n      // в”ҳГ в•Әв•Јв•ӘШҜв”ҳВ„в•ӘШҙв•ӘШұ в”ҳВҶв•ӘШІв•ӘШҜв•ӘШ®в•ӘШҙ в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ\r\n      if (examsResponse.status === 'fulfilled' && !examsResponse.value.error) {\r\n        setExamResults(examsResponse.value.data?.exams || []);\r\n        setUserGrades(examsResponse.value.data?.grades || []);\r\n      } else {\r\n        logger.error('Error fetching exam results:', examsResponse.status === 'rejected' ? examsResponse.reason : examsResponse.value.error);\r\n        setError(\"в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„ в”ҳВҶв•ӘШІв•ӘШҜв•ӘШ®в•ӘШҙ в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ\");\r\n      }\r\n\r\n      // в”ҳГ в•Әв•Јв•ӘШҜв”ҳВ„в•ӘШҙв•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІ в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•–в•ӘШҜв•ӘШІ\r\n      if (gradesResponse.status === 'fulfilled' && !gradesResponse.value.error) {\r\n        const gradesData = gradesResponse.value.data;\r\n        if (gradesData?.grades) {\r\n          setUserGrades((prev) => {\r\n            // в•ӘВ»в”ҳГ в•ӘШҙ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІ в”ҳГ в•Әв•Ј в•ӘШІв•ӘШҙв”ҳВҶв•ӘШ° в•ӘШҜв”ҳВ„в•ӘШІв”ҳГўв•Әв–’в•ӘШҜв•Әв–’\r\n            const merged = [...prev];\r\n            gradesData.grades.forEach((grade) => {\r\n              if (!merged.find((g) => g.id === grade.id)) {\r\n                merged.push(grade);\r\n              }\r\n            });\r\n            return merged;\r\n          });\r\n        }\r\n        if (gradesData?.averages) {\r\n          setSubjectAverages(gradesData.averages);\r\n        }\r\n      } else {\r\n        logger.error('Error fetching grades:', gradesResponse.status === 'rejected' ? gradesResponse.reason : gradesResponse.value.error);\r\n        if (!error) setError(\"в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІ\");\r\n      }\r\n\r\n      // в”ҳГ в•Әв•Јв•ӘШҜв”ҳВ„в•ӘШҙв•ӘШұ в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШІв•ӘШҜв•ӘШөв•ӘШұ\r\n      if (examsListResponse.status === 'fulfilled' && !examsListResponse.value.error) {\r\n        setAvailableExams(Array.isArray(examsListResponse.value.data?.exams) ? examsListResponse.value.data.exams : []);\r\n      } else {\r\n        logger.warn('Error fetching available exams:', examsListResponse.status === 'rejected' ? examsListResponse.reason : examsListResponse.value.error);\r\n      }\r\n    } catch (err) {\r\n      logger.error('Error fetching data:', err);\r\n      setError(\"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ\");\r\n    } finally {\r\n      setIsLoading(false);\r\n    }\r\n  }, [userId, error]);\r\n\r\n  const handleAddGrade = async (e: React.FormEvent) => {\r\n    e.preventDefault();\r\n    setIsSubmitting(true);\r\n    setSubmitError(null);\r\n\r\n    // Validation\r\n    const gradeNum = parseFloat(newGrade.grade);\r\n    const maxGradeNum = parseFloat(newGrade.maxGrade);\r\n\r\n    if (isNaN(gradeNum) || gradeNum < 0) {\r\n      setSubmitError(\"в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҙв•ӘШҜв•ӘШ© в•ӘШӯв•ӘВ»в•ӘВ«в•ӘШҜв”ҳВ„ в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в•Әв•Ўв•ӘШөв”ҳГЁв•ӘШөв•ӘШұ\");\r\n      setIsSubmitting(false);\r\n      return;\r\n    }\r\n\r\n    if (isNaN(maxGradeNum) || maxGradeNum <= 0) {\r\n      setSubmitError(\"в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҙв•ӘШҜв•ӘШ© в•ӘШӯв•ӘВ»в•ӘВ«в•ӘШҜв”ҳВ„ в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в•Әв•Јв•Әв••в”ҳГ в”ҳГ« в•Әв•Ўв•ӘШөв”ҳГЁв•ӘШөв•ӘШұ\");\r\n      setIsSubmitting(false);\r\n      return;\r\n    }\r\n\r\n    if (gradeNum > maxGradeNum) {\r\n      setSubmitError(\"в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в”ҳВ„в•ӘШҜ в”ҳГЁв”ҳГ в”ҳГўв”ҳВҶ в•ӘШ«в”ҳВҶ в•ӘШІв”ҳГўв”ҳГӘв”ҳВҶ в•ӘШ«в”ҳГўв•ӘШ°в•Әв–’ в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в•ӘШҜв”ҳВ„в•Әв•Јв•Әв••в”ҳГ в”ҳГ«\");\r\n      setIsSubmitting(false);\r\n      return;\r\n    }\r\n\r\n    if (!newGrade.subject) {\r\n      setSubmitError(\"в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҙв•ӘШҜв•ӘШ© в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ\");\r\n      setIsSubmitting(false);\r\n      return;\r\n    }\r\n\r\n    try {\r\n      const { data, error: responseError } = await safeFetch<{success: boolean;}>(\r\n        '/api/grades',\r\n        {\r\n          method: 'POST',\r\n          headers: {\r\n            'Content-Type': 'application/json'\r\n          },\r\n          body: JSON.stringify({\r\n            userId,\r\n            subject: newGrade.subject,\r\n            grade: gradeNum,\r\n            maxGrade: maxGradeNum,\r\n            date: newGrade.date,\r\n            notes: newGrade.notes,\r\n            isOnline: newGrade.isOnline,\r\n            assignmentType: newGrade.assignmentType,\r\n            teacherId: newGrade.teacherId || undefined\r\n          })\r\n        },\r\n        { success: false }\r\n      );\r\n\r\n      if (responseError || !data?.success) {\r\n        const errorMessage = responseError?.message || \"в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ\";\r\n        setSubmitError(errorMessage);\r\n        logger.error('Failed to add grade:', responseError);\r\n      } else {\r\n        // в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШІв•Әв•Јв”ҳГЁв”ҳГЁв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ в”ҳГӘв•Әв–‘в•ӘШҙ в”ҳГӘв•ӘШӯв•ӘВ«в”ҳВҒв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ в”ҳГӘв•Әв–‘в•ӘШҙ\r\n        setNewGrade({\r\n          subject: '',\r\n          grade: '',\r\n          maxGrade: '100',\r\n          date: new Date().toISOString().split('T')[0],\r\n          notes: '',\r\n          isOnline: false,\r\n          assignmentType: 'OTHER',\r\n          teacherId: ''\r\n        });\r\n        setShowAddGradeForm(false);\r\n        setSubmitError(null);\r\n        // в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҙв”ҳВ„в•ӘШ° в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ\r\n        await fetchData();\r\n      }\r\n    } catch (error) {\r\n      logger.error('Error adding grade:', error);\r\n      setSubmitError(\"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШІв”ҳГӘв”ҳГ©в•Әв•Ј\");\r\n    } finally {\r\n      setIsSubmitting(false);\r\n    }\r\n  };\r\n\r\n  const handleAddExamResult = async (e: React.FormEvent) => {\r\n    e.preventDefault();\r\n    setIsSubmitting(true);\r\n    setSubmitError(null);\r\n\r\n    // Validation\r\n    const scoreNum = parseFloat(newExamResult.score);\r\n\r\n    if (!newExamResult.examId) {\r\n      setSubmitError(\"в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҙв•ӘШҜв•ӘШ© в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ\");\r\n      setIsSubmitting(false);\r\n      return;\r\n    }\r\n\r\n    if (isNaN(scoreNum) || scoreNum < 0 || scoreNum > 100) {\r\n      setSubmitError(\"в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҙв•ӘШҜв•ӘШ© в•ӘШӯв•ӘВ»в•ӘВ«в•ӘШҜв”ҳВ„ в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в•Әв•Ўв•ӘШөв”ҳГЁв•ӘШөв•ӘШұ в•ӘШ°в”ҳГЁв”ҳВҶ 0 в”ҳГӘ 100\");\r\n      setIsSubmitting(false);\r\n      return;\r\n    }\r\n\r\n    try {\r\n      const { data, error: responseError } = await safeFetch<{success: boolean;examResult: ExamResult;}>(\r\n        '/api/exams/grades',\r\n        {\r\n          method: 'POST',\r\n          headers: {\r\n            'Content-Type': 'application/json'\r\n          },\r\n          body: JSON.stringify({\r\n            userId,\r\n            examId: newExamResult.examId,\r\n            score: scoreNum,\r\n            teacherId: newExamResult.teacherId || undefined,\r\n            isOnline: newExamResult.isOnline,\r\n            notes: newExamResult.notes\r\n          })\r\n        },\r\n        { success: false, examResult: null as unknown as ExamResult }\r\n      );\r\n\r\n      if (responseError || !data?.success) {\r\n        const errorMessage = responseError?.message || \"в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в”ҳВҶв•ӘШІв”ҳГЁв•ӘШҙв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ\";\r\n        setSubmitError(errorMessage);\r\n        logger.error('Failed to add exam result:', responseError);\r\n      } else {\r\n        // в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШІв•Әв•Јв”ҳГЁв”ҳГЁв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ в”ҳГӘв•Әв–‘в•ӘШҙ в”ҳГӘв•ӘШӯв•ӘВ«в”ҳВҒв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ в”ҳГӘв•Әв–‘в•ӘШҙ\r\n        setNewExamResult({\r\n          examId: '',\r\n          score: '',\r\n          teacherId: '',\r\n          notes: '',\r\n          isOnline: false\r\n        });\r\n        setShowAddExamForm(false);\r\n        setSubmitError(null);\r\n        // в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҙв”ҳВ„в•ӘШ° в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ\r\n        await fetchData();\r\n      }\r\n    } catch (error) {\r\n      logger.error('Error adding exam result:', error);\r\n      setSubmitError(\"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШІв”ҳГӘв”ҳГ©в•Әв•Ј\");\r\n    } finally {\r\n      setIsSubmitting(false);\r\n    }\r\n  };\r\n\r\n  const formatDate = (dateString: string) => {\r\n    const date = new Date(dateString);\r\n    return date.toLocaleDateString('ar-EG', {\r\n      year: 'numeric',\r\n      month: 'short',\r\n      day: 'numeric'\r\n    });\r\n  };\r\n\r\n  const getGradeColor = useCallback((grade: number, maxGrade: number) => {\r\n    const percentage = grade / maxGrade * 100;\r\n    if (percentage >= 90) return 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200';\r\n    if (percentage >= 80) return 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200';\r\n    if (percentage >= 70) return 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200';\r\n    return 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200';\r\n  }, []);\r\n\r\n  const getAssignmentTypeLabel = useCallback((type: string) => {\r\n    const assignmentType = assignmentTypes.find((t) => t.value === type);\r\n    return assignmentType ? assignmentType.label : type;\r\n  }, []);\r\n\r\n  // в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ° в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШөв•Әв•Ўв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШҜв•ӘШІ\r\n  const statistics = useMemo(() => {\r\n    if (userGrades.length === 0) return null;\r\n\r\n    const totalGrades = userGrades.length;\r\n    const averageGrade = userGrades.reduce((sum, grade) => sum + grade.grade / grade.maxGrade * 100, 0) / totalGrades;\r\n    const maxGrade = Math.max(...userGrades.map((g) => g.grade));\r\n    const minGrade = Math.min(...userGrades.map((g) => g.grade));\r\n\r\n    return { totalGrades, averageGrade, maxGrade, minGrade };\r\n  }, [userGrades]);\r\n\r\n  // в•ӘВ»в•ӘШҜв”ҳВ„в•ӘШұ в•ӘШөв•Әв–‘в”ҳВҒ в”ҳВҶв•ӘШІв”ҳГЁв•ӘШҙв•ӘШұ в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ\r\n  const handleDeleteExamResult = useCallback(async (resultId: string) => {\r\n    if (!confirm('в”ҳГ§в”ҳВ„ в•ӘШ«в”ҳВҶв•ӘШІ в”ҳГ в•ӘШІв•ӘШ«в”ҳГўв•ӘВ» в”ҳГ в”ҳВҶ в•ӘШөв•Әв–‘в”ҳВҒ в”ҳГ§в•Әв–‘в”ҳГ§ в•ӘШҜв”ҳВ„в”ҳВҶв•ӘШІв”ҳГЁв•ӘШҙв•ӘШұв•ӘШ§')) return;\r\n\r\n    try {\r\n      const { error: deleteError } = await safeFetch(\r\n        `/api/exams/results/${resultId}`,\r\n        { method: 'DELETE' },\r\n        null\r\n      );\r\n\r\n      if (deleteError) {\r\n        logger.error('Error deleting exam result:', deleteError);\r\n        setError(\"в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШҜв”ҳВ„в”ҳВҶв•ӘШІв”ҳГЁв•ӘШҙв•ӘШұ\");\r\n      } else {\r\n        setExamResults((prev) => prev.filter((r) => r.id !== resultId));\r\n      }\r\n    } catch (err) {\r\n      logger.error('Error deleting exam result:', err);\r\n      setError(\"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШҜв”ҳВ„в”ҳВҶв•ӘШІв”ҳГЁв•ӘШҙв•ӘШұ\");\r\n    }\r\n  }, []);\r\n\r\n  if (isLoading) {\r\n    return (\r\n      <div className=\"flex flex-col justify-center items-center h-64 gap-4\" role=\"status\" aria-live=\"polite\">\r\n        <Loader2 className=\"h-12 w-12 animate-spin text-primary\" aria-hidden=\"true\" />\r\n        <p className=\"text-gray-600 dark:text-gray-400\">в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ...</p>\r\n      </div>);\r\n\r\n  }\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      <div className=\"flex justify-between items-center\">\r\n        <div>\r\n          <h2 className=\"text-2xl font-bold text-gray-800\">в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в”ҳГӘв•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІ</h2>\r\n          <p className=\"text-gray-600\">в•ӘШІв•ӘШІв•ӘШ°в•Әв•Ј в•ӘШ«в•ӘВ»в•ӘШҜв•ӘШ®в”ҳГў в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГўв•ӘШҜв•ӘВ»в”ҳГЁв”ҳГ в”ҳГЁ в”ҳГӘв•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІв”ҳГў в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘШҜв•ӘВ» в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ«в•ӘШІв”ҳВ„в”ҳВҒв•ӘШұ</p>\r\n        </div>\r\n        <div className=\"flex gap-2\">\r\n          <Button\r\n            onClick={() => setShowAddGradeForm(true)}\r\n            className=\"flex items-center gap-2\">\r\n            \r\n            <PlusCircle className=\"h-4 w-4\" />\r\n            в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ\r\n          </Button>\r\n          <Button\r\n            onClick={() => setShowAddExamForm(true)}\r\n            variant=\"outline\"\r\n            className=\"flex items-center gap-2\">\r\n            \r\n            <PlusCircle className=\"h-4 w-4\" />\r\n            в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в”ҳВҶв•ӘШІв”ҳГЁв•ӘШҙв•ӘШұ в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ\r\n          </Button>\r\n        </div>\r\n      </div>\r\n\r\n      <Tabs value={activeTab} onValueChange={setActiveTab} className=\"w-full\">\r\n        <TabsList className=\"grid w-full grid-cols-3\">\r\n          <TabsTrigger value=\"exams\">в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ</TabsTrigger>\r\n          <TabsTrigger value=\"grades\">в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІ</TabsTrigger>\r\n          <TabsTrigger value=\"analytics\">в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳВ„в”ҳГЁв”ҳВ„в•ӘШҜв•ӘШІ</TabsTrigger>\r\n        </TabsList>\r\n\r\n        <TabsContent value=\"exams\" className=\"space-y-4\">\r\n          {examResults.length === 0 ?\r\n          <Card>\r\n              <CardContent className=\"flex flex-col items-center justify-center py-12\">\r\n                <BookOpen className=\"h-12 w-12 text-gray-400 mb-4\" />\r\n                <h3 className=\"text-lg font-medium text-gray-900 mb-2\">в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в”ҳГ в•Әв”Ӯв•ӘШҙв”ҳВ„в•ӘШұ</h3>\r\n                <p className=\"text-gray-500 mb-4\">в•ӘШҜв•ӘШ°в•ӘВ»в•ӘШ« в•ӘШ°в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в”ҳВҶв•ӘШІв•ӘШҜв•ӘШ®в•ӘШҙ в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІв”ҳГў в”ҳВ„в•ӘШІв•ӘШІв•ӘШ°в•Әв•Ј в•ӘШІв”ҳГ©в•ӘВ»в”ҳГ в”ҳГў</p>\r\n                <Button onClick={() => setShowAddExamForm(true)}>\r\n                  в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в”ҳВҶв•ӘШІв”ҳГЁв•ӘШҙв•ӘШұ в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ\r\n                </Button>\r\n              </CardContent>\r\n            </Card> :\r\n\r\n          <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4\">\r\n              {examResults.map((exam) =>\r\n            <Card key={exam.id} className=\"hover:shadow-md transition-shadow\">\r\n                  <CardHeader className=\"pb-3\">\r\n                    <div className=\"flex justify-between items-start\">\r\n                      <CardTitle className=\"text-lg\">{exam.exam.title}</CardTitle>\r\n                      <Badge className={getGradeColor(exam.score, 100)}>\r\n                        {exam.score}%\r\n                      </Badge>\r\n                    </div>\r\n                    <CardDescription className=\"flex items-center gap-2\">\r\n                      <BookOpen className=\"h-4 w-4\" />\r\n                      {exam.exam.subject} - в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВҶв•ӘШұ {exam.exam.year}\r\n                    </CardDescription>\r\n                  </CardHeader>\r\n                  <CardContent>\r\n                    <div className=\"space-y-2\">\r\n                      <div className=\"flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400\">\r\n                        <Calendar className=\"h-4 w-4\" />\r\n                        {formatDate(exam.takenAt)}\r\n                      </div>\r\n                      {exam.teacher &&\r\n                  <div className=\"flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400\">\r\n                          <User className=\"h-4 w-4\" />\r\n                          {exam.teacher.name}\r\n                        </div>\r\n                  }\r\n                      <div className=\"flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400\">\r\n                        <Award className=\"h-4 w-4\" />\r\n                        {exam.exam.type === 'MIDTERM' ? 'в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ в”ҳВҶв•Әв•Ўв”ҳВҒв”ҳГЁ' :\r\n                    exam.exam.type === 'FINAL' ? 'в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ в”ҳВҶв”ҳГ§в•ӘШҜв•ӘШ®в”ҳГЁ' :\r\n                    exam.exam.type === 'QUIZ' ? 'в•ӘШҜв•ӘВ«в•ӘШІв•ӘШ°в•ӘШҜв•Әв–’ в”ҳГ©в•Әв•Ўв”ҳГЁв•Әв–’' : 'в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ'}\r\n                      </div>\r\n                      <div className=\"flex justify-end pt-2\">\r\n                        <Button\r\n                      variant=\"ghost\"\r\n                      size=\"sm\"\r\n                      onClick={() => handleDeleteExamResult(exam.id)}\r\n                      className=\"text-red-600 hover:text-red-700 hover:bg-red-50\"\r\n                      aria-label={`в•ӘШөв•Әв–‘в”ҳВҒ в”ҳВҶв•ӘШІв”ҳГЁв•ӘШҙв•ӘШұ ${exam.exam.title}`}>\r\n                      \r\n                          <Trash2 className=\"h-4 w-4\" />\r\n                        </Button>\r\n                      </div>\r\n                    </div>\r\n                  </CardContent>\r\n                </Card>\r\n            )}\r\n            </div>\r\n          }\r\n        </TabsContent>\r\n\r\n        <TabsContent value=\"grades\" className=\"space-y-4\">\r\n          {userGrades.length === 0 ?\r\n          <Card>\r\n              <CardContent className=\"flex flex-col items-center justify-center py-12\">\r\n                <Award className=\"h-12 w-12 text-gray-400 mb-4\" />\r\n                <h3 className=\"text-lg font-medium text-gray-900 mb-2\">в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІ в”ҳГ в•Әв”Ӯв•ӘШҙв”ҳВ„в•ӘШұ</h3>\r\n                <p className=\"text-gray-500 mb-4\">в•ӘШҜв•ӘШ°в•ӘВ»в•ӘШ« в•ӘШ°в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІв”ҳГў в”ҳВ„в•ӘШІв•ӘШІв•ӘШ°в•Әв•Ј в•ӘШІв”ҳГ©в•ӘВ»в”ҳГ в”ҳГў в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГўв•ӘШҜв•ӘВ»в”ҳГЁв”ҳГ в”ҳГЁ</p>\r\n                <Button onClick={() => setShowAddGradeForm(true)}>\r\n                  в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ\r\n                </Button>\r\n              </CardContent>\r\n            </Card> :\r\n\r\n          <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4\">\r\n              {userGrades.map((grade) =>\r\n            <Card key={grade.id} className=\"hover:shadow-md transition-shadow\">\r\n                  <CardHeader className=\"pb-3\">\r\n                    <div className=\"flex justify-between items-start\">\r\n                      <CardTitle className=\"text-lg\">{grade.subject}</CardTitle>\r\n                      <Badge className={getGradeColor(grade.grade, grade.maxGrade)}>\r\n                        {grade.grade}/{grade.maxGrade}\r\n                      </Badge>\r\n                    </div>\r\n                    <CardDescription className=\"flex items-center gap-2\">\r\n                      {getAssignmentTypeLabel(grade.assignmentType)}\r\n                      {grade.isOnline &&\r\n                  <Badge variant=\"outline\">в•ӘШ«в”ҳГӘв”ҳВҶв”ҳВ„в•ӘШҜв”ҳГЁв”ҳВҶ</Badge>\r\n                  }\r\n                    </CardDescription>\r\n                  </CardHeader>\r\n                  <CardContent>\r\n                    <div className=\"space-y-2\">\r\n                      <div className=\"flex items-center gap-2 text-sm text-gray-600\">\r\n                        <Calendar className=\"h-4 w-4\" />\r\n                        {formatDate(grade.date)}\r\n                      </div>\r\n                      {grade.teacher &&\r\n                  <div className=\"flex items-center gap-2 text-sm text-gray-600\">\r\n                          <User className=\"h-4 w-4\" />\r\n                          {grade.teacher.name}\r\n                        </div>\r\n                  }\r\n                      {grade.notes &&\r\n                  <p className=\"text-sm text-gray-600 mt-2 line-clamp-2\">\r\n                          {grade.notes}\r\n                        </p>\r\n                  }\r\n                    </div>\r\n                  </CardContent>\r\n                </Card>\r\n            )}\r\n            </div>\r\n          }\r\n        </TabsContent>\r\n\r\n        <TabsContent value=\"analytics\" className=\"space-y-4\">\r\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\r\n            <Card>\r\n              <CardHeader>\r\n                <CardTitle className=\"flex items-center gap-2\">\r\n                  <TrendingUp className=\"h-5 w-5\" />\r\n                  в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•– в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІ в•ӘШөв•Әв”Ӯв•ӘШ° в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ\r\n                </CardTitle>\r\n              </CardHeader>\r\n              <CardContent>\r\n                {subjectAverages.length === 0 ?\r\n                <p className=\"text-gray-500 text-center py-4\">в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в”ҳГўв•ӘШҜв”ҳВҒв”ҳГЁв•ӘШұ в”ҳВ„в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳВ„в”ҳГЁв”ҳВ„в•ӘШҜв•ӘШІ</p> :\r\n\r\n                <div className=\"space-y-4\">\r\n                    {subjectAverages.map((average) => {\r\n                    const gradeValue = Number(average._avg.grade);\r\n                    const widthPercent = Math.min(100, gradeValue);\r\n                    const roundedValue = Math.round(gradeValue);\r\n                    const gradeColor = gradeValue >= 90 ? 'bg-green-600' :\r\n                    gradeValue >= 80 ? 'bg-blue-600' :\r\n                    gradeValue >= 70 ? 'bg-yellow-500' : 'bg-red-600';\r\n                    const ariaLabel = `в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•– ${average.subject}: ${gradeValue.toFixed(1)}%`;\r\n                    const ariaValueNow = roundedValue;\r\n                    const ariaValueMin = 0;\r\n                    const ariaValueMax = 100;\r\n\r\n                    return (\r\n                      <div key={average.subject} className=\"space-y-2\">\r\n                          <div className=\"flex justify-between\">\r\n                            <span className=\"font-medium\">{average.subject}</span>\r\n                            <span className=\"font-bold\">{gradeValue.toFixed(1)}%</span>\r\n                          </div>\r\n                          <div className=\"w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2.5\" title={ariaLabel}>\r\n                            <div\r\n                            className={`h-2.5 rounded-full transition-all duration-300 ${gradeColor}`}\r\n                            style={{ width: `${widthPercent}%` }}\r\n                            title={`${gradeValue.toFixed(1)}%`}\r\n                            role=\"progressbar\"\r\n                            aria-valuenow={ariaValueNow}\r\n                            aria-valuemin={ariaValueMin}\r\n                            aria-valuemax={ariaValueMax}\r\n                            aria-label={ariaLabel}>\r\n                          </div>\r\n                          </div>\r\n                        </div>);\r\n\r\n                  })}\r\n                  </div>\r\n                }\r\n              </CardContent>\r\n            </Card>\r\n\r\n            <Card>\r\n              <CardHeader>\r\n                <CardTitle>в•ӘШӯв•ӘШөв•Әв•Ўв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШҜв•ӘШІ в•Әв•Јв•ӘШҜв”ҳГ в•ӘШұ</CardTitle>\r\n              </CardHeader>\r\n              <CardContent>\r\n                {!statistics ?\r\n                <p className=\"text-gray-500 dark:text-gray-400 text-center py-4\">в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в”ҳГўв•ӘШҜв”ҳВҒв”ҳГЁв•ӘШұ в”ҳВ„в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШөв•Әв•Ўв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШҜв•ӘШІ</p> :\r\n\r\n                <div className=\"space-y-4\">\r\n                    <div className=\"grid grid-cols-2 gap-4\">\r\n                      <div className=\"bg-blue-50 dark:bg-blue-900/20 p-4 rounded-lg\">\r\n                        <p className=\"text-sm text-blue-800 dark:text-blue-200\">в•Әв•Јв•ӘВ»в•ӘВ» в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШҙв”ҳВ„в•ӘШұ</p>\r\n                        <p className=\"text-2xl font-bold text-blue-600 dark:text-blue-400\">{statistics.totalGrades}</p>\r\n                      </div>\r\n                      <div className=\"bg-green-50 dark:bg-green-900/20 p-4 rounded-lg\">\r\n                        <p className=\"text-sm text-green-800 dark:text-green-200\">в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•– в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•Әв•Јв•ӘШҜв”ҳГ </p>\r\n                        <p className=\"text-2xl font-bold text-green-600 dark:text-green-400\">\r\n                          {statistics.averageGrade.toFixed(1)}%\r\n                        </p>\r\n                      </div>\r\n                    </div>\r\n                    <div className=\"grid grid-cols-2 gap-4\">\r\n                      <div className=\"bg-purple-50 dark:bg-purple-900/20 p-4 rounded-lg\">\r\n                        <p className=\"text-sm text-purple-800 dark:text-purple-200\">в•ӘШ«в•Әв•Јв”ҳВ„в”ҳГ« в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ</p>\r\n                        <p className=\"text-2xl font-bold text-purple-600 dark:text-purple-400\">\r\n                          {statistics.maxGrade}\r\n                        </p>\r\n                      </div>\r\n                      <div className=\"bg-yellow-50 dark:bg-yellow-900/20 p-4 rounded-lg\">\r\n                        <p className=\"text-sm text-yellow-800 dark:text-yellow-200\">в•ӘШ«в”ҳГ©в”ҳВ„ в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ</p>\r\n                        <p className=\"text-2xl font-bold text-yellow-600 dark:text-yellow-400\">\r\n                          {statistics.minGrade}\r\n                        </p>\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                }\r\n              </CardContent>\r\n            </Card>\r\n          </div>\r\n        </TabsContent>\r\n      </Tabs>\r\n\r\n      {/* в”ҳВҶв”ҳГ в”ҳГӘв•Әв–‘в•ӘШҙ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ */}\r\n      <Dialog open={showAddGradeForm} onOpenChange={setShowAddGradeForm}>\r\n        <DialogContent className=\"max-w-md max-h-[90vh] overflow-y-auto\">\r\n          <DialogHeader>\r\n            <DialogTitle>в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ</DialogTitle>\r\n            <DialogDescription>\r\n              в•ӘШ«в•ӘВ»в•ӘВ«в”ҳВ„ в”ҳГ в•Әв•Јв”ҳВ„в”ҳГӘв”ҳГ в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ\r\n            </DialogDescription>\r\n          </DialogHeader>\r\n          <form onSubmit={handleAddGrade} className=\"space-y-4\">\r\n                <div>\r\n                  <Label htmlFor=\"subject\">в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ</Label>\r\n                  <Select\r\n                value={newGrade.subject}\r\n                onValueChange={(value) => setNewGrade({ ...newGrade, subject: value })}>\r\n                \r\n                    <SelectTrigger>\r\n                      <SelectValue placeholder=\"в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ\" />\r\n                    </SelectTrigger>\r\n                    <SelectContent>\r\n                      {subjects.map((subject) =>\r\n                  <SelectItem key={subject} value={subject}>\r\n                          {subject}\r\n                        </SelectItem>\r\n                  )}\r\n                    </SelectContent>\r\n                  </Select>\r\n                </div>\r\n\r\n                <div className=\"grid grid-cols-2 gap-4\">\r\n                  <div>\r\n                    <Label htmlFor=\"grade\">в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ</Label>\r\n                    <Input\r\n                  id=\"grade\"\r\n                  type=\"number\"\r\n                  min=\"0\"\r\n                  value={newGrade.grade}\r\n                  onChange={(e) => setNewGrade({ ...newGrade, grade: e.target.value })}\r\n                  required />\r\n                \r\n                  </div>\r\n                  <div>\r\n                    <Label htmlFor=\"maxGrade\">в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в•ӘШҜв”ҳВ„в•Әв•Јв•Әв••в”ҳГ в”ҳГ«</Label>\r\n                    <Input\r\n                  id=\"maxGrade\"\r\n                  type=\"number\"\r\n                  min=\"1\"\r\n                  value={newGrade.maxGrade}\r\n                  onChange={(e) => setNewGrade({ ...newGrade, maxGrade: e.target.value })}\r\n                  required />\r\n                \r\n                  </div>\r\n                </div>\r\n\r\n                <div>\r\n                  <Label htmlFor=\"date\">в•ӘШҜв”ҳВ„в•ӘШІв•ӘШҜв•Әв–’в”ҳГЁв•ӘВ«</Label>\r\n                  <Input\r\n                id=\"date\"\r\n                type=\"date\"\r\n                value={newGrade.date}\r\n                onChange={(e) => setNewGrade({ ...newGrade, date: e.target.value })}\r\n                required />\r\n              \r\n                </div>\r\n\r\n                <div>\r\n                  <Label htmlFor=\"assignmentType\">в”ҳВҶв”ҳГӘв•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГӘв•ӘШҜв•ӘШҙв•ӘШ°</Label>\r\n                  <Select\r\n                value={newGrade.assignmentType}\r\n                onValueChange={(value) => setNewGrade({ ...newGrade, assignmentType: value })}>\r\n                \r\n                    <SelectTrigger>\r\n                      <SelectValue />\r\n                    </SelectTrigger>\r\n                    <SelectContent>\r\n                      {assignmentTypes.map((type) =>\r\n                  <SelectItem key={type.value} value={type.value}>\r\n                          {type.label}\r\n                        </SelectItem>\r\n                  )}\r\n                    </SelectContent>\r\n                  </Select>\r\n                </div>\r\n\r\n                <div>\r\n                  <Label htmlFor=\"teacher\">в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯ (в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’в”ҳГЁ)</Label>\r\n                  <Select\r\n                value={newGrade.teacherId}\r\n                onValueChange={(value) => setNewGrade({ ...newGrade, teacherId: value })}>\r\n                \r\n                    <SelectTrigger>\r\n                      <SelectValue placeholder=\"в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯ\" />\r\n                    </SelectTrigger>\r\n                    <SelectContent>\r\n                      {teachers.map((teacher) =>\r\n                  <SelectItem key={teacher.id} value={teacher.id}>\r\n                          {teacher.name} ({teacher.subject})\r\n                        </SelectItem>\r\n                  )}\r\n                    </SelectContent>\r\n                  </Select>\r\n                </div>\r\n\r\n                <div>\r\n                  <Label htmlFor=\"notes\">в”ҳГ в”ҳВ„в•ӘШҜв•ӘШөв•Әв••в•ӘШҜв•ӘШІ (в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’в”ҳГЁ)</Label>\r\n                  <Textarea\r\n                id=\"notes\"\r\n                value={newGrade.notes}\r\n                onChange={(e) => setNewGrade({ ...newGrade, notes: e.target.value })}\r\n                rows={3} />\r\n              \r\n                </div>\r\n\r\n                <div className=\"flex items-center space-x-2\">\r\n                  <input\r\n                type=\"checkbox\"\r\n                id=\"gradeIsOnline\"\r\n                checked={newGrade.isOnline}\r\n                onChange={(e) => setNewGrade({ ...newGrade, isOnline: e.target.checked })}\r\n                className=\"rounded\"\r\n                aria-label=\"в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶ в•ӘШ«в”ҳГӘв”ҳВҶв”ҳВ„в•ӘШҜв”ҳГЁв”ҳВҶ\" />\r\n              \r\n                  <Label htmlFor=\"gradeIsOnline\">в•ӘШ«в”ҳГӘв”ҳВҶв”ҳВ„в•ӘШҜв”ҳГЁв”ҳВҶ</Label>\r\n                </div>\r\n\r\n            {submitError &&\r\n            <div className=\"bg-red-50 border border-red-200 rounded-lg p-3 flex items-center gap-2 text-red-700\">\r\n                <AlertCircle className=\"h-4 w-4 flex-shrink-0\" />\r\n                <p className=\"text-sm\">{submitError}</p>\r\n              </div>\r\n            }\r\n            <DialogFooter>\r\n              <Button\r\n                type=\"button\"\r\n                variant=\"outline\"\r\n                onClick={() => {\r\n                  setShowAddGradeForm(false);\r\n                  setSubmitError(null);\r\n                }}\r\n                disabled={isSubmitting}>\r\n                \r\n                в•ӘШӯв”ҳВ„в•Әв•‘в•ӘШҜв•ӘШ©\r\n              </Button>\r\n              <Button type=\"submit\" disabled={isSubmitting}>\r\n                {isSubmitting ?\r\n                <>\r\n                    <Loader2 className=\"h-4 w-4 mr-2 animate-spin\" />\r\n                    в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШөв”ҳВҒв