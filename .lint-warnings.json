X\" \r\n                      icon={<Phone size={18} />} \r\n                      error={errors.phone?.message} \r\n                    />\r\n                    \r\n                    <AuthField {...register('dateOfBirth')} type=\"date\" label=\"в•ӘШІв•ӘШҜв•Әв–’в”ҳГЁв•ӘВ« в•ӘШҜв”ҳВ„в”ҳГ в”ҳГЁв”ҳВ„в•ӘШҜв•ӘВ»\" icon={<Calendar size={18} />} error={errors.dateOfBirth?.message} />\r\n                  </div>\r\n\r\n                  <div className=\"flex gap-4\">\r\n                    <Button type=\"button\" variant=\"outline\" onClick={() => setStep(1)} className=\"h-14 flex-1 rounded-2xl border-white/10 bg-white/5 font-black text-white hover:bg-white/10\">\r\n                      в•Әв”Ӯв•ӘШҜв•ӘШ°в”ҳВҖв”ҳГ©\r\n                    </Button>\r\n                    <Button type=\"button\" onClick={handleNextStep} className=\"h-14 flex-[2] rounded-2xl bg-primary font-black text-black\">\r\n                      в•ӘШІв•ӘШ«в”ҳГўв”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ <ArrowRight className=\"mr-2 h-5 w-5\" />\r\n                    </Button>\r\n                  </div>\r\n                </motion.div>\r\n              )}\r\n\r\n              {step === 3 && (\r\n                <motion.div \r\n                  key=\"step3\"\r\n                  initial={{ opacity: 0, x: 20 }}\r\n                  animate={{ opacity: 1, x: 0 }}\r\n                  exit={{ opacity: 0, x: -20 }}\r\n                  className=\"space-y-8\"\r\n                >\r\n                  <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\r\n                    <div className=\"space-y-2\">\r\n                      <Label className=\"text-[10px] font-black uppercase text-gray-500 tracking-widest\">в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГӘв”ҳГ« в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁ</Label>\r\n                      <select {...register('gradeLevel')} className=\"w-full h-14 rounded-2xl border border-white/10 bg-white/5 px-6 font-bold text-white outline-none focus:border-primary/50\">\r\n          