iv>\r\n              <p className=\"text-xs text-muted-foreground\">\r\n                {currentPomodoroState === 'work' ? 'в•Әв–’в”ҳГўв•Әв–“ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ' : 'в•ӘВ«в•Әв–‘ в”ҳВҶв”ҳВҒв•Әв”Ӯв”ҳГў'} \r\n              </p>\r\n            </CardContent>\r\n          </Card>\r\n        </div>\r\n      </div>\r\n      \r\n      <div>\r\n        <SessionsList sessions={sessions} tasks={tasks} />\r\n        <TimerSettingsCard settings={settings} />\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default TimeTracker;\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\time\\components\\TimerSettingsCard.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\time\\components\\UpcomingRemindersCard.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\time\\components\\UpcomingTasksCard.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\time\\components\\WeeklySchedule.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\time\\components\\WeeklySchedule\\AgendaView.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\time\\components\\WeeklySchedule\\BlockFormDialog.tsx","messages":[],"suppressedMessages":[],