ў в•ӘШҜв”ҳВ„в”ҳГ©в•ӘВ»в”ҳГЁв”ҳГ в•ӘШұ в•ӘШ«в”ҳГӘв”ҳВ„в•ӘШҜв”ҳГҜ. в”ҳГ©в”ҳГ§в•Әв–’ в”ҳВҶв”ҳГ©в•ӘШҜв•Әв•– в•Әв•ўв•Әв•Јв”ҳВҒв”ҳГў в”ҳГ§в”ҳГӘ в•ӘШ«в•Әв•Јв•Әв••в”ҳГ  в•ӘШҜв”ҳВҶв•ӘШІв•Әв•Ўв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІв”ҳГў.\" }\r\n      ]\r\n    }\r\n  ];\r\n\r\n  const subjects = [\r\n    { name: \"в•ӘШҜв”ҳВ„в•Әв–’в”ҳГЁв•ӘШҜв•Әв•ўв”ҳГЁв•ӘШҜв•ӘШІ\", desc: \"в•ӘШөв”ҳВ„ в”ҳГ в•Әв”Ӯв•ӘШҜв•ӘШ®в”ҳВ„ в”ҳГ в•ӘШІв”ҳВҶв”ҳГӘв•Әв•Јв•ӘШұ в”ҳГЁв”ҳГӘв”ҳГ в”ҳГЁв”ҳГҜв•ӘШҜ в”ҳГӘв•Әв–’в•ӘШҜв•ӘШҙв•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГ©в”ҳГӘв•ӘШҜв”ҳВҶв”ҳГЁв”ҳВҶ в•ӘШ°в•ӘШІв”ҳВ„в•ӘВ«в”ҳГЁв•Әв•Ў в•ӘШ°в•Әв•Ўв•Әв–’в”ҳГЁ в”ҳГ в”ҳГўв•ӘШів”ҳВҒ.\", icon: activity },\r\n    { name: \"в•ӘШҜв”ҳВ„в”ҳВҒв”ҳГЁв•Әв–“в”ҳГЁв•ӘШҜв•ӘШ©\", desc: \"в•ӘШҜв”ҳВҒв”ҳГ§в”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ©в”ҳГӘв”ҳГ« в•ӘШҜв”ҳВ„в•ӘВ«в”ҳВҒв”ҳГЁв•ӘШұ в”ҳГӘв•Әв–’в•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҒв•ӘШҜв”ҳГ§в”ҳГЁв”ҳГ  в•ӘШів”ҳГ  в•Әв•–в•ӘШ°в”ҳЩ‘в”ҳГ©в”ҳГ§в•ӘШҜ в•ӘШ°в•ӘШІв•ӘШҙв•ӘШҜв•Әв–’в•ӘШ° в•ӘШҜв”ҳВҒв•ӘШІв•Әв–’в•ӘШҜв•Әв•ўв”ҳГЁв•ӘШұ.\", icon: zap },\r\n    { name: \"в•ӘШҜв”ҳВ„в”ҳГўв”ҳГЁв”ҳГ в”ҳГЁв•ӘШҜв•ӘШ©\", desc: \"в•ӘШҜв•Әв–’в•ӘШ°в•Әв•– в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Јв•ӘШҜв•ӘВ»в”ҳВ„в•ӘШҜв•ӘШІ в•ӘШ°в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Јв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в”ҳВ„в”ҳГ в”ҳГӘв•Әв”Ӯ в”ҳГӘв•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в•ӘШҙв•ӘВ»в•ӘШҜв”ҳГӘв”ҳВ„в”ҳГў в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Јв”ҳВ„в”ҳГЁв•ӘШұ.\", icon: spark },\r\n    { name: \"в•ӘШҜв”ҳВ„в”ҳВ„в•Әв•‘в•ӘШҜв•ӘШІ\", desc: \"в•Әв•Јв•Әв•ўв”ҳВ„в•ӘШҜв•ӘШІв”ҳГў в•ӘШҜв”ҳВ„в”ҳВ„в•Әв•‘в”ҳГӘв”ҳГЁв•ӘШұ в•ӘШІв”ҳВҶв”ҳГ в”ҳГӘ в•ӘШ°в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҒв•Әв–’в•ӘВ»в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГЁв”ҳГӘв”ҳГ в”ҳГЁв•ӘШұ в”ҳГӘв•ӘШҜв”ҳВ„в•ӘШІв•ӘВ»в•Әв–’в”ҳГЁв•ӘШ° в•ӘШҜв”ҳВ„в”ҳГўв•ӘШІв•ӘШҜв•ӘШ°в”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГ в•Әв–’.\", icon: scroll }\r\n  ];\r\n\r\n  function activity(props: any) { return <Activity {...props} /> }\r\n  function zap(props: any) { return <Zap {...props} /> }\r\n  function spark(props: any) { return <Sparkles {...props} /> }\r\n  function scroll(props: any) { return <Scroll {...props} /> }\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-background text-gray-100 overflow-hidden\" dir=\"rtl\">\r\n      {/* --- Ambient Background --- */}\r\n      <div className=\"fixed inset-0 pointer-events-none -z-10\">\r\n        <div className=\"absolute top-0 right-0 w-[600px] h-[600px] bg-primary/10 blur-[130px] rounded-full opacity-40 translate-x-1/2 -translate-y-1/2\" />\r\n        <div className=\"absolute bottom-0 left-0 w-[500px] h-[500px] bg-purple-600/10 blur-[130px] rounded-full opacity-20 -translate-x-1/2 translate-y-1/2\" />\r\n        <div className=\"absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.01)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.01)_1px,transparent_1px)] bg-[size:50px_50px]\" />\r\n      </div>\r\n\r\n      <div className=\"mx-auto w-full max-w-7xl px-4 py-12 sm:px-6 lg:px-8 space-y-12\">\r\n        \r\n        {/* --- Header: Wisdom Arrival --- */}\r\n        <motion.div\r\n           initial={{ opacity: 0, y: -30 }}\r\n           animate={{ opacity: 1, y: 0 }}\r\n           className=\"text-center space-y-6\"\r\n        >\r\n           <div className=\"inline-flex items-center gap-3 rounded-full border border-primary/30 bg-primary/10 px-6 py-2 text-xs font-black uppercase tracking-[0.2em] text-primary shadow-[0_0_20px_rgba(var(--primary),0.2)]\">\r\n              <Lightbulb className=\"h-5 w-5\" />\r\n              <span>в•ӘВ«в•Әв–“в•ӘШҜв”ҳВҶв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШөв”ҳГўв”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҒв”ҳГ©в”ҳГӘв•ӘВ»в•ӘШұ</span>\r\n           </div>\r\n           <h1 className=\"text-4xl md:text-7xl font-black tracking-tight leading-tight\">\r\n              в”ҳВ„в”ҳВҒв•ӘШҜв•ӘШ®в”ҳВҒ <span className={STYLES.neonText}>в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШІв”ҳГ©в•ӘШҜв”ҳВҶ</span> в”ҳГҜв”Ңв•‘ШёВҖШҘв”¬В«\r\n           </h1>\r\n           <p className=\"text-lg md:text-xl text-gray-400 font-medium max-w-3xl mx-auto leading-relaxed\">\r\n              в•ӘШҜв•Әв”Ӯв•ӘШІв•Әв–’в•ӘШҜв•ӘШІв”ҳГЁв•ӘШҙв”ҳГЁв•ӘШҜв•ӘШІ в”ҳГӘв•ӘШІв”ҳГўв•ӘШІв”ҳГЁв”ҳГўв•ӘШҜв•ӘШІ в”ҳГ в•ӘШөв•Әв•Ўв”ҳВҶв•ӘШұ в•ӘШ°в•ӘШҜв”ҳВ„в”ҳГЁв”ҳГ©в”ҳГЁв”ҳВҶв•ӘГ® в•ӘШҙв”ҳГ в”ҢШІв•ӘШҜ в”ҳВ„в”ҳГў в”ҳГўв•ӘШ°в•ӘШҜв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШөв”ҳГўв”ҳГ в•ӘШҜв•ӘШ© в”ҳВ„в•ӘШІв•ӘВ«в•ӘШІв•Әв•Ўв•Әв–’ в•Әв•Јв”ҳВ„в”ҳГЁв”ҳГў в•Әв•–в•Әв–’в”ҳГЁв”ҳГ© в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳГЁв•ӘШҜв•ӘВ»в•ӘШұ в”ҳГӘв•ӘШІв•Әв•ўв•ӘШҜв•Әв•Јв”ҳВҒ в”ҳГ в”ҳВҶ в•Әв”Ӯв•Әв–’в•Әв•Јв•ӘШұ в•ӘШІв•Әв•–в”ҳГӘв•Әв–’в”ҳГў в•ӘШҜв”ҳВ„в•Әв•Јв”ҳВ„в”ҳГ в”ҳГЁ.\r\n           </p>\r\n        </motion.div>\r\n\r\n        {/* --- Categories Grid --- */}\r\n        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-8\">\r\n           {categories.map((cat, i) => (\r\n              <motion.div\r\n                key={i}\r\n                initial={{ opacity: 0, scale: 0.95 }}\r\n                animate={{ opacity: 1, scale: 1 }}\r\n                transition={{ delay: i * 0.1 }}\r\n                className={STYLES.glass + \" p-10 group hover:border-primary/50 transition-all\"}\r\n              >\r\n                 <div className=\"flex items-center gap-6 mb-8\">\r\n                    <div className={`p-4 rounded-3xl bg-white/5 border border-white/10 ${cat.color} group-hover:scale-110 transition-transform`}>\r\n                       <cat.icon className=\"w-8 h-8\" />\r\n                    </div>\r\n                    <h2 className=\"text-2xl font-black text-white\">{cat.title}</h2>\r\n                 </div>\r\n                 <div className=\"space-y-6\">\r\n                    {cat.tips.map((tip, j) => (\r\n                       <div key={j} className=\"flex gap-4 group/tip\">\r\n                          <div className=\"mt-1.5 h-1.5 w-1.5 rounded-full bg-primary shadow-[0_0_10px_rgba(var(--primary),0.8)] shrink-0\" />\r\n                          <div className=\"space-y-1\">\r\n                             <h4 className=\"font-black text-white text-lg group-hover/tip:text-primary transition-colors\">{tip.label}</h4>\r\n                             <p className=\"text-gray-500 font-medium leading-relaxed\">{tip.desc}</p>\r\n                          </div>\r\n                       </div>\r\n                    ))}\r\n                 </div>\r\n              </motion.div>\r\n           ))}\r\n        </div>\r\n\r\n        {/* --- Subject-Specific Wisdom --- */}\r\n        <div className=\"space-y-8 pt-12\">\r\n           <div className=\"flex items-center gap-4\">\r\n              <div className=\"p-3 bg-white/5 rounded-2xl border border-white/10\">\r\n                 <Target className=\"w-6 h-6 text-primary\" />\r\n              </div>\r\n              <div>\r\n                 <h2 className=\"text-2xl font-black text-white\">в•ӘВ»в•Әв–’в”ҳГӘв•Әв”Ӯ в•ӘШөв•Әв”Ӯв•ӘШ° в”ҳГўв”ҳВ„ в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ</h2>\r\n                 <p className=\"text-[10px] text-gray-500 font-bold uppercase tracking-widest mt-1\">в•ӘШІв”ҳГӘв•ӘШҙв”ҳГЁв”ҳГ§в•ӘШҜв•ӘШІ в”ҳГ в•ӘВ«в•Әв•Ўв•Әв•Ўв•ӘШұ в”ҳВ„в”ҳГўв”ҳВ„ в•ӘШҜв•ӘВ«в•ӘШІв•Әв•Ўв•ӘШҜв•Әв•Ў</p>\r\n              </div>\r\n           </div>\r\n\r\n           <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6\">\r\n              {subjects.map((sub, i) => (\r\n                 <motion.div\r\n                   key={i}\r\n                   initial={{ opacity: 0, y: 20 }}\r\n                   animate={{ opacity: 1, y: 0 }}\r\n                   transition={{ delay: i * 0.05 }}\r\n                   className={STYLES.glass + \" p-8 space-y-4 group hover:bg-primary/5 transition-all text-center\"}\r\n                 >\r\n                    <div className=\"p-4 bg-white/5 rounded-2xl w-max mx-auto group-hover:scale-110 group-hover:bg-primary/20 transition-all\">\r\n                       <sub.icon className=\"w-8 h-8 text-primary\" />\r\n                    </div>\r\n                    <h3 className=\"text-xl font-black text-white\">{sub.name}</h3>\r\n                    <p className=\"text-[11px] text-gray-500 font-bold leading-relaxed\">{sub.desc}</p>\r\n                 </motion.div>\r\n              ))}\r\n           </div>\r\n        </div>\r\n\r\n        {/* --- Bottom Call to Action: The Oath --- */}\r\n        <motion.div\r\n           initial={{ opacity: 0, y: 40 }}\r\n           animate={{ opacity: 1, y: 0 }}\r\n           className={STYLES.glass + \" p-12 text-center border-emerald-500/20 shadow-emerald-500/5\"}\r\n        >\r\n           <div className=\"max-w-2xl mx-auto space-y-6\">\r\n              <div className=\"p-4 bg-emerald-500/10 rounded-full w-max mx-auto border border-emerald-500/30\">\r\n                 <Shield className=\"w-10 h-10 text-emerald-400\" />\r\n              </div>\r\n              <h2 className=\"text-3xl font-black text-white\">в”ҳГ§в”ҳВ„ в•ӘШ«в”ҳВҶв•ӘШІ в”ҳГ в•Әв”Ӯв•ӘШІв•Әв•Јв•ӘВ» в”ҳВ„в•ӘШІв•Әв•–в•ӘШ°в”ҳГЁв”ҳГ© в”ҳГ§в•Әв–‘в”ҳГ§ в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв•ӘШІв•Әв–’в•ӘШҜв•ӘШІв”ҳГЁв•ӘШҙв”ҳГЁв•ӘШҜв•ӘШІв•ӘШ§</h2>\r\n              <p className=\"text-gray-500 font-medium\">в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Јв•Әв–’в”ҳВҒв•ӘШұ в•ӘШ°в•ӘВ»в”ҳГӘв”ҳВҶ в”ҳВҒв•Әв•Јв”ҳВ„ в”ҳГ§в”ҳГЁ в•Әв”Ӯв”ҳГЁв”ҳВҒ в•Әв•Ўв•ӘВ»в•ӘШ®. в•ӘШҜв”ҳВҶв•Әв•–в”ҳВ„в”ҳГ© в•ӘШҜв”ҳВ„в•ӘШӘв”ҳВҶ в•ӘШӯв”ҳВ„в”ҳГ« в”ҳВ„в”ҳГӘв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГўв”ҳГ  в”ҳГӘв•Әв•–в•ӘШ°в”ҳГ© в•ӘШІв”ҳГўв•ӘШІв”ҳГЁв”ҳГўв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв•ӘШІв•Әв–’в•ӘШҙв•ӘШҜв•Әв•Ј в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Өв•Әв•– в”ҳВҒв”ҳГЁ в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв•ӘВ»в”ҳГ в•ӘШұ.</p>\r\n              <div className=\"pt-4\">\r\n                 <Badge className=\"bg-emerald-500 text-black font-black px-6 h-10 text-sm uppercase tracking-widest rounded-xl shadow-lg shadow-emerald-500/20\">в•ӘШҜв”ҳВҶв•Әв•–в”ҳВ„в”ҳГ© в”ҳВ„в”ҳВ„в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШұ &gt;</Badge>\r\n              </div>\r\n           </div>\r\n        </motion.div>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(misc)\\offline\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\api\\ab-testing\\[id]\\route.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\api\\ab-testing\\route.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\api\\admin\\achievements\\route.ts","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'NextResponse' is defined but never used. Allowed unused vars must match /^_/u.","line":1,"column":23,"nodeType":"Identifier","messageId":"unusedVar","endLine":1,"endColumn":35,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"NextResponse"},"fix":{"range":[20,34],"text":""},"desc":"Remove unused variable \"NextResponse\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'AchievementCategory' is defined but never used. Allowed unused vars must match /^_/u.","line":2,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":2,"endColumn":29,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"AchievementCategory"},"fix":{"range":[67,87],"text":""},"desc":"Remove unused variable \"AchievementCategory\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Difficulty' is defined but never used. Allowed unused vars must match /^_/u.","line":2,"column":31,"nodeType":"Identifier","messageId":"unusedVar","endLine":2,"endColumn":41,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"Difficulty"},"fix":{"range":[58,124],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'notFoundResponse' is defined but never used. Allowed unused vars must match /^_/u.","line":6,"column":92,"nodeType":"Identifier","messageId":"unusedVar","endLine":6,"endColumn":108,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"notFoundResponse"},"fix":{"range":[314,332],"text":""},"desc":"Remove unused variable \"notFoundResponse\"."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":0,"source":"ЩҠв•—в”җimport { NextRequest, NextResponse } from \"next/server\";\r\nimport { AchievementCategory, Difficulty } from \"@/types/enums\";\r\n\r\nimport { prisma } from \"@/lib/db\";\r\nimport { opsWrapper } from \"@/lib/middleware/ops-middleware\";\r\nimport { successResponse, withAuth, handleApiError, badRequestResponse, forbiddenResponse, notFoundResponse } from '@/lib/api-utils';\r\nimport { z } from \"zod\";\r\n\r\nconst achievementSchema = z.object({\r\n  key: z.string().min(1, \"в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҒв•ӘШІв•ӘШҜв•ӘШө в”ҳГ в•Әв•–в”ҳВ„в”ҳГӘв•ӘШ°\"),\r\n  title: z.string().min(1, \"в•ӘШҜв”ҳВ„в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ в”ҳГ в•Әв•–в”ҳВ„в”ҳГӘв•ӘШ°\"),\r\n  description: z.string().min(1, \"в•ӘШҜв”ҳВ„в”ҳГӘв•Әв•Ўв”ҳВҒ в”ҳГ в•Әв•–в”ҳВ„в”ҳГӘв•ӘШ°\"),\r\n  icon: z.string().default(\"trophy\"),\r\n  rarity: z.string().default(\"common\"),\r\n  xpReward: z.number().min(0, \"в•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв•ӘШҜв”ҳВҒв•ӘШ«в•ӘШұ в”ҳГЁв•ӘШҙв•ӘШ° в•ӘШ«в”ҳВҶ в•ӘШІв”ҳГўв”ҳГӘв”ҳВҶ 0 в•ӘШ«в”ҳГӘ в•ӘШ«в”ҳГўв•ӘШів•Әв–’\"),\r\n  requirements: z.string().default(\"\"),\r\n  isSecret: z.boolean().default(false),\r\n  category: z.enum([\"STUDY\", \"TASKS\", \"EXAMS\", \"TIME\", \"STREAK\"]).default(\"STUDY\"),\r\n  difficulty: z.enum([\"EASY\", \"MEDIUM\", \"HARD\", \"EXPERT\"]).default(\"MEDIUM\"),\r\n});\r\n\r\n\r\nexport async function GET(request: NextRequest) {\r\n  return opsWrapper(request, async (req) => {\r\n    return withAuth(req, async (authUser) => {\r\n      if (authUser.userRole !== \"ADMIN\") {\r\n        return forbiddenResponse(\"в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв”Ӯв”ҳГ в”ҳГӘв•ӘШө в”ҳВ„в”ҳГў в•ӘШ°в•ӘШҜв”ҳВ„в”ҳГӘв•Әв•Ўв”ҳГӘв”ҳВ„ в•ӘШӯв”ҳВ„в”ҳГ« в”ҳВ„в”ҳГӘв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГўв”ҳГ \");\r\n      }\r\n\r\n      try {\r\n        const searchParams = req.nextUrl.searchParams;\r\n        const page = parseInt(searchParams.get(\"page\") || \"1\");\r\n        const limit = parseInt(searchParams.get(\"limit\") || \"10\");\r\n        const search = searchParams.get(\"search\") || \"\";\r\n\r\n        const skip = (page - 1) * limit;\r\n\r\n        const where = search\r\n          ? {\r\n            OR: [\r\n              { title: { contains: search, mode: \"insensitive\" as const } },\r\n              { key: { contains: search, mode: \"insensitive\" as const } },\r\n            ],\r\n          }\r\n          : {};\r\n\r\n        const [achievements, total] = await Promise.all([\r\n          prisma.achievement.findMany({\r\n            where,\r\n            skip,\r\n            take: limit,\r\n            orderBy: { createdAt: \"desc\" },\r\n            include: {\r\n              _count: {\r\n                select: { users: true },\r\n              },\r\n            },\r\n          }),\r\n          prisma.achievement.count({ where }),\r\n        ]);\r\n\r\n        return successResponse({\r\n          achievements,\r\n          pagination: {\r\n            page,\r\n            limit,\r\n            total,\r\n            totalPages: Math.ceil(total / limit),\r\n          },\r\n        });\r\n      } catch (error) {\r\n        return handleApiError(error);\r\n      }\r\n    });\r\n  });\r\n}\r\n\r\nexport async function POST(request: NextRequest) {\r\n  return opsWrapper(request, async (req) => {\r\n    return withAuth(req, async (authUser) => {\r\n      if (authUser.userRole !== \"ADMIN\") {\r\n        return forbiddenResponse(\"в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв”Ӯв”ҳГ в”ҳГӘв•ӘШө в”ҳВ„в”ҳГў в•ӘШ°в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШӯв”ҳВҶв•ӘШҙв•ӘШҜв•Әв–“в•ӘШҜв•ӘШІ\");\r\n      }\r\n\r\n      try {\r\n        const body = await req.json();\r\n        const validation = achievementSchema.safeParse(body);\r\n\r\n        if (!validation.success) {\r\n          return badRequestResponse(validation.error.errors[0].message);\r\n        }\r\n\r\n        const data = validation.data;\r\n\r\n        const achievement = await prisma.achievement.create({\r\n          data: {\r\n            id: data.key,\r\n            ...data,\r\n            category: data.category as any,\r\n            difficulty: data.difficulty as any,\r\n          } as any,\r\n        });\r\n\r\n\r\n        return successResponse(achievement, \"в•ӘШІв”ҳГ  в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШҙв•ӘШҜв•Әв–“ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө\", 201);\r\n      } catch (error) {\r\n        return handleApiError(error);\r\n      }\r\n    });\r\n  });\r\n}\r\n\r\nexport async function DELETE(request: NextRequest) {\r\n  return opsWrapper(request, async (req) => {\r\n    return withAuth(req, async (authUser) => {\r\n      if (authUser.userRole !== \"ADMIN\") {\r\n        return forbiddenResponse(\"в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв”Ӯв”ҳГ в”ҳГӘв•ӘШө в”ҳВ„в”ҳГў в•ӘШ°в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШӯв”ҳВҶв•ӘШҙв•ӘШҜв•Әв–“в•ӘШҜв•ӘШІ\");\r\n      }\r\n\r\n      try {\r\n        const body = await req.json();\r\n        const { id } = body;\r\n\r\n        if (!id) {\r\n          return badRequestResponse(\"в”ҳГ в•Әв•Јв•Әв–’в”ҳВҒ в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШҙв•ӘШҜв•Әв–“ в”ҳГ в•Әв•–в”ҳВ„в”ҳГӘв•ӘШ°\");\r\n        }\r\n\r\n        await prisma.achievement.delete({\r\n          where: { id },\r\n        });\r\n\r\n        return successResponse({ success: true }, \"в•ӘШІв”ҳГ  в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШҙв•ӘШҜв•Әв–“ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө\");\r\n      } catch (error) {\r\n        return handleApiError(error);\r\n      }\r\n    });\r\n  });\r\n}\r\n\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\api\\admin\\ai\\route.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\api\\admin\\analytics\\revenue\\route.ts","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'req' is defined but never used. Allowed unused args must match /^_/u.","line":6,"column":27,"nodeType":"Identifier","messageId":"unusedVar","endLine":6,"endColumn":30}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"ЩҠв•—в”җimport { NextResponse } from 'next/server';\r\nimport { prisma } from '@/lib/db';\r\nimport { startOfDay, endOfDay, startOfMonth, endOfMonth, subMonths } from 'date-fns';\r\nimport { logger } from '@/lib/logger';\r\n\r\nexport async function GET(req: Request) {\r\n  try {\r\n    // --- Revenue Stats ---\r\n    const now = new Date();\r\n    \r\n    // Daily Revenue (Today)\r\n    const todayRevenue = await prisma.payment.aggregate({\r\n      where: {\r\n        status: 'SUCCESS',\r\n        createdAt: { gte: startOfDay(now), lte: endOfDay(now) }\r\n      },\r\n      _sum: { amount: true }\r\n    });\r\n\r\n    // Monthly Revenue (This Month)\r\n    const currentMonthRevenue = await prisma.payment.aggregate({\r\n      where: {\r\n        status: 'SUCCESS',\r\n        createdAt: { gte: startOfMonth(now), lte: endOfMonth(now) }\r\n      },\r\n      _sum: { amount: true }\r\n    });\r\n\r\n    // --- Chart Data (Last 6 Months) ---\r\n    const chartData = [];\r\n    for (let i = 5; i >= 0; i--) {\r\n        const monthDate = subMonths(now, i);\r\n        const start = startOfMonth(monthDate);\r\n        const end = endOfMonth(monthDate);\r\n        \r\n        const monthlySum = await prisma.payment.aggregate({\r\n            where: {\r\n                status: 'SUCCESS',\r\n                createdAt: { gte: start, lte: end }\r\n            },\r\n            _sum: { amount: true }\r\n        });\r\n        \r\n        chartData.push({\r\n            name: monthDate.toLocaleString('ar-EG', { month: 'short' }),\r\n            revenue: monthlySum._sum.amount || 0\r\n        });\r\n    }\r\n\r\n    // --- Top Selling Plans ---\r\n    const topPlansRaw = await (prisma.payment as any).groupBy({\r\n        by: ['subscriptionId'],\r\n        where: { status: 'SUCCESS', subscriptionId: { not: null } },\r\n        _count: { id: true },\r\n        orderBy: { _count: { id: 'desc' } },\r\n        take: 5\r\n    });\r\n\r\n    // Process top plans to get names\r\n    const topPlans = await Promise.all(topPlansRaw.map(async (p: any) => {\r\n        const sub = await prisma.subscription.findUnique({\r\n            where: { id: p.subscriptionId as string },\r\n            include: { plan: true }\r\n        });\r\n        return {\r\n            name: sub?.plan.nameAr || sub?.plan.name || 'в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв•Јв•Әв–’в”ҳГӘв”ҳВҒ',\r\n            count: p._count.id\r\n        };\r\n    }));\r\n\r\n    // --- Conversion Rate ---\r\n    // Total Checkout Visits vs Total Successful Payments\r\n    const totalVisits = await prisma.analyticsEvent.count({\r\n        where: { type: 'CHECKOUT_VISIT' }\r\n    });\r\n    \r\n    const successfulPayments = await prisma.payment.count({\r\n        where: { status: 'SUCCESS' }\r\n    });\r\n\r\n    const conversionRate = totalVisits > 0 \r\n        ? ((successfulPayments / totalVisits) * 100).toFixed(1) \r\n        : \"0.0\";\r\n\r\n    return NextResponse.json({\r\n      summary: {\r\n        today: todayRevenue._sum.amount || 0,\r\n        thisMonth: currentMonthRevenue._sum.amount || 0,\r\n        totalTransactions: successfulPayments,\r\n        conversionRate: `${conversionRate}%`\r\n      },\r\n      chartData,\r\n      topPlans\r\n    });\r\n\r\n  } catch (error) {\r\n    logger.error('Admin Revenue Stats Error:', error);\r\n    return NextResponse.json({ error: 'Internal Server Error' }, { status: 500 });\r\n  }\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\api\\admin\\analytics\\route.ts","messages":[],"suppress