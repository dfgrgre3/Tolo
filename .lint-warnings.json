 group-hover:rotate-6 transition-all\">\r\n                                {entry.username.charAt(0).toUpperCase()}\r\n                             </div>\r\n                             <div className=\"space-y-1\">\r\n                                <p className=\"font-black text-lg text-white group-hover:text-primary transition-colors\">\r\n                                   {entry.username}\r\n                                   {entry.userId === userId && <Badge className=\"mr-3 bg-primary text-[10px] font-black h-5 uppercase\">в•ӘШ«в”ҳВҶв•ӘШІ</Badge>}\r\n                                </p>\r\n                                <div className=\"flex items-center gap-4 text-xs font-bold text-gray-500\">\r\n                                   <span className=\"uppercase tracking-widest text-primary/70\">в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГӘв”ҳГ« {entry.level}</span>\r\n                                   <div className=\"h-1 w-20 bg-white/5 rounded-full overflow-hidden\">\r\n                                      <div className=\"h-full bg-primary/40 w-[65%]\" />\r\n                                   </div>\r\n                                </div>\r\n                             </div>\r\n                          </div>\r\n                          <div className=\"text-left\">\r\n                             <p className=\"text-2xl font-black text-white\">{entry.totalXP.toLocaleString()}</p>\r\n                             <p className=\"text-[10px] text-gray-500 font-bold uppercase tracking-widest\">XP в•Әв•Јв•Әв”Ӯв”ҳГўв•Әв–’в”ҳГЁ</p>\r\n                          </div>\r\n                       </motion.div>\r\n              )\r\n              }\r\n              </div>\r\n           </div>\r\n        </div>\r\n\r\n        {/* --- Summary Boxes --- */}\r\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6 pt-12 pb-20\">\r\n            {[\r\n          { label: \"в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв•Әв–’в•ӘШ°в”ҳГӘв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШҙв”ҳВ„в”ҳГӘв”ҳВҶ\", val: safeLeaderboard.length, icon: Users, color: \"text-blue-400\" },\r\n          { label: \"в•ӘШ«в•Әв•Јв”ҳВ„в”ҳГ« в”ҳВҶв”ҳГ©в•ӘШҜв•Әв•– в”ҳГ в•Әв”Ӯв•ӘШҙв”ҳВ„в•ӘШұ\", val: safeLeaderboard.length > 0 ? Math.max(...safeLeaderboard.map((l) => l.totalXP)).toLocaleString() : '0', icon: Crown, color: \"text-amber-400\" },\r\n          { label: \"в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҒв”ҳГӘв”ҳГ©\", val: userProgress ? Math.floor(userProgress.totalStudyTime / 60) : 0, icon: Clock, color: \"text-purple-400\" }].\r\n          map((stat, i) =>\r\n          <div key={i} className={STYLES.glass + \" p-6 flex items-center gap-6 group hover:translate-y-[-5px] transition-all\"}>\r\n                 <div className={`p-4 rounded-2xl bg-white/5 border border-white/10 ${stat.color} group-hover:scale-110 transition-transform`}>\r\n                    <stat.icon className=\"w-6 h-6\" />\r\n                 </div>\r\n                 <div>\r\n                    <h3 className=\"text-2xl font-black text-white\">{stat.val}</h3>\r\n                    <p className=\"text-[10px] text-gray-500 font-bold uppercase tracking-widest mt-1\">{stat.label}</p>\r\n                 </div>\r\n              </div>\r\n          )}\r\n        </div>\r\n      </div>\r\n\r\n      <AchievementToast\r\n        achievement={currentAchievement}\r\n        onClose={clearAchievementNotification} />\r\n      \r\n    </div>);\r\n\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\loading.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\notifications\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\profile\\components\\AdvancedProtection.tsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"The 'loadProtectionSettings' function makes the dependencies of useEffect Hook (at line 89) change on every render. Move it inside the useEffect callback. Alternatively, wrap the definition of 'loadProtectionSettings' in its own useCallback() Hook.","line":37,"column":9,"nodeType":"VariableDeclarator","endLine":54,"endColumn":4},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"The 'loadIPWhitelist' function makes the dependencies of useEffect Hook (at line 89) change on every render. Move it inside the useEffect callback. Alternatively, wrap the definition of 'loadIPWhitelist' in its own useCallback() Hook.","line":56,"column":9,"nodeType":"VariableDeclarator","endLine":70,"endColumn":4},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"The 'detectCurrentLocation' function makes the dependencies of useEffect Hook (at line 89) change on every render. Move it inside the useEffect callback. Alternatively, wrap the definition of 'detectCurrentLocation' in its own useCallback() Hook.","line":72,"column":9,"nodeType":"VariableDeclarator","endLine":83,"endColumn":4},{"ruleId":"react-hooks/set-state-in-effect","severity":1,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nD:\\thanawy\\src\\app\\(dashboard)\\profile\\components\\AdvancedProtection.tsx:86:5\n  84 |\n  85 |   useEffect(() => {\n> 86 |     loadProtectionSettings();\n     |     ^^^^^^^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  87 |     loadIPWhitelist();\n  88 |     detectCurrentLocation();\n  89 |   }, [_userId, loadProtectionSettings, loadIPWhitelist, detectCurrentLocation]);","line":86,"column":5,"nodeType":null,"endLine":86,"endColumn":27}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":0,"source":"ЩҠв•—в”җ'use client';\r\n\r\nimport { useState, useEffect } from 'react';\r\nimport { Card, CardContent, CardDescription, CardHeader, CardTitle } from \"@/components/ui/card\";\r\nimport { Button } from \"@/components/ui/button\";\r\nimport { Switch } from \"@/components/ui/switch\";\r\nimport { Label } from \"@/components/ui/label\";\r\nimport { Input } from \"@/components/ui/input\";\r\nimport { Badge } from \"@/components/ui/badge\";\r\nimport { toast } from 'sonner';\r\nimport { Shield, MapPin, AlertTriangle, Plus, Trash2, Globe, Lock } from \"lucide-react\";\r\nimport { Separator } from \"@/components/ui/separator\";\r\n\r\nimport { logger } from '@/lib/logger';\r\n\r\ninterface AdvancedProtectionProps {\r\n  userId: string;\r\n}\r\n\r\ninterface IPWhitelistEntry {\r\n  id: string;\r\n  ip: string;\r\n  label?: string;\r\n  createdAt: string;\r\n}\r\n\r\nexport default function AdvancedProtection({ userId: _userId }: AdvancedProtectionProps) {\r\n  const [recaptchaEnabled, setRecaptchaEnabled] = useState(false);\r\n  const [geographicSecurityEnabled, setGeographicSecurityEnabled] = useState(false);\r\n  const [suspiciousActivityDetection, setSuspiciousActivityDetection] = useState(true);\r\n  const [ipWhitelistEnabled, setIpWhitelistEnabled] = useState(false);\r\n  const [ipWhitelist, setIpWhitelist] = useState<IPWhitelistEntry[]>([]);\r\n  const [newIp, setNewIp] = useState('');\r\n  const [newIpLabel, setNewIpLabel] = useState('');\r\n  const [currentLocation, setCurrentLocation] = useState<string>('');\r\n\r\n  const loadProtectionSettings = async () => {\r\n    try {\r\n      // Token is in httpOnly cookie - no need to send Authorization header\r\n      const response = await fetch('/api/auth/security/protection', {\r\n        credentials: 'include'\r\n      });\r\n\r\n      if (response.ok) {\r\n        const data = await response.json();\r\n        setRecaptchaEnabled(data.recaptchaEnabled || false);\r\n        setGeographicSecurityEnabled(data.geographicSecurityEnabled || false);\r\n        setSuspiciousActivityDetection(data.suspiciousActivityDetection !== false);\r\n        setIpWhitelistEnabled(data.ipWhitelistEnabled || false);\r\n      }\r\n    } catch (error) {\r\n      logger.error('Error loading protection settings:', error);\r\n    }\r\n  };\r\n\r\n  const loadIPWhitelist = async () => {\r\n    try {\r\n      // Token is in httpOnly cookie - no need to send Authorization header\r\n      const response = await fetch('/api/auth/security/ip-whitelist', {\r\n        credentials: 'include'\r\n      });\r\n\r\n      if (response.ok) {\r\n        const data = await response.json();\r\n        setIpWhitelist(data.ips || []);\r\n      }\r\n    } catch (error) {\r\n      logger.error('Error loading IP whitelist:', error);\r\n    }\r\n  };\r\n\r\n  const detectCurrentLocation = async () => {\r\n    try {\r\n      // Use a geolocation service or IP-based location detection\r\n      const response = await fetch('https://ipapi.co/json/');\r\n      if (response.ok) {\r\n        const data = await response.json();\r\n        setCurrentLocation(`${data.city || ''}, ${data.country_name || ''}`);\r\n      }\r\n    } catch (error) {\r\n      logger.error('Error detecting location:', error);\r\n    }\r\n  };\r\n\r\n  useEffect(() => {\r\n    loadProtectionSettings();\r\n    loadIPWhitelist();\r\n    detectCurrentLocation();\r\n  }, [_userId, loadProtectionSettings, loadIPWhitelist, detectCurrentLocation]);\r\n\r\n\r\n  const handleSaveProtectionSettings = async () => {\r\n    try {\r\n      // Token is in httpOnly cookie - no need to send Authorization header\r\n      const response = await fetch('/api/auth/security/protection', {\r\n        method: 'POST',\r\n        headers: {\r\n          'Content-Type': 'application/json'\r\n        },\r\n        credentials: 'include',\r\n        body: JSON.stringify({\r\n          recaptchaEnabled,\r\n          geographicSecurityEnabled,\r\n          suspiciousActivityDetection,\r\n          ipWhitelistEnabled\r\n        })\r\n      });\r\n\r\n      if (response.ok) {\r\n        toast.success('в•ӘШІв”ҳГ  в•ӘШөв”ҳВҒв•Әв•• в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШөв”ҳГ в•ӘШҜв”ҳГЁв•ӘШұ');\r\n      } else {\r\n        toast.error('в”ҳВҒв•Әв”Өв”ҳВ„ в”ҳВҒв”ҳГЁ в•ӘШөв”ҳВҒв•Әв•• в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ');\r\n      }\r\n    } catch (error) {\r\n      logger.error('Error saving protection settings:', error);\r\n      toast.error('в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШөв”ҳВҒв•Әв•• в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ');\r\n    }\r\n  };\r\n\r\n  const handleAddIP = async () => {\r\n    if (!newIp) {\r\n      toast.error('в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҙв•ӘШҜв•ӘШ© в•ӘШӯв•ӘВ»в•ӘВ«в•ӘШҜв”ҳВ„ в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ IP');\r\n      return;\r\n    }\r\n\r\n    // Basic IP validation\r\n    const ipRegex = /^(?:(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.){3}(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$/;\r\n    if (!ipRegex.test(newIp)) {\r\n      toast.error('в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ IP в•Әв•‘в”ҳГЁв•Әв–’ в•Әв•Ўв•ӘШөв”ҳГЁв•ӘШө');\r\n      return;\r\n    }\r\n\r\n    try {\r\n      // Token is in httpOnly cookie - no need to send Authorization header\r\n      const response = await fetch('/api/auth/security/ip-whitelist', {\r\n        method: 'POST',\r\n        headers: {\r\n          'Content-Type': 'application/json'\r\n        },\r\n        credentials: 'include',\r\n        body: JSON.stringify({\r\n          ip: newIp,\r\n          label: newIpLabel || 'в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ IP'\r\n        })\r\n      });\r\n\r\n      if (response.ok) {\r\n        const data = await response.json();\r\n        setIpWhitelist([...ipWhitelist, data.ip]);\r\n        setNewIp('');\r\n        setNewIpLabel('');\r\n        toast.success('в•ӘШІв”ҳГ  в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ IP в•ӘШӯв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•Әв•ўв•ӘШҜв•ӘШ©');\r\n      } else {\r\n        toast.error('в”ҳВҒв•Әв”Өв”ҳВ„ в”ҳВҒв”ҳГЁ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ IP');\r\n      }\r\n    } catch (error) {\r\n      logger.error('Error adding IP:', error);\r\n      toast.error('в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ IP');\r\n    }\r\n  };\r\n\r\n  const handleRemoveIP = async (ipId: string) => {\r\n    try {\r\n      // Token is in httpOnly cookie - no need to send Authorization header\r\n      const response = await fetch(`/api/auth/security/ip-whitelist/${ipId}`, {\r\n        method: 'DELETE',\r\n        credentials: 'include'\r\n      });\r\n\r\n      if (response.ok) {\r\n        setIpWhitelist(ipWhitelist.filter((ip) => ip.id !== ipId));\r\n        toast.success('в•ӘШІв”ҳГ  в•ӘШӯв•Әв–“в•ӘШҜв”ҳВ„в•ӘШұ в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ IP в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•Әв•ўв•ӘШҜв•ӘШ©');\r\n      } else {\r\n        toast.error('в”ҳВҒв•Әв”Өв”ҳВ„ в”ҳВҒв”ҳГЁ в•ӘШӯв•Әв–“в•ӘШҜв”ҳВ„в•ӘШұ в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ IP');\r\n      }\r\n    } catch (error) {\r\n      logger.error('Error removing IP:', error);\r\n      toast.error('в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШӯв•Әв–“в•ӘШҜв”ҳВ„в•ӘШұ в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ IP');\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      {/* Google reCAPTCHA */}\r\n      <Card>\r\n        <CardHeader>\r\n          <CardTitle className=\"flex items-center gap-2\">\r\n            <Shield className=\"h-5 w-5\" />\r\n            Google reCAPTCHA\r\n          </CardTitle>\r\n          <CardDescription>\r\n            в•ӘШөв”ҳГ в•ӘШҜв”ҳГЁв•ӘШұ в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°в”ҳГў в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в•Әв–’в”ҳГӘв•ӘШ°в”ҳГӘв•ӘШІв•ӘШҜв•ӘШІ в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГ§в•ӘШҙв”ҳГ в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШІв”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГЁв•ӘШұ\r\n          </CardDescription>\r\n        </CardHeader>\r\n        <CardContent className=\"space-y-4\">\r\n          <div className=\"flex items-center justify-between p-4 rounded-lg border\">\r\n            <div className=\"flex items-center gap-3\">\r\n              <Globe className=\"h-5 w-5 text-muted-foreground\" />\r\n              <div>\r\n                <Label className=\"text-base\">в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„ reCAPTCHA</Label>\r\n                <p className=\"text-sm text-muted-foreground\">\r\n                  в”ҳГЁв•ӘШІв•Әв•–в”ҳВ„в•ӘШ° в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в”ҳГ в”ҳВҶ reCAPTCHA в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„\r\n                </p>\r\n              </div>\r\n            </div>\r\n            <Switch\r\n              checked={recaptchaEnabled}\r\n              onCheckedChange={setRecaptchaEnabled} />\r\n            \r\n          </div>\r\n\r\n          {recaptchaEnabled &&\r\n          <div className=\"p-4 rounded-lg border bg-blue-50 dark:bg-blue-900/20\">\r\n              <div className=\"text-sm text-center py-4\">в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө</div>\r\n            </div>\r\n          }\r\n        </CardContent>\r\n      </Card>\r\n\r\n      {/* Geographic Security */}\r\n      <Card>\r\n        <CardHeader>\r\n          <CardTitle className=\"flex items-center gap-2\">\r\n            <MapPin className=\"h-5 w-5\" />\r\n            в•ӘШ«в”ҳГ в•ӘШҜв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв”ҳГ©в•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШҙв•Әв•‘в•Әв–’в•ӘШҜв”ҳВҒв”ҳГЁ\r\n          </CardTitle>\r\n          <CardDescription>\r\n            в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв”ҳГ©в•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШҙв•Әв•‘в•Әв–’в•ӘШҜв”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв”ҳГ в”ҳГӘв•ӘШө в”ҳВ„в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„\r\n          </CardDescription>\r\n        </CardHeader>\r\n        <CardContent className=\"space-y-4\">\r\n          <div className=\"flex items-center justify-between p-4 rounded-lg border\">\r\n            <div className=\"flex items-center gap-3\">\r\n              <MapPin className=\"h-5 w-5 text-muted-foreground\" />\r\n              <div>\r\n                <Label className=\"text-base\">в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„ в•ӘШ«в”ҳГ в•ӘШҜв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв”ҳГ©в•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШҙв•Әв•‘в•Әв–’в•ӘШҜв”ҳВҒв”ҳГЁ</Label>\r\n                <p className=\"text-sm text-muted-foreground\">\r\n                  {currentLocation && `в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв”ҳГ©в•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁ: ${currentLocation}`}\r\n                </p>\r\n              </div>\r\n            </div>\r\n            <Switch\r\n              checked={geographicSecurityEnabled}\r\n              onCheckedChange={setGeographicSecurityEnabled} />\r\n            \r\n          </div>\r\n\r\n          {geographicSecurityEnabled &&\r\n          <div className=\"p-4 rounded-lg border bg-yellow-50 dark:bg-yellow-900/20\">\r\n              <div className=\"flex items-start gap-3\">\r\n                <AlertTriangle className=\"h-5 w-5 text-yellow-600 mt-0.5\" />\r\n                <div className=\"text-sm text-yellow-800 dark:text-yellow-200\">\r\n                  <p className=\"font-medium mb-1\">в•ӘШІв”ҳВҶв•ӘШ°в”ҳГЁв”ҳГ§:</p>\r\n                  <p>в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„ в”ҳГ§в•Әв–‘в”ҳГ§ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГЁв•Әв–“в•ӘШұв•ӘГ® в•Әв”Ӯв”ҳГЁв•ӘШІв”ҳГ  в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„ в•ӘШІв”ҳВҶв•ӘШ°в”ҳГЁв”ҳГ§ в•Әв•Јв”ҳВҶв•ӘВ» в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳГ в”ҳВҶ в”ҳГ в”ҳГӘв”ҳГ©в•Әв•Ј в•ӘШҙв•Әв•‘в•Әв–’в•ӘШҜв”ҳВҒв”ҳГЁ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ» в•ӘШ«в”ҳГӘ в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв•Јв•ӘШІв•ӘШҜв•ӘВ».</p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          }\r\n        </CardContent>\r\n      </Card>\r\n\r\n      {/* Suspicious Activity Detection */}\r\n      <Card>\r\n        <CardHeader>\r\n          <CardTitle className=\"flex items-center gap-2\">\r\n            <AlertTriangle className=\"h-5 w-5\" />\r\n            в”ҳГўв•Әв”Өв”ҳВҒ в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Өв•ӘШҜв•Әв•– в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Өв•ӘШ°в”ҳГӘв”ҳГ§\r\n          </CardTitle>\r\n          <CardDescription>\r\n            в”ҳГ в•Әв–’в•ӘШҜв”ҳГ©в•ӘШ°в•ӘШұ в”ҳГӘв•ӘШҜв”ҳГўв•ӘШІв•Әв”Өв•ӘШҜв”ҳВҒ в•ӘШҜв”ҳВ„в•ӘШ«в”ҳВҶв•Әв”Өв•Әв•–в•ӘШұ в•Әв•‘в”ҳГЁв•Әв–’ в•ӘШҜв”ҳВ„в•Әв•Јв•ӘШҜв•ӘВ»в”ҳГЁв•ӘШұ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°в”ҳГў\r\n          </CardDescription>\r\n        </CardHeader>\r\n        <CardContent className=\"space-y-4\">\r\n          <div className=\"flex items-center justify-between p-4 rounded-lg border\">\r\n            <div className=\"flex items-center gap-3\">\r\n              <AlertTriangle className=\"h-5 w-5 text-muted-foreground\" />\r\n              <div>\r\n                <Label className=\"text-base\">в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„ в”ҳГўв•Әв”Өв”ҳВҒ в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Өв•ӘШҜв•Әв•– в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Өв•ӘШ°в”ҳГӘв”ҳГ§</Label>\r\n                <p className=\"text-sm text-muted-foreground\">\r\n                  в•Әв”Ӯв”ҳГЁв•ӘШІв”ҳГ  в•ӘШҜв”ҳГўв•ӘШІв•Әв”Өв•ӘШҜв”ҳВҒ в”ҳГӘв•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„ в•ӘШІв”ҳВҶв•ӘШ°в”ҳГЁв”ҳГ§в•ӘШҜв•ӘШІ в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШҜв”ҳГўв•ӘШІв•Әв”Өв•ӘШҜв”ҳВҒ в”ҳВҶв•Әв”Өв•ӘШҜв•Әв•– в•Әв•‘в”ҳГЁв•Әв–’ в•Әв•Јв•ӘШҜв•ӘВ»в”ҳГЁ\r\n                </p>\r\n              </div>\r\n            </div>\r\n            <Switch\r\n              checked={suspiciousActivityDetection}\r\n              onCheckedChange={setSuspiciousActivityDetection} />\r\n            \r\n          </div>\r\n\r\n          {suspiciousActivityDetection &&\r\n          <div className=\"p-4 rounded-lg border bg-blue-50 dark:bg-blue-900/20\">\r\n              <h3 className=\"font-medium mb-2\">в”ҳГ в•ӘШҜ в”ҳГЁв•ӘШІв”ҳГ  в”ҳГ в•Әв–’в•ӘШҜв”ҳГ©в•ӘШ°в•ӘШІв”ҳГ§:</h3>\r\n              <ul className=\"text-sm space-y-1 text-muted-foreground list-disc list-inside\">\r\n                <li>в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШҜв•ӘШІ в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳГ в•ӘШІв•Әв•Јв•ӘВ»в•ӘВ»в•ӘШұ в”ҳВҒв•ӘШҜв•Әв”Өв”ҳВ„в•ӘШұ</li>\r\n                <li>в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳГ в”ҳВҶ в”ҳГ в”ҳГӘв•ӘШҜв”ҳГ©в•Әв•Ј в•ӘШҙв•Әв•‘в•Әв–’в•ӘШҜв”ҳВҒв”ҳГЁв•ӘШұ в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв•Јв•ӘШІв•ӘШҜв•ӘВ»в•ӘШұ</li>\r\n                <li>в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳГ в”ҳВҶ в•ӘШ«в•ӘШҙв”ҳГ§в•Әв–“в•ӘШұ в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв•Јв•Әв–’в”ҳГӘв”ҳВҒв•ӘШұ</li>\r\n                <li>в•ӘШ«в”ҳВҶв•Әв”Өв•Әв•–в•ӘШұ в•Әв•‘в”ҳГЁв•Әв–’ в•Әв•Јв•ӘШҜв•ӘВ»в”ҳГЁв•ӘШұ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°</li>\r\n              </ul>\r\n            </div>\r\n          }\r\n        </CardContent>\r\n      </Card>\r\n\r\n      {/* IP Whitelisting */}\r\n      <Card>\r\n        <CardHeader>\r\n          <CardTitle className=\"flex items-center gap-2\">\r\n            <Lock className=\"h-5 w-5\" />\r\n            IP Whitelisting\r\n          </CardTitle>\r\n          <CardDescription>\r\n            в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘВ» в•Әв•Јв”ҳВҶв•ӘШҜв”ҳГӘв”ҳГЁв”ҳВҶ IP в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв”ҳГ в”ҳГӘв•ӘШө в”ҳВ„в”ҳГ§в•ӘШҜ в•ӘШ°в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в•ӘШӯв”ҳВ„в”ҳГ« в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°в”ҳГў\r\n          </CardDescription>\r\n        </CardHeader>\r\n        <CardContent className=\"space-y-4\">\r\n          <div className=\"flex items-center justify-between p-4 rounded-lg border\">\r\n            <div className=\"flex items-center gap-3\">\r\n              <Lock className=\"h-5 w-5 text-muted-foreground\" />\r\n              <div>\r\n                <Label className=\"text-base\">в•ӘШІв”ҳВҒв•Әв•Јв”