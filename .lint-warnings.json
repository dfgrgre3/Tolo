EP_1\": \"в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в”ҳГЁ\",\n  \"PREP_2\": \"в•ӘШҜв”ҳВ„в•ӘШів•ӘШҜв”ҳВҶв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в”ҳГЁ\",\n  \"PREP_3\": \"в•ӘШҜв”ҳВ„в•ӘШів•ӘШҜв”ҳВ„в•ӘШі в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в”ҳГЁ\",\n  \"SEC_1\": \"в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШів•ӘШҜв”ҳВҶв”ҳГӘв”ҳГЁ\",\n  \"SEC_2\": \"в•ӘШҜв”ҳВ„в•ӘШів•ӘШҜв”ҳВҶв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШів•ӘШҜв”ҳВҶв”ҳГӘв”ҳГЁ\",\n  \"SEC_3\": \"в•ӘШҜв”ҳВ„в•ӘШів•ӘШҜв”ҳВ„в•ӘШі в•ӘШҜв”ҳВ„в•ӘШів•ӘШҜв”ҳВҶв”ҳГӘв”ҳГЁ\",\n};\n\nexport default function UserDetailPage() {\n  const params = useParams();\n  const router = useRouter();\n  const userId = params.id as string;\n\n  const [user, setUser] = React.useState<UserDetails | null>(null);\n  const [loading, setLoading] = React.useState(true);\n  const [isEditing, setIsEditing] = React.useState(false);\n  const [activeTab, setActiveTab] = React.useState(\"overview\");\n  const [editedUser, setEditedUser] = React.useState<Partial<UserDetails>>({});\n\n  const fetchUser = React.useCallback(async () => {\n    try {\n      const response = await fetch(`/api/admin/users/${userId}`);\n      if (response.ok) {\n        const data = await response.json();\n        setUser(data);\n        setEditedUser(data);\n      } else {\n        toast.error(\"в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в”ҳГӘв•ӘШҙв”ҳГӘв•ӘВ»\");\n        router.push(\"/admin/users\");\n      }\n    } catch (error) {\n      logger.error(\"Error fetching user:\", error);\n      toast.error(\"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШҙв”ҳВ„в•ӘШ° в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ \");\n    } finally {\n      setLoading(false);\n    }\n  }, [userId, router]);\n\n  React.useEffect(() => {\n    fetchUser();\n  }, [fetchUser]);\n\n  const handleUpdate = async () => {\n    try {\n      const response = await fetch(`/api/admin/users/${userId}`, {\n        method: \"PATCH\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify(editedUser),\n      });\n\n      if (response.ok) {\n        toast.success(\"в•ӘШІв”ҳГ  в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө\");\n        setIsEditing(false);\n        fetchUser();\n      } else {\n        const data = await response.json();\n        toast.error(data.message || \"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі\");\n      }\n    } catch (error) {\n      logger.error(\"Error updating user:\", error);\n      toast.error(\"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ \");\n    }\n  };\n\n  const handleRoleChange = async (role: string) => {\n    try {\n      const response = await fetch(`/api/admin/users/${userId}`, {\n        method: \"PATCH\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ role }),\n      });\n\n      if (response.ok) {\n        toast.success(\"в•ӘШІв”ҳГ  в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в•ӘВ»в”ҳГӘв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө\");\n        if (user) {\n          setUser({ ...user, role });\n        }\n      } else {\n        toast.error(\"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в•ӘВ»в”ҳГӘв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ \");\n      }\n    } catch (error) {\n      logger.error(\"Error updating user role:\", error);\n      toast.error(\"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в•ӘВ»в”ҳГӘв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ \");\n    }\n  };\n\n  const handleDelete = async () => {\n    if (!confirm(\"в”ҳГ§в”ҳВ„ в•ӘШ«в”ҳВҶв•ӘШІ в”ҳГ в•ӘШІв•ӘШ«в”ҳГўв•ӘВ» в”ҳГ в”ҳВҶ в•ӘШөв•Әв–‘в”ҳВҒ в”ҳГ§в•Әв–‘в•ӘШҜ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ в•ӘШ§ в”ҳВ„в•ӘШҜ в”ҳГЁв”ҳГ в”ҳГўв”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШІв•Әв–’в•ӘШҜв•ӘШҙв•Әв•Ј в•Әв•Јв”ҳВҶ в”ҳГ§в•Әв–‘в•ӘШҜ в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШҙв•Әв–’в•ӘШҜв•ӘШ©.\")) {\n      return;\n    }\n\n    try {\n      const response = await fetch(`/api/admin/users/${userId}`, {\n        method: \"DELETE\",\n      });\n\n      if (response.ok) {\n        toast.success(\"в•ӘШІв”ҳГ  в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө\");\n        router.push(\"/admin/users\");\n      } else {\n        toast.error(\"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ \");\n      }\n    } catch (error) {\n      logger.error(\"Error deleting user:\", error);\n      toast.error(\"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ \");\n    }\n  };\n\n  if (loading) {\n    return (\n      <div className=\"space-y-8 animate-in fade-in duration-500\">\n        <div className=\"flex items-center justify-between\">\n          <div className=\"space-y-3\">\n            <div className=\"h-10 w-64 bg-muted animate-pulse rounded-lg\" />\n            <div className=\"h-5 w-80 bg-muted animate-pulse rounded-md\" />\n          </div>\n          <div className=\"h-11 w-36 bg-muted animate-pulse rounded-xl\" />\n        </div>\n        <div className=\"grid gap-8 lg:grid-cols-4\">\n          <div className=\"lg:col-span-1 space-y-8\">\n            <div className=\"rounded-2xl border bg-card p-8 flex flex-col items-center gap-6\">\n              <div className=\"h-32 w-32 rounded-full bg-muted animate-pulse\" />\n              <div className=\"space-y-2 w-full\">\n                <div className=\"h-7 w-3/4 mx-auto bg-muted animate-pulse rounded\" />\n                <div className=\"h-5 w-1/2 mx-auto bg-muted animate-pulse rounded\" />\n              </div>\n              <div className=\"h-8 w-24 bg-muted animate-pulse rounded-full\" />\n            </div>\n          </div>\n          <div className=\"lg:col-span-3 space-y-8\">\n            <div className=\"grid gap-6 md:grid-cols-4\">\n              {[...Array(4)].map((_, i) => (\n                <div key={i} className=\"rounded-2xl border bg-card p-6 space-y-4\">\n                  <div className=\"h-10 w-10 bg-muted animate-pulse rounded-xl\" />\n                  <div className=\"space-y-2\">\n                    <div className=\"h-8 w-20 bg-muted animate-pulse rounded\" />\n                    <div className=\"h-4 w-16 bg-muted animate-pulse rounded\" />\n                  </div>\n                </div>\n              ))}\n            </div>\n            <div className=\"h-96 w-full bg-muted animate-pulse rounded-2xl border\" />\n          </div>\n        </div>\n      </div>\n    );\n  }\n\n  if (!user) return null;\n\n  const xpToNextLevel = (user.level * 1000) - (user.totalXP % 1000);\n  const levelProgress = ((user.totalXP % 1000) / 1000) * 100;\n\n  return (\n    <div className=\"space-y-8 pb-10\">\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4\">\n        <PageHeader\n          title={user.name || \"в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Ўв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ \"}\n          description={`в•ӘШӯв•ӘВ»в•ӘШҜв•Әв–’в•ӘШұ в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в”ҳГӘв”ҳВҶв•Әв”Өв•ӘШҜв•Әв•– ${user.name || user.email}`}\n          className=\"p-0\"\n        />\n        <div className=\"flex items-center gap-3\">\n          <Button variant=\"outline\" className=\"rounded-xl\" onClick={() => router.push(\"/admin/users\")}>\n            <ArrowRight className=\"ml-2 h-4 w-4\" />\n            в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГӘв•ӘВ»в•ӘШұ в”ҳВ„в”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ\n          </Button>\n          <Button \n            variant=\"destructive\" \n            className=\"rounded-xl shadow-lg shadow-danger/20\"\n            onClick={handleDelete}\n          >\n            <Trash2 className=\"ml-2 h-4 w-4\" />\n            в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШҜв”ҳВ„в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°\n          </Button>\n        </div>\n      </div>\n\n      <div className=\"grid gap-8 lg:grid-cols-4\">\n        {/* Profile Sidebar */}\n        <div className=\"lg:col-span-1 space-y-8\">\n          <Card className=\"border-none shadow-xl bg-gradient-to-b from-card to-card/50 overflow-hidden\">\n            <div className=\"h-24 bg-gradient-to-r from-primary/20 via-primary/10 to-transparent\" />\n            <CardContent className=\"-mt-12 flex flex-col items-center text-center p-8\">\n              <div className=\"relative group\">\n                <Avatar className=\"h-32 w-32 border-4 border-background shadow-2xl transition-transform duration-300 group-hover:scale-105\">\n                  <AvatarImage src={user.avatar || undefined} className=\"object-cover\" />\n                  <AvatarFallback className=\"text-4xl bg-primary/10 text-primary font-bold\">\n                    {user.name?.charAt(0) || user.email.charAt(0).toUpperCase()}\n                  </AvatarFallback>\n                </Avatar>\n                {user.emailVerified && (\n                  <div className=\"absolute bottom-1 right-1 bg-background rounded-full p-1 border shadow-sm\">\n                    <CheckCircle className=\"h-6 w-6 text-success fill-success/10\" />\n                  </div>\n                )}\n              </div>\n              \n              <div className=\"mt-6 space-y-1\">\n                <CardTitle className=\"text-2xl font-bold tracking-tight\">\n                  {user.name || \"в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв•Јв•Әв–’в”ҳГӘв”ҳВҒ\"}\n                </CardTitle>\n                <div className=\"flex items-center justify-center gap-2 text-muted-foreground\">\n                  <span className=\"text-sm font-medium\">@{user.username || \"в•ӘШ°в•ӘВ»в”ҳГӘв”ҳВҶ_в•ӘШҜв•Әв”Ӯв”ҳГ \"}</span>\n                </div>\n              </div>\n\n              <div className=\"mt-6 w-full space-y-4\">\n                <div className=\"flex flex-wrap justify-center gap-2\">\n                  <Badge variant=\"outline\" className={`${roleColors[user.role]} px-4 py-1.5 rounded-full border-none font-semibold`}>\n                    {roleLabels[user.role] || user.role}\n                  </Badge>\n                  {user.gradeLevel && (\n                    <Badge variant=\"secondary\" className=\"px-4 py-1.5 rounded-full font-semibold\">\n                      {gradeLabels[user.gradeLevel] || user.gradeLevel}\n                    </Badge>\n                  )}\n                </div>\n\n                <div className=\"pt-6 border-t w-full space-y-4 text-right\">\n                  <div className=\"flex items-center gap-3 text-sm\">\n                    <div className=\"p-2 rounded-lg bg-primary/10 text-primary\">\n                      <Mail className=\"h-4 w-4\" />\n                    </div>\n                    <div className=\"flex-1 min-w-0\">\n                      <p className=\"font-semibold text-foreground truncate\">{user.email}</p>\n                      <p className=\"text-xs text-muted-foreground\">в•ӘШҜв”ҳВ„в•ӘШ°в•Әв–’в”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВ„в”ҳГўв•ӘШІв•Әв–’в”ҳГӘв”ҳВҶв”ҳГЁ</p>\n                    </div>\n                  </div>\n\n                  {user.phone && (\n                    <div className=\"flex items-center gap-3 text-sm\">\n                      <div className=\"p-2 rounded-lg bg-green-500/10 text-green-600\">\n                        <Phone className=\"h-4 w-4\" />\n                      </div>\n                      <div className=\"flex-1 min-w-0\">\n                        <p className=\"font-semibold text-foreground truncate\">{user.phone}</p>\n                        <p className=\"text-xs text-muted-foreground\">в•Әв–’в”ҳГ©в”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ§в•ӘШҜв•ӘШІв”ҳВҒ</p>\n                      </div>\n                    </div>\n                  )}\n\n                  <div className=\"flex items-center gap-3 text-sm\">\n                    <div className=\"p-2 rounded-lg bg-orange-500/10 text-orange-600\">\n                      <Calendar className=\"h-4 w-4\" />\n                    </div>\n                    <div className=\"flex-1 min-w-0\">\n                      <p className=\"font-semibold text-foreground\">\n                        {format(new Date(user.createdAt), \"d MMMM yyyy\", { locale: ar })}\n                      </p>\n                      <p className=\"text-xs text-muted-foreground\">в•ӘШІв•ӘШҜв•Әв–’в”ҳГЁв•ӘВ« в•ӘШҜв”ҳВ„в•ӘШҜв”ҳВҶв•Әв•ўв”ҳГ в•ӘШҜв”ҳГ </p>\n                    </div>\n                  </div>\n                </div>\n              </div>\n\n              <div className=\"mt-8 w-full\">\n                <div className=\"flex items-center justify-between mb-2\">\n                  <span className=\"text-sm font-bold text-primary\">в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГӘв”ҳГ« {user.level}</span>\n                  <span className=\"text-xs text-muted-foreground\">{xpToNextLevel} XP в”ҳВ„в”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГӘв”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв•ӘВ»в”ҳГ </span>\n                </div>\n                <Progress value={levelProgress} className=\"h-2 rounded-full bg-primary/10\" />\n              </div>\n            </CardContent>\n          </Card>\n\n          {/* Quick Actions Card */}\n          <Card className=\"border-none shadow-lg\">\n            <CardHeader className=\"pb-4\">\n              <CardTitle className=\"text-sm font-bold flex items-center gap-2\">\n                <Settings className=\"h-4 w-4\" />\n                в•ӘШӯв•ӘШҙв•Әв–’в•ӘШҜв•ӘШ©в•ӘШҜв•ӘШІ в•Әв”Ӯв•Әв–’в”ҳГЁв•Әв•Јв•ӘШұ\n              </CardTitle>\n            </CardHeader>\n            <CardContent className=\"space-y-2\">\n              <Button \n                variant=\"outline\" \n                className=\"w-full justify-start rounded-xl gap-2 h-11\"\n                onClick={() => setActiveTab(\"settings\")}\n              >\n                <Edit className=\"h-4 w-4\" />\n                в•ӘШІв•Әв•Јв•ӘВ»в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ\n              </Button>\n              <Button variant=\"outline\" className=\"w-full justify-start rounded-xl gap-2 h-11\">\n                <Lock className=\"h-4 w-4\" />\n                в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’\n              </Button>\n              <Button variant=\"outline\" className=\"w-full justify-start rounded-xl gap-2 h-11\">\n                <ShieldCheck className=\"h-4 w-4\" />\n                в•ӘШӯв•ӘВ»в•ӘШҜв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в•Әв•Ўв”ҳВ„в•ӘШҜв•ӘШөв”ҳГЁв•ӘШҜв•ӘШІ\n              </Button>\n            </CardContent>\n          </Card>\n        </div>\n\n        {/* Main Content Areas */}\n        <div className=\"lg:col-span-3 space-y-8\">\n          {/* Dashboard Stats */}\n          <div className=\"grid gap-6 md:grid-cols-4\">\n            {[\n              { label: \"в•ӘШӯв•ӘШҙв”ҳГ в•ӘШҜв”ҳВ„в”ҳГЁ XP\", value: user.totalXP.toLocaleString(), icon: Star, color: \"text-yellow-500\", bg: \"bg-yellow-500/10\" },\n              { label: \"в•ӘШІв•ӘШІв•ӘШҜв•ӘШ°в•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГЁв•ӘШҜв”ҳГ \", value: user.currentStreak, icon: Zap, color: \"text-orange-500\", bg: \"bg-orange-500/10\" },\n              { label: \"в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв•ӘШұ\", value: Math.floor(user.totalStudyTime / 60), icon: Clock, color: \"text-blue-500\", bg: \"bg-blue-500/10\" },\n              { label: \"в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в”ҳГ в”ҳГўв•ӘШІв”ҳГ в”ҳВ„в•ӘШұ\", value: user.examsPassed, icon: Award, color: \"text-green-500\", bg: \"bg-green-500/10\" },\n            ].map((stat, i) => (\n              <Card key={i} className=\"border-none shadow-lg overflow-hidden relative group hover:scale-[1.02] transition-all duration-300\">\n                <CardContent className=\"p-6\">\n                  <div className={`p-3 rounded-xl ${stat.bg} ${stat.color} w-fit mb-4 group-hover:scale-110 transition-transform`}>\n                    <stat.icon className=\"h-6 w-6\" />\n                  </div>\n                  <div>\n                    <h3 className=\"text-2xl font-bold tracking-tight\">{stat.value}</h3>\n                    <p className=\"text-sm text-muted-foreground font-medium\">{stat.label}</p>\n                  </div>\n                </CardContent>\n                <div className={`absolute bottom-0 left-0 h-1 w-full scale-x-0 group-hover:scale-x-100 transition-transform origin-right ${stat.bg.replace('/10', '')}`} />\n              </Card>\n            ))}\n          </div>\n\n          <Tabs value={activeTab} onValueChange={setActiveTab} className=\"space-y-8\">\n            <div className=\"bg-card p-1.5 rounded-2xl border shadow-sm inline-flex w-full md:w-auto\">\n              <TabsList className=\"bg-transparent h-10 w-full md:w-auto\">\n                <TabsTrigger value=\"overview\" className=\"rounded-xl data-[state=active]:bg-primary data-[state=active]:text-primary-foreground data-[state=active]:shadow-lg flex items-center gap-2 px-6\">\n                  <Activity className=\"h-4 w-4\" />\n                  в”ҳВҶв•Әв••в•Әв–’в•ӘШұ в•Әв•Јв•ӘШҜв”ҳГ в•ӘШұ\n                </TabsTrigger>\n                <TabsTrigger value=\"academic\" className=\"rounded-xl data-[state=active]:bg-primary data-[state=active]:text-primary-foreground data-[state=active]:shadow-lg flex items-center gap-2 px-6\">\n                  <BookOpen className=\"h-4 w-4\" />\n                  в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ»в•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГўв•ӘШҜв•ӘВ»в”ҳГЁв”ҳГ в”ҳГЁ\n                </TabsTrigger>\n                <TabsTrigger value=\"activity\" className=\"rounded-xl data-[state=active]:bg-primary data-[state=active]:text-primary-foreground data-[state=active]:shadow-lg flex items-center gap-2 px-6\">\n                  <History className=\"h-4 w-4\" />\n                  в•Әв”Ӯв•ӘШҙв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Өв•ӘШҜв•Әв•–\n                </TabsTrigger>\n                <TabsTrigger value=\"settings\" className=\"rounded-xl data-[state=active]:bg-primary data-[state=active]:text-primary-foreground data-[state=active]:shadow-lg flex items-center gap-2 px-6\">\n                  <Settings className=\"h-4 w-4\" />\n                  в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ\n                </TabsTrigger>\n              </TabsList>\n            </div>\n\n            <TabsContent value=\"overview\" className=\"space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-500\">\n              {/* Bio Section */}\n              {user.bio && (\n                <Card className=\"border-none shadow-lg\">\n                  <CardHeader className=\"pb-2\">\n                    <CardTitle className=\"text-lg flex items-center gap-2\">\n                      <UserIcon className=\"h-5 w-5 text-primary\" />\n                      в”ҳВҶв•ӘШ°в•Әв–‘в•ӘШұ в•ӘШІв•Әв•Јв•Әв–’в”ҳГЁв”ҳВҒв”ҳГЁв•ӘШұ\n                    </CardTitle>\n                  </CardHeader>\n                  <CardContent>\n                    <p className=\"text-muted-foreground leading-relaxed\">\n                      {user.bio}\n                    </p>\n                  </CardContent>\n                </Card>\n              )}\n\n              <div className=\"grid gap-8 md:grid-cols-2\">\n                {/* XP Distribution */}\n                <Card className=\"border-none shadow-lg\">\n                  <CardHeader>\n                    <CardTitle className=\"text-lg flex items-center gap-2\">\n                      <TrendingUp className=\"h-5 w-5 text-primary\" />\n                      в•ӘШІв”ҳГӘв•Әв–“в”ҳГЁв•Әв•Ј в”ҳВҶв”ҳГ©в•ӘШҜв•Әв•– в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШ°в•Әв–’в•ӘШұ (XP)\n                    </CardTitle>\n                    <CardDescription>в•ӘШІв•ӘШөв”ҳВ„в”ҳГЁв”ҳВ„ в”ҳВ„в”ҳГ в•Әв•Ўв•ӘШҜв•ӘВ»в•Әв–’ в”ҳВҶв”ҳГ©в•ӘШҜв•Әв•– в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШ°в•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв”ҳГЁ в•ӘШҜв”ҳГўв•ӘШІв•Әв”Ӯв•ӘШ°в”ҳГ§в•ӘШҜ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ </CardDescription>\n                  </CardHeader>\n                  <CardContent className=\"space-y-6\">\n                    {[\n                      { label: \"в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв•ӘШұ\", value: user.studyXP, color: \"bg-blue-500\" },\n                      { label: \"в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ \", value: user.taskXP, color: \"bg-green-500\" },\n                      { label: \"в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ\", value: user.examXP, color: \"bg-purple-500\" },\n                      { label: \"в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШҜв•ӘШІ\", value: user.challengeXP, color: \"bg-orange-500\" },\n                      { label: \"в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•Әв”Ӯв”ҳГ \", value: user.seasonXP, color: \"bg-red-500\" },\n                    ].map((xp, i) => (\n                      <div key={i} className=\"space-y-2\">\n                        <div className=\"flex justify-between text-sm font-medium\">\n                          <span>{xp.label}</span>\n                          <span>{xp.value.toLocaleString()} XP</span>\n                        </div>\n                        <Progress \n                          value={(xp.value / (user.totalXP || 1)) * 100} \n                          className={`h-2 rounded-full bg-muted`}\n                        />\n                      </div>\n                    ))}\n                  </CardContent>\n                </Card>\n\n                {/* Engagement Stats */}\n                <Card className=\"border-none shadow-lg\">\n                  <CardHeader>\n                    <CardTitle className=\"text-lg flex items-center gap-2\">\n                      <Target className=\"h-5 w-5 text-primary\" />\n                      в”ҳГ в•ӘШ¬в•Әв”Өв•Әв–’в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Јв”ҳВ„\n                    </CardTitle>\n                    <CardDescription>в”ҳВҶв•Әв••в•Әв–’в•ӘШұ в”ҳГ в”ҳВҒв•Әв•Ўв”ҳВ„в•ӘШұ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Јв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в”ҳГ в•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•Әв•Ўв•ӘШұ</CardDescription>\n                  </CardHeader>\n                  <CardContent className=\"p-0\">\n                    <div className=\"divide-y\">\n                      {[\n                        { label: \"в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв•ӘШІв”ҳГ в”ҳВ„в•ӘШұ\", value: user.tasksCompleted, total: user._count.tasks, icon: CheckCircle, color: \"text-green-500\" },\n                        { label: \"в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–‘в•ӘШҜв”ҳГўв•Әв–’в•ӘШұ\", value: user._count.studySessions, icon: BookOpen, color: \"text-blue-500\" },\n                        { label: \"в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШҜв•ӘШІ в•ӘШ°в”ҳГӘв”ҳГ в”ҳГӘв•ӘВ»в”ҳГӘв•Әв–’в”ҳГӘ\", value: user.pomodoroSessions, icon: Clock, color: \"text-orange-500\" },\n                        { label: \"в•ӘШ«в•Әв•–в”ҳГӘв”ҳВ„ в•ӘШІв•ӘШІв•ӘШҜв•ӘШ°в•Әв•Ј\", value: `${user.longestStreak} в”ҳГЁв”ҳГӘв”ҳГ `, icon: Trophy, color: \"text-yellow-500\" },\n                        { label: \"в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШҙв•ӘШҜв•Әв–“в•ӘШҜв•ӘШІ\", value: user._count.achievements, icon: Award, color: \"text-purple-500\" },\n                      ].map((item, i) => (\n                        <div key={i} className=\"flex items-center justify-between p-4 px-6\">\n                          <div className=\"flex items-center gap-3\">\n                            <item.icon className={`h-5 w-5 ${item.color}`} />\n                            <span className=\"text-sm font-medium\">{item.label}</span>\n                          </div>\n                          <span className=\"font-bold\">{item.value}</span>\n                        </div>\n                      ))}\n                    </div>\n                  </CardContent>\n                </Card>\n              </div>\n\n              {/* Recent Achievements */}\n              <Card className=\"border-none shadow-lg\">\n                <CardHeader className=\"flex flex-row items-center justify-between\">\n                  <CardTitle className=\"text-lg flex items-center gap-2\">\n                    <Award className=\"h-5 w-5 text-primary\" />\n                    в•ӘШӘв•ӘВ«в•Әв–’ в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШҙв•ӘШҜв•Әв–“в•ӘШҜв•ӘШІ\n                  </CardTitle>\n                  <Button variant=\"ghost\" size=\"sm\" className=\"rounded-xl\">в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в”ҳГўв”ҳВ„</Button>\n                </CardHeader>\n                <CardContent>\n                  {user.achievements.length > 0 ? (\n                    <div className=\"grid gap-4 sm:grid-cols-2 lg:grid-cols-3\">\n                      {user.achievements.map((item) => (\n                        <div key={item.id} className=\"flex items-center gap-4 p-4 rounded-2xl bg-muted/30 border border-transparent hover:border-primary/20 hover:bg-muted/50 transition-all\">\n                          <div className=\"flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-primary/10 text-primary shadow-inner\">\n                            <Trophy className=\"h-6 w-6\" />\n                          </div>\n                          <div className=\"flex-1 min-w-0\">\n                            <p className=\"font-bold text-sm truncate\">{item.achievement.title}</p>\n                            <p className=\"text-xs text-primary font-medium\">+{item.achievement.xpReward} XP</p>\n                            <p className=\"text-[10px] text-muted-foreground mt-1\">\n                              {format(new Date(item.earnedAt), \"d MMM yyyy\", { locale: ar })}\n                            </p>\n                          </div>\n                        </div>\n                      ))}\n                    </div>\n                  ) : (\n                    <div className=\"text-center py-10 text-muted-foreground\">\n                      в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в•ӘШӯв”ҳВҶв•ӘШҙв•ӘШҜв•Әв–“в•ӘШҜв•ӘШІ в”ҳГ в•Әв”Ӯв•ӘШҙв”ҳВ„в•ӘШұ в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШҜв”ҳГҜ\n                    </div>\n                  )}\n                </CardContent>\n              </Card>\n            </TabsContent>\n\n            <TabsContent value=\"academic\" className=\"space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-500\">\n              {/* Exam Results */}\n              <Card className=\"border-none shadow-lg\">\n                <CardHeader>\n                  <CardTitle className=\"text-lg flex items-center gap-2\">\n                    <BookOpen className=\"h-5 w-5 text-primary\" />\n                    в”ҳВҶв•ӘШІв•ӘШҜв•ӘШ®в•ӘШҙ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘВ«в•ӘШІв•ӘШ°в•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ«в”ҳГЁв•Әв–’в•ӘШұ\n                  </CardTitle>\n                </CardHeader>\n                <CardContent className=\"p-0\">\n                  <div className=\"overflow-x-auto\">\n                    <table className=\"w-full text-right\">\n                      <thead className=\"bg-muted/50 text-xs font-bold uppercase text-muted-foreground\">\n                        <tr>\n                          <th className=\"px-6 py-4\">в•ӘШҜв”ҳВ„в•ӘШҜв•ӘВ«в•ӘШІв•ӘШ°в•ӘШҜв•Әв–’</th>\n                          <th className=\"px-6 py-4\">в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ</th>\n                          <th className=\"px-6 py-4\">в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ</th>\n                          <th className=\"px-6 py-4 text-center\">в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ</th>\n                          <th className=\"px-6 py-4\">в•ӘШҜв”ҳВ„в•ӘШІв•ӘШҜв•Әв–’в”ҳГЁв•ӘВ«</th>\n                        </tr>\n                      </thead>\n                      <tbody className=\"divide-y\">\n                        {user.examResults.length > 0 ? (\n                          user.examResults.map((result) => (\n                            <tr key={result.id} className=\"hover:bg-muted/30 transition-colors\">\n                              <td className=\"px-6 py-4 font-bold text-sm\">{result.exam.title}</td>\n                              <td className=\"px-6 py-4 text-sm text-muted-foreground\">{result.exam.subject.name}</td>\n                              <td className=\"px-6 py-4\">\n                                <span className={`text-lg font-black ${result.score >= 50 ? 'text-success' : 'text-danger'}`}>\n                                  {result.score}%\n                                </span>\n                              </td>\n                              <td className=\"px-6 py-4 text-center\">\n                                <Badge variant={result.score >= 50 ? \"success\" : \"destructive\"} className=\"rounded-full px-3\">\n                                  {result.score >= 50 ? \"в”ҳВҶв•ӘШҜв•ӘШҙв•ӘШө\" : \"в•Әв–’в•ӘШҜв•Әв”Ӯв•ӘШ°\"}\n                                </Badge>\n                              </td>\n                              <td className=\"px-6 py-4 text-sm text-muted-foreground\">\n                                {format(new Date(result.takenAt), \"d MMM yyyy\", { locale: ar })}\n                              </td>\n                            </tr>\n                          ))\n                        ) : (\n                          <tr>\n                            <td colSpan={5} className=\"px-6 py-10 text-center text-muted-foreground\">\n                              в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в”ҳВҶв•ӘШІв•ӘШҜв•ӘШ®в•ӘШҙ в•ӘШҜв•ӘВ«в•ӘШІв•ӘШ°в•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ в”ҳГ в•Әв”Ӯв•ӘШҙв”ҳВ„в•ӘШұ в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШҜв”ҳГҜ\n                            </td>\n                          </tr>\n                        )}\n                      </tbody>\n                    </table>\n                  </div>\n                </CardContent>\n              </Card>\n\n              {/* Study Info */}\n              <div className=\"grid gap-8 md:grid-cols-2\">\n                <Card className=\"border-none shadow-lg\">\n                  <CardHeader>\n                    <CardTitle className=\"text-lg\">в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Јв”ҳВ„в”ҳГЁв”ҳГ </CardTitle>\n                  </CardHeader>\n                  <CardContent className=\"space-y-4\">\n                    <div className=\"grid grid-cols-2 gap-4\">\n                      <div className=\"bg-muted/30 p-4 rounded-2xl\">\n                        <p className=\"text-xs text-muted-foreground mb-1\">в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в•ӘШөв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв”ҳГЁв•ӘШұ</p>\n                        <p className=\"font-bold\">{gradeLabels[user.gradeLevel || \"\"] || user.gradeLevel || \"в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШөв•ӘВ»в•ӘВ»\"}</p>\n                      </div>\n                      <div className=\"bg-muted/30 p-4 rounded-2xl\">\n                        <p className=\"text-xs text-muted-foreground mb-1\">в”ҳВҶв”ҳГӘв•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Јв”ҳВ„в”ҳГЁв”ҳГ </p>\n                        <p className=\"font-bold\">{user.educationType || \"в•Әв•Јв•ӘШҜв”ҳГ \"}</p>\n                      </div>\n                      <div className=\"bg-muted/30 p-4 rounded-2xl\">\n                        <p className=\"text-xs text-muted-foreground mb-1\">в•ӘШҜв”ҳВ„в•Әв”Өв•Әв•Јв•ӘШ°в•ӘШұ</p>\n                        <p className=\"font-bold\">{user.section || \"в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШөв•ӘВ»в•ӘВ»\"}</p>\n                      </div>\n                      <div className=\"bg-muted/30 p-4 rounded-2xl\">\n                        <p className=\"text-xs text-muted-foreground mb-1\">в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯв•ӘШұ</p>\n                        <p className=\"font-bold truncate\" title={user.school || \"\"}>{user.school || \"в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШөв•ӘВ»в•ӘВ»\"}</p>\n                      </div>\n                    </div>\n                  </CardContent>\n                </Card>\n\n                <Card className=\"border-none shadow-lg\">\n                  <CardHeader>\n                    <CardTitle className=\"text-lg\">в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘШҜв•ӘВ» в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШІв”ҳГ  в•ӘШ°в”ҳГ§в•ӘШҜ</CardTitle>\n                  </CardHeader>\n                  <CardContent>\n                    <div className=\"flex flex-wrap gap-2\">\n                      {user.interestedSubjects.length > 0 ? (\n                        user.interestedSubjects.map((subject, i) => (\n                          <Badge key={i} variant=\"outline\" className=\"px-4 py-1.5 rounded-xl border-primary/20 bg-primary/5 text-primary\">\n                            {subject}\n                          </Badge>\n                        ))\n                      ) : (\n                        <p className=\"text-muted-foreground italic text-sm\">в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в”ҳГ в”ҳГӘв•ӘШҜв•ӘВ» в”ҳГ в•ӘВ«в•ӘШІв•ӘШҜв•Әв–’в•ӘШұ</p>\n                      )}\n                    </div>\n                    {user.studyGoal && (\n                      <div className=\"mt-6 p-4 rounded-2xl bg-muted/30\">\n                        <p className=\"text-xs text-muted-foreground mb-1\">в”ҳГ§в•ӘВ»в”ҳВҒ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв•ӘШұ</p>\n                        <p className=\"text-sm italic font-medium\">\"{user.studyGoal}\"</p>\n                      </div>\n                    )}\n                  </CardContent>\n                </Card>\n              </div>\n            </TabsContent>\n\n            <TabsContent value=\"activity\" className=\"space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-500\">\n               {/* Recent Study Sessions */}\n               <Card className=\"border-none shadow-lg\">\n                <CardHeader>\n                  <CardTitle className=\"text-lg flex items-center gap-2\">\n                    <History className=\"h-5 w-5 text-primary\" />\n                    в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–‘в•ӘШҜв”ҳГўв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ«в”ҳГЁв•Әв–’в•ӘШұ\n                  </CardTitle>\n                </CardHeader>\n                <CardContent className=\"p-0\">\n                  <div className=\"divide-y\">\n                    {user.studySessions.length > 0 ? (\n                      user.studySessions.map((session) => (\n                        <div key={session.id} className=\"p-6 flex items-center justify-between hover:bg-muted/30 transition-colors\">\n                          <div className=\"flex items-center gap-4\">\n                            <div className=\"h-12 w-12 rounded-2xl bg-blue-500/10 text-blue-500 flex items-center justify-center\">\n                              <BookOpen className=\"h-6 w-6\" />\n                            </div>\n                            <div>\n                              <p className=\"font-bold\">{session.subject?.name || \"в”ҳГ в•Әв–‘в•ӘШҜв”ҳГўв•Әв–’в•ӘШұ в•Әв•Јв•ӘШҜв”ҳГ в•ӘШұ\"}</p>\n                              <p className=\"text-sm text-muted-foreground\">\n                                {format(new Date(session.startTime), \"d MMMM yyyy HH:mm\", { locale: ar })}\n                              </p>\n                            </div>\n                          </div>\n                          <div className=\"text-left\">\n                            <div className=\"flex items-center gap-2 mb-1 justify-end\">\n                              <Clock className=\"h-4 w-4 text-muted-foreground\" />\n                              <span className=\"font-bold\">{session.durationMin} в•ӘВ»в”ҳГ©в”ҳГЁв”ҳГ©в•ӘШұ</span>\n                            </div>\n                            <div className=\"flex items-center gap-2 justify-end\">\n                              <span className=\"text-xs text-muted-foreground\">в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•Әв–’в”ҳГўв”ҳГЁв•Әв–“:</span>\n                              <span className={`text-sm font-bold ${session.focusScore >= 80 ? 'text-success' : 'text-warning'}`}>\n                                {session.focusScore}%\n                              </span>\n                            </div>\n                          </div>\n                        </div>\n                      ))\n                    ) : (\n                      <div className=\"text-center py-10 text-muted-foreground\">\n                        в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШҜв•ӘШІ в”ҳГ в•Әв–‘в•ӘШҜв”ҳГўв•Әв–’в•ӘШұ в”ҳГ в•Әв”Ӯв•ӘШҙв”ҳВ„в•ӘШұ\n                      </div>\n                    )}\n                  </div>\n                </CardContent>\n              </Card>\n\n              {/* Login History / Status */}\n              <div className=\"grid gap-8 md:grid-cols-2\">\n                <Card className=\"border-none shadow-lg\">\n                  <CardHeader>\n                    <CardTitle className=\"text-sm font-bold\">в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ° в”ҳГӘв•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ в•ӘШҜв”ҳВҶ</CardTitle>\n                  </CardHeader>\n                  <CardContent className=\"space-y-4\">\n                    <div className=\"flex items-center justify-between p-3 rounded-xl bg-card border\">\n                      <div className=\"flex items-center gap-3\">\n                        {user.emailVerified ? (\n                          <div className=\"h-8 w-8 rounded-full bg-success/10 text-success flex items-center justify-center\">\n                            <CheckCircle className=\"h-4 w-4\" />\n                          </div>\n                        ) : (\n                          <div className=\"h-8 w-8 rounded-full bg-danger/10 text-danger flex items-center justify-center\">\n                            <XCircle className=\"h-4 w-4\" />\n                          </div>\n                        )}\n                        <span className=\"text-sm font-medium\">в•ӘШҜв”ҳВ„в•ӘШ°в•Әв–’в”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВ„в”ҳГўв•ӘШІв•Әв–’в”ҳГӘв”ҳВҶв”ҳГЁ</span>\n                      </div>\n                      <Badge variant={user.emailVerified ? \"success\" : \"destructive\"}>\n                        {user.emailVerified ? \"в”ҳГ в”ҳГӘв•ӘШів”ҳГ©\" : \"в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в”ҳГӘв•ӘШів”ҳГ©\"}\n                      </Badge>\n                    </div>\n\n                    <div className=\"flex items-center justify-between p-3 rounded-xl bg-card border\">\n                      <div className=\"flex items-center gap-3\">\n                        <div className={`h-8 w-8 rounded-full flex items-center justify-center ${user.twoFactorEnabled ? 'bg-success/10 text-success' : 'bg-muted text-muted-foreground'}`}>\n                          <ShieldCheck className=\"h-4 w-4\" />\n                        </div>\n                        <span className=\"text-sm font-medium\">в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в•ӘШҜв”ҳВ„в•ӘШів”ҳВҶв•ӘШҜв•ӘШ®в”ҳГЁ</span>\n                      </div>\n                      <Badge variant={user.twoFactorEnabled ? \"success\" : \"secondary\"}>\n                        {user.twoFactorEnabled ? \"в”ҳГ в”ҳВҒв•Әв•Јв”ҳЩ‘в”ҳВ„\" : \"в”ҳГ в•Әв•Јв•Әв•–в”ҳЩ‘в”ҳВ„\"}\n                      </Badge>\n                    </div>\n\n                    <div className=\"flex items-center justify-between p-3 rounded-xl bg-card border\">\n                      <div className=\"flex items-center gap-3\">\n                        <div className=\"h-8 w-8 rounded-full bg-primary/10 text-primary flex items-center justify-center\">\n                          <Activity className=\"h-4 w-4\" />\n                        </div>\n                        <span className=\"text-sm font-medium\">в•ӘШӘв•ӘВ«в•Әв–’ в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„</span>\n                      </div>\n                      <span className=\"text-sm font-bold\">\n                        {user.lastLogin ? format(new Date(user.lastLogin), \"d MMM yyyy\", { locale: ar }) : \"в”ҳВ„в”ҳГ  в”ҳГЁв•Әв”Ӯв•ӘШ°в”ҳГ©\"}\n                      </span>\n                    </div>\n                  </CardContent>\n                </Card>\n\n                <Card className=\"border-none shadow-lg\">\n                  <CardHeader>\n                    <CardTitle className=\"text-sm font-bold\">в•ӘШӯв•ӘШөв•Әв•Ўв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШҜв•ӘШІ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв”ҳГЁв•ӘШұ</CardTitle>\n                  </CardHeader>\n                  <CardContent className=\"space-y-4\">\n                     <div className=\"flex items-center justify-between\">\n                        <span className=\"text-sm font-medium\">в•Әв•Јв•ӘВ»в•ӘВ» в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҶв•ӘШ°в”ҳГЁв”ҳГ§в•ӘШҜв•ӘШІ</span>\n                        <span className=\"font-bold\">{user._count.notifications}</span>\n                     </div>\n                     <Separator />\n                     <div className=\"flex items-center justify-between\">\n                        <span className=\"text-sm font-medium\">в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШІв”ҳВҶв”ҳВҒв”ҳГЁв•Әв–‘в”ҳГ§в•ӘШҜ</span>\n                        <span className=\"font-bold\">{user._count.customGoals}</span>\n                     </div>\n                     <Separator />\n                     <div className=\"flex items-center justify-between\">\n                        <span className=\"text-sm font-medium\">в•Әв•Јв•ӘВ»в•ӘВ» в•ӘШҜв”ҳВ„в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Өв•Әв•–в•ӘШұ</span>\n                        <span className=\"font-bold\">{user._count.sessions}</span>\n                     </div>\n                  </CardContent>\n                </Card>\n              </div>\n            </TabsContent>\n\n            <TabsContent value=\"settings\" className=\"space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-500\">\n               <Card className=\"border-none shadow-lg\">\n                  <CardHeader>\n                    <CardTitle className=\"text-lg flex items-center gap-2\">\n                       <Shield className=\"h-5 w-5 text-primary\" />\n                       в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ° в”ҳГӘв•ӘШҜв”ҳВ„в•Әв•Ўв”ҳВ„в•ӘШҜв•ӘШөв”ҳГЁв•ӘШҜв•ӘШІ\n                    </CardTitle>\n                    <CardDescription>в•ӘШІв•Әв•Јв•ӘВ»в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’ в”ҳГӘв•ӘШҜв”ҳВ„в•Әв•Ўв”ҳВ„в•ӘШҜв•ӘШөв”ҳГЁв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•ӘШҜв•Әв”Ӯв”ҳГЁв•ӘШұ в”ҳВ„в”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ </CardDescription>\n                  </CardHeader>\n                  <CardContent className=\"space-y-8\">\n                    <div className=\"grid gap-6 md:grid-cols-2\">\n                        <div className=\"space-y-2\">\n                           <label className=\"text-sm font-bold\">в•ӘВ»в”ҳГӘв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ </label>\n                           <Select value={editedUser.role || user.role} onValueChange={(val) => setEditedUser({...editedUser, role: val})}>\n                              <SelectTrigger className=\"h-12 rounded-xl\">\n                                <SelectValue />\n                              </SelectTrigger>\n                              <SelectContent>\n                                <SelectItem value=\"STUDENT\">в•Әв•–в•ӘШҜв”ҳВ„в•ӘШ°</SelectItem>\n                                <SelectItem value=\"TEACHER\">в”ҳГ в•Әв•Јв”ҳВ„в”ҳГ </SelectItem>\n                                <SelectItem value=\"ADMIN\">в”ҳГ в•ӘВ»в”ҳГЁв•Әв–’</SelectItem>\n                                <SelectItem value=\"MODERATOR\">в”ҳГ в•Әв”Өв•Әв–’в”ҳВҒ</SelectItem>\n                              </SelectContent>\n                           </Select>\n                           <p className=\"text-xs text-muted-foreground mt-1\">в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’ в•Әв”Ӯв”ҳГЁв•ӘШ¬в•ӘШів•Әв–’ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•Әв•Ўв”ҳВ„в•ӘШҜв•ӘШөв”ҳГЁв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШІв”ҳГЁ в”ҳГЁв”ҳГ в•ӘШІв”ҳВ„в”ҳГўв”ҳГ§в•ӘШҜ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•Әв•Ўв•ӘШұ.</p>\n                        </div>\n\n                        <div className=\"space-y-2\">\n                            <label className=\"text-sm font-bold\">в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в•ӘШөв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв”ҳГЁв•ӘШұ</label>\n                            <Select value={editedUser.gradeLevel || \"\"} onValueChange={(val) => setEditedUser({...editedUser, gradeLevel: val})}>\n                               <SelectTrigger className=\"h-12 rounded-xl\">\n                                 <SelectValue placeholder=\"в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в•ӘШөв”ҳВ„в•ӘШұ\" />\n                               </SelectTrigger>\n                               <SelectContent>\n                                 <SelectItem value=\"в•ӘШ«в”ҳГӘв”ҳВ„в”ҳГ« в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в”ҳГЁ\">в•ӘШ«в”ҳГӘв”ҳВ„в”ҳГ« в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в”ҳГЁ</SelectItem>\n                                 <SelectItem value=\"в•ӘШів•ӘШҜв”ҳВҶв”ҳГЁв•ӘШұ в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в”ҳГЁ\">в•ӘШів•ӘШҜв”ҳВҶв”ҳГЁв•ӘШұ в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в”ҳГЁ</SelectItem>\n                                 <SelectItem value=\"в•ӘШів•ӘШҜв”ҳВ„в•ӘШів•ӘШұ в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в”ҳГЁ\">в•ӘШів•ӘШҜв”ҳВ„в•ӘШів•ӘШұ в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в”ҳГЁ</SelectItem>\n                                 <SelectItem value=\"в•ӘШ«в”ҳГӘв”ҳВ„в”ҳГ« в•ӘШів•ӘШҜв”ҳВҶв”ҳГӘв”ҳГЁ\">в•ӘШ«в”ҳГӘв”ҳВ„в”ҳГ« в•ӘШів•ӘШҜв”ҳВҶв”ҳГӘв”ҳГЁ</SelectItem>\n                                 <SelectItem value=\"в•ӘШів•ӘШҜв”ҳВҶв”ҳГЁв•ӘШұ в•ӘШів•ӘШҜв”ҳВҶв”ҳГӘв”ҳГЁ\">в•ӘШів•ӘШҜв”ҳВҶв”ҳГЁв•ӘШұ в•ӘШів•ӘШҜв”ҳВҶв”ҳГӘв”ҳГЁ</SelectItem>\n                                 <SelectItem value=\"в•ӘШів•ӘШҜв”ҳВ„в•ӘШів•ӘШұ в•ӘШів•ӘШҜв”ҳВҶв”ҳГӘв”ҳГЁ\">в•ӘШів•ӘШҜв”ҳВ„в•ӘШів•ӘШұ в•ӘШів•ӘШҜв”ҳВҶв”ҳГӘв”ҳГЁ</SelectItem>\n                               </SelectContent>\n                            </Select>\n                        </div>\n                    </div>\n\n                    <Separator />\n\n                    <div className=\"space-y-6\">\n                        <h4 className=\"font-bold text-sm\">в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в”ҳВ„в”ҳВҒ в•ӘШҜв”ҳВ„в•Әв”Өв•ӘВ«в•Әв•Ўв”ҳГЁ</h4>\n                        <div className=\"grid gap-6 md:grid-cols-2\">\n                           <div className=\"space-y-2\">\n                              <label className=\"text-sm font-medium\">в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГўв•ӘШҜв”ҳГ в”ҳВ„</label>\n                              <div className=\"relative\">\n                                 <UserIcon className=\"absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground\" />\n                                 <input \n                                    className=\"w-full h-11 pr-10 rounded-xl border bg-muted/50 px-4 text-sm focus:ring-2 ring-primary/20 outline-none transition-all\"\n                                    value={editedUser.name || \"\"} \n                                    onChange={(e) => setEditedUser({...editedUser, name: e.target.value})}\n                                    placeholder=\"в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГўв•ӘШҜв”ҳГ в”ҳВ„\"\n                                 />\n                              </div>\n                           </div>\n                           <div className=\"space-y-2\">\n                              <label className=\"text-sm font-medium\">в•ӘШҜв”ҳВ„в•ӘШ°в•Әв–’в”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВ„в”ҳГўв•ӘШІв•Әв–’в”ҳГӘв”ҳВҶв”ҳГЁ</label>\n                              <div className=\"relative\">\n                                 <Mail className=\"absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground\" />\n                                 <input \n                                    className=\"w-full h-11 pr-10 rounded-xl border bg-muted/50 px-4 text-sm focus:ring-2 ring-primary/20 outline-none transition-all\"\n                                    value={editedUser.email || \"\"} \n                                    onChange={(e) => setEditedUser({...editedUser, email: e.target.value})}\n                                    placeholder=\"в•ӘШҜв”ҳВ„в•ӘШ°в•Әв–’в”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВ„в”ҳГўв•ӘШІв•Әв–’в”ҳГӘв”ҳВҶв”ҳГЁ\"\n                                 />\n                              </div>\n                           </div>\n                           <div className=\"space-y-2\">\n                              <label className=\"text-sm font-medium\">в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ </label>\n                              <div className=\"relative\">\n                                 <Hash className=\"absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground\" />\n                                 <input \n                                    className=\"w-full h-11 pr-10 rounded-xl border bg-muted/50 px-4 text-sm focus:ring-2 ring-primary/20 outline-none transition-all\"\n                                    value={editedUser.username || \"\"} \n                                    onChange={(e) => setEditedUser({...editedUser, username: e.target.value})}\n                                    placeholder=\"в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ \"\n                                 />\n                              </div>\n                           </div>\n                           <div className=\"space-y-2\">\n                              <label className=\"text-sm font-medium\">в•Әв–’в”ҳГ©в”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ§в•ӘШҜв•ӘШІв”ҳВҒ</label>\n                              <div className=\"relative\">\n                                 <Phone className=\"absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground\" />\n                                 <input \n                                    className=\"w-full h-11 pr-10 rounded-xl border bg-muted/50 px-4 text-sm focus:ring-2 ring-primary/20 outline-none transition-all\"\n                                    value={editedUser.phone || \"\"} \n                                    onChange={(e) => setEditedUser({...editedUser, phone: e.target.value})}\n                                    placeholder=\"в•Әв–’в”ҳГ©в”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ§в•ӘШҜв•ӘШІв”ҳВҒ\"\n                                 />\n                              </div>\n                           </div>\n                           <div className=\"space-y-2\">\n                              <label className=\"text-sm font-medium\">в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯв•ӘШұ</label>\n                              <div className=\"relative\">\n                                 <School className=\"absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground\" />\n                                 <input \n                                    className=\"w-full h-11 pr-10 rounded-xl border bg-muted/50 px-4 text-sm focus:ring-2 ring-primary/20 outline-none transition-all\"\n                                    value={editedUser.school || \"\"} \n                                    onChange={(e) => setEditedUser({...editedUser, school: e.target.value})}\n                                    placeholder=\"в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯв•ӘШұ\"\n                                 />\n                              </div>\n                           </div>\n                           <div className=\"space-y-2\">\n                              <label className=\"text-sm font-medium\">в”ҳВҶв”ҳГӘв•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Јв”ҳВ„в”ҳГЁв”ҳГ </label>\n                              <Select value={editedUser.educationType || \"\"} onValueChange={(val) => setEditedUser({...editedUser, educationType: val})}>\n                                 <SelectTrigger className=\"h-11 rounded-xl\">\n                                   <SelectValue placeholder=\"в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГӘв•Әв•Ј\" />\n                                 </SelectTrigger>\n                                 <SelectContent>\n                                   <SelectItem value=\"в•Әв•Јв•ӘШҜв”ҳГ \">в•Әв•Јв•ӘШҜв”ҳГ </SelectItem>\n                                   <SelectItem value=\"в•ӘШ«в•Әв–“в”ҳГ§в•Әв–’в”ҳГЁ\">в•ӘШ«в•Әв–“в”ҳГ§в•Әв–’в”ҳГЁ</SelectItem>\n                                   <SelectItem value=\"в•ӘВ»в”ҳГӘв”ҳВ„в”ҳГЁ\">в•ӘВ»в”ҳГӘв”ҳВ„в”ҳГЁ</SelectItem>\n                                   <SelectItem value=\"IG\">IG</SelectItem>\n                                   <SelectItem value=\"American\">American</SelectItem>\n                                   <SelectItem value=\"в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ«\">в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ«</SelectItem>\n                                 </SelectContent>\n                              </Select>\n                           </div>\n                           <div className=\"space-y-2 md:col-span-2\">\n                              <label className=\"text-sm font-medium\">в”ҳВҶв•ӘШ°в•Әв–‘в•ӘШұ в•ӘШІв•Әв•Јв•Әв–’в”ҳГЁв”ҳВҒв”ҳГЁв•ӘШұ (Bio)</label>\n                              <textarea \n                                 className=\"w-full h-24 rounded-xl border bg-muted/50 p-4 text-sm focus:ring-2 ring-primary/20 outline-none transition-all resize-none\"\n                                 value={editedUser.bio || \"\"} \n                                 onChange={(e) => setEditedUser({...editedUser, bio: e.target.value})}\n                                 placeholder=\"в•ӘШҜв”ҳГўв•ӘШІв•ӘШ° в”ҳВҶв•ӘШ°в•Әв–‘в•ӘШұ в•Әв•Јв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ ...\"\n                              />\n                           </div>\n                        </div>\n\n                        <div className=\"flex justify-start gap-3 pt-4\">\n                           <Button \n                              className=\"rounded-xl px-8 shadow-lg shadow-primary/20\" \n                              onClick={handleUpdate}\n                           >\n                              <Save className=\"ml-2 h-4 w-4\" />\n                              в•ӘШөв”ҳВҒв•Әв•• в•ӘШҜв”ҳВ„в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’в•ӘШҜв•ӘШІ\n                           </Button>\n                           <Button \n                              variant=\"ghost\" \n                              className=\"rounded-xl\"\n                              onClick={() => {\n                                setIsEditing(false);\n                                setEditedUser(user);\n                              }}\n                           >\n                              в•ӘШӯв”ҳВ„в•Әв•‘в•ӘШҜв•ӘШ©\n                           </Button>\n                        </div>\n                    </div>\n                  </CardContent>\n               </Card>\n            </TabsContent>\n          </Tabs>\n        </div>\n      </div>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(admin)\\admin\\users\\[id]\\permissions\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(admin)\\admin\\users\\create\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(admin)\\admin\\users\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(admin)\\admin\\users\\permissions\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(admin)\\coupons\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(admin)\\revenue\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(auth)\\admin-login\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(auth)\\forgot-password\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(auth)\\layout.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(auth)\\login\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'err' is defined but never used. Allowed unused caught errors must match /^_/u.","line":116,"column":14,"nodeType":"Identifier","messageId":"unusedVar","endLine":116,"endColumn":17},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'err' is defined but never used. Allowed unused caught errors must match /^_/u.","line":146,"column":14,"nodeType":"Identifier","messageId":"unusedVar","endLine":146,"endColumn":17}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"ЩҠв•—в”җ\"use client\";\n\nimport { useCallback, useEffect, useMemo, useState } from 'react';\nimport { useForm } from 'react-hook-form';\nimport { zodResolver } from '@hookform/resolvers/zod';\nimport { z } from 'zod';\nimport { useRouter, useSearchParams } from 'next/navigation';\nimport { \n  Mail, \n  Lock, \n  Loader2, \n  AlertCircle, \n  ArrowRight, \n  Eye, \n  EyeOff, \n  Github, \n  Chrome, \n  Wand2,\n  Shield,\n  Zap,\n  Bot,\n  Sparkles,\n  KeyRound\n} from 'lucide-react';\nimport Link from 'next/link';\nimport { motion, AnimatePresence } from 'framer-motion';\nimport { useAuth } from '@/contexts/auth-context';\nimport { Button } from '@/components/ui/button';\nimport {\n  DEFAULT_AUTHENTICATED_ROUTE,\n  sanitizeRedirectPath,\n} from '@/services/auth/navigation';\nimport { Suspense } from 'react';\nimport { toast } from 'sonner';\n\nconst loginSchema = z.object({\n  email: z.string().trim().email('в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШӯв•ӘВ»в•ӘВ«в•ӘШҜв”ҳВ„ в•ӘШ°в•Әв–’в”ҳГЁв•ӘВ» в•ӘШӯв”ҳВ„в”ҳГўв•ӘШІв•Әв–’в”ҳГӘв”ҳВҶв”ҳГЁ в•Әв•Ўв•ӘШөв”ҳГЁв•ӘШө'),\n  password: z.string().min(1, 'в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в”ҳГ в•Әв•–в”ҳВ„в”ҳГӘв•ӘШ°в•ӘШұ').optional().or(z.literal('')),\n  rememberMe: z.boolean().optional(),\n});\n\ntype LoginFormValues = z.infer<typeof loginSchema>;\n\nfunction LoginForm() {\n  const router = useRouter();\n  const searchParams = useSearchParams();\n  const { login, isAuthenticated, isLoading: isAuthLoading } = useAuth();\n  const [errorStatus, setErrorStatus] = useState<string | null>(null);\n  const [isSubmitting, setIsSubmitting] = useState(false);\n  const [showPassword, setShowPassword] = useState(false);\n  const [loginMode, setLoginMode] = useState<'password' | 'magic-link'>('password');\n  const [requires2FA, setRequires2FA] = useState(false);\n  const [userId2FA, setUserId2FA] = useState<string | null>(null);\n  const [twoFactorCode, setTwoFactorCode] = useState('');\n  const { verify2FA } = useAuth();\n\n  const redirectUrl = useMemo(\n    () => sanitizeRedirectPath(searchParams.get('redirect'), DEFAULT_AUTHENTICATED_ROUTE),\n    [searchParams]\n  );\n\n  const {\n    register,\n    handleSubmit,\n    getValues,\n    formState: { errors },\n    trigger,\n  } = useForm<LoginFormValues>({\n    resolver: zodResolver(loginSchema),\n    defaultValues: { rememberMe: false },\n  });\n\n  const redirectAfterLogin = useCallback((target: string) => {\n    router.replace(target);\n    router.refresh();\n  }, [router]);\n\n  useEffect(() => {\n    if (!isAuthLoading && isAuthenticated) {\n      redirectAfterLogin(redirectUrl);\n    }\n  }, [isAuthLoading, isAuthenticated, redirectAfterLogin, redirectUrl]);\n\n  const onSubmit = async (data: LoginFormValues) => {\n    if (isAuthLoading || isAuthenticated) return;\n    \n    if (loginMode === 'magic-link') {\n      handleMagicLinkRequest();\n      return;\n    }\n\n    setIsSubmitting(true);\n    setErrorStatus(null);\n\n    try {\n      const result = await login(\n        data.email.trim().toLowerCase(),\n        data.password || '',\n        data.rememberMe ?? false\n      );\n\n      if (result.success) {\n        if (result.requires2FA) {\n          toast.success('в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШөв•ӘГ® в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШӯв•ӘВ»в•ӘВ«в•ӘШҜв”ҳВ„ в•Әв–’в”ҳГ в•Әв–“ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в•ӘШҜв”ҳВ„в”ҳГ в•Әв–“в•ӘВ»в”ҳГӘв•ӘШҙ');\n          setRequires2FA(true);\n          setUserId2FA(result.userId || null);\n          return;\n        }\n        toast.success('в•ӘШІв”ҳГ  в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө! в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШІв”ҳГӘв•ӘШҙв”ҳГЁв”ҳГ§в”ҳГў...');\n        redirectAfterLogin(redirectUrl);\n        return;\n      }\n      \n      setErrorStatus(result.error || 'в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ«.');\n      toast.error(result.error || 'в•ӘВ«в•Әв•–в•ӘШ« в”ҳВҒв”ҳГЁ в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„');\n    } catch (err) {\n      toast.error('в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШІв”ҳГӘв”ҳГ©в•Әв•Ј');\n    } finally {\n      setIsSubmitting(false);\n    }\n  };\n\n  const handleMagicLinkRequest = async () => {\n    const emailValid = await trigger('email');\n    if (!emailValid) return;\n\n    setIsSubmitting(true);\n    setErrorStatus(null);\n\n    try {\n      const email = getValues('email');\n      const res = await fetch('/api/auth/magic-link/request', {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({ email }),\n      });\n\n      const data = await res.json();\n      if (res.ok && data.success) {\n        toast.success('в•ӘШІв”ҳГ  в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„ в•Әв–’в•ӘШҜв•ӘШ°в•Әв•– в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв”Ӯв•ӘШөв•Әв–’в”ҳГЁ в•ӘШӯв”ҳВ„в”ҳГ« в•ӘШ°в•Әв–’в”ҳГЁв•ӘВ»в”ҳГў в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВ„в”ҳГўв•ӘШІв•Әв–’в”ҳГӘв”ҳВҶв”ҳГЁ');\n        setErrorStatus('в•ӘШІв”ҳГ  в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҜв•ӘШ°в•Әв•–! в•ӘШІв”ҳВҒв”ҳГ©в•ӘВ» в•ӘШ°в•Әв–’в”ҳГЁв•ӘВ»в”ҳГў в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВ„в”ҳГўв•ӘШІв•Әв–’в”ҳГӘв”ҳВҶв”ҳГЁ (в•ӘШ°в”ҳГ в•ӘШҜ в”ҳВҒв”ҳГЁ в•Әв–‘в”ҳВ„в”ҳГў в•ӘШҜв”ҳВ„в•ӘШ°в•Әв–’в”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в”ҳГ в•Әв–“в•Әв•Јв•ӘШҙ).');\n      } else {\n        setErrorStatus(data.error || 'в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„ в•Әв–’в•ӘШҜв•ӘШ°в•Әв•– в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„.');\n        toast.error(data.error || 'в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•Әв•–в”ҳВ„в•ӘШ° в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҜв•ӘШ°в•Әв•–');\n      }\n    } catch (err) {\n      toast.error('в•ӘВ«в•Әв•–в•ӘШ« в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„ в•ӘШ°в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШҜв•ӘВ»в”ҳГ ');\n    } finally {\n      setIsSubmitting(false);\n    }\n  };\n\n  const onVerify2FA = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!userId2FA || twoFactorCode.length < 6) return;\n    \n    setIsSubmitting(true);\n    setErrorStatus(null);\n    try {\n      const result = await verify2FA(userId2FA, twoFactorCode, getValues('rememberMe'));\n      if (result.success) {\n        toast.success('в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө! в”ҳГ в•Әв–’в•ӘШөв•ӘШ°в•ӘШҜв”ҳГҜ в•ӘШ°в”ҳГў.');\n        redirectAfterLogin(redirectUrl);\n        return;\n      }\n      setErrorStatus(result.error || 'в•Әв–’в”ҳГ в•Әв–“ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в•Әв•‘в”ҳГЁв•Әв–’ в•Әв•Ўв•ӘШөв”ҳГЁв•ӘШө');\n      toast.error(result.error || 'в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ©');\n    } finally {\n      setIsSubmitting(false);\n    }\n  };\n\n  if (isAuthLoading || isAuthenticated) {\n    return (\n      <div className=\"flex min-h-screen flex-col items-center justify-center space-y-6 text-center bg-black\">\n        <div className=\"relative h-24 w-24\">\n          <motion.div \n            animate={{ rotate: 360 }}\n            transition={{ duration: 4, repeat: Infinity, ease: \"linear\" }}\n            className=\"absolute inset-0 rounded-full border-2 border-primary/20 border-t-primary shadow-[0_0_20px_rgba(var(--primary),0.3)]\" \n          />\n          <div className=\"flex h-full w-full items-center justify-center rounded-full bg-primary/5 backdrop-blur-sm\">\n             <Bot className=\"h-12 w-12 text-primary\" />\n          </div>\n        </div>\n        <div className=\"space-y-2\">\n          <p className=\"animate-pulse text-sm font-black uppercase tracking-[0.3em] text-primary\">в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ»в•Әв•Јв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ...</p>\n          <p className=\"text-gray-500 text-xs font-medium\">в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в”ҳГ в”ҳВҶ в•Әв•Ўв”ҳВ„в•ӘШҜв•ӘШөв”ҳГЁв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳВ„в”ҳВ„в”ҳГ в”ҳГ в”ҳВ„в”ҳГўв•ӘШұ</p>\n        </div>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"relative min-h-screen w-full flex items-center justify-center p-4 bg-black overflow-hidden\" dir=\"rtl\">\n      {/* Dynamic Background Elements */}\n      <div className=\"absolute top-[-10%] right-[-10%] w-[500px] h-[500px] bg-primary/20 blur-[120px] rounded-full animate-pulse\" />\n      <div className=\"absolute bottom-[-10%] left-[-10%] w-[400px] h-[400px] bg-blue-600/10 blur-[120px] rounded-full\" />\n      \n      <div className=\"absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 pointer-events-none\" />\n\n      <motion.div\n        initial={{ opacity: 0, y: 40 }}\n        animate={{ opacity: 1, y: 0 }}\n        transition={{ duration: 0.8, ease: [0.16, 1, 0.3, 1] }}\n        className=\"relative w-full max-w-[500px] overflow-hidden rounded-[2.5rem] border border-white/10 bg-white/5 p-8 md:p-12 backdrop-blur-2xl shadow-[0_20px_80px_rgba(0,0,0,0.6)]\"\n      >\n        {/* Glow Border Effect */}\n        <div className=\"absolute inset-0 pointer-events-none border border-white/5 rounded-[2.5rem]\" />\n        \n        <div className=\"mb-10 text-center space-y-4\">\n           <motion.div \n             whileHover={{ scale: 1.05, rotate: 5 }}\n             className=\"mx-auto w-20 h-20 rounded-2xl bg-gradient-to-br from-primary/20 to-primary/5 border border-primary/30 flex items-center justify-center mb-6 shadow-[0_0_30px_rgba(var(--primary),0.2)]\"\n           >\n              <Shield className=\"w-10 h-10 text-primary drop-shadow-[0_0_8px_rgba(var(--primary),0.8)]\" />\n           </motion.div>\n           <h2 className=\"text-4xl font-black text-white tracking-tight leading-tight\">\n             в•ӘШ°в”ҳГӘв•ӘШҜв•ӘШ°в”ҳВҖв•ӘШұ <span className=\"text-transparent bg-clip-text bg-gradient-to-r from-primary to-blue-400\">в•ӘШІв”ҳВҖв”ҳГӘв”ҳВ„в”ҳВҖв”ҳГӘ</span>\n           </h2>\n           <p className=\"text-gray-400 font-medium\">в•ӘВ«в•Әв•–в”ҳГӘв•ӘШІв”ҳГў в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГӘв”ҳВ„в”ҳГ« в”ҳВҶв•ӘШөв”ҳГӘ в•ӘШҜв”ҳВ„в•Әв•Јв•Әв••в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв”ҳГЁв•ӘШұ</p>\n        </div>\n\n        {/* Auth Selection */}\n        <div className=\"mb-8 grid grid-cols-2 gap-4\">\n          <motion.button\n            whileHover={{ y: -2 }}\n            whileTap={{ scale: 0.98 }}\n            onClick={() => { window.location.href = `/api/auth/oauth/google`; }}\n            className=\"flex items-center justify-center gap-3 rounded-2xl border border-white/10 bg-white/5 h-14 transition-all hover:bg-white/10 hover:border-primary/40 group\"\n          >\n            <Chrome className=\"h-5 w-5 text-red-500\" />\n            <span className=\"text-[10px] font-black uppercase tracking-widest text-white\">Google</span>\n          </motion.button>\n          <motion.button\n            whileHover={{ y: -2 }}\n            whileTap={{ scale: 0.98 }}\n            onClick={() => { window.location.href = `/api/auth/oauth/github`; }}\n            className=\"flex items-center justify-center gap-3 rounded-2xl border border-white/10 bg-white/5 h-14 transition-all hover:bg-white/10 hover:border-primary/40 group\"\n          >\n            <Github className=\"h-5 w-5 text-white\" />\n            <span className=\"text-[10px] font-black uppercase tracking-widest text-white\">Github</span>\n          </motion.button>\n        </div>\n\n        <div className=\"relative mb-8 flex items-center justify-center\">\n          <div className=\"absolute inset-x-0 h-px bg-white/5\" />\n          <span className=\"relative bg-[#0a0a0a] px-4 text-[9px] font-black uppercase tracking-[0.2em] text-gray-500\">в•ӘШ«в”ҳГӘ в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в•ӘШҜв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Јв•Әв–’в”ҳВҒ в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВ„в”ҳГўв•ӘШІв•Әв–’в”ҳГӘв”ҳВҶв”ҳГЁ</span>\n        </div>\n\n        <AnimatePresence mode=\"wait\">\n          {errorStatus && (\n            <motion.div\n              initial={{ opacity: 0, height: 0 }}\n              animate={{ opacity: 1, height: 'auto' }}\n              exit={{ opacity: 0, height: 0 }}\n              className=\"mb-6 overflow-hidden\"\n            >\n              <div className=\"p-4 rounded-2xl bg-red-500/10 border border-red-500/20 text-red-400 text-sm font-bold flex items-start gap-3\">\n                <AlertCircle className=\"h-5 w-5 shrink-0 mt-0.5\" />\n                <div className=\"flex-1\">\n                  <p>{errorStatus}</p>\n                  {errorStatus.includes('в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„') && (\n                    <button\n                      type=\"button\"\n                      onClick={async () => {\n                        const email = getValues('email');\n                        if (!email) {\n                          toast.error('в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШӯв•ӘВ»в•ӘВ«в•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ°в•Әв–’в”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВ„в”ҳГўв•ӘШІв•Әв–’в”ҳГӘв”ҳВҶв”ҳГЁ в•ӘШ«в”ҳГӘв”ҳВ„в•ӘШҜв”ҳГҜ');\n                          return;\n                        }\n                        const promise = fetch('/api/auth/resend-verification', {\n                          method: 'POST',\n                          headers: { 'Content-Type': 'application/json' },\n                          body: JSON.stringify({ email }),\n                        });\n                        \n                        toast.promise(promise, {\n                          loading: 'в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„ в•Әв–’в•ӘШҜв•ӘШ°в•Әв•– в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„...',\n                          success: 'в•ӘШІв”ҳГ  в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҜв•ӘШ°в•Әв•– в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө!',\n                          error: 'в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҜв•ӘШ°в•Әв•–. в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„ в”ҳВ„в•ӘШҜв•ӘШөв”ҳГ©в•ӘШҜв”ҳГҜ.'\n                        });\n                      }}\n                      className=\"mt-2 text-[10px] font-black underline uppercase tracking-widest text-primary/80 hover:text-primary\"\n                    >\n                      в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҜв•ӘШ°в•Әв•–\n                    </button>\n                  )}\n                </div>\n              </div>\n            </motion.div>\n          )}\n        </AnimatePresence>\n\n        <div className=\"space-y-6\">\n          {!requires2FA ? (\n            <motion.form \n              layout\n              onSubmit={handleSubmit(onSubmit)} \n              className=\"space-y-6\"\n            >\n              <div className=\"space-y-2\">\n                <label className=\"text-[10px] font-black uppercase text-gray-500 tracking-widest mr-1\">в•ӘШҜв”ҳВ„в•ӘШ°в•Әв–’в”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВ„в”ҳГўв•ӘШІв•Әв–’в”ҳГӘв”ҳВҶв”ҳГЁ</label>\n                <div className=\"group relative\">\n                   <div className=\"absolute right-4 top-1/2 -translate-y-1/2 h-5 w-5 text-gray-500 group-focus-within:text-primary transition-colors flex items-center justify-center\">\n                     <Mail size={18} />\n                   </div>\n                   <input\n                     {...register('email')}\n                     type=\"email\"\n                     autoComplete=\"email\"\n                     className=\"w-full h-14 rounded-2xl bg-white/5 border border-white/10 pr-12 pl-6 text-white text-sm font-bold outline-none ring-primary/20 transition-all focus:border-primary/50 focus:bg-white/10\"\n                     placeholder=\"warrior@thanawy.me\"\n                   />\n                </div>\n                {errors.email && <p className=\"mr-1 text-[10px] font-bold text-red-500 uppercase tracking-tight\">{errors.email.message}</p>}\n              </div>\n\n              <AnimatePresence mode=\"wait\">\n                {loginMode === 'password' && (\n                  <motion.div \n                    key=\"password-field\"\n                    initial={{ opacity: 0, height: 0, y: -20 }}\n                    animate={{ opacity: 1, height: 'auto', y: 0 }}\n                    exit={{ opacity: 0, height: 0, y: -20 }}\n                    className=\"space-y-2\"\n                  >\n                    <div className=\"mr-1 flex items-center justify-between\">\n                      <label className=\"text-[10px] font-black uppercase text-gray-500 tracking-widest\">в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’</label>\n                      <Link href=\"/forgot-password\" disable-nav=\"true\" className=\"text-[10px] font-black text-primary/60 hover:text-primary transition-colors uppercase tracking-widest\">в”ҳВҶв•Әв”Ӯв”ҳГЁв•ӘШІв•ӘШ§</Link>\n                    </div>\n                    <div className=\"group relative\">\n                      <div className=\"absolute right-4 top-1/2 -translate-y-1/2 h-5 w-5 text-gray-500 group-focus-within:text-primary transition-colors flex items-center justify-center\">\n                        <Lock size={18} />\n                      </div>\n                      <input\n                        {...register('password')}\n                        type={showPassword ? 'text' : 'password'}\n                        autoComplete=\"current-password\"\n                        className=\"w-full h-14 rounded-2xl bg-white/5 border border-white/10 pr-12 pl-12 text-white text-sm font-bold outline-none ring-primary/20 transition-all focus:border-primary/50 focus:bg-white/10\"\n                        placeholder=\"ШёШҙШӘШёШҙШӘШёШҙШӘШёШҙШӘШёШҙШӘШёШҙШӘШёШҙШӘШёШҙШӘ\"\n                      />\n                      <button\n                        type=\"button\"\n                        onClick={() => setShowPassword(!showPassword)}\n                        className=\"absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 hover:text-white transition-colors p-2\"\n                      >\n                        {showPassword ? <EyeOff size={16} /> : <Eye size={16} />}\n                      </button>\n                    </div>\n                    {errors.password && <p className=\"mr-1 text-[10px] font-bold text-red-500 uppercase tracking-tight\">{errors.password.message}</p>}\n                  </motion.div>\n                )}\n              </AnimatePresence>\n\n              <div className=\"flex items-center justify-between px-1\">\n                 <div className=\"flex items-center gap-3 cursor-pointer group\">\n                   <div className=\"relative flex items-center\">\n                      <input\n                        {...register('rememberMe')}\n                        type=\"checkbox\"\n                        id=\"rememberMe\"\n                        className=\"h-4 w-4 appearance-none rounded-md border border-white/20 bg-white/5 checked:bg-primary checked:border-primary transition-all cursor-pointer\"\n                      />\n                      <div className=\"absolute inset-0 flex items-center justify-center pointer-events-none opacity-0 peer-checked:opacity-100\">\n                        <svg className=\"h-3 w-3 text-black\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth=\"4\" d=\"M5 13l4 4L19 7\"></path></svg>\n                      </div>\n                   </div>\n                   <label htmlFor=\"rememberMe\" className=\"text-[10px] font-bold text-gray-500 group-hover:text-gray-300 transition-colors cursor-pointer uppercase tracking-widest\">в•ӘШІв•Әв–‘в”ҳГўв•Әв–’в”ҳВҶв”ҳГЁ</label>\n                 </div>\n                 \n                 <button\n                   type=\"button\"\n                   onClick={() => setLoginMode(loginMode === 'password' ? 'magic-link' : 'password')}\n                   className=\"flex items-center gap-2 text-[10px] font-black text-primary/60 hover:text-primary transition-all uppercase tracking-widest group\"\n                 >\n                   {loginMode === 'password' ? (\n                     <>\n                        <Wand2 className=\"h-3 w-3 group-hover:rotate-12 transition-transform\" />\n                        <span>в•Әв–’в•ӘШҜв•ӘШ°в•Әв•– в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв”Ӯв•Әв–’в”ҳГЁв•Әв•Ј</span>\n                     </>\n                   ) : (\n                     <>\n                        <KeyRound className=\"h-3 w-3\" />\n                        <span>в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВҖв•Әв–’</span>\n                     </>\n                   )}\n                 </button>\n              </div>\n\n              <motion.div whileHover={{ scale: 1.01 }} whileTap={{ scale: 0.99 }}>\n                <Button\n                  type=\"submit\"\n                  disabled={isSubmitting}\n                  className=\"h-14 w-full rounded-2xl bg-primary text-black font-black text-md overflow-hidden relative group hover:shadow-[0_0_30px_rgba(var(--primary),0.3)] transition-all\"\n                >\n                  <div className=\"absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity\" />\n                  {isSubmitting ? (\n                    <Loader2 className=\"h-5 w-5 animate-spin mx-auto\" />\n                  ) : (\n                    <div className=\"flex items-center justify-center gap-3\">\n                      <span className=\"uppercase tracking-[0.2em]\">\n                        {loginMode === 'password' ? 'в•ӘШІв•ӘШ«в”ҳГўв”ҳГЁв”ҳВҖв•ӘВ» в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳВҖв”ҳГӘв”ҳВ„' : 'в•ӘШӯв•Әв–’в•Әв”Ӯв”ҳВҖв•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҜв•ӘШ°в”ҳВҖв•Әв•–'}\n                      </span>\n                      <ArrowRight className=\"h-4 w-4 rotate-180 group-hover:-translate-x-1 transition-transform\" />\n                    </div>\n                  )}\n                </Button>\n              </motion.div>\n            </motion.form>\n          ) : (\n            <motion.form\n              initial={{ opacity: 0, x: 20 }}\n              animate={{ opacity: 1, x: 0 }}\n              onSubmit={onVerify2FA}\n              className=\"space-y-8\"\n            >\n              <div className=\"text-center space-y-4\">\n                 <div className=\"mx-auto h-20 w-20 rounded-3xl bg-primary/10 border border-primary/20 flex items-center justify-center relative\">\n                    <div className=\"absolute inset-0 animate-ping rounded-3xl bg-primary/5\" />\n                    <Zap className=\"h-10 w-10 text-primary\" />\n                 </div>\n                 <h3 className=\"text-2xl font-black text-white uppercase tracking-tight\">в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҖв•Әв–“в•ӘВ»в”ҳГӘв•ӘШҙ</h3>\n                 <p className=\"text-sm text-gray-500 font-medium\">в•ӘШ«в•ӘВ»в•ӘВ«в”ҳВ„ в•Әв–’в”ҳГ в•Әв–“ в•ӘШҜв”ҳВ„в•ӘШөв”ҳГ в•ӘШҜв”ҳГЁв•ӘШұ в”ҳГ в”ҳВҶ в•ӘШІв•Әв•–в•ӘШ°в”ҳГЁв”ҳГ© в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Ўв•ӘШҜв•ӘВ»в”ҳГ©в•ӘШұ</p>\n              </div>\n\n              <div className=\"flex justify-center flex-row-reverse gap-3\">\n                <input\n                  type=\"text\"\n                  maxLength={6}\n                  value={twoFactorCode}\n                  onChange={(e) => setTwoFactorCode(e.target.value.replace(/[^0-9]/g, ''))}\n                  className=\"w-full h-20 text-center text-5xl font-black tracking-[0.6em] rounded-3xl bg-white/5 border border-white/10 text-primary outline-none transition-all focus:border-primary/50 focus:bg-white/10\"\n                  placeholder=\"000000\"\n                  autoFocus\n                />\n              </div>\n\n              <div className=\"space-y-4\">\n                <Button\n                  type=\"submit\"\n                  disabled={isSubmitting || twoFactorCode.length < 6}\n                  className=\"h-14 w-full rounded-2xl bg-primary text-black font-black text-md shadow-xl group\"\n                >\n                  {isSubmitting ? <Loader2 className=\"h-5 w-5 animate-spin mx-auto\" /> : \"в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в”ҳГӘв•ӘШӘв•ӘВ«в•ӘШІв•Әв–’в”ҳГ©\"}\n                </Button>\n\n                <button\n                  type=\"button\"\n                  onClick={() => setRequires2FA(false)}\n                  className=\"w-full text-[10px] font-black text-gray-500 hover:text-white transition-colors uppercase tracking-[0.2em]\"\n                >\n                  в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГӘв•ӘВ»в•ӘШұ в”ҳВ„в”ҳВ„в•ӘВ«в”ҳВ„в”ҳВҒ\n                </button>\n              </div>\n            </motion.form>\n          )}\n        </div>\n\n        <div className=\"mt-12 text-center\">\n          <p className=\"text-xs font-bold text-gray-500 uppercase tracking-widest\">\n            в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГ в•ӘШІв”ҳВ„в”ҳГў в•ӘВ»в•Әв•Јв”ҳВҖв”ҳГӘв•ӘШұв•ӘШ§{' '}\n            <Link href=\"/register\" className=\"font-black text-white hover:text-primary transition-all border-b border-white/20 hover:border-primary pb-0.5\">\n              в•ӘШҜв”ҳВҶв•Әв”Өв”ҳВҖв•ӘШ® в”ҳГ§в”ҳГӘв”ҳГЁв•ӘШІв”ҳГў в•ӘШҜв”ҳВ„в•ӘШӘв”ҳВҶ\n            </Link>\n          </p>\n        </div>\n        \n        {/* Subtle Bottom Decorations */}\n        <div className=\"mt-8 pt-6 border-t border-white/5 flex items-center justify-between opacity-30\">\n          <Sparkles size={12} className=\"text-primary\" />\n          <span className=\"text-[8px] font-black uppercase tracking-[0.3em] text-gray-500\">Security Rank: Grade A</span>\n          <Sparkles size={12} className=\"text-primary\" />\n        </div>\n      </motion.div>\n    </div>\n  );\n}\n\nexport default function LoginPage() {\n  return (\n    <Suspense fallback={\n      <div className=\"min-h-screen bg-black flex items-center justify-center\">\n        <Loader2 className=\"h-8 w-8 text-primary animate-spin\" />\n      </div>\n    }>\n      <LoginForm />\n    </Suspense>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(auth)\\register\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'ArrowLeft' is defined but never used. Allowed unused vars must match /^_/u.","line":9,"column":30,"nodeType":"Identifier","messageId":"unusedVar","endLine":9,"endColumn":39,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"ArrowLeft"},"fix":{"range":[332,343],"text":""},"desc":"Remove unused variable \"ArrowLeft\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Target' is defined but never used. Allowed unused vars must match /^_/u.","line":10,"column":39,"nodeType":"Identifier","messageId":"unusedVar","endLine":10,"endColumn":45,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Target"},"fix":{"range":[410,418],"text":""},"desc":"Remove unused variable \"Target\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Sparkles' is defined but never used. Allowed unused vars must match /^_/u.","line":10,"column":53,"nodeType":"Identifier","messageId":"unusedVar","endLine":10,"endColumn":61,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Sparkles"},"fix":{"range":[424,434],"text":""},"desc":"Remove unused variable \"