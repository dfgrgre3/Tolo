ationFix: в•ӘШІв•ӘШҙв”ҳГ в”ҳГЁв•Әв•Јв•ӘШұ в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШөв”ҳВ„в”ҳГӘв”ҳВ„ в”ҳВ„в”ҳГ в•Әв”Өв•ӘШҜв”ҳГўв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳВҖ Hydration в•ӘШҜв”ҳВ„в”ҳВҶв•ӘШҜв•ӘШІв•ӘШҙв•ӘШұ в•Әв•Јв”ҳВҶ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШІв•Әв•Ўв”ҳВҒв•ӘШө.\r\n * в•ӘШІв”ҳГ  в•ӘШІв•ӘШөв•Әв”Ӯв”ҳГЁв”ҳВҶв”ҳГ§ в”ҳВ„в”ҳГЁв”ҳГўв”ҳГӘв”ҳВҶ в”ҳВҒв•ӘШҜв•ӘШ®в”ҳГ© в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ»в•ӘШҜв•ӘШ© в”ҳГӘв”ҳВ„в•ӘШҜ в”ҳГЁв•Әв”Ӯв•ӘШ°в•ӘШ° в•ӘШІв•ӘШҙв”ҳГ в•ӘВ» в•ӘШҜв”ҳВ„в”ҳГ в•ӘШІв•Әв•Ўв”ҳВҒв•ӘШө в•Әв•Јв•ӘШ°в•Әв–’ в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в•ӘШҜв”ҳГ  в•ӘШҜв•Әв”Ӯв•ӘШІв”ҳГ§в•ӘВ»в•ӘШҜв”ҳВҒ в”ҳГ в•ӘШөв•ӘВ»в•ӘВ» в”ҳВ„в”ҳВ„в•Әв•Јв”ҳВҶв•ӘШҜв•Әв•Ўв•Әв–’.\r\n */\r\nexport function HydrationFix() {\r\n  const cleanElements = useCallback(() => {\r\n    // в•ӘШҜв•Әв”Ӯв•ӘШІв”ҳГ§в•ӘВ»в•ӘШҜв”ҳВҒ в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳГ в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Јв•Әв–’в”ҳГӘв”ҳВҒв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв”ҳГЁ в•ӘШІв•Әв”Ӯв•ӘШ°в•ӘШ° в”ҳГ в•Әв”Өв•ӘШҜв”ҳГўв”ҳВ„ в”ҳВҒв”ҳГ©в•Әв•– в•ӘШ°в•ӘВ»в”ҳВ„в•ӘШҜв”ҳГҜ в”ҳГ в”ҳВҶ в”ҳГ в•Әв”Ӯв•ӘШө в”ҳГўв”ҳВ„ в•Әв”Өв”ҳГЁв•ӘШ©\r\n    const selectors = [\r\n      '[bis_skin_checked]',\r\n      '[bis_register]',\r\n      '[data-gr-ext-installed]',\r\n      '[data-new-gr-c-s-check-loaded]',\r\n      '[data-lastpass-icon]',\r\n      '[data-dashlane-rid]',\r\n      '[__processed_id]',\r\n      '[style*=\"--processed\"]'\r\n    ];\r\n\r\n    try {\r\n      const elements = document.querySelectorAll(selectors.join(','));\r\n      \r\n      elements.forEach((el) => {\r\n        const attributesToRemove = [\r\n          'bis_skin_checked',\r\n          'bis_register',\r\n          'data-gr-ext-installed',\r\n          'data-new-gr-c-s-check-loaded',\r\n          'data-lastpass-icon',\r\n          'data-dashlane-rid'\r\n        ];\r\n\r\n        attributesToRemove.forEach(attr => {\r\n          if (el.hasAttribute(attr)) el.removeAttribute(attr);\r\n        });\r\n\r\n        // в”ҳГ в•Әв”Ӯв•ӘШө в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳГ в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШІв”ҳГЁ в•ӘШІв•ӘШ°в•ӘВ»в•ӘШ« в•ӘШ°в”ҳВҖ __processed_\r\n        if (el.attributes) {\r\n          Array.from(el.attributes).forEach(attr => {\r\n            if (attr.name.startsWith('__processed_')) {\r\n              el.removeAttribute(attr.name);\r\n            }\r\n          });\r\n        }\r\n      });\r\n    } catch (e) {\r\n      // Silently fail if selector is invalid or parsing fails\r\n    }\r\n  }, []);\r\n\r\n  useEffect(() => {\r\n    if (typeof window === 'undefined') return;\r\n\r\n    // в•ӘШІв•Әв”Өв•Әв•‘в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҶв•Әв••в”ҳГЁв”ҳВҒ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в”ҳВҒв”ҳГӘв•Әв–’ в•ӘШ°в•Әв•Јв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„\r\n    const immediateTimer = setTimeout(cleanElements, 100);\r\n    \r\n    // в•ӘШІв•Әв”Өв•Әв•‘в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҶв•Әв••в”ҳГЁв”ҳВҒ в•ӘШ°в•Әв•Јв•ӘВ» в”ҳВҒв•ӘШІв•Әв–’в•ӘШұ в•ӘШ°в•Әв”Ӯв”ҳГЁв•Әв•–в•ӘШұ в”ҳВ„в”ҳВ„в•ӘШІв•Әв•Јв•ӘШҜв”ҳГ в”ҳВ„ в”ҳГ в•Әв•Ј в•ӘШҜв”ҳВ„в•Әв•Јв”ҳВҶв•ӘШҜв•Әв•Ўв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШІв”ҳГЁ в•ӘШІв•Әв•ўв•ӘШҜв”ҳВҒ в”ҳВ„в•ӘШҜв•ӘШөв”ҳГ©в•ӘШҜв”ҳГҜ\r\n    const delayTimer = setTimeout(cleanElements, 1000);\r\n\r\n    return () => {\r\n      clearTimeout(immediateTimer);\r\n      clearTimeout(delayTimer);\r\n    };\r\n  }, [cleanElements]);\r\n\r\n  return null;\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\components\\index.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\components\\layout\\app-client-root.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\components\\layout\\client-layout-wrapper.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\components\\layout\\global-settings-applier.