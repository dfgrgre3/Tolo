ption: courseData.subject.description\n          });\n        }\n        setWalletBalance(walletData.balance || 0);\n      } catch (error) {\n        console.error(error);\n      } finally {\n        setLoading(false);\n      }\n    };\n\n    fetchData();\n  }, [courseId]);\n\n  const handleCheckout = async () => {\n    if (!user) {\n      toast.error(\"в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳГ©в•ӘШ°в”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в”ҳВҒв•Әв•Ј\");\n      router.push(`/login?redirect=/courses/${courseId}/checkout`);\n      return;\n    }\n    setProcessing(true);\n    setIframeUrl(null);\n    try {\n      const res = await fetch(`/api/courses/${courseId}/checkout`, {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({\n          paymentMethod,\n          couponCode: couponCode || undefined,\n        }),\n      });\n\n      const data = await res.json();\n      if (!res.ok) {\n         toast.error(data.error || \"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШІв”ҳГ§в”ҳГЁв•ӘШ®в•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в”ҳВҒв•Әв•Ј\");\n         return;\n      }\n\n      if (data.success) {\n        toast.success(\"в•ӘШІв”ҳГ  в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„в”ҳГў в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө!\");\n        router.push(`/courses/${courseId}?payment_success=true`);\n        return;\n      }\n\n      if (data.paymentKey && data.iframeId) {\n        setIframeUrl(`https://egypt.paymob.com/api/acceptance/iframes/${data.iframeId}?payment_token=${data.paymentKey}`);\n      } else {\n        toast.error(\"в•ӘШІв”ҳГўв”ҳГӘв”ҳГЁв”ҳВҶ в•ӘШҜв”ҳВ„в•ӘВ»в”ҳВҒв•Әв•Ј в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в”ҳГўв•ӘШІв”ҳГ в”ҳВ„ в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳГЁв•Әв–’в”ҳВҒв•Әв–’\");\n      }\n    } catch (error) {\n      console.error(error);\n      toast.error(\"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„ в•ӘШ°в”ҳВҶв•Әв••в•ӘШҜв”ҳГ  в•ӘШҜв”ҳВ„в•ӘВ»в”ҳВҒв•Әв•Ј\");\n    } finally {\n      setProcessing(false);\n    }\n  };\n\n  if (loading) {\n    return (\n      <div className=\"min-h-screen flex items-center justify-center bg-[#09111f]\">\n        <div className=\"flex flex-col items-center gap-4\">\n          <Loader2 className=\"w-12 h-12 animate-spin text-primary\" />\n          <p className=\"text-gray-400 font-bold\">в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШІв•ӘШҙв”ҳГ§в”ҳГЁв•Әв–“ в•Әв•–в”ҳВ„в•ӘШ°в”ҳГў...</p>\n        </div>\n      </div>\n    );\n  }\n\n  if (!course) {\n    return (\n      <div className=\"min-h-screen flex items-center justify-center bg-[#09111f]\">\n        <div className=\"text-center p-8 bg-white/5 border border-white/10 rounded-[2rem] max-w-md\">\n          <AlertCircle className=\"mx-auto w-20 h-20 text-rose-500 mb-6\" />\n          <h2 className=\"text-3xl font-black text-white mb-2\">в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в”ҳГӘв•ӘШҙв”ҳГӘв•ӘВ»в•ӘШұ</h2>\n          <p className=\"text-gray-400 mb-8\">в”ҳВ„в”ҳГ  в”ҳГЁв•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•Әв•Јв•ӘШів”ҳГӘв•Әв–’ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•–в”ҳВ„в”ҳГӘв•ӘШ°в•ӘШұв•ӘГ® в•Әв–’в•ӘШ°в”ҳГ в•ӘШҜ в•ӘШІв”ҳГ  в”ҳВҶв”ҳГ©в”ҳВ„в”ҳГ§в•ӘШҜ в•ӘШ«в”ҳГӘ в•ӘШөв•Әв–‘в”ҳВҒв”ҳГ§в•ӘШҜ.</p>\n          <button onClick={() => router.push('/courses')} className=\"w-full py-4 bg-white text-gray-900 font-bold rounded-2xl\">в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГӘв•ӘВ»в•ӘШұ в”ҳВ„в”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШҜв•ӘШІ</button>\n        </div>\n      </div>\n    );\n  }\n  \n  if (iframeUrl) {\n    return (\n      <div className=\"fixed inset-0 z-50 bg-[#0B0D14] flex flex-col\" dir=\"rtl\">\n        <div className=\"bg-[#101222] border-b border-white/10 text-white p-4 flex justify-between items-center shadow-2xl\">\n          <div className=\"flex items-center gap-3\">\n             <div className=\"bg-primary/20 p-2 rounded-xl\">\n                <ShieldCheck className=\"w-6 h-6 text-primary\" />\n             </div>\n             <h2 className=\"font-black text-xl\">в•ӘШ°в”ҳГӘв•ӘШҜв•ӘШ°в•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в”ҳВҒв•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШӘв”ҳГ в”ҳВҶв•ӘШұ</h2>\n          </div>\n          <button \n            onClick={() => setIframeUrl(null)}\n            className=\"text-white hover:text-rose-400 font-black px-6 py-2.5 bg-white/5 border border-white/10 rounded-2xl transition-all active:scale-95 flex items-center gap-2\"\n          >\n            <span>в•ӘШӯв”ҳВ„в•Әв•‘в•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГ в”ҳВ„в”ҳГЁв•ӘШұ</span>\n            <ArrowRight className=\"w-4 h-4 rotate-180\" />\n          </button>\n        </div>\n        <div className=\"flex-1 bg-white relative\">\n           <iframe src={iframeUrl} className=\"w-full h-full\" allow=\"payment\" />\n        </div>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"min-h-screen bg-[#09111f] text-white py-12 px-4 md:px-8\" dir=\"rtl\">\n      {/* Background blobs */}\n      <div className=\"fixed inset-0 pointer-events-none -z-10 overflow-hidden\">\n        <div className=\"absolute top-0 right-1/4 w-[500px] h-[500px] bg-primary/10 rounded-full blur-[120px]\" />\n        <div className=\"absolute bottom-0 left-1/4 w-[500px] h-[500px] bg-purple-500/10 rounded-full blur-[120px]\" />\n      </div>\n\n      <div className=\"max-w-6xl mx-auto\">\n        <header className=\"mb-12 flex flex-col md:flex-row md:items-center justify-between gap-6\">\n           <div className=\"space-y-2\">\n              <h1 className=\"text-4xl font-black tracking-tight\">в•ӘШӯв•ӘШІв”ҳГ в•ӘШҜв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„</h1>\n              <p className=\"text-gray-400 font-medium\">в•ӘВ«в•Әв•–в”ҳГӘв•ӘШұ в”ҳГӘв•ӘШҜв•ӘШөв•ӘВ»в•ӘШұ в•ӘШІв”ҳВҒв•Әв•Ўв”ҳВ„в”ҳГў в•Әв•Јв”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШ°в•ӘВ»в•ӘШ© в”ҳВҒв”ҳГЁ в•Әв–’в•ӘШөв”ҳВ„в•ӘШұ в•ӘШІв•Әв•Јв”ҳВ„в”ҳГЁв”ҳГ в”ҳГЁв•ӘШұ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ</p>\n           </div>\n           <button onClick={() => router.back()} className=\"flex items-center gap-2 text-gray-400 hover:text-white transition-colors font-bold group\">\n              <ArrowRight className=\"w-5 h-5 group-hover:translate-x-1 transition-transform\" />\n              <span>в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҙв”ҳГӘв•Әв•Ј в”ҳВ„в”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ</span>\n           </button>\n        </header>\n\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-10\">\n          {/* Order Details Column */}\n          <div className=\"lg:col-span-4 space-y-8\">\n            <motion.div initial={{ opacity: 0, scale: 0.95 }} animate={{ opacity: 1, scale: 1 }} className=\"rounded-[2.5rem] bg-gradient-to-b from-white/10 to-transparent border border-white/10 p-2 overflow-hidden shadow-2xl\">\n               <div className=\"aspect-video rounded-[2rem] overflow-hidden relative\">\n                  {course.thumbnailUrl ? (\n                    <img src={course.thumbnailUrl} alt={course.nameAr} className=\"w-full h-full object-cover\" />\n                  ) : (\n                    <div className=\"w-full h-full bg-[#101222] flex items-center justify-center\">\n                       <GraduationCap className=\"w-20 h-20 text-gray-700\" />\n                    </div>\n                  )}\n                  <div className=\"absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/80 to-transparent p-6 pt-12\">\n                     <span className=\"text-xs bg-primary/80 text-white font-black px-3 py-1 rounded-full uppercase tracking-widest mb-2 inline-block\">в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ в•ӘШІв•ӘВ»в•Әв–’в”ҳГЁв•ӘШ°в”ҳГЁв•ӘШұ</span>\n                     <h2 className=\"text-2xl font-black text-white\">{course.nameAr || course.name}</h2>\n                  </div>\n               </div>\n               \n               <div className=\"p-6 space-y-6\">\n                  <div className=\"flex justify-between items-center\">\n                     <span className=\"text-gray-400 font-bold\">в•Әв”Ӯв•Әв•Јв•Әв–’ в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ</span>\n                     <span className=\"text-2xl font-black text-white\">{course.price} в•ӘШҙ.в”ҳГ </span>\n                  </div>\n                  \n                  <div className=\"space-y-3 pt-6 border-t border-white/10\">\n                     {[\n                       \"в”ҳГӘв•Әв•Ўв”ҳГӘв”ҳВ„ в”ҳГ в•ӘВ»в”ҳГ« в•ӘШҜв”ҳВ„в•ӘШөв”ҳГЁв•ӘШҜв•ӘШұ в”ҳВ„в”ҳВ„в”ҳГ в•ӘШөв•ӘШІв”ҳГӘв”ҳГ«\",\n                       \"в•Әв”Өв”ҳГ§в•ӘШҜв•ӘВ»в•ӘШұ в•ӘШӯв”ҳГўв”ҳГ в•ӘШҜв”ҳВ„ в”ҳГ в•Әв•Јв•ӘШІв”ҳГ в•ӘВ»в•ӘШұ\",\n                       \"в”ҳГ в”ҳВ„в”ҳВҒв•ӘШҜв•ӘШІ в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘВ»в•ӘШұ в”ҳВ„в”ҳВ„в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„\"\n                     ].map((text, i) => (\n                       <div key={i} className=\"flex items-center gap-3 text-sm text-gray-300\">\n                          <CheckCircle2 className=\"w-4 h-4 text-emerald-500\" />\n                          <span>{text}</span>\n                       </div>\n                     ))}\n                  </div>\n\n                  <div className=\"pt-6 border-t border-white/10 flex justify-between items-center text-3xl font-black text-primary\">\n                    <span>в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШҙв”ҳГ в•ӘШҜв”ҳВ„в”ҳГЁ</span>\n                    <span>{course.price} <span className=\"text-lg\">в•ӘШҙ.в”ҳГ </span></span>\n                  </div>\n               </div>\n            </motion.div>\n\n            <div className=\"bg-emerald-500/10 border border-emerald-500/20 p-6 rounded-[2rem] flex gap-4\">\n               <ShieldCheck className=\"w-8 h-8 text-emerald-500 shrink-0\" />\n               <p className=\"text-sm font-medium text-emerald-100/80 leading-relaxed\">\n                  в”ҳВҶв•ӘШөв”ҳВҶ в”ҳВҶв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в•ӘШ«в•ӘШөв•ӘВ»в•ӘШі в•ӘШ«в”ҳВҶв•Әв••в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•Әв”Өв”ҳВҒв”ҳГЁв•Әв–’ в”ҳВ„в•Әв•ўв”ҳГ в•ӘШҜв”ҳВҶ в•ӘШ«в”ҳГ в•ӘШҜв”ҳВҶ в”ҳГ в•ӘВ»в”ҳВҒв”ҳГӘв•Әв•Јв•ӘШҜв•ӘШІв”ҳГў. в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШ°в•Әв•–в•ӘШҜв”ҳГ©в•ӘШІв”ҳГў в”ҳВ„в•ӘШҜ в•ӘШІв•ӘВ«в•Әв–“в”ҳВҶ в•ӘШ«в•ӘШ°в•ӘВ»в•ӘШҜв”ҳГҜ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШ«в”ҳВҶв•Әв••в”ҳГ в•ӘШІв”ҳВҶв•ӘШҜ.\n               </p>\n            </div>\n          </div>\n\n          {/* Payment Selection Column */}\n          <div className=\"lg:col-span-8 space-y-8\">\n            <div className=\"rounded-[2.5rem] bg-white/5 border border-white/10 p-8 md:p-12 shadow-2xl backdrop-blur-xl relative overflow-hidden\">\n               <div className=\"absolute -top-20 -left-20 w-60 h-60 bg-primary/5 rounded-full blur-[100px]\" />\n               \n               <h3 className=\"text-2xl font-black mb-10 flex items-center gap-3\">\n                  <CreditCard className=\"text-primary w-8 h-8\" />\n                  в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в”ҳГӘв•Әв”Ӯв”ҳГЁв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в”ҳВҒв•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•ӘШҜв•Әв”Ӯв•ӘШ°в•ӘШұ\n               </h3>\n\n               <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4 mb-10\">\n                 {[\n                   { id: \"card\", icon: CreditCard, label: \"в•ӘШ°в•Әв•–в•ӘШҜв”ҳГ©в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШ®в•ӘШІв”ҳГ в•ӘШҜв”ҳВҶ\", sub: \"Visa / Mastercard / Meeza\", accent: \"primary\" },\n                   { id: \"wallet\", icon: Smartphone, label: \"в”ҳГ в•ӘШөв•ӘШҜв”ҳВҒв•Әв•• в•ӘШӯв”ҳВ„в”ҳГўв•ӘШІв•Әв–’в”ҳГӘв”ҳВҶв”ҳГЁв•ӘШұ\", sub: \"Vodafone Cash / Instant Pay\", accent: \"emerald\" },\n                   { id: \"fawry\", icon: Wallet, label: \"в”ҳГўв”ҳГӘв•ӘВ» в”ҳВҒв”ҳГӘв•Әв–’в”ҳГЁ\", sub: \"в•ӘВ»в”ҳВҒв•Әв•Ј в”ҳВҶв”ҳГ©в•ӘВ»в”ҳГЁ в•Әв•Јв•ӘШ°в•Әв–’ в”ҳГ в”ҳВҶв•ӘШҜв”ҳВҒв•Әв–‘ в”ҳВҒв”ҳГӘв•Әв–’в”ҳГЁ\", accent: \"amber\" },\n                   { id: \"internal_wallet\", icon: Zap, label: \"в•Әв–’в•Әв•Ўв”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•Әв•Ўв•ӘШұ\", sub: \"в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в”ҳГ в•ӘШөв”ҳВҒв•Әв••в•ӘШІв”ҳГў в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВ„в”ҳГўв•ӘШІв•Әв–’в”ҳГӘв”ҳВҶв”ҳГЁв•ӘШұ\", accent: \"indigo\" }\n                 ].map((opt) => (\n                   <label \n                     key={opt.id}\n                     onClick={() => setPaymentMethod(opt.id as any)}\n                     className={`group relative flex items-center gap-4 p-6 rounded-[2rem] border-2 cursor-pointer transition-all active:scale-[0.98] ${paymentMethod === opt.id ? `border-primary bg-primary/10 shadow-lg shadow-primary/5` : 'border-white/5 bg-white/5 hover:bg-white/10 hover:border-white/10'}`}\n                   >\n                     <div className={`w-14 h-14 rounded-2xl flex items-center justify-center transition-all ${paymentMethod === opt.id ? 'bg-primary text-white scale-110' : 'bg-white/5 text-gray-500 group-hover:text-white'}`}>\n                        <opt.icon className=\"w-7 h-7\" />\n                     </div>\n                     <div className=\"flex-1\">\n                        <span className=\"block font-black text-lg transition-colors\">{opt.label}</span>\n                        <span className=\"text-xs text-gray-500 font-bold uppercase tracking-wide\">{opt.sub}</span>\n                        {opt.id === 'internal_wallet' && walletBalance !== null && (\n                          <div className={`mt-2 text-xs font-bold ${walletBalance >= course.price ? 'text-emerald-400' : 'text-rose-400'}`}>\n                             в•Әв–’в•Әв•Ўв”ҳГЁв•ӘВ»в”ҳГў в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁ: {walletBalance.toLocaleString()} в•ӘШҙ.в”ҳГ \n                          </div>\n                        )}\n                     </div>\n                     <div className={`w-6 h-6 rounded-full border-2 flex items-center justify-center transition-all ${paymentMethod === opt.id ? 'border-primary' : 'border-white/20'}`}>\n                        {paymentMethod === opt.id && <div className=\"w-3 h-3 rounded-full bg-primary\" />}\n                     </div>\n                   </label>\n                 ))}\n               </div>\n\n               <div className=\"space-y-6\">\n                  <div className=\"relative group\">\n                     <Tag className=\"absolute right-5 top-1/2 -translate-y-1/2 w-6 h-6 text-gray-500 group-focus-within:text-primary transition-colors\" />\n                     <input \n                       type=\"text\" \n                       placeholder=\"в”ҳГ§в”ҳВ„ в”ҳВ„в•ӘВ»в”ҳГЁв”ҳГў в”ҳГўв”ҳГӘв•ӘВ» в•ӘВ«в•Әв•Ўв”ҳГ в•ӘШ§ (в•ӘШ«в•ӘВ»в•ӘВ«в”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГўв”ҳГӘв•ӘВ» в”ҳГ§в”ҳВҶв•ӘШҜ)\" \n                       value={couponCode}\n                       onChange={(e) => setCouponCode(e.target.value)}\n                       className=\"w-full bg-white/5 border border-white/10 rounded-2xl py-5 px-14 text-white font-bold outline-none focus:border-primary/50 focus:ring-4 focus:ring-primary/5 transition-all text-center tracking-[0.2em]\"\n                     />\n                  </div>\n\n                  <div className=\"flex flex-col gap-4\">\n                     <button\n                        disabled={processing || !user || (paymentMethod === 'internal_wallet' && (walletBalance || 0) < course.price)}\n                        onClick={handleCheckout}\n                        className=\"w-full py-6 rounded-3xl bg-primary hover:bg-primary/90 text-white font-black text-xl flex items-center justify-center gap-3 shadow-2xl shadow-primary/20 transition-all active:scale-[0.96] disabled:opacity-50 disabled:grayscale\"\n                     >\n                        {processing ? <Loader2 className=\"w-7 h-7 animate-spin\" /> : <Sparkles className=\"w-7 h-7\" />}\n                        <span>{processing ? \"в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„ в•ӘШ°в•ӘШҜв”ҳВ„в”ҳВҶв•Әв••в•ӘШҜв”ҳГ ...\" : \"в•ӘШІв•ӘШ«в”ҳГўв”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҙв•Әв–“ в”ҳГӘв•ӘШҜв”ҳВ„в•ӘШ°в•ӘВ»в•ӘШ© в•ӘШҜв”ҳВ„в•ӘШӘв”ҳВҶ\"}</span>\n                     </button>\n                     \n                     {paymentMethod === 'internal_wallet' && (walletBalance || 0) < course.price && (\n                       <div className=\"bg-rose-500/10 border border-rose-500/20 p-4 rounded-2xl flex items-center gap-3 text-rose-400 text-sm font-bold justify-center\">\n                          <Info className=\"w-5 h-5\" />\n                          <span>в•Әв–’в•Әв•Ўв”ҳГЁв