./ui/input';\r\n\r\nimport { logger } from '@/lib/logger';\r\n\r\n/**\r\n * в•ӘВ«в•Әв•Ўв•ӘШҜв•ӘШ®в•Әв•Ў в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶ в•Әв–’в•ӘШ«в•Әв”Ӯ в•ӘШҜв”ҳВ„в”ҳГ©в•Әв”Ӯв”ҳГ \r\n */\r\nexport interface SectionHeaderProps {\r\n  /** в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ©в•Әв”Ӯв”ҳГ  */\r\n  title: string;\r\n  /** в”ҳГӘв•Әв•Ўв”ҳВҒ в•ӘШҜв”ҳВ„в”ҳГ©в•Әв”Ӯв”ҳГ  (в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’в”ҳГЁ) */\r\n  description?: string;\r\n  /** в”ҳГ§в”ҳВ„ в”ҳГЁв•ӘШІв”ҳГ  в•Әв•Јв•Әв–’в•Әв•ў в•Әв–“в•Әв–’ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұв•ӘШ§ */\r\n  showAddButton?: boolean;\r\n  /** в”ҳВҶв•Әв•Ў в•Әв–“в•Әв–’ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ */\r\n  addButtonText?: string;\r\n  /** в•ӘВ»в•ӘШҜв”ҳВ„в•ӘШұ callback в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ©в•Әв–’ в•Әв•Јв”ҳВ„в”ҳГ« в•Әв–“в•Әв–’ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ */\r\n  onAdd?: () => void;\r\n  /** в”ҳГ§в”ҳВ„ в”ҳГЁв•ӘШІв”ҳГ  в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШөв•ӘШів•ӘШ§ */\r\n  showSearch?: boolean;\r\n  /** placeholder в”ҳВ„в”ҳВ„в•ӘШ°в•ӘШөв•ӘШі */\r\n  searchPlaceholder?: string;\r\n  /** в”ҳГ©в”ҳГЁв”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШөв•ӘШі */\r\n  searchValue?: string;\r\n  /** в•ӘВ»в•ӘШҜв”ҳВ„в•ӘШұ callback в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШөв•ӘШі */\r\n  onSearchChange?: (value: string) => void;\r\n  /** в”ҳГ§в”ҳВ„ в”ҳГЁв•ӘШІв”ҳГ  в•Әв•Јв•Әв–’в•Әв•ў в•Әв–“в•Әв–’ в•ӘШҜв”ҳВ„в”ҳВҒв”ҳВ„в•ӘШІв•Әв–’в•ӘШ§ */\r\n  showFilter?: boolean;\r\n  /** в•ӘВ»в•ӘШҜв”ҳВ„в•ӘШұ callback в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ©в•Әв–’ в•Әв•Јв”ҳВ„в”ҳГ« в•Әв–“в•Әв–’ в•ӘШҜв”ҳВ„в”ҳВҒв”ҳВ„в•ӘШІв•Әв–’ */\r\n  onFilter?: () => void;\r\n  /** в•Әв•Јв”ҳВҶв•ӘШҜв•Әв•Ўв•Әв–’ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв”ҳГЁв•ӘШұ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•Әв–’в•ӘШ«в•Әв”Ӯ */\r\n  actions?: React.ReactNode;\r\n}\r\n\r\n/**\r\n * в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶ в•Әв–’в•ӘШ«в•Әв”Ӯ в•ӘШҜв”ҳВ„в”ҳГ©в•Әв”Ӯв”ҳГ \r\n * \r\n * в•Әв–’в•ӘШ«в•Әв”Ӯ в”ҳГ©в•ӘШҜв•ӘШ°в”ҳВ„ в”ҳВ„в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в•ӘШҜв”ҳГ  в”ҳВ„в•ӘШ«в”ҳГ©в•Әв”Ӯв•ӘШҜв”ҳГ  в”ҳВ„в”ҳГӘв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГўв”ҳГ \r\n * \r\n * @example\r\n * ```tsx\r\n * <SectionHeader \r\n *   title=\"в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ \"\r\n *   description=\"в•ӘШӯв•ӘВ»в•ӘШҜв•Әв–’в•ӘШұ в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ в”ҳГў в•ӘШҜв”ҳВ„в”ҳГЁв”ҳГӘв”ҳГ в”ҳГЁв•ӘШұ\"\r\n *   showAddButton\r\n *   addButtonText=\"в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ\"\r\n *   onAdd={() => logger.info('Add task')}\r\n * />\r\n * ```\r\n */\r\nexport const SectionHeader: React.FC<SectionHeaderProps> = React.memo(({\r\n  title,\r\n  description,\r\n  showAddButton = false,\r\n  addButtonText = 'в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ',\r\n  onAdd,\r\n  showSearch = false,\r\n  searchPlaceholder = 'в•ӘШ°в•ӘШөв•ӘШі...',\r\n  searchValue = '',\r\n  onSearchChange,\r\n  showFilter = false,\r\n  onFilter,\r\n  actions,\r\n}) => {\r\n  return (\r\n    <div className=\"flex flex-col space-y-4 mb-4\">\r\n      <div className=\"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4\">\r\n        <div>\r\n          <h2 className=\"text-2xl font-bold tracking-tight\">{title}</h2>\r\n          {description && (\r\n            <p className=\"text-sm text-muted-foreground mt-1\">\r\n              {description}\r\n            </p>\r\n          )}\r\n        </div>\r\n        \r\n        <div className=\"flex items-center gap-2\">\r\n          {showFilter && (\r\n            <Button\r\n              variant=\"outline\"\r\n              size=\"sm\"\r\n              onClick={onFilter}\r\n              className=\"gap-2\"\r\n            >\r\n              <Filter className=\"h-4 w-4\" />\r\n              в”ҳВҒв”ҳВ„в•ӘШІв•Әв–’\r\n            </Button>\r\n          )}\r\n          \r\n          {showAddButton && (\r\n            <Button\r\n              onClick={onAdd}\r\n              size=\"sm\"\r\n              className=\"gap-2\"\r\n            >\r\n              <Plus className=\"h-4 w-4\" />\r\n              {addButtonText}\r\n            </Button>\r\n          )}\r\n          \r\n          {actions}\r\n        </div>\r\n      </div>\r\n      \r\n      {showSearch && (\r\n        <div className=\"relative\">\r\n          <Search className=\"absolute right-3 top-1/2 transform -translate-y-1/2 h-4 w-4 text-muted-foreground\" />\r\n          <Input\r\n            type=\"text\"\r\n            placeholder={searchPlaceholder}\r\n            value={searchValue}\r\n            onChange={(e) => onSearchChange?.(e.target.value)}\r\n            className=\"pr-10\"\r\n          />\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n});\r\n\r\nSectionHeader.displayName = 'SectionHeader';\r\n\r\nexport default SectionHeader;\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\components\\dashboard\\index.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\components\\error-boundary.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'AlertCircle' is defined but never used. Allowed unused vars must match /^_/u.","line":2,"column":57,"nodeType":"Identifier","messageId":"unusedVar","endLine":2,"endColumn":68,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"AlertCircle"},"fix":{"range":[142,155],"text":""},"desc":"Remove unused variable \"AlertCircle\"."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"ЩҠв•—в”җimport React, { Component, ErrorInfo, ReactNode, useState, useCallback } from 'react';\r\nimport { AlertTriangle, RefreshCw, Home, MessageCircle, AlertCircle } from 'lucide-react';\r\nimport { errorService as errorManager } from '@/lib/logging/error-service';\r\nimport ErrorPage, { ErrorType } from './error-pages';\r\nimport { logger } from '@/lib/logger';\r\n\r\n/**\r\n * в•ӘВ«в•Әв•Ўв•ӘШҜв•ӘШ®в•Әв•Ў в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶ ErrorBoundary\r\n */\r\ninterface Props {\r\n  /** в•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳВҒв•Әв–’в•Әв•Јв”ҳГЁв•ӘШұ */\r\n  children: ReactNode;\r\n  /** в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶ в•ӘШ°в•ӘВ»в”ҳГЁв”ҳВ„ в”ҳГЁв•Әв••в”ҢГӘв•Әв•Јв•Әв–’в•Әв•ў в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШөв•ӘВ»в”ҳГӘв•ӘШі в•ӘВ«в•Әв•–в•ӘШ« */\r\n  fallback?: ReactNode;\r\n  /** в•ӘВ»в•ӘШҜв”ҳВ„в•ӘШұ callback в•ӘШІв•Әв••в”ҢГӘв•Әв”Ӯв•ӘШІв•ӘВ»в•Әв•Јв”ҳГ« в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШөв•ӘВ»в”ҳГӘв•ӘШі в•ӘВ«в•Әв•–в•ӘШ« */\r\n  onError?: (error: Error, errorInfo: ErrorInfo) => void;\r\n  /** в”ҳВҶв”ҳГӘв•Әв•Ј в•ӘШҜв”ҳВ„в•ӘВ«в•Әв•–в•ӘШ« в”ҳВ„в•ӘШІв•ӘВ«в•Әв•Ўв”ҳГЁв•Әв•Ў в•Әв•Ўв”ҳВҒв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ«в•Әв•–в•ӘШ« */\r\n  errorType?: ErrorType;\r\n  /** в”ҳГ§в”ҳВ„ в”ҳГЁв•ӘШІв”ҳГ  в•Әв•Јв•Әв–’в•Әв•ў в•Әв•Ўв”ҳВҒв•ӘШөв•ӘШұ в•ӘВ«в•Әв•–в•ӘШ« в”ҳГ в•ӘВ«в•Әв•Ўв•Әв•Ўв•ӘШұв•ӘШ§ */\r\n  showErrorPage?: boolean;\r\n  /** в”ҳГ§в”ҳВ„ в”ҳГЁв•ӘШІв”ҳГ  в•Әв•Јв•Әв–’в•Әв•ў в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Ўв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ«в•Әв•–в•ӘШ«в•ӘШ§ */\r\n  showDetails?: boolean;\r\n  /** в•ӘШІв”ҳГ в”ҳГўв”ҳГЁв”ҳВҶ в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГЁв•ӘШұ */\r\n  enableRetry?: boolean;\r\n  /** в•ӘШ«в”ҳГ©в•Әв•Ўв”ҳГ« в•Әв•Јв•ӘВ»в•ӘВ» в”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШҜв•ӘШІ в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ */\r\n  maxRetries?: number;\r\n  /** в”ҳВҒв•ӘШ®в•ӘШұ CSS в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв”ҳГЁв•ӘШұ */\r\n  className?: string;\r\n  /** в”ҳВҶв”ҳГӘв•Әв•Ј в•ӘШҜв”ҳВ„в•Әв•Јв•Әв–’в•Әв•ў: 'global' в”ҳВ„в”ҳВ„в•ӘВ«в•Әв•–в•ӘШ« в•ӘШҜв”ҳВ„в”ҳГўв•ӘШҜв”ҳГ в”ҳВ„ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•Әв•Ўв”ҳВҒв•ӘШөв•ӘШұв•ӘГ® в•ӘШ«в”ҳГӘ 'component' в”ҳВ„в”ҳВ„в•ӘВ«в•Әв•–в•ӘШ« в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв”ҳВ„в”ҳГЁ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶ */\r\n  variant?: 'global' | 'component';\r\n}\r\n\r\n/**\r\n * в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶ ErrorBoundary\r\n */\r\ninterface State {\r\n  /** в”ҳГ§в”ҳВ„ в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ«в•ӘШ§ */\r\n  hasError: boolean;\r\n  /** в”ҳГўв•ӘШҜв•ӘШ®в”ҳВҶ в•ӘШҜв”ҳВ„в•ӘВ«в•Әв•–в•ӘШ« */\r\n  error: Error | null;\r\n  /** в”ҳГ в•Әв•Јв”ҳВ„в”ҳГӘв”ҳГ в•ӘШҜв•ӘШІ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв”ҳГЁв•ӘШұ в•Әв•Јв”ҳВҶ в•ӘШҜв”ҳВ„в•ӘВ«в•Әв•–в•ӘШ« */\r\n  errorInfo: ErrorInfo | null;\r\n  /** в”ҳГ в•Әв•Јв•Әв–’в”ҳВҒ в”ҳВҒв•Әв–’в”ҳГЁв•ӘВ» в”ҳВ„в”ҳВ„в•ӘВ«в•Әв•–в•ӘШ« */\r\n  errorId: string | null;\r\n  /** в•Әв•Јв•ӘВ»в•ӘВ» в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШҜв•ӘШІ в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ */\r\n  retryCount: number;\r\n  /** в”ҳГ§в”ҳВ„ в•ӘШІв”ҳГ  в•ӘШІв•Әв–’в•Әв•–в”ҳГЁв•ӘШ° в•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶ (Hydrated)в•ӘШ§ */\r\n  isHydrated: boolean;\r\n}\r\n\r\n/**\r\n * ErrorBoundary - в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶ в”ҳГ в•Әв•Јв•ӘШҜв”ҳВ„в•ӘШҙв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ«в•Әв•–в•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘШөв•ӘВ»\r\n * в”ҳГЁв”ҳГӘв”ҳВҒв•Әв–’ в”ҳГӘв•ӘШҜв•ӘШҙв”ҳГ§в•ӘШұ в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в•Әв•‘в”ҳВҶв”ҳГЁв•ӘШұв•ӘГ® в”ҳГ в•Әв•Јв•ӘШҜв”ҳВ„в•ӘШҙв•ӘШұ в•ӘШ«в•ӘВ«в•Әв•–в•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШІв•Әв–’в•Әв•–в”ҳГЁв•ӘШ° (Hydration)в•ӘГ® в”ҳГӘв”ҳГ в”ҳВҶв•Әв•–в”ҳГ© в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ.\r\n */\r\nclass ErrorBoundary extends Component<Props, State> {\r\n  private retryTimeoutId: NodeJS.Timeout | null = null;\r\n\r\n  constructor(props: Props) {\r\n    super(props);\r\n    this.state = {\r\n      hasError: false,\r\n      error: null,\r\n      errorInfo: null,\r\n      errorId: null,\r\n      retryCount: 0,\r\n      isHydrated: false,\r\n    };\r\n  }\r\n\r\n  componentDidMount() {\r\n    // Register this boundary with the error manager\r\n    errorManager.registerBoundaryCallback(this.handleBoundaryError);\r\n    \r\n    // Set hydrated state on client\r\n    this.setState({ isHydrated: true });\r\n  }\r\n\r\n  componentWillUnmount() {\r\n    // Unregister when unmounting\r\n    errorManager.registerBoundaryCallback(() => {});\r\n    \r\n    if (this.retryTimeoutId) {\r\n      clearTimeout(this.retryTimeoutId);\r\n    }\r\n  }\r\n\r\n  handleBoundaryError = (error: Error, errorId: string) => {\r\n    // This is called from the error manager\r\n    this.setState({\r\n      hasError: true,\r\n      error,\r\n      errorId,\r\n    });\r\n  };\r\n\r\n  static getDerivedStateFromError(error: Error): Partial<State> {\r\n    // Generate unique error ID for tracking\r\n    const errorId = `err-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`;\r\n\r\n    return {\r\n      hasError: true,\r\n      error,\r\n      errorId,\r\n    };\r\n  }\r\n\r\n  componentDidCatch(error: Error, errorInfo: ErrorInfo) {\r\n    // Check if this is a hydration mismatch\r\n    const isHydrationError = error.message.toLowerCase().includes('hydration') ||\r\n                           error.message.toLowerCase().includes('server') ||\r\n                           error.message.toLowerCase().includes('client');\r\n\r\n    // Log error to console\r\n    if (isHydrationError) {\r\n      logger.warn('Hydration mismatch detected by ErrorBoundary:', error.message);\r\n    } else {\r\n      logger.error('Error caught by ErrorBoundary:', error, errorInfo);\r\n    }\r\n\r\n    // Update state with error info\r\n    this.setState({\r\n      errorInfo,\r\n      // If it's a hydration error, we might not be fully hydrated\r\n      isHydrated: !isHydrationError\r\n    });\r\n\r\n    // Call custom error handler if provided\r\n    if (this.props.onError) {\r\n      this.props.onError(error, errorInfo);\r\n    }\r\n\r\n    // Log to ErrorManager unless it's a simple hydration mismatch we can recover from\r\n    if (!isHydrationError || this.state.retryCount > 0) {\r\n      this.logErrorToService(error, errorInfo);\r\n    }\r\n  }\r\n\r\n  componentDidUpdate(prevProps: Props) {\r\n    // Reset error state when children change (useful for route changes)\r\n    if (prevProps.children !== this.props.children && this.state.hasError) {\r\n      this.handleReset();\r\n    }\r\n  }\r\n\r\n  logErrorToService = (error: Error, errorInfo: ErrorInfo) => {\r\n    try {\r\n      const errorId = errorManager.logError(error, {\r\n        source: 'ErrorBoundary',\r\n        severity: 'high',\r\n        componentStack: errorInfo.componentStack,\r\n        errorBoundaryId: this.state.errorId,\r\n        retryCount: this.state.retryCount,\r\n      });\r\n\r\n      this.setState({ errorId });\r\n    } catch (e) {\r\n      logger.error('Failed to log error to ErrorManager:', e);\r\n    }\r\n  };\r\n\r\n  handleRetry = () => {\r\n    const { maxRetries = 3 } = this.props;\r\n\r\n    if (this.state.retryCount < maxRetries) {\r\n      this.setState(prevState => ({\r\n        hasError: false,\r\n        error: null,\r\n        errorInfo: null,\r\n        retryCount: prevState.retryCount + 1\r\n      }));\r\n\r\n      if (this.retryTimeoutId) {\r\n        clearTimeout(this.retryTimeoutId);\r\n      }\r\n    } else {\r\n      // If max retries reached, just reload effectively\r\n      this.handleReload();\r\n    }\r\n  };\r\n\r\n  handleReset = () => {\r\n    this.setState({\r\n      hasError: false,\r\n      error: null,\r\n      errorInfo: null,\r\n      errorId: null,\r\n      retryCount: 0,\r\n    });\r\n  };\r\n\r\n  handleGoHome = () => {\r\n    window.location.href = '/';\r\n  };\r\n\r\n  handleReload = () => {\r\n    window.location.reload();\r\n  };\r\n\r\n  handleReportError = () => {\r\n    const errorDetails = {\r\n      message: this.state.error?.message,\r\n      stack: this.state.error?.stack,\r\n      componentStack: this.state.errorInfo?.componentStack,\r\n      errorId: this.state.errorId,\r\n    };\r\n\r\n    const subject = `Error Report: ${this.state.errorId}`;\r\n    const body = `Error ID: ${this.state.errorId}\\n\\nError Message: ${errorDetails.message}\\n\\nStack Trace:\\n${errorDetails.stack}\\n\\nComponent Stack:\\n${errorDetails.componentStack}`;\r\n    window.open(`mailto:support@example.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`);\r\n  };\r\n\r\n  render() {\r\n    const { hasError, error, errorId, retryCount } = this.state;\r\n    const { children, fallback, showErrorPage, errorType, showDetails, className = \"\", variant = \"global\" } = this.props;\r\n\r\n    if (hasError) {\r\n      // If custom fallback is provided, use it\r\n      if (fallback) {\r\n        return fallback;\r\n      }\r\n\r\n      // If variant is 'component' or it's localized\r\n      if (variant === 'component') {\r\n        return (\r\n          <div className={`flex flex-col items-center justify-center p-6 border-2 border-dashed border-red-200 dark:border-red-900/30 rounded-xl bg-red-50/50 dark:bg-red-950/20 text-center animate-in fade-in zoom-in duration-300 ${className}`} dir=\"rtl\">\r\n            <div className=\"relative mb-4\">\r\n              <div className=\"absolute inset-0 bg-red-500/10 rounded-full blur-lg animate-pulse\"></div>\r\n              <AlertTriangle className=\"relative h-10 w-10 text-red-500\" />\r\n            </div>\r\n            \r\n            <h3 className=\"text-lg font-bold mb-1\">в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в”ҳВҒв”ҳГЁ в”ҳГ§в•Әв–‘в•ӘШҜ в•ӘШҜв”ҳВ„в•ӘШҙв•Әв–“в•ӘШ©</h3>\r\n            <p className=\"text-xs text-muted-foreground mb-4 max-w-xs\">\r\n              в”ҳГӘв•ӘШҜв•ӘШҙв”ҳГ§в”ҳВҶв•ӘШҜ в”ҳГ в•Әв”Өв”ҳГўв”ҳВ„в•ӘШұ в”ҳВҒв”ҳГЁ в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„ в”ҳГ§в•Әв–‘в•ӘШҜ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶ. в”ҳГЁв”ҳГ в”ҳГўв”ҳВҶв”ҳГў в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„.\r\n            </p>\r\n            \r\n            <div className=\"flex gap-2\">\r\n              <button\r\n                onClick={this.handleRetry}\r\n                className=\"flex items-center gap-2 px-3 py-1.5 bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-300 rounded-lg text-xs font-semibold hover:bg-red-200 transition-colors\"\r\n                disabled={retryCount >= (this.props.maxRetries || 3)}\r\n              >\r\n                <RefreshCw className={`h-3 w-3 ${retryCount > 0 ? 'animate-spin' : ''}`} />\r\n                {retryCount > 0 ? `в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ (${retryCount})` : 'в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ'}\r\n              </button>\r\n              \r\n              {showDetails && (\r\n                <details className=\"mt-2 text-right\">\r\n                  <summary className=\"cursor-pointer text-[10px] text-muted-foreground hover:text-red-500 underline\">\r\n                    в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Ўв”ҳГЁв”ҳВ„\r\n                  </summary>\r\n                  <div className=\"mt-2 p-2 bg-background border rounded text-[10px] text-red-600 font-mono overflow-auto max-w-[250px]\">\r\n                    {error?.message}\r\n                  </div>\r\n                </details>\r\n              )}\r\n            </div>\r\n          </div>\r\n        );\r\n      }\r\n\r\n      // Use custom error page if enabled\r\n      if (showErrorPage) {\r\n        return (\r\n          <ErrorPage\r\n            type={errorType || 'generic'}\r\n            errorId={errorId || undefined}\r\n            error={error || undefined}\r\n            showDetails={showDetails}\r\n            onRetry={this.handleRetry}\r\n            onGoHome={this.handleGoHome}\r\n          />\r\n        );\r\n      }\r\n\r\n      const isHydrationError = error?.message.toLowerCase().includes('hydration') ||\r\n                             error?.message.toLowerCase().includes('server') ||\r\n                             error?.message.toLowerCase().includes('client');\r\n\r\n      // Default high-quality error UI (Global Variant)\r\n      return (\r\n        <div className={`min-h-screen bg-gray-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8 ${className}`} dir=\"rtl\">\r\n          <div className=\"sm:mx-auto sm:w-full sm:max-w-md\">\r\n            <div className=\"flex justify-center\">\r\n              <div className={`flex items-center justify-center h-16 w-16 rounded-full ${isHydrationError ? 'bg-yellow-100' : 'bg-red-100'}`}>\r\n                {isHydrationError ? (\r\n                  <RefreshCw className=\"h-8 w-8 text-yellow-600 animate-spin-slow\" aria-hidden=\"true\" />\r\n                ) : (\r\n                  <AlertTriangle className=\"h-8 w-8 text-red-600\" aria-hidden=\"true\" />\r\n                )}\r\n              </div>\r\n            </div>\r\n            <h2 className=\"mt-6 text-center text-3xl font-extrabold text-gray-900\">\r\n              {isHydrationError ? 'в•ӘВ«в•Әв•–в•ӘШ« в”ҳВҒв”ҳГЁ в”ҳГ в•Әв–“в•ӘШҜв”ҳГ в”ҳВҶв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ' : 'в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШІв”ҳГӘв”ҳГ©в•Әв•Ј'}\r\n            </h2>\r\n            <p className=\"mt-2 text-center text-sm text-gray-600\">\r\n              {isHydrationError \r\n                ? 'в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШІв•Әв•–в•ӘШ°в”ҳГЁв”ҳГ© в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–“в•ӘШҜв”ҳГ в”ҳВҶв•ӘШұ в•ӘШ°в”ҳГЁв”ҳВҶ в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШҜв•ӘВ»в”ҳГ  в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГ в•ӘШІв•Әв•Ўв”ҳВҒв•ӘШө. в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•Ўв”ҳВ„в•ӘШҜв•ӘШө...'\r\n                : 'в”ҳВҶв•Әв•Јв•ӘШІв•Әв–‘в•Әв–’ в•Әв•Јв”ҳВҶ в”ҳГ§в•Әв–‘в•ӘШҜ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв–“в•Әв•Јв•ӘШҜв•ӘШҙ. в”ҳВҒв•Әв–’в”ҳГЁв”ҳГ©в”ҳВҶв•ӘШҜ в”ҳГЁв•Әв•Јв”ҳГ в”ҳВ„ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШөв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Өв”ҳГўв”ҳВ„в•ӘШұ.'}\r\n            </p>\r\n            {errorId && (\r\n              <p className=\"mt-1 text-center text-xs text-gray-500\">\r\n                в•Әв–’в”ҳГ в•Әв–“ в•ӘШҜв”ҳВ„в•ӘВ«в•Әв•–в•ӘШ«: {errorId}\r\n              </p>\r\n            )}\r\n          </div>\r\n\r\n          <div className=\"mt-8 sm:mx-auto sm:w-full sm:max-w-md\">\r\n            <div className=\"bg-white py-8 px-4 shadow sm:rounded-lg sm:px-10\">\r\n              <div className=\"space-y-4\">\r\n                <div className=\"flex flex-col space-y-3\">\r\n                  <button\r\n                    onClick={this.handleRetry}\r\n                    className=\"w-full flex justify-center items-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500\"\r\n                  >\r\n                    <RefreshCw className={`ml-2 h-4 w-4 ${retryCount > 0 ? 'animate-spin' : ''}`} />\r\n                    в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ {retryCount > 0 && `(${retryCount})`}\r\n                  </button>\r\n\r\n                  <button\r\n                    onClick={this.handleGoHome}\r\n                    className=\"w-full flex justify-center items-center py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500\"\r\n                  >\r\n                    <Home className=\"ml-2 h-4 w-4\" />\r\n                    в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГӘв•ӘВ»в•ӘШұ в”ҳВ„в”ҳВ„в•Әв•Ўв”ҳВҒв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•Әв–’в•ӘШ®в”ҳГЁв•Әв”Ӯв”ҳГЁв•ӘШұ\r\n                  </button>\r\n\r\n                  {!isHydrationError && (\r\n                    <button\r\n                      onClick={this.handleReportError}\r\n                      className=\"w-full flex justify-center items-center py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500\"\r\n                    >\r\n                      <MessageCircle className=\"ml-2 h-4 w-4\" />\r\n                      в•ӘШӯв•ӘШ°в”ҳВ„в•ӘШҜв•Әв•‘ в•Әв•Јв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Өв”ҳГўв”ҳВ„в•ӘШұ\r\n                    </button>\r\n                  )}\r\n                </div>\r\n\r\n                <details className=\"mt-4\">\r\n                  <summary className=\"cursor-pointer text-sm font-medium text-gray-700\">\r\n                    в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Ўв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ«в•Әв•–в•ӘШ« (в”ҳВ„в”ҳВ„в”ҳГ в•Әв•–в”ҳГӘв•Әв–’в”ҳГЁв”ҳВҶ)\r\n                  </summary>\r\n                  <div className=\"mt-2 p-3 bg-gray-100 rounded-md text-xs text-gray-800 overflow-auto max-h-40\">\r\n                    <p className=\"font-semibold\">{error?.toString()}</p>\r\n                    <pre className=\"whitespace-pre-wrap mt-2\">{error?.stack}</pre>\r\n                    {this.state.errorInfo && (\r\n                      <pre className=\"whitespace-pre-wrap mt-2\">{this.state.errorInfo.componentStack}</pre>\r\n                    )}\r\n                  </div>\r\n                </details>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      );\r\n    }\r\n\r\n    return children;\r\n  }\r\n}\r\n\r\n/**\r\n * useErrorBoundary - в”ҳГ§в”ҳГӘв”ҳГў в”ҳВ„в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в•ӘШҜв”ҳГ  ErrorBoundary в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГӘв•Әв••в”ҳГЁв”ҳВҒв”ҳГЁв•ӘШұ\r\n */\r\nexport function useErrorBoundary() {\r\n  const [error, setError] = useState<Error | null>(null);\r\n  const [hasError, setHasError] = useState(false);\r\n\r\n  const resetError = useCallback(() => {\r\n    setError(null);\r\n    setHasError(false);\r\n  }, []);\r\n\r\n  const captureError = useCallback((err: Error) => {\r\n    setError(err);\r\n    setHasError(true);\r\n  }, []);\r\n\r\n  return {\r\n    error,\r\n    hasError,\r\n    resetError,\r\n    captureError\r\n  };\r\n}\r\n\r\n/**\r\n * withErrorBoundary - HOC в”ҳВ„в•ӘШІв•Әв•‘в”ҳВ„в”ҳГЁв”ҳВҒ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШ°в”ҳВҖ ErrorBoundary\r\n */\r\nexport function withErrorBoundary<P extends object>(\r\n  Component: React.ComponentType<P>,\r\n  errorBoundaryProps?: Omit<Props, 'children'>\r\n) {\r\n  const WrappedComponent = (props: P) => (\r\n    <ErrorBoundary {...errorBoundaryProps}>\r\n      <Component {...props} />\r\n    </ErrorBoundary>\r\n  );\r\n\r\n  WrappedComponent.displayName = `withErrorBoundary(${Component.displayName || Component.name})`;\r\n  return WrappedComponent;\r\n}\r\n\r\nexport default ErrorBoundary;\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\components\\error-pages.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\components\\examples\\ContactFormExample.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'saveFormData' is assigned a value but never used. Allowed unused vars must match /^_/u.","line":18,"column":5,"nodeType":"Identifier","messageId":"unusedVar","endLine":18,"endColumn":17},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'restoreField' is assigned a value but never used. Allowed unused vars must match /^_/u.","line":22,"column":5,"nodeType":"Identifier","messageId":"unusedVar","endLine":22,"endColumn":17}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"ЩҠв•—в”җ'use client';\r\n\r\nimport { useState } from 'react';\r\nimport { useFormPersistence as useSessionPersistence } from '@/hooks/use-form-persistence';\r\n\r\nimport { logger } from '@/lib/logger';\r\n\r\ninterface ContactFormData {\r\n  name: string;\r\n  email: string;\r\n  message: string;\r\n  newsletter: boolean;\r\n}\r\n\r\nexport default function ContactPage() {\r\n  // в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в•ӘШҜв”ҳГ  в•ӘШҜв”ҳВ„в”ҳВҖ hook в•ӘШҜв”ҳВ„в•Әв”Өв•ӘШҜв”ҳГ в”ҳВ„ в”ҳВ„в•ӘШөв”ҳВҒв•Әв•• в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШұ\r\n  const {\r\n    saveFormData,\r\n    restoreFormData,\r\n    clearFormData,\r\n    saveField,\r\n    restoreField\r\n  } = useSessionPersistence<ContactFormData>(\r\n    'contact-form', // в”ҳГ в•Әв•Јв•Әв–’в”ҳВҒ в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ в”ҳГӘв•Әв–‘в•ӘШҙ\r\n    {\r\n      name: '',\r\n      email: '',\r\n      message: '',\r\n      newsletter: false\r\n    },\r\n    {\r\n      debounceMs: 300, // в•ӘШөв”ҳВҒв•Әв•• в”ҳГўв”ҳВ„ 300ms\r\n      excludeFields: [], // в”ҳВ„в•ӘШҜ в”ҳВҶв•Әв”Ӯв•ӘШІв•ӘШ°в•Әв•Јв•ӘВ» в•ӘШ«в”ҳГЁ в•ӘШөв”ҳГ©в”ҳГӘв”ҳВ„\r\n      autoSave: true\r\n    }\r\n  );\r\n\r\n  // в•ӘШҜв•Әв”Ӯв•ӘШІв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГӘв”ҳВ„в”ҳГЁ\r\n  const [formData, setFormData] = useState<ContactFormData>(() => restoreFormData());\r\n\r\n  // в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в•ӘШөв”ҳГ©в”ҳВ„ в”ҳГ в•Әв•Јв”ҳГЁв”ҳВҶ\r\n  const updateField = (field: keyof ContactFormData, value: any) => {\r\n    const newData = { ...formData, [field]: value };\r\n    setFormData(newData);\r\n    saveField(field, value); // в•ӘШөв”ҳВҒв•Әв•• в•ӘШҜв”ҳВ„в•ӘШөв”ҳГ©в”ҳВ„ в”ҳВҒв”ҳГӘв•Әв–’в•ӘШҜв”ҳГҜ\r\n  };\r\n\r\n  // в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ в”ҳГӘв•Әв–‘в•ӘШҙ\r\n  const handleSubmit = (e: React.FormEvent) => {\r\n    e.preventDefault();\r\n    logger.info('в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ:', formData);\r\n\r\n    // в”ҳГ в•Әв”Ӯв•ӘШө в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШ°в•Әв•Јв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳВҶв•ӘШҜв•ӘШҙв•ӘШө\r\n    clearFormData();\r\n    setFormData({\r\n      name: '',\r\n      email: '',\r\n      message: '',\r\n      newsletter: false\r\n    });\r\n\r\n    alert('в•ӘШІв”ҳГ  в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ в”ҳГӘв•Әв–‘в•ӘШҙ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө!');\r\n  };\r\n\r\n  return (\r\n    <div className=\"max-w-2xl mx-auto p-6\">\r\n      <h1 className=\"text-2xl font-bold mb-6\">в•ӘШҜв•ӘШІв•Әв•Ўв”ҳВ„ в•ӘШ°в”ҳВҶв•ӘШҜ</h1>\r\n\r\n      <form onSubmit={handleSubmit} className=\"space-y-4\">\r\n        <div>\r\n          <label htmlFor=\"name\" className=\"block text-sm font-medium mb-1\">\r\n            в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв”ҳГ \r\n          </label>\r\n          <input\r\n            type=\"text\"\r\n            id=\"name\"\r\n            value={formData.name}\r\n            onChange={(e) => updateField('name', e.target.value)}\r\n            className=\"w-full p-2 border rounded-md\"\r\n            placeholder=\"в•ӘШ«в•ӘВ»в•ӘВ«в”ҳВ„ в•ӘШҜв•Әв”Ӯв”ҳГ в”ҳГў\"\r\n          />\r\n        </div>\r\n\r\n        <div>\r\n          <label htmlFor=\"email\" className=\"block text-sm font-medium mb-1\">\r\n            в•ӘШҜв”ҳВ„в•ӘШ°в•Әв–’в”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВ„в”ҳГўв•ӘШІв•Әв–’в”ҳГӘв”ҳВҶв”ҳГЁ\r\n          </label>\r\n          <input\r\n            type=\"email\"\r\n            id=\"email\"\r\n            value={formData.email}\r\n            onChange={(e) => updateField('email', e.target.value)}\r\n            className=\"w-full p-2 border rounded-md\"\r\n            placeholder=\"в•ӘШ«в•ӘВ»в•ӘВ«в”ҳВ„ в•ӘШ°в•Әв–’в”ҳГЁв•ӘВ»в”ҳГў в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВ„в”ҳГўв•ӘШІв•Әв–’в”ҳГӘв”ҳВҶв”ҳГЁ\"\r\n          />\r\n        </div>\r\n\r\n        <div>\r\n          <label htmlFor=\"message\" className=\"block text-sm font-medium mb-1\">\r\n            в•ӘШҜв”ҳВ„в•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„в•ӘШұ\r\n          </label>\r\n          <textarea\r\n            id=\"message\"\r\n            value={formData.message}\r\n            onChange={(e) => updateField('message', e.target.value)}\r\n            rows={4}\r\n            className=\"w-full p-2 border rounded-md\"\r\n            placeholder=\"в•ӘШҜв”ҳГўв•ӘШІв•ӘШ° в•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„в•ӘШІв”ҳГў в”ҳГ§в”ҳВҶв•ӘШҜ\"\r\n          />\r\n        </div>\r\n\r\n        <div className=\"flex items-center\">\r\n          <input\r\n            type=\"checkbox\"\r\n            id=\"newsletter\"\r\n            checked={formData.newsletter}\r\n            onChange={(e) => updateField('newsletter', e.target.checked)}\r\n            className=\"mr-2\"\r\n          />\r\n          <label htmlFor=\"newsletter\" className=\"text-sm\">\r\n            в•ӘШҜв•Әв”Өв•ӘШІв•Әв–’в”ҳГў в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Өв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШӯв•ӘВ«в•ӘШ°в•ӘШҜв•Әв–’в”ҳГЁв•ӘШұ\r\n          </label>\r\n        </div>\r\n\r\n        <div className=\"flex gap-4\">\r\n          <button\r\n            type=\"submit\"\r\n            className=\"bg-blue-500 text-white px-6 py-2 rounded-md hover:bg-blue-600\"\r\n          >\r\n            в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„\r\n          </button>\r\n          <button\r\n            type=\"button\"\r\n            onClick={() => {\r\n              clearFormData();\r\n              setFormData({\r\n                name: '',\r\n                email: '',\r\n                message: '',\r\n                newsletter: false\r\n              });\r\n            }}\r\n            className=\"bg-gray-500 text-white px-6 py-2 rounded-md hover:bg-gray-600\"\r\n          >\r\n            в”ҳГ в•Әв”Ӯв•ӘШө в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ\r\n          </button>\r\n        </div>\r\n      </form>\r\n\r\n      <div className=\"mt-8 p-4 bg-gray-100 rounded-md\">\r\n        <h2 className=\"text-lg font-semibold mb-2\">в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв”ҳВҒв”ҳГӘв•Әв••в•ӘШұ:</h2>\r\n        <pre className=\"text-sm\">\r\n          {JSON.stringify(formData, null, 2)}\r\n        </pre>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\components\\features\\Hero.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Link' is defined but never used. Allowed unused vars must match /^_/u.","line":1,"column":8,"nodeType":"Identifier","messageId":"unusedVar","endLine":1,"endColumn":12,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"Link"},"fix":{"range":[0,31],"text":""},"desc":"Remove unused import declaration."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"ЩҠв•—в”җimport Link from \"next/link\";\r\nimport { Button } from \"@/components/ui/button\";\r\nimport { ArrowRight, Sparkles } from \"lucide-react\";\r\n\r\nexport function Hero() {\r\n  return (\r\n    <section className=\"relative overflow-hidden pt-32 pb-20 lg:pt-40 lg:pb-32\">\r\n      <div className=\"container px-4 text-center\">\r\n        {/* Badge */}\r\n        <div className=\"mx-auto mb-8 flex max-w-fit items-center gap-2 rounded-full border bg-muted/50 px-4 py-1.5 backdrop-blur-sm\">\r\n          <Sparkles className=\"h-4 w-4 text-primary\" />\r\n          <span className=\"text-sm font-medium\">New Feature: AI Tutor</span>\r\n        </div>\r\n\r\n        {/* Heading */}\r\n        <h1 className=\"mx-auto mb-6 max-w-4xl text-5xl font-extrabold tracking-tight sm:text-6xl lg:text-7xl\">\r\n          Master Your Studies with <br />\r\n          <span className=\"bg-gradient-to-r from-primary to-blue-600 bg-clip-text text-transparent\">\r\n            AI-Powered Learning\r\n          </span>\r\n        </h1>\r\n\r\n        {/* Subheading */}\r\n        <p className=\"mx-auto mb-10 max-w-2xl text-lg text-muted-foreground sm:text-xl\">\r\n          Tolo provides personalized learning paths, real-time progress tracking, and interactive quizzes to help you excel in your exams.\r\n        </p>\r\n\r\n        {/* CTA Buttons */}\r\n        <div className=\"flex flex-col items-center justify-center gap-4 sm:flex-row\">\r\n          <Button size=\"lg\" className=\"h-12 min-w-[200px] px-8 text-base\">\r\n            Start Learning Now\r\n            <ArrowRight className=\"ml-2 h-4 w-4\" />\r\n          </Button>\r\n          <Button size=\"lg\" variant=\"outline\" className=\"h-12 min-w-[200px] px-8 text-base\">\r\n            View Analytics\r\n          </Button>\r\n        </div>\r\n\r\n        {/* Visual Element (Gradient Blob) */}\r\n        <div className=\"absolute top-1/2 left-1/2 -z-10 h-[800px] w-[800px] -translate-x-1/2 -translate-y-1/2 opacity-20 dark:opacity-40\">\r\n           <div className=\"absolute inset-0 rounded-full bg-gradient-to-r from-primary to-blue-600 blur-[100px]\" />\r\n        </div>\r\n      </div>