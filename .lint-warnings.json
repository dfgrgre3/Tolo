ty":1,"message":"'TransactionSkeleton' is defined but never used. Allowed unused vars must match /^_/u.","line":39,"column":44,"nodeType":"Identifier","messageId":"unusedVar","endLine":39,"endColumn":63,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"TransactionSkeleton"},"fix":{"range":[686,707],"text":""},"desc":"Remove unused variable \"TransactionSkeleton\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'error' is defined but never used. Allowed unused caught errors must match /^_/u.","line":252,"column":14,"nodeType":"Identifier","messageId":"unusedVar","endLine":252,"endColumn":19}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":10,"fixableErrorCount":0,"fixableWarningCount":0,"source":"ЩҠв•—в”җ\"use client\";\n\nimport React, { useState, useEffect, useMemo } from \"react\";\nimport { \n  Wallet, \n  ArrowUpRight, \n  ArrowDownLeft, \n  History, \n  CreditCard, \n  Plus, \n  Download,\n  Receipt,\n  Search,\n  ChevronRight,\n  TrendingUp,\n  ShieldCheck,\n  Zap,\n  ArrowRight,\n  Activity,\n  Calendar,\n  DollarSign,\n  Sparkles,\n  Star,\n  Loader2\n} from \"lucide-react\";\nimport { motion, AnimatePresence } from \"framer-motion\";\nimport { toast } from \"sonner\";\nimport { format } from \"date-fns\";\nimport { ar } from \"date-fns/locale\";\nimport { \n  AreaChart, \n  Area, \n  XAxis, \n  YAxis, \n  CartesianGrid, \n  Tooltip, \n  ResponsiveContainer \n} from 'recharts';\nimport { WalletHeroSkeleton, CardSkeleton, TransactionSkeleton } from \"./BillingSkeletons\";\n\ninterface Transaction {\n  id: string;\n  amount: number;\n  type: string;\n  status: string;\n  description: string;\n  createdAt: string;\n}\n\ninterface Invoice {\n  id: string;\n  invoiceNumber: string;\n  amount: number;\n  status: string;\n  issueDate: string;\n  pdfUrl?: string;\n}\n\nconst statusMap: Record<string, { label: string, color: string }> = {\n  \"COMPLETED\": { label: \"в”ҳГ в”ҳГўв•ӘШІв”ҳГ в”ҳВ„\", color: \"text-emerald-500 bg-emerald-500/10 border-emerald-500/20\" },\n  \"SUCCESS\": { label: \"в”ҳВҶв•ӘШҜв•ӘШҙв•ӘШө\", color: \"text-emerald-500 bg-emerald-500/10 border-emerald-500/20\" },\n  \"PAID\": { label: \"в”ҳГ в•ӘВ»в”ҳВҒв”ҳГӘв•Әв•Ј\", color: \"text-emerald-500 bg-emerald-500/10 border-emerald-500/20\" },\n  \"PENDING\": { label: \"в”ҳГ©в”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШҜв”ҳВҶв•ӘШІв•Әв••в•ӘШҜв•Әв–’\", color: \"text-amber-500 bg-amber-500/10 border-amber-500/20\" },\n  \"FAILED\": { label: \"в”ҳВҒв•Әв”Өв”ҳВ„\", color: \"text-rose-500 bg-rose-500/10 border-rose-500/20\" },\n  \"CANCELLED\": { label: \"в”ҳГ в”ҳВ„в•Әв•‘в”ҳГЁ\", color: \"text-gray-500 bg-gray-500/10 border-gray-500/20\" },\n};\n\nconst typeMap: Record<string, { label: string, icon: any, color: string, bg: string }> = {\n  \"DEPOSIT\": { label: \"в•ӘШӯв”ҳГЁв•ӘВ»в•ӘШҜв•Әв•Ј\", icon: ArrowUpRight, color: \"text-emerald-500\", bg: \"bg-emerald-500/10\" },\n  \"PAYMENT\": { label: \"в”ҳГ в•ӘВ»в”ҳВҒв”ҳГӘв•Әв•Јв•ӘШҜв•ӘШІ\", icon: ArrowDownLeft, color: \"text-rose-500\", bg: \"bg-rose-500/10\" },\n  \"REFUND\": { label: \"в•ӘШҜв•Әв”Ӯв•ӘШІв•Әв–’в•ӘВ»в•ӘШҜв•ӘВ»\", icon: History, color: \"text-blue-500\", bg: \"bg-blue-500/10\" },\n  \"REFERRAL_REWARD\": { label: \"в”ҳГ в”ҳГўв•ӘШҜв”ҳВҒв•ӘШ«в•ӘШұ\", icon: TrendingUp, color: \"text-amber-500\", bg: \"bg-amber-500/10\" },\n  \"BONUS\": { label: \"в•ӘШ°в”ҳГӘв”ҳВҶв•Әв•Ў\", icon: Zap, color: \"text-purple-500\", bg: \"bg-purple-500/10\" },\n};\n\nconst handleComingSoon = () => {\n  toast.info(\"в”ҳГ§в•Әв–‘в”ҳГ§ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГЁв•Әв–“в•ӘШұ в•Әв”Ӯв•ӘШІв”ҳГўв”ҳГӘв”ҳВҶ в”ҳГ в•ӘШІв•ӘШҜв•ӘШөв•ӘШұ в”ҳГ©в•Әв–’в”ҳГЁв•ӘШ°в•ӘШҜв”ҳГҜ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв•ӘВ»в”ҳГ \", {\n    description: \"в”ҳВҶв•ӘШөв”ҳВҶ в”ҳВҶв•Әв•Јв”ҳГ в”ҳВ„ в•ӘШ°в•ӘШҙв•ӘВ» в”ҳВ„в•ӘШІв”ҳГӘв”ҳВҒв”ҳГЁв•Әв–’ в•ӘШ«в”ҳВҒв•Әв•ўв”ҳВ„ в•ӘШІв•ӘШҙв•Әв–’в•ӘШ°в•ӘШұ в”ҳГ в•ӘШҜв”ҳВ„в”ҳГЁв•ӘШұ в”ҳВ„в”ҳГў.\",\n    duration: 3000,\n  });\n};\n\n// --- Enhanced Sub-components ---\n\nconst VirtualCard = ({ balance }: { balance: number }) => (\n  <motion.div \n    whileHover={{ rotateY: 5, rotateX: -5, scale: 1.02 }}\n    className=\"relative w-full aspect-[1.6/1] rounded-[2.5rem] p-8 overflow-hidden group shadow-[0_30px_60px_-15px_rgba(0,0,0,0.5)] cursor-pointer\"\n  >\n    <div className=\"absolute inset-0 bg-gradient-to-br from-primary via-purple-600 to-primary/80 transition-all duration-700 group-hover:hue-rotate-30\" />\n    <div className=\"absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-10 mix-blend-overlay\" />\n    <div className=\"absolute top-0 right-0 w-64 h-64 bg-white/20 blur-[100px] rounded-full -mr-32 -mt-32\" />\n    \n    <div className=\"relative h-full flex flex-col justify-between text-white z-10\">\n      <div className=\"flex justify-between items-start\">\n        <div className=\"space-y-1\">\n          <p className=\"text-[10px] font-black uppercase tracking-[0.3em] opacity-60\">в•ӘШІв”ҳГӘв”ҳВ„в”ҳГӘ в•ӘШ°в•Әв–’в”ҳГЁв”ҳГ в”ҳГЁв”ҳГӘв”ҳГ </p>\n          <div className=\"flex items-center gap-2\">\n            <Sparkles className=\"w-5 h-5 text-amber-300 animate-pulse\" />\n            <span className=\"font-black text-xl italic uppercase tracking-wider\">Tolo Platinum</span>\n          </div>\n        </div>\n        <div className=\"w-12 h-12 bg-white/20 rounded-xl backdrop-blur-md flex items-center justify-center border border-white/30\">\n          <Zap className=\"w-6 h-6 text-amber-300\" />\n        </div>\n      </div>\n\n      <div className=\"space-y-4\">\n        <div className=\"space-y-1\">\n           <p className=\"text-[10px] font-black uppercase tracking-[0.2em] opacity-60\">в•ӘШҜв”ҳВ„в•Әв–’в•Әв•Ўв”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в”ҳГ в•ӘШІв•ӘШҜв•ӘШө</p>\n           <h3 className=\"text-4xl font-black tracking-tight\">{balance.toLocaleString()} <span className=\"text-lg font-bold opacity-60\">в•ӘШҙ.в”ҳГ </span></h3>\n        </div>\n        <div className=\"flex justify-between items-end\">\n          <div className=\"flex gap-4\">\n            <div className=\"space-y-1\">\n              <p className=\"text-[8px] font-black uppercase opacity-40\">в•Әв•Ўв•ӘШҜв”ҳВ„в•ӘШө в•ӘШөв•ӘШІв”ҳГ«</p>\n              <p className=\"text-xs font-black\">12/30</p>\n            </div>\n            <div className=\"space-y-1\">\n              <p className=\"text-[8px] font-black uppercase opacity-40\">в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв”ҳГ </p>\n              <p className=\"text-xs font-black\">в•ӘШ«в•ӘШөв”ҳГ в•ӘВ» в”ҳГ в•ӘШөв”ҳГ в•ӘВ»</p>\n            </div>\n          </div>\n          <div className=\"flex items-center -space-x-4\">\n             <div className=\"w-10 h-10 rounded-full bg-white/20 backdrop-blur-sm border border-white/40\" />\n             <div className=\"w-10 h-10 rounded-full bg-white/20 backdrop-blur-sm border border-white/40\" />\n          </div>\n        </div>\n      </div>\n    </div>\n  </motion.div>\n);\n\nconst DepositModal = ({ isOpen, onClose, onDeposit }: { isOpen: boolean, onClose: () => void, onDeposit: (amount: number) => void }) => {\n  const [amount, setAmount] = useState(\"\");\n  const [loading, setLoading] = useState(false);\n\n  const handleSubmit = async () => {\n    const val = parseFloat(amount);\n    if (!val || val <= 0) return toast.error(\"в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШӯв•ӘВ»в•ӘВ«в•ӘШҜв”ҳВ„ в”ҳГ в•ӘШ°в”ҳВ„в•Әв•‘ в•Әв•Ўв•ӘШөв”ҳГЁв•ӘШө\");\n    setLoading(true);\n    await onDeposit(val);\n    setLoading(false);\n    onClose();\n  };\n\n  return (\n    <AnimatePresence>\n      {isOpen && (\n        <div className=\"fixed inset-0 z-[100] flex items-center justify-center p-4\">\n          <motion.div \n            initial={{ opacity: 0 }} \n            animate={{ opacity: 1 }} \n            exit={{ opacity: 0 }}\n            onClick={onClose}\n            className=\"absolute inset-0 bg-[#07080f]/90 backdrop-blur-md\" \n          />\n          <motion.div \n            initial={{ opacity: 0, scale: 0.9, y: 20 }}\n            animate={{ opacity: 1, scale: 1, y: 0 }}\n            exit={{ opacity: 0, scale: 0.9, y: 20 }}\n            className=\"relative w-full max-w-lg bg-[#111322] border border-white/10 rounded-[3rem] p-10 shadow-2xl overflow-hidden\"\n          >\n            <div className=\"absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-primary to-purple-600\" />\n            \n            <div className=\"flex justify-between items-start mb-10\">\n              <div className=\"space-y-2\">\n                <h3 className=\"text-3xl font-black text-white\">в•Әв”Өв•ӘШөв”ҳВҶ в•ӘШҜв”ҳВ„в•Әв–’в•Әв•Ўв”ҳГЁв•ӘВ»</h3>\n                <p className=\"text-gray-400 font-medium\">в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШ°в”ҳВ„в•Әв•‘ в•ӘШҜв”ҳВ„в•Әв–‘в”ҳГЁ в•ӘШІв”ҳГӘв•ӘВ» в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШІв”ҳГ§ в”ҳВ„в”ҳГ в•ӘШөв”ҳВҒв•Әв••в•ӘШІв”ҳГў в”ҳВҒв”ҳГӘв•Әв–’в•ӘШҜв”ҳГҜ.</p>\n              </div>\n              <button onClick={onClose} className=\"p-3 bg-white/5 hover:bg-white/10 rounded-2xl transition-colors\">\n                <ArrowRight className=\"w-6 h-6 text-white rotate-180\" />\n              </button>\n            </div>\n\n            <div className=\"space-y-8\">\n              <div className=\"relative\">\n                <DollarSign className=\"absolute right-6 top-1/2 -translate-y-1/2 w-8 h-8 text-primary\" />\n                <input \n                  type=\"number\" \n                  value={amount}\n                  onChange={(e) => setAmount(e.target.value)}\n                  placeholder=\"0.00\"\n                  className=\"w-full bg-white/5 border border-white/10 rounded-[2.2rem] py-8 px-20 text-4xl font-black text-white outline-none focus:border-primary/50 transition-all text-center\"\n                />\n                <span className=\"absolute left-6 top-1/2 -translate-y-1/2 text-xl font-bold text-gray-500\">в•ӘШҙ.в”ҳГ </span>\n              </div>\n\n              <div className=\"grid grid-cols-3 gap-4\">\n                {[50, 100, 250].map((num) => (\n                  <button \n                    key={num}\n                    onClick={() => setAmount(num.toString())}\n                    className=\"py-4 rounded-2xl border border-white/10 bg-white/5 hover:bg-primary hover:text-white font-black transition-all transform active:scale-95\"\n                  >\n                    +{num}\n                  </button>\n                ))}\n              </div>\n\n              <button \n                onClick={handleSubmit}\n                disabled={loading}\n                className=\"w-full py-6 rounded-[2rem] bg-primary hover:bg-primary/90 text-white font-black text-xl transition-all shadow-2xl shadow-primary/30 flex items-center justify-center gap-4 active:scale-[0.98] disabled:opacity-70\"\n              >\n                {loading ? <Loader2 className=\"w-7 h-7 animate-spin\" /> : <Zap className=\"w-6 h-6\" />}\n                {loading ? \"в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Јв•ӘШҜв”ҳВ„в•ӘШҙв•ӘШұ...\" : \"в•ӘШІв•ӘШ«в”ҳГўв”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в•Әв”Өв•ӘШөв”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШӘв”ҳВҶ\"}\n              </button>\n            </div>\n            \n            <div className=\"mt-8 flex items-center justify-center gap-3 text-[10px] text-gray-500 font-black uppercase tracking-widest bg-white/5 py-4 rounded-2xl border border-white/5\">\n               <ShieldCheck className=\"w-4 h-4 text-emerald-500\" />\n               в•ӘШ°в”ҳГӘв•ӘШҜв•ӘШ°в•ӘШҜв•ӘШІ в•ӘВ»в”ҳВҒв•Әв•Ј в”ҳГ в•Әв”Өв”ҳВҒв•Әв–’в•ӘШұ в”ҳГӘв•ӘШӘв”ҳГ в”ҳВҶв•ӘШұ в•ӘШІв”ҳГ в•ӘШҜв”ҳГ в•ӘШҜв”ҳГҜ\n            </div>\n          </motion.div>\n        </div>\n      )}\n    </AnimatePresence>\n  );\n};\n\nconst copyToClipboard = (text: string) => {\n  navigator.clipboard.writeText(text);\n  toast.success(\"в•ӘШІв”ҳГ  в”ҳВҶв•Әв”Ӯв•ӘВ« в•Әв–’в”ҳГ©в”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Јв•ӘШҜв”ҳГ в”ҳВ„в•ӘШұ\");\n};\n\nexport default function WalletDashboard() {\n  const [balance, setBalance] = useState(0);\n  const [transactions, setTransactions] = useState<Transaction[]>([]);\n  const [invoices, setInvoices] = useState<Invoice[]>([]);\n  const [loading, setLoading] = useState(true);\n  const [activeTab, setActiveTab] = useState<\"activity\" | \"invoices\">(\"activity\");\n  const [isDepositModalOpen, setIsDepositModalOpen] = useState(false);\n\n  useEffect(() => {\n    fetchData();\n  }, []);\n\n  const fetchData = async () => {\n    try {\n      const [walletRes, invoiceRes] = await Promise.all([\n        fetch(\"/api/billing/wallet\"),\n        fetch(\"/api/billing/invoices\")\n      ]);\n      \n      const walletData = await walletRes.json();\n      const invoiceData = await invoiceRes.json();\n\n      setBalance(walletData.balance || 0);\n      setTransactions(walletData.history || []);\n      setInvoices(invoiceData.invoices || []);\n    } catch (error) {\n      toast.error(\"в”ҳВҒв•Әв”Өв”ҳВ„ в”ҳВҒв”ҳГЁ в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„ в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв”ҳВҒв•Әв••в•ӘШұ\");\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  const handleDeposit = async (amount: number) => {\n    try {\n      const res = await fetch(\"/api/billing/wallet\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ amount })\n      });\n      const data = await res.json();\n      if (!res.ok) throw new Error(data.error || \"в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв”Өв•ӘШөв”ҳВҶ\");\n      \n      setBalance(data.balance);\n      toast.success(data.message);\n      fetchData(); // Refresh history\n    } catch (err: any) {\n      toast.error(err.message);\n    }\n  };\n\n  const chartData = useMemo(() => {\n    if (transactions.length === 0) return [];\n    \n    let currentBalance = balance;\n    const history = [...transactions].reverse().map(tx => {\n      const point = {\n        name: format(new Date(tx.createdAt), \"dd MMM\", { locale: ar }),\n        balance: currentBalance\n      };\n      currentBalance -= tx.amount; \n      return point;\n    }).reverse();\n\n    return history;\n  }, [transactions, balance]);\n\n  const stats = useMemo(() => {\n    const now = new Date();\n    const thisMonth = transactions.filter(tx => {\n      const date = new Date(tx.createdAt);\n      return date.getMonth() === now.getMonth() && date.getFullYear() === now.getFullYear();\n    });\n\n    const spent = Math.abs(thisMonth.filter(tx => tx.amount < 0).reduce((acc, curr) => acc + curr.amount, 0));\n    const received = thisMonth.filter(tx => tx.amount > 0).reduce((acc, curr) => acc + curr.amount, 0);\n\n    return { spent, received };\n  }, [transactions]);\n\n  const groupedTransactions = useMemo(() => {\n    const groups: Record<string, Transaction[]> = {};\n    transactions.forEach(tx => {\n      const date = format(new Date(tx.createdAt), \"yyyy-MM-dd\");\n      if (!groups[date]) groups[date] = [];\n      groups[date].push(tx);\n    });\n    return groups;\n  }, [transactions]);\n\n  return (\n    <div className=\"space-y-12\" dir=\"rtl\">\n      <DepositModal \n        isOpen={isDepositModalOpen} \n        onClose={() => setIsDepositModalOpen(false)} \n        onDeposit={handleDeposit} \n      />\n\n      {/* Hero Section */}\n      {loading ? (\n        <WalletHeroSkeleton />\n      ) : (\n        <section className=\"relative overflow-hidden rounded-[4rem] bg-gradient-to-br from-[#1a1c2e] via-[#101222] to-[#010205] p-1 shadow-[0_40px_100px_rgba(0,0,0,0.5)]\">\n          <div className=\"absolute top-0 right-0 -mr-20 -mt-20 w-[600px] h-[600px] bg-primary/20 rounded-full blur-[120px] opacity-40 pointer-events-none\" />\n          <div className=\"absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 bg-purple-500/20 rounded-full blur-[100px] opacity-40 pointer-events-none\" />\n          \n          <div className=\"relative rounded-[3.9rem] bg-[#101222]/40 backdrop-blur-3xl p-8 md:p-16\">\n            <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-16 items-center\">\n              {/* Card & Chart Group */}\n              <div className=\"space-y-12\">\n                <VirtualCard balance={balance} />\n                \n                <div className=\"flex flex-wrap gap-6\">\n                  <motion.button \n                    whileHover={{ scale: 1.05 }}\n                    whileTap={{ scale: 0.95 }}\n                    onClick={() => setIsDepositModalOpen(true)}\n                    className=\"group relative overflow-hidden bg-primary px-12 py-6 rounded-[2.2rem] font-black text-white shadow-[0_20px_50px_rgba(var(--primary-rgb),0.5)] flex items-center gap-4 transition-all\"\n                  >\n                    <Plus className=\"w-7 h-7\" />\n                    <span className=\"text-xl\">в•Әв”Өв•ӘШөв”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°</span>\n                    <div className=\"absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-500\" />\n                  </motion.button>\n                  <motion.button \n                    whileHover={{ scale: 1.05 }}\n                    whileTap={{ scale: 0.95 }}\n                    onClick={handleComingSoon}\n                    className=\"group px-12 py-6 rounded-[2.2rem] border-2 border-white/10 bg-white/5 text-white font-black backdrop-blur-xl transition-all hover:bg-white/10 hover:border-white/20 flex items-center gap-4\"\n                  >\n                    <ArrowUpRight className=\"w-7 h-7 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform\" />\n                    <span className=\"text-xl\">в•Әв”Ӯв•ӘШөв•ӘШ° в”ҳВҶв”ҳГ©в•ӘВ»в”ҳГЁ</span>\n                  </motion.button>\n                </div>\n              </div>\n\n              {/* Progress & Stats */}\n              <div className=\"space-y-10\">\n                <div className=\"h-[280px] w-full bg-white/5 rounded-[3rem] p-8 border border-white/10 backdrop-blur-sm relative group overflow-hidden shadow-inner\">\n                  <div className=\"flex justify-between items-center mb-6\">\n                    <div className=\"flex items-center gap-4\">\n                      <div className=\"p-2 bg-primary/20 rounded-xl\">\n                        <Activity className=\"w-5 h-5 text-primary\" />\n                      </div>\n                      <span className=\"text-sm font-black text-gray-300 uppercase tracking-[0.2em]\">в•ӘШІв•ӘШөв”ҳВ„в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ в”ҳГӘ</span>\n                    </div>\n                    <div className=\"text-[10px] bg-emerald-500/10 text-emerald-500 font-black px-3 py-1 rounded-full border border-emerald-500/20\">в•Әв•Ўв•ӘШҜв•Әв•Јв•ӘВ» +12%</div>\n                  </div>\n                  \n                  <div className=\"h-full\">\n                    {chartData.length > 1 ? (\n                      <ResponsiveContainer width=\"100%\" height=\"80%\">\n                        <AreaChart data={chartData}>\n                          <defs>\n                            <linearGradient id=\"colorBalance\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                              <stop offset=\"5%\" stopColor=\"#8b5cf6\" stopOpacity={0.5}/>\n                              <stop offset=\"95%\" stopColor=\"#8b5cf6\" stopOpacity={0}/>\n                            </linearGradient>\n                          </defs>\n                          <Tooltip \n                             contentStyle={{ backgroundColor: '#07080f', border: '1px solid rgba(255,255,255,0.1)', borderRadius: '20px', color: '#fff', boxShadow: '0 20px 40px rgba(0,0,0,0.5)' }}\n                             itemStyle={{ color: '#fff', fontWeight: '900' }}\n                             cursor={{ stroke: '#8b5cf6', strokeWidth: 2, strokeDasharray: '5 5' }}\n                          />\n                          <Area \n                            type=\"monotone\" \n                            dataKey=\"balance\" \n                            stroke=\"#8b5cf6\" \n                            strokeWidth={6} \n                            fillOpacity=