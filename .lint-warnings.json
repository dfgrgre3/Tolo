opacity: 0, scale: 0.9 }}\r\n\t\t\t\t\t\t\t\t\tclassName={STYLES.glass + \" border-primary/40 bg-primary/5 p-8 relative overflow-hidden group\"}\r\n\t\t\t\t\t\t\t\t>\r\n\t\t\t\t\t\t\t\t\t<div className=\"absolute inset-0 bg-primary/10 opacity-0 group-hover:opacity-100 transition-opacity\" />\r\n\t\t\t\t\t\t\t\t\t<div className=\"relative z-10 flex flex-col md:flex-row items-center justify-between gap-8\">\r\n\t\t\t\t\t\t\t\t\t\t<div className=\"flex items-center gap-6\">\r\n\t\t\t\t\t\t\t\t\t\t\t<div className=\"h-16 w-16 rounded-3xl bg-amber-500 flex items-center justify-center text-4xl animate-bounce shadow-lg shadow-amber-500/30\">\r\n\t\t\t\t\t\t\t\t\t\t\t\tв”ҳГҜв”Ңв•‘в”ҢШЎШёВҖв–‘\r\n\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t\t<div className=\"space-y-1 text-center md:text-right\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t<h3 className=\"text-2xl font-black text-white\">в”ҳГЁв”ҳГӘв”ҳГ  в•Әв•Јв•Әв••в”ҳГЁв”ҳГ  в”ҳВ„в”ҳВ„в•ӘШҙв”ҳГ в”ҳГ§в”ҳГӘв•Әв–’в”ҳГЁв•ӘШұ!</h3>\r\n\t\t\t\t\t\t\t\t\t\t\t\t<p className=\"text-gray-400 font-medium\">в”ҳВ„в”ҳГ©в•ӘВ» в•ӘШөв•Әв•Ўв”ҳВ„в•ӘШІ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШ«в•Әв”Ӯв•ӘШҜв•Әв•–в”ҳГЁв•Әв–’ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ в•ӘШІв”ҳВ„в”ҳГЁв”ҳГ© в•ӘШ°в”ҳГ в”ҳГ©в•ӘШҜв”ҳГ в”ҳГў в•ӘШҜв”ҳВ„в•Әв•Јв•ӘШҜв”ҳВ„в”ҳГЁ. в•ӘШІв”ҳВҒв”ҳГ©в•ӘВ» в•Әв”Ӯв•ӘШҙв”ҳВ„в•ӘШҜв•ӘШІв”ҳГў в•ӘШҜв”ҳВ„в•ӘШӘв”ҳВҶ!</p>\r\n\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t<Button variant=\"ghost\" onClick={() => setShowCelebration(false)} className=\"h-12 px-6 rounded-xl hover:bg-white/5 uppercase font-black text-xs tracking-widest text-gray-500\">в•ӘШӯв•Әв•‘в”ҳВ„в•ӘШҜв”ҳГ© в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҶв•ӘШ°в”ҳГЁв”ҳГ§</Button>\r\n\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t</motion.div>\r\n\t\t\t\t\t\t\t)}\r\n\t\t\t\t\t\t</AnimatePresence>\r\n\r\n\t\t\t\t\t\t{/* Statistics */}\r\n\t\t\t\t\t\t{stats && (\r\n\t\t\t\t\t\t\t<motion.div initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} transition={{ delay: 0.1 }}>\r\n\t\t\t\t\t\t\t\t<AchievementStats st