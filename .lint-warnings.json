ed-2xl shadow-xl shadow-amber-500/20\">\n                  <Star className=\"w-6 h-6 text-white\" />\n                </div>\n                <h4 className=\"text-xl font-black text-white\">в”ҳВҶв•Әв••в•ӘШҜв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГӘв”ҳВ„в•ӘШҜв•ӘШ©</h4>\n              </div>\n              <div className=\"space-y-6\">\n                <div className=\"bg-white/5 p-5 rounded-2xl border border-white/5\">\n                   <div className=\"flex justify-between items-center mb-3\">\n                      <span className=\"text-xs font-black text-gray-400\">в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГӘв”ҳГ« в•ӘШҜв”ҳВ„в•ӘШІв”ҳГ©в•ӘВ»в”ҳГ </span>\n                      <span className=\"text-xs font-black text-amber-500\">Gold Tier</span>\n                   </div>\n                   <div className=\"h-2 w-full bg-white/5 rounded-full overflow-hidden\">\n                      <motion.div initial={{ width: 0 }} animate={{ width: \"75%\" }} className=\"h-full bg-amber-500 shadow-[0_0_15px_rgba(245,158,11,0.5)]\" />\n                   </div>\n                </div>\n                <button \n                  onClick={handleComingSoon}\n                  className=\"w-full py-4 rounded-2xl bg-white text-gray-900 font-black text-sm hover:bg-amber-500 hover:text-white transition-all transform active:scale-95\"\n                >\n                  в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘШ°в•ӘВ»в•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ©в•ӘШҜв•Әв•–\n                </button>\n              </div>\n           </div>\n\n           {/* Support */}\n           <div className=\"p-8 rounded-[3rem] bg-[#111322] border border-white/5 flex flex-col items-center text-center gap-6 group\">\n              <div className=\"w-20 h-20 rounded-full bg-primary/10 flex items-center justify-center group-hover:scale-110 transition-transform\">\n                 <Zap className=\"w-10 h-10 text-primary animate-pulse\" />\n              </div>\n              <div className=\"space-y-2\">\n                 <h4 className=\"text-xl font-black text-white\">в•ӘВ»