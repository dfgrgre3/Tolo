         isSettingsOpen && \"rotate-90\",\r\n                )}\r\n              />\r\n            </button>\r\n            <button onClick={toggleFullscreen}>\r\n              {isFullscreen ? (\r\n                <Minimize className=\"h-5 w-5 text-white\" />\r\n              ) : (\r\n                <Maximize className=\"h-5 w-5 text-white\" />\r\n              )}\r\n            </button>\r\n          </div>\r\n        </div>\r\n\r\n        {/* Speed Menu */}\r\n        <AnimatePresence>\r\n          {isSettingsOpen && (\r\n            <motion.div\r\n              initial={{ opacity: 0, y: 10 }}\r\n              animate={{ opacity: 1, y: 0 }}\r\n              exit={{ opacity: 0, y: 10 }}\r\n              className=\"absolute bottom-20 left-4 w-40 rounded-xl bg-black/90 p-2 border border-white/10\"\r\n            >\r\n              {PLAYBACK_RATES.map((rate) => (\r\n                <button\r\n                  key={rate}\r\n                  onClick={() => handlePlaybackRateChange(rate)}\r\n                  className={cn(\r\n                    \"w-full px-4 py-2 text-left text-sm text-white hover:bg-white/10 rounded-lg\",\r\n                    playbackRate === rate && \"text-blue-400 font-bold\",\r\n                  )}\r\n                >\r\n                  {rate}x\r\n                </button>\r\n              ))}\r\n            </motion.div>\r\n          )}\r\n        </AnimatePresence>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default memo(CourseVideoPlayer);\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\config\\metadata.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\contexts\\auth-context.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'resetStore' is assigned a value but never used. Allowed unused vars must match /^_/u.","line":68,"column"