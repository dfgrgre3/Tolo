•ӘШҜв”ҳГЁв”ҳВҶ&ldquo;. \n               "},"desc":"Replace with `&ldquo;`."},{"messageId":"replaceWithAlt","data":{"alt":"&#34;"},"fix":{"range":[7841,7933],"text":"\n               в”ҳГ§в•Әв–‘в”ҳГ§ в•ӘШҜв”ҳВ„в”ҳВҒв•ӘШҜв•ӘШІв”ҳГӘв•Әв–’в•ӘШұ в•ӘШІв”ҳГ  в•ӘШІв”ҳГӘв”ҳВ„в”ҳГЁв•ӘВ»в”ҳГ§в•ӘШҜ в•ӘШӘв”ҳВ„в”ҳГЁв•ӘШҜв”ҳГҜ в•ӘШ°в”ҳГӘв•ӘШҜв•Әв”Ӯв•Әв•–в•ӘШұ в”ҳВҶв•Әв••в•ӘШҜв”ҳГ  \"в•ӘШів•ӘШҜв”ҳВҶв”ҳГӘв”ҳГЁв•ӘШұ в•ӘШ«в”ҳГӘв”ҳВҶв”ҳВ„в•ӘШҜв”ҳГЁв”ҳВҶ&#34;. \n               "},"desc":"Replace with `&#34;`."},{"messageId":"replaceWithAlt","data":{"alt":"&rdquo;"},"fix":{"range":[7841,7933],"text":"\n               в”ҳГ§в•Әв–‘в”ҳГ§ в•ӘШҜв”ҳВ„в”ҳВҒв•ӘШҜв•ӘШІв”ҳГӘв•Әв–’в•ӘШұ в•ӘШІв”ҳГ  в•ӘШІв”ҳГӘв”ҳВ„в”ҳГЁв•ӘВ»в”ҳГ§в•ӘШҜ в•ӘШӘв”ҳВ„в”ҳГЁв•ӘШҜв”ҳГҜ в•ӘШ°в”ҳГӘв•ӘШҜв•Әв”Ӯв•Әв•–в•ӘШұ в”ҳВҶв•Әв••в•ӘШҜв”ҳГ  \"в•ӘШів•ӘШҜв”ҳВҶв”ҳГӘв”ҳГЁв•ӘШұ в•ӘШ«в”ҳГӘв”ҳВҶв”ҳВ„в•ӘШҜв”ҳГЁв”ҳВҶ&rdquo;. \n               "},"desc":"Replace with `&rdquo;`."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"ЩҠв•—в”җ\"use client\";\n\nimport React, { useEffect, useState } from \"react\";\nimport { format } from \"date-fns\";\nimport { ar } from \"date-fns/locale\";\nimport QRCode from \"qrcode\";\n\ninterface InvoiceData {\n  paymentId: string;\n  orderId?: string;\n  customerName: string;\n  customerEmail: string;\n  planName: string;\n  amount: number;\n  discountAmount?: number; // Total discount\n  promoDiscount?: number;\n  prorationDiscount?: number;\n  balanceUsed?: number;\n  finalAmount: number;\n  date: string;\n  paymentMethod: string;\n}\n\nexport const InvoiceTemplate = ({ data }: { data: InvoiceData }) => {\n  const [qrCodeUrl, setQrCodeUrl] = useState<string>(\"\");\n\n  useEffect(() => {\n    // Verification URL (mock)\n    const verificationUrl = `https://thanawy.online/verify/${data.paymentId}`;\n    QRCode.toDataURL(verificationUrl, { margin: 1, width: 100 }, (err, url) => {\n      if (!err) setQrCodeUrl(url);\n    });\n  }, [data.paymentId]);\n\n  return (\n    <div id={`invoice-${data.paymentId}`} className=\"bg-white text-black p-12 max-w-[800px] mx-auto font-sans border shadow-sm relative\" dir=\"rtl\">\n      {/* Top Banner (Optional Branded Touch) */}\n      <div className=\"absolute top-0 right-0 left-0 h-1.5 bg-blue-600\" />\n\n      {/* Header */}\n      <div className=\"flex justify-between items-start border-b-2 border-gray-100 pb-8 mb-10\">\n        <div className=\"flex gap-6\">\n            {qrCodeUrl && (\n                <div className=\"border p-1 rounded-lg\">\n                    <img src={qrCodeUrl} alt=\"QR Verification\" className=\"w-20 h-20\" />\n                </div>\n            )}\n            <div>\n                <h1 className=\"text-3xl font-extrabold text-blue-600 mb-1\">в”ҳГ в”ҳВҶв•Әв•Ўв•ӘШұ в•ӘШів•ӘШҜв”ҳВҶв”ҳГӘв”ҳГЁв•ӘШұ в•ӘШ«в”ҳГӘв”ҳВҶв”ҳВ„в•ӘШҜв”ҳГЁв”ҳВҶ</h1>\n                <p className=\"text-gray-400 text-xs font-bold uppercase tracking-widest\">Thanawy Online Educational Platform</p>\n                <div className=\"mt-3 flex gap-4 text-[10px] text-gray-500 font-bold\">\n                    <span>в•ӘШҜв”ҳВ„в•Әв–’в”ҳГ©в”ҳГ  в•ӘШҜв”ҳВ„в•Әв•ўв•Әв–’в”ҳГЁв•ӘШ°в”ҳГЁ: в”ҳШ«в”ҳШ©в”ҳШӘ-в”ҳШ¬в”ҳШӯв”ҳШ®-в”ҳШҜв”ҳШ°в”ҳШұ</span>\n                    <span>в•Әв”Ӯв•ӘШҙв”ҳВ„ в•ӘШІв•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ: в”ҳШ©в”ҳШӘв”ҳШ«в”ҳШ¬в”ҳШӯв”ҳШ®в”ҳШҜв”ҳШ°в”ҳШұв”ҳШЁ</span>\n                </div>\n            </div>\n        </div>\n        <div className=\"text-left\" dir=\"ltr\">\n          <div className=\"text-3xl font-black text-gray-200 mb-1 tracking-tighter\">INVOICE</div>\n          <p className=\"text-blue-600 font-bold text-sm\">#{data.paymentId.slice(-8).toUpperCase()}</p>\n          <div className=\"mt-2 text-[10px] text-gray-400\">\n               <p>Simplified Tax Invoice</p>\n               <p>в”ҳВҒв•ӘШҜв•ӘШІв”ҳГӘв•Әв–’в•ӘШұ в•Әв•ўв•Әв–’в”ҳГЁв•ӘШ°в”ҳГЁв•ӘШұ в”ҳГ в•ӘШ°в•Әв”Ӯв•Әв•–в•ӘШұ</p>\n          </div>\n        </div>\n      </div>\n\n      {/* Info Grid */}\n      <div className=\"grid grid-cols-2 gap-12 mb-12\">\n        <div>\n          <h3 className=\"text-blue-600/50 text-[10px] font-black mb-3 border-b pb-1 uppercase tracking-widest\">в”ҳГ в•Әв••в”ҢГӘв”ҳГ©в•ӘВ»в”ҳГ в•ӘШұ в•ӘШӯв”ҳВ„в”ҳГ« (Billed To):</h3>\n          <div className=\"space-y-1\">\n            <p className=\"font-bold text-lg text-gray-800\">{data.customerName}</p>\n            <p className=\"text-gray-500 text-sm\">{data.customerEmail}</p>\n          </div>\n        </div>\n        <div className=\"text-left\" dir=\"ltr\">\n          <h3 className=\"text-blue-600/50 text-[10px] font-black mb-3 border-b pb-1 uppercase tracking-widest\">TRANSACTION INFO:</h3>\n          <div className=\"space-y-1 text-sm\">\n            <p><span className=\"text-gray-400 font-medium\">Date:</span> <span className=\"text-gray-700 font-bold\">{format(new Date(data.date), 'dd/MM/yyyy')}</span></p>\n            <p><span className=\"text-gray-400 font-medium\">Method:</span> <span className=\"text-gray-700 font-bold\">{data.paymentMethod}</span></p>\n            {data.orderId && <p><span className=\"text-gray-400 font-medium\">Order ID:</span> <span className=\"text-gray-700 font-bold\">#{data.orderId}</span></p>}\n          </div>\n        </div>\n      </div>\n\n      {/* Table */}\n      <div className=\"mb-12\">\n        <table className=\"w-full text-right border-collapse\">\n          <thead>\n            <tr className=\"bg-blue-50/50 text-blue-600\">\n                <th className=\"p-4 border-b text-[11px] font-black uppercase tracking-wider\">в•ӘШҜв”ҳВ„в•ӘШ°в”ҳВҶв•ӘВ» (Item Description)</th>\n                <th className=\"p-4 border-b text-center text-[11px] font-black uppercase tracking-wider\">в•ӘШҜв”ҳВ„в”ҳГўв”ҳГ в”ҳГЁв•ӘШұ</th>\n                <th className=\"p-4 border-b text-left text-[11px] font-black uppercase tracking-wider\">в•ӘШҜв”ҳВ„в•Әв”Ӯв•Әв•Јв•Әв–’</th>\n            </tr>\n          </thead>\n          <tbody className=\"divide-y divide-gray-50 text-sm\">\n            <tr>\n                <td className=\"p-4\">\n                    <p className=\"font-bold text-gray-800\">{data.planName}</p>\n                    <p className=\"text-[10px] text-gray-400 mt-1\">в”ҳГӘв•Әв•Ўв”ҳГӘв”ҳВ„ в”ҳГўв•ӘШҜв”ҳГ в”ҳВ„ в”ҳВ„в•ӘШҙв”ҳГ в”ҳГЁв•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв•Әв•ўв•Әв–’в•ӘШҜв•ӘШІ в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГ в”ҳВ„в•ӘВ«в•Әв•Ўв•ӘШҜв•ӘШІ в”ҳГӘв•ӘШҜв”ҳВ„в•ӘШҜв•ӘВ«в•ӘШІв•ӘШ°в•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ</p>\n                </td>\n                <td className=\"p-4 text-center text-gray-600 font-bold\">1</td>\n                <td className=\"p-4 text-left font-mono font-bold text-gray-800\">{data.amount} в•ӘШҙ.в”ҳГ </td>\n            </tr>\n            {data.promoDiscount && data.promoDiscount > 0 && (\n                <tr className=\"text-green-600 italic\">\n                    <td className=\"p-4\">в•ӘВ«в•Әв•Ўв”ҳГ  в”ҳГўв”ҳГӘв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШІв•Әв–’в”ҳГӘв”ҳГЁв•ӘШҙв”ҳГЁ (Promo Code)</td>\n                    <td className=\"p-4 text-center\">---</td>\n                    <td className=\"p-4 text-left font-mono font-bold\">-{data.promoDiscount} в•ӘШҙ.в”ҳГ </td>\n                </tr>\n            )}\n            {data.prorationDiscount && data.prorationDiscount > 0 && (\n                <tr className=\"text-blue-500 italic\">\n                    <td className=\"p-4\">в•ӘВ«в•Әв•Ўв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШІв•Әв–’в”ҳГ©в”ҳГЁв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҶв•ӘШҜв•Әв”Ӯв•ӘШ°в”ҳГЁ (Proration Discount)</td>\n                    <td className=\"p-4 text-center\">---</td>\n                    <td className=\"p-4 text-left font-mono font-bold\">-{data.prorationDiscount} в•ӘШҙ.m</td>\n                </tr>\n            )}\n            {data.balanceUsed && data.balanceUsed > 0 && (\n                <tr className=\"text-purple-600 italic\">\n                    <td className=\"p-4\">в•Әв–’в•Әв•Ўв”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв”ҳВҒв•Әв••в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  (Wallet Balance)</td>\n                    <td className=\"p-4 text-center\">---</td>\n                    <td className=\"p-4 text-left font-mono font-bold\">-{data.balanceUsed} в•ӘШҙ.в”ҳГ </td>\n                </tr>\n            )}\n          </tbody>\n        </table>\n      </div>\n\n      {/* Totals Section */}\n      <div className=\"flex justify-between items-end\">\n        <div className=\"text-[10px] text-gray-400 max-w-[300px]\" dir=\"rtl\">\n            <p className=\"font-bold mb-1\">в•Әв”Өв•Әв–’в”ҳГӘв•Әв•– в•Әв•Јв•ӘШҜв”ҳГ в•ӘШұ:</p>\n            <p>в”ҳГ§в•Әв–‘в•ӘШҜ в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Өв•ӘШІв•Әв–’в•ӘШҜв”ҳГў в•Әв•Ўв•ӘШҜв”ҳВ„в•ӘШө в”ҳВ„в”ҳГ в•ӘВ»в•ӘШұ в”ҳГ в•ӘШөв•ӘВ»в•ӘВ»в•ӘШұ в•ӘШөв•Әв”Ӯв•ӘШ° в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШҜв”ҳГ©в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ«в•ӘШІв•ӘШҜв•Әв–’в•ӘШұ в”ҳГ в”ҳВҶ в•ӘШІв•ӘШҜв•Әв–’в”ҳГЁв•ӘВ« в•ӘШҜв”ҳВ„в•ӘВ»в”ҳВҒв•Әв•Ј. в”ҳВ„в•ӘШҜ в”ҳГЁв•ӘШІв”ҳГ  в•ӘШҜв•Әв”Ӯв•ӘШІв•Әв–’в•ӘВ»в•ӘШҜв•ӘВ» в•ӘШҜв”ҳВ„в”ҳГ в•ӘШ°в•ӘШҜв”ҳВ„в•Әв•‘ в•ӘШ°в•Әв•Јв•ӘВ» в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ«в•ӘВ»в”ҳГ в•ӘШұ.</p>\n        </div>\n        <div className=\"w-72 space-y-3 bg-gray-50/50 p-6 rounded-2xl border border-gray-100\">\n            <div className=\"flex justify-between text-gray-400 text-sm\">\n                <span>в•Әв”Ӯв•Әв•Јв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШҜв”ҳГ©в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ«в•Әв•Ўв”ҳВ„в”ҳГЁ</span>\n                <span>{data.amount} в•ӘШҙ.в”ҳГ </span>\n            </div>\n            {data.discountAmount !== undefined && data.discountAmount > 0 && (\n                <div className=\"flex justify-between text-green-600 font-bold text-sm\">\n                    <span>в•ӘШӯв•ӘШөв•Әв•Ўв•ӘШҜв”ҳВ„в”ҳГЁ в•ӘШҜв”ҳВ„в•ӘВ«в•Әв•Ўв”ҳГӘв”ҳГ в•ӘШҜв•ӘШІ</span>\n                    <span>-{data.discountAmount} в•ӘШҙ.в”ҳГ </span>\n                </div>\n            )}\n            <div className=\"flex justify-between text-2xl font-black border-t-2 border-dashed border-gray-200 pt-4 text-blue-600\">\n                <span>в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШҙв”ҳГ в•ӘШҜв”ҳВ„в”ҳГЁ</span>\n                <span className=\"font-mono\">{data.finalAmount} в•ӘШҙ.в”ҳГ </span>\n            </div>\n        </div>\n      </div>\n\n      {/* Footer / Legal info */}\n      <div className=\"mt-20 pt-8 border-t border-gray-100 text-center\">\n          <div className=\"flex justify-center gap-12 mb-6 text-[10px] text-gray-500 font-bold grayscale opacity-50\">\n               <img src=\"/pci-logo.png\" alt=\"PCI DSS\" className=\"h-4\" />\n               <img src=\"/paymob-logo.png\" alt=\"Paymob Secured\" className=\"h-4\" />\n               <p>SECURE TRANSACTION</p>\n          </div>\n          <p className=\"text-[11px] text-gray-400 mb-2 leading-relaxed\">\n               в”ҳГ§в•Әв–‘в”ҳГ§ в•ӘШҜв”ҳВ„в”ҳВҒв•ӘШҜв•ӘШІв”ҳГӘв•Әв–’в•ӘШұ в•ӘШІв”ҳГ  в•ӘШІв”ҳГӘв”ҳВ„в”ҳГЁв•ӘВ»в”ҳГ§в•ӘШҜ в•ӘШӘв”ҳВ„в”ҳГЁв•ӘШҜв”ҳГҜ в•ӘШ°в”ҳГӘв•ӘШҜв•Әв”Ӯв•Әв•–в•ӘШұ в”ҳВҶв•Әв••в•ӘШҜв”ҳГ  \"в•ӘШів•ӘШҜв”ҳВҶв”ҳГӘв”ҳГЁв•ӘШұ в•ӘШ«в”ҳГӘв”ҳВҶв”ҳВ„в•ӘШҜв”ҳГЁв”ҳВҶ\". \n               <br />\n               в•ӘШІв”ҳГ  в•Әв–’в•Әв•Ўв•ӘВ» в•Әв•ўв•Әв–’в”ҳГЁв•ӘШ°в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ©в”ҳГЁв”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•Әв•–в•ӘШ°в”ҳГ©в•ӘШҜв”ҳГҜ в”ҳВ„в•ӘШ«в•ӘШөв”ҳГўв•ӘШҜв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв”ҳВҶв”ҳГӘв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Ўв•Әв–’в”ҳГЁ.\n          </p>\n          <div className=\"text-blue-600 text-[10px] font-black tracking-widest mt-4\">\n              THANAWY.ONLINE ШёШҙШӘ CAIRO, EGYPT\n          </div>\n      </div>\n\n      <style jsx>{`\n        @import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap');\n        div { font-family: 'Cairo', sans-serif; }\n      `}</style>\n    </div>\n  );\n};\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\components\\dashboard\\DashboardStatsCards.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Badge' is defined but never used. Allowed unused vars must match /^_/u.","line":3,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":3,"endColumn":15,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"Badge"},"fix":{"range":[100,138],"text":""},"desc":"Remove unused import declaration."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"ЩҠв•—в”җimport React from 'react';\r\nimport { Card, CardContent, CardHeader, CardTitle } from '../ui/card';\r\nimport { Badge } from '../ui/badge';\r\nimport { Clock, Calendar, Target, TrendingUp } from 'lucide-react';\r\n\r\n/**\r\n * в•ӘШӯв•ӘШөв•Әв•Ўв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШҜв•ӘШІ в”ҳВ„в”ҳГӘв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГўв”ҳГ \r\n */\r\nexport interface DashboardStats {\r\n  /** в•ӘШӯв•ӘШҙв”ҳГ в•ӘШҜв”ҳВ„в”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ  */\r\n  totalTasks: number;\r\n  /** в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв•ӘШІв”ҳГ в”ҳВ„в•ӘШұ */\r\n  completedTasks: number;\r\n  /** в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГ©в•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•Әв•‘в•Әв–’в”ҳГ© в•ӘШҜв”ҳВ„в”ҳГЁв”ҳГӘв”ҳГ  (в•ӘШ°в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ©) */\r\n  todayTimeSpent: number;\r\n  /** в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГ©в•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•Әв•‘в•Әв–’в”ҳГ© в”ҳГ§в•Әв–‘в•ӘШҜ в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•ӘШ°в”ҳГӘв•Әв•Ј (в•ӘШ°в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ©) */\r\n  weekTimeSpent: number;\r\n  /** в•Әв•Јв•ӘВ»в•ӘВ» в•ӘШҜв”ҳВ„в•ӘШ«в•ӘШөв•ӘВ»в•ӘШҜв•ӘШі в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв•ӘВ»в”ҳГ в•ӘШұ */\r\n  upcomingEvents: number;\r\n  /** в”ҳГ в•Әв•Јв•ӘВ»в”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШҙв•ӘШҜв•Әв–“ (в”ҳВҶв•Әв”Ӯв•ӘШ°в•ӘШұ в”ҳГ в•ӘШ®в”ҳГӘв”ҳГЁв•ӘШұ) */\r\n  completionRate: number;\r\n}\r\n\r\n/**\r\n * в•ӘВ«в•Әв•Ўв•ӘШҜв•ӘШ®в•Әв•Ў в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶ в•ӘШӯв•ӘШөв•Әв•Ўв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШҜв•ӘШІ в”ҳВ„в”ҳГӘв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГўв”ҳГ \r\n */\r\nexport interface DashboardStatsProps {\r\n  /** в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШөв•Әв•Ўв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШҜв•ӘШІ */\r\n  stats: DashboardStats;\r\n}\r\n\r\n/**\r\n * в•ӘШІв”ҳВҶв•Әв”Ӯв”ҳГЁв”ҳГ© в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГ©в•ӘШІ в”ҳГ в”ҳВҶ в•ӘВ»в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ© в•ӘШӯв”ҳВ„в”ҳГ« в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘШҜв•ӘШІ в”ҳГӘв•ӘВ»в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ©\r\n */\r\nconst formatTime = (minutes: number): string => {\r\n  const hours = Math.floor(minutes / 60);\r\n  const mins = minutes % 60;\r\n  \r\n  if (hours === 0) {\r\n    return `${mins} в•ӘВ»в”ҳГ©в”ҳГЁв”ҳГ©в•ӘШұ`;\r\n  }\r\n  \r\n  return `${hours} в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘШұ${mins > 0 ? ` в”ҳГӘ ${mins} в•ӘВ»в”ҳГ©в”ҳГЁв”ҳГ©в•ӘШұ` : ''}`;\r\n};\r\n\r\n/**\r\n * в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶ в•ӘШӯв•ӘШөв•Әв•Ўв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШҜв•ӘШІ в”ҳВ„в”ҳГӘв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГўв”ҳГ \r\n * \r\n * в”ҳГЁв•Әв•Јв•Әв–’в•Әв•ў в”ҳГ в”ҳВ„в•ӘВ«в•Әв•Ў в•Әв”Ӯв•Әв–’в”ҳГЁв•Әв•Ј в”ҳВ„в•ӘШ«в•ӘВ»в•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ \r\n * \r\n * @example\r\n * ```tsx\r\n * <DashboardStatsCards stats={{\r\n *   totalTasks: 10,\r\n *   completedTasks: 7,\r\n *   todayTimeSpent: 120,\r\n *   weekTimeSpent: 600,\r\n *   upcomingEvents: 3,\r\n *   completionRate: 70\r\n * }} />\r\n * ```\r\n */\r\nexport const DashboardStatsCards: React.FC<DashboardStatsProps> = React.memo(({ stats }) => {\r\n  const statsCards = [\r\n    {\r\n      title: 'в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ ',\r\n      value: `${stats.completedTasks}/${stats.totalTasks}`,\r\n      description: 'в”ҳГ в”ҳГўв•ӘШІв”ҳГ в”ҳВ„в•ӘШұ',\r\n      icon: Target,\r\n      color: 'text-blue-600',\r\n      bgColor: 'bg-blue-50',\r\n    },\r\n    {\r\n      title: 'в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГ©в•ӘШІ в•ӘШҜв”ҳВ„в”ҳГЁв”ҳГӘв”ҳГ ',\r\n      value: formatTime(stats.todayTimeSpent),\r\n      description: 'в”ҳГӘв”ҳГ©в•ӘШІ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв•ӘШұ',\r\n      icon: Clock,\r\n      color: 'text-green-600',\r\n      bgColor: 'bg-green-50',\r\n    },\r\n    {\r\n      title: 'в•ӘШҜв”ҳВ„в•ӘШ«в•ӘШөв•ӘВ»в•ӘШҜв•ӘШі в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв•ӘВ»в”ҳГ в•ӘШұ',\r\n      value: stats.upcomingEvents.toString(),\r\n      description: 'в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШҙв•ӘВ»в”ҳГӘв”ҳВ„',\r\n      icon: Calendar,\r\n      color: 'text-purple-600',\r\n      bgColor: 'bg-purple-50',\r\n    },\r\n    {\r\n      title: 'в”ҳГ в•Әв•Јв•ӘВ»в”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШҙв•ӘШҜв•Әв–“',\r\n      value: `${stats.completionRate}%`,\r\n      description: 'в”ҳГ§в•Әв–‘в•ӘШҜ в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•ӘШ°в”ҳГӘв•Әв•Ј',\r\n      icon: TrendingUp,\r\n      color: 'text-orange-600',\r\n      bgColor: 'bg-orange-50',\r\n    },\r\n  ];\r\n\r\n  return (\r\n    <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6\">\r\n      {statsCards.map((stat, index) => {\r\n        const Icon = stat.icon;\r\n        return (\r\n          <Card \r\n            key={index} \r\n            className=\"hover:shadow-lg transition-shadow duration-300\"\r\n          >\r\n            <CardHeader className=\"flex flex-row items-center justify-between space-y-0 pb-2\">\r\n              <CardTitle className=\"text-sm font-medium\">\r\n                {stat.title}\r\n              </CardTitle>\r\n              <div className={`${stat.bgColor} p-2 rounded-lg`}>\r\n                <Icon className={`h-4 w-4 ${stat.color}`} />\r\n              </div>\r\n            </CardHeader>\r\n            <CardContent>\r\n              <div className=\"text-2xl font-bold\">{stat.value}</div>\r\n              <p className=\"text-xs text-muted-foreground mt-1\">\r\n                {stat.description}\r\n              </p>\r\n            </CardContent>\r\n          </Card>\r\n        );\r\n      })}\r\n    </div>\r\n  );\r\n});\r\n\r\nDashboardStatsCards.displayName = 'DashboardStatsCards';\r\n\r\nexport default DashboardStatsCards;\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\components\\dashboard\\SectionHeader.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Card' is defined but never used. Allowed unused vars must match /^_/u.","line":2,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":2,"endColumn":14,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Card"},"fix":{"range":[37,42],"text":""},"desc":"Remove unused variable \"Card\"."}]},{"ruleId":"@t