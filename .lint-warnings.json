\n      variantAName: \"\",\r\n      variantBName: \"\",\r\n      targetAudience: \"all\"\r\n    });\r\n    handleOpenChange(false);\r\n    setIsCreating(false);\r\n  };\r\n\r\n  return (\r\n    <Dialog open={isOpen} onOpenChange={handleOpenChange}>\r\n      <DialogTrigger asChild>\r\n        {children}\r\n      </DialogTrigger>\r\n      <DialogContent className=\"max-w-2xl max-h-[90vh] overflow-y-auto\">\r\n        <DialogHeader>\r\n          <DialogTitle>в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШІв•ӘШҙв•Әв–’в•ӘШ°в•ӘШұ A/B в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ</DialogTitle>\r\n          <DialogDescription>\r\n            в”ҳГ©в”ҳГ  в•ӘШ°в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘВ» в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Ўв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШҙв•Әв–’в•ӘШ°в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв”ҳГЁ в•ӘШІв•Әв–’в•Әв•‘в•ӘШ° в”ҳВҒв”ҳГЁ в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ®в”ҳГ§в•ӘШҜ в”ҳВ„в”ҳГ в”ҳГ©в•ӘШҜв•Әв–’в”ҳВҶв•ӘШұ в”ҳВҶв•Әв”Ӯв•ӘВ«в•ӘШІв”ҳГЁв”ҳВҶ в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШІв”ҳГӘв”ҳГ« в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Јв”ҳВ„в”ҳГЁв”ҳГ в”ҳГЁ\r\n          </DialogDescription>\r\n        </DialogHeader>\r\n        \r\n        <div className=\"grid gap-4 py-4\">\r\n          <div className=\"grid grid-cols-1 gap-4\">\r\n            <div>\r\n              <Label htmlFor=\"title\">в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШҙв•Әв–’в•ӘШ°в•ӘШұ *</Label>\r\n              <Input \r\n                id=\"title\" \r\n                value={newExperiment.title}\r\n                onChange={(e) => setNewExperiment({...newExperiment, title: e.target.value})}\r\n                placeholder=\"в”ҳГ в•ӘШів”ҳВ„в•ӘШҜв”ҳГҜ: в•ӘШІв•ӘШҙв•Әв–’в•ӘШ°в•ӘШұ в•ӘШІв•ӘШ«в•ӘШів”ҳГЁв•Әв–’ в•Әв”Өв”ҳГўв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•ӘШ®в”ҳВ„в•ӘШұ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШ«в•ӘВ»в•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•Әв•–в”ҳВ„в•ӘШҜв•ӘШ°\"\r\n              />\r\n            </div>\r\n            \r\n            <div>\r\n              <Label htmlFor=\"description\">в”ҳГӘв•Әв•Ўв”ҳВҒ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШҙв•Әв–’в•ӘШ°в•ӘШұ</Label>\r\n              <Textarea \r\n                id=\"description\" \r\n                value={newExperiment.description}\r\n                onChange={(e) => setNewExperiment({...newExperiment, description: e.target.value})}\r\n                placeholder=\"в•ӘШҜв•Әв”Өв•Әв–’в•ӘШө в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Ўв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШҙв•Әв–’в•ӘШ°в•ӘШұ в”ҳГӘв•ӘШ«в”ҳГ§в•ӘВ»в•ӘШҜв”ҳВҒв”ҳГ§в•ӘШҜ...\"\r\n                rows={3}\r\n              />\r\n            </div>\r\n            \r\n            <div className=\"grid grid-cols-2 gap-4\">\r\n              <div>\r\n                <Label htmlFor=\"variantA\">в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Ӯв•ӘВ«в•ӘШұ (в•ӘШ«) *</Label>\r\n                <Input \r\n                  id=\"variantA\" \r\n                  value={newExperiment.variantAName}\r\n                  onChange={(e) => setNewExperiment({...newExperiment, variantAName: e.target.value})}\r\n                  placeholder=\"в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Ӯв•ӘВ«в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГӘв”ҳВ„в”ҳГ«\"\r\n                />\r\n              </div>\r\n              \r\n              <div>\r\n                <Label htmlFor=\"variantB\">в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Ӯв•ӘВ«в•ӘШұ (в•ӘШ°) *</Label>\r\n                <Input \r\n                  id=\"variantB\" \r\n                  value={newExperiment.variantBName}\r\n                  onChange={(e) => setNewExperiment({...newExperiment, variantBName: e.target.value})}\r\n                  placeholder=\"в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Ӯв•ӘВ«в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШів•ӘШҜв”ҳВҶв”ҳГЁв•ӘШұ\"\r\n                />\r\n              </div>\r\n            </div>\r\n            \r\n            <div>\r\n              <Label htmlFor=\"audience\">в•ӘШҜв”ҳВ„в”ҳВҒв•ӘШ®в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГ§в•ӘВ»в”ҳВҒв•ӘШұ</Label>\r\n              <Select \r\n                value={newExperiment.targetAudience}\r\n                onValueChange={(value) => setNewExperiment({...newExperiment, targetAudience: value})}\r\n              >\r\n                <SelectTrigger>\r\n                  <SelectValue placeholder=\"в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в”ҳВҒв•ӘШ®в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГ§в•ӘВ»в”ҳВҒв•ӘШұ\" />\r\n                </SelectTrigger>\r\n                <SelectContent>\r\n                  <SelectItem value=\"all\">в•ӘШҙв”ҳГ в”ҳГЁв•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ в”ҳГЁв”ҳВҶ</SelectItem>\r\n                  <SelectItem value=\"new_users\">в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ в”ҳГӘв”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШҙв•ӘВ»в•ӘВ» в”ҳВҒв”ҳГ©в•Әв•–</SelectItem>\r\n                  <SelectItem value=\"premium\">в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Өв•ӘШІв•Әв–’в”ҳГўв”ҳГЁв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ в”ҳГЁв•Әв–“в”ҳГЁв”ҳВҶ</SelectItem>\r\n                  <SelectItem value=\"math\">в•Әв•–в”ҳВ„в•ӘШҜв•ӘШ° в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в•Әв–’в”ҳГЁв•ӘШҜв•Әв•ўв”ҳГЁв•ӘШҜв•ӘШІ</SelectItem>\r\n                  <SelectItem value=\"physics\">в•Әв•–в”ҳВ„в•ӘШҜв•ӘШ° в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в”ҳВҒв”ҳГЁв•Әв–“в”ҳГЁв•ӘШҜв•ӘШ©</SelectItem>\r\n                </SelectContent>\r\n              </Select>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        \r\n        <DialogFooter>\r\n          <AdminButton \r\n            variant=\"outline\" \r\n            onClick={() => handleOpenChange(false)}\r\n            className=\"gap-2\"\r\n          >\r\n            <X className=\"w-4 h-4\" /> в•ӘШӯв”ҳВ„в•Әв•‘в•ӘШҜв•ӘШ©\r\n          </AdminButton>\r\n          <AdminButton \r\n            className=\"gap-2 bg-gradient-to-r from-teal-500 to-emerald-600 hover:from-teal-600 hover:to-emerald-700\"\r\n            onClick={handleCreate}\r\n            disabled={isCreating}\r\n          >\r\n            <Plus className=\"w-4 h-4\" /> {isCreating ? \"в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ©...\" : \"в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШІв•ӘШҙв•Әв–’в•ӘШ°в•ӘШұ\"}\r\n          </AdminButton>\r\n        </DialogFooter>\r\n      </DialogContent>\r\n    </Dialog>\r\n  );\r\n};\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\components\\ab-testing\\empty-state.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\components\\ab-testing\\experiment-card.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\components\\ab-testing\\filters-bar.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\components\\ab-testing\\stats-cards.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\components\\admin\\courses\\course-card.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'ExternalLink' is defined but never used. Allowed unused vars must match /^_/u.","line":19,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":19,"endColumn":15,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"ExternalLink"},"fix":{"range":[201,217],"text":""},"desc":"Remove unused variable \"ExternalLink\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Star' is defined but never used. Allowed unused vars must match /^_/u.","line":20,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":20,"endColumn":7,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Star"},"fix":{"range":[217,225],"text":""},"desc":"Remove unused variable \"Star\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'reviewsCount' is assigned a value but never used. Allowed unused vars must match /^_/u.","line":53,"column":9,"nodeType":"Identifier","messageId":"unusedVar","endLine":53,"endColumn":21}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"ЩҠв•—в”җ\"use client\";\n\nimport * as React from \"react\";\nimport {\n  Users,\n  Clock,\n  MoreVertical,\n  Edit,\n  Eye,\n  Copy,\n  Trash2,\n  CheckCircle2,\n  XCircle,\n  TrendingUp,\n  BookOpen,\n  Crown,\n  Lock,\n  Unlock,\n  ExternalLink,\n  Star,\n  Layers,\n} from \"lucide-react\";\nimport { AdminButton } from \"@/components/admin/ui/admin-button\";\nimport { Badge } from \"@/components/ui/badge\";\nimport {\n  DropdownMenu,\n  DropdownMenuContent,\n  DropdownMenuItem,\n  DropdownMenuLabel,\n  DropdownMenuSeparator,\n  DropdownMenuTrigger,\n} from \"@/components/ui/dropdown-menu\";\nimport { cn, formatPrice } from \"@/lib/utils\";\nimport Link from \"next/link\";\n\ninterface CourseCardProps {\n  course: any;\n  onEdit: (course: any) => void;\n  onDuplicate: (course: any) => void;\n  onDelete: (course: any) => void;\n  onToggleStatus: (course: any) => void;\n}\n\nconst levelConfig: Record<string, { label: string; color: string; num: string }> = {\n  BEGINNER: { label: \"в”ҳГ в•ӘШ°в•ӘШІв•ӘВ»в•ӘШ®\", color: \"text-emerald-400 bg-emerald-500/10 border-emerald-500/25\", num: \"1\" },\n  INTERMEDIATE: { label: \"в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•–\", color: \"text-sky-400 bg-sky-500/10 border-sky-500/25\", num: \"2\" },\n  ADVANCED: { label: \"в”ҳГ в•ӘШІв”ҳГ©в•ӘВ»в”ҳГ \", color: \"text-violet-400 bg-violet-500/10 border-violet-500/25\", num: \"3\" },\n};\n\nexport function CourseCard({ course, onEdit, onDuplicate, onDelete, onToggleStatus }: CourseCardProps) {\n  const learnersCount = course._count?.enrollments ?? 0;\n  const topicsCount = course._count?.topics ?? 0;\n  const reviewsCount = course._count?.reviews ?? 0;\n  const level = levelConfig[course.level] ?? levelConfig.INTERMEDIATE;\n  const isFree = !course.price || course.price === 0;\n\n  return (\n    <div\n      className={cn(\n        \"group relative flex flex-col overflow-hidden rounded-2xl border bg-card/60 backdrop-blur-sm\",\n        \"transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-primary/10\",\n        course.isFeatured && \"ring-1 ring-amber-500/40\",\n        !course.isActive && \"opacity-70\"\n      )}\n    >\n      {/* Featured Crown Badge */}\n      {course.isFeatured && (\n        <div className=\"absolute left-3 top-3 z-10\">\n          <div className=\"flex items-center gap-1 rounded-full bg-amber-500/20 border border-amber-500/30 px-2 py-0.5 backdrop-blur-md\">\n            <Crown className=\"h-3 w-3 text-amber-400\" />\n            <span className=\"text-[10px] font-black text-amber-400\">в”ҳГ в”ҳГ в”ҳГЁв•Әв–“в•ӘШұ</span>\n          </div>\n        </div>\n      )}\n\n      {/* Thumbnail */}\n      <div className=\"relative aspect-video overflow-hidden bg-muted\">\n        {course.thumbnailUrl ? (\n          <img\n            src={course.thumbnailUrl}\n            alt={course.nameAr || course.name}\n            className=\"h-full w-full object-cover transition-transform duration-700 group-hover:scale-105\"\n          />\n        ) : (\n          <div className=\"flex h-full w-full items-center justify-center bg-gradient-to-br from-primary/20 via-primary/5 to-transparent\">\n            <BookOpen className=\"h-12 w-12 text-primary/30\" />\n          </div>\n        )}\n\n        {/* Overlay gradient */}\n        <div className=\"absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300\" />\n\n        {/* Status badges */}\n        <div className=\"absolute top-3 right-3 flex flex-col gap-1.5\">\n          <Badge\n            className={cn(\n              \"rounded-lg px-2 py-0.5 text-[10px] font-black uppercase tracking-wider border backdrop-blur-md shadow-lg\",\n              course.isPublished\n                ? \"bg-emerald-500/20 text-emerald-300 border-emerald-500/30\"\n                : \"bg-orange-500/20 text-orange-300 border-orange-500/30\"\n            )}\n          >\n            {course.isPublished ? \"в”ҳГ в”ҳВҶв•Әв”Өв”ҳГӘв•Әв–’в•ӘШұ\" : \"в”ҳГ в•Әв”Ӯв”ҳГӘв•ӘВ»в•ӘШұ\"}\n          </Badge>\n          {!course.isActive && (\n            <Badge className=\"rounded-lg px-2 py-0.5 text-[10px] font-black bg-red-500/20 text-red-300 border border-red-500/30 backdrop-blur-md\">\n              в”ҳГ в”ҳГӘв”ҳГ©в”ҳГӘв”ҳВҒв•ӘШұ\n            </Badge>\n          )}\n        </div>\n\n        {/* Level badge */}\n        <div className=\"absolute bottom-3 left-3\">\n          <Badge\n            className={cn(\n              \"rounded-lg px-2 py-0.5 text-[10px] font-black border backdrop-blur-md\",\n              level.color\n            )}\n          >\n            {level.label}\n          </Badge>\n        </div>\n\n        {/* Price overlay */}\n        <div className=\"absolute bottom-3 right-3\">\n          <div\n            className={cn(\n              \"rounded-lg px-2.5 py-0.5 text-[11px] font-black backdrop-blur-md border\",\n              isFree\n                ? \"bg-teal-500/20 text-teal-300 border-teal-500/30\"\n                : \"bg-black/60 text-white border-white/20\"\n            )}\n          >\n            {isFree ? \"в”ҳГ в•ӘШҙв•ӘШҜв”ҳВҶв”ҳГЁв•ӘШұ\" : formatPrice(course.price)}\n          </div>\n        </div>\n      </div>\n\n      {/* Content */}\n      <div className=\"flex flex-1 flex-col gap-3 p-4\">\n        {/* Header */}\n        <div className=\"flex items-start justify-between gap-2\">\n          <div className=\"min-w-0 flex-1 space-y-1\">\n            <h3 className=\"truncate text-sm font-black leading-snug group-hover:text-primary transition-colors\">\n              {course.nameAr || course.name}\n            </h3>\n            <p className=\"truncate text-[11px] font-bold text-muted-foreground/70 uppercase tracking-wide\">\n              {course.code && <span className=\"text-primary/60\">#{course.code} ШёШҙШӘ </span>}\n              {course.instructorName || \"в•ӘШ°в•ӘВ»в”ҳГӘв”ҳВҶ в”ҳГ в•ӘШөв•ӘШҜв•Әв•ўв•Әв–’\"}\n            </p>\n          </div>\n\n          <DropdownMenu>\n            <DropdownMenuTrigger asChild>\n              <AdminButton\n                variant=\"ghost\"\n                size=\"icon-sm\"\n                className=\"h-8 w-8 shrink-0 rounded-full hover:bg-primary/10\"\n              >\n                <MoreVertical className=\"h-4 w-4\" />\n              </AdminButton>\n            </DropdownMenuTrigger>\n            <DropdownMenuContent align=\"end\" className=\"w-52 rounded-xl border-border/60\" dir=\"rtl\">\n              <DropdownMenuLabel className=\"text-xs font-black text-muted-foreground\">\n                в•ӘШӯв•ӘШҙв•Әв–’в•ӘШҜв•ӘШ©в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ\n              </DropdownMenuLabel>\n              <DropdownMenuSeparator />\n              <DropdownMenuItem\n                onClick={() => onEdit(course)}\n                className=\"gap-2.5 font-bold cursor-pointer rounded-lg\"\n              >\n                <Edit className=\"h-4 w-4 text-blue-500\" />\n                в•ӘШІв•Әв•Јв•ӘВ»в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ\n              </DropdownMenuItem>\n              <Link href={`/admin/courses/${course.id}/curriculum`} className=\"block\">\n                <DropdownMenuItem className=\"gap-2.5 font-bold cursor-pointer rounded-lg\">\n                  <Layers className=\"h-4 w-4 text-violet-500\" />\n                  в•ӘШӯв•ӘВ»в•ӘШҜв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв”ҳГ§в•ӘШҙ\n                </DropdownMenuItem>\n              </Link>\n              <DropdownMenuItem\n                onClick={() => onDuplicate(course)}\n                className=\"gap-2.5 font-bold cursor-pointer rounded-lg\"\n              >\n                <Copy className=\"h-4 w-4 text-amber-500\" />\n                в•ӘШҜв•Әв”Ӯв•ӘШІв”ҳВҶв•Әв”Ӯв•ӘШҜв•ӘВ« в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ\n              </DropdownMenuItem>\n              <Link href={`/admin/courses/${course.id}/analytics`} className=\"block\">\n                <DropdownMenuItem className=\"gap-2.5 font-bold cursor-pointer rounded-lg\">\n                  <TrendingUp className=\"h-4 w-4 text-emerald-500\" />\n                  в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳВ„в”ҳГЁв”ҳВ„в•ӘШҜв•ӘШІ\n                </DropdownMenuItem>\n              </Link>\n              <DropdownMenuSeparator />\n              <DropdownMenuItem\n                onClick={() => onToggleStatus(course)}\n                className=\"gap-2.5 font-bold cursor-pointer rounded-lg\"\n              >\n                {course.isPublished ? (\n                  <>\n                    <Lock className=\"h-4 w-4 text-orange-500\" />\n                    <span>в•ӘШӯв•ӘВ«в”ҳВҒв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ</span>\n                  </>\n                ) : (\n                  <>\n                    <Unlock className=\"h-4 w-4 text-emerald-500\" />\n                    <span>в”ҳВҶв•Әв”Өв•Әв–’ в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ</span>\n                  </>\n                )}\n              </DropdownMenuItem>\n              <DropdownMenuSeparator />\n              <DropdownMenuItem\n                onClick={() => onDelete(course)}\n                className=\"gap-2.5 font-black cursor-pointer rounded-lg text-red-500 focus:text-red-500 focus:bg-red-500/10\"\n              >\n                <Trash2 className=\"h-4 w-4\" />\n                в•ӘШөв•Әв–‘в”ҳВҒ в”ҳВҶв”ҳГ§в•ӘШҜв•ӘШ®в”ҳГЁ\n              </DropdownMenuItem>\n            </DropdownMenuContent>\n          </DropdownMenu>\n        </div>\n\n        {/* Stats Row */}\n        <div className=\"grid grid-cols-3 gap-2 rounded-xl bg-muted/30 p-2.5\">\n          <div className=\"flex flex-col items-center gap-0.5\">\n            <div className=\"flex items-center gap-1\">\n              <Users className=\"h-3 w-3 text-blue-500\" />\n              <span className=\"text-xs font-black\">{learnersCount}</span>\n            </div>\n            <p className=\"text-[9px] font-bold text-muted-foreground/50 uppercase\">в•Әв•–в•ӘШҜв”ҳВ„в•ӘШ°</p>\n          </div>\n          <div className=\"flex flex-col items-center gap-0.5 border-x border-border/30\">\n            <div className=\"flex items-center gap-1\">\n              <BookOpen className=\"h-3 w-3 text-violet-500\" />\n              <span className=\"text-xs font-black\">{topicsCount}</span>\n            </div>\n            <p className=\"text-[9px] font-bold text-muted-foreground/50 uppercase\">в”ҳГӘв•ӘШөв•ӘВ»в•ӘШұ</p>\n          </div>\n          <div className=\"flex flex-col items-center gap-0.5\">\n            <div className=\"flex items-center gap-1\">\n              <Clock className=\"h-3 w-3 text-emerald-500\" />\n              <span className=\"text-xs font-black\">{course.durationHours ?? 0}</span>\n            </div>\n            <p className=\"text-[9px] font-bold text-muted-foreground/50 uppercase\">в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘШұ</p>\n          </div>\n        </div>\n\n        {/* Footer Actions */}\n        <div className=\"mt-auto flex items-center gap-2 pt-1\">\n          <AdminButton\n            variant={course.isPublished ? \"outline\" : \"default\"}\n            size=\"sm\"\n            className={cn(\n              \"flex-1 h-9 rounded-xl text-[11px] font-black\",\n              !course.isPublished && \"shadow-md\"\n            )}\n            onClick={() => onToggleStatus(course)}\n          >\n            {course.isPublished ? (\n              <><XCircle className=\"h-3.5 w-3.5 ml-1\" /> в•ӘШӯв•ӘВ«в”ҳВҒв•ӘШҜв•ӘШ©</>\n            ) : (\n              <><CheckCircle2 className=\"h-3.5 w-3.5 ml-1\" /> в”ҳВҶв•Әв”Өв•Әв–’</>\n            )}\n          </AdminButton>\n          <Link href={`/admin/courses/${course.id}`} className=\"flex-1\">\n            <AdminButton\n              variant=\"outline\"\n              size=\"sm\"\n              className=\"w-full h-9 rounded-xl text-[11px] font-black gap-1\"\n            >\n              <Eye className=\"