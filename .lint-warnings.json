{ safeFetch } from '@/lib/safe-client-utils';\r\n\r\nimport { logger } from '@/lib/logger';\r\n\r\nconst taskSchema = z.object({\r\n  title: z.string().min(1, { message: 'в•ӘШҜв”ҳВ„в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ в”ҳГ в•Әв•–в”ҳВ„в”ҳГӘв•ӘШ°' }),\r\n  description: z.string().optional(),\r\n  subject: z.nativeEnum(SubjectType).optional(),\r\n  dueAt: z.string().optional(),\r\n  priority: z.number().int().min(0).max(2).optional()\r\n});\r\n\r\nconst STYLES = {\r\n  glass: \"relative overflow-hidden rounded-[2rem] border border-white/10 bg-black/40 shadow-2xl backdrop-blur-2xl ring-1 ring-white/5\",\r\n  card: \"rpg-card h-full\",\r\n  neonText: \"rpg-neon-text font-black\",\r\n  goldText: \"rpg-gold-text font-black\"\r\n};\r\n\r\nexport default function TasksPage() {\r\n  const [tasks, setTasks] = useState<Task[]>([]);\r\n  const [loading, setLoading] = useState(true);\r\n  const [isAddDialogOpen, setIsAddDialogOpen] = useState(false);\r\n  const [isEditDialogOpen, setIsEditDialogOpen] = useState(false);\r\n  const [editingTask, setEditingTask] = useState<Task | null>(null);\r\n  const [statusFilter, setStatusFilter] = useState<TaskStatus | 'ALL'>('ALL');\r\n  const [sortBy, setSortBy] = useState<'dueAt' | 'priority'>('priority');\r\n  const [searchTerm, setSearchTerm] = useState('');\r\n  const [activeTab, setActiveTab] = useState('all');\r\n\r\n  const extractTaskFromPayload = (payload: {data?: Task;} | Task | null): Task | null => {\r\n    if (!payload) return null;\r\n    return 'id' in payload ? payload : payload.data ?? null;\r\n  };\r\n\r\n  const {\r\n    control,\r\n    register,\r\n    handleSubmit,\r\n    reset,\r\n    setValue,\r\n    formState: { errors }\r\n  } = useForm<z.infer<typeof taskSchema>>({\r\n    resolver: zodResolver(taskSchema)\r\n  });\r\n\r\n  const fetchTasks = async () => {\r\n    setLoading(true);\r\n\r\n    try {\r\n      const { data, error } = await safeFetch<Task[]>('/api/tasks', undefined, []);\r\n\r\n      if (error) {\r\n        throw error;\r\n      }\r\n\r\n      setTasks(Array.isArray(data) ? data : []);\r\n    } catch (error) {\r\n      logger.error('Error fetching tasks:', error);\r\n      toast.error(error instanceof Error ? error.message : 'в”ҳВҒв•Әв”Өв”ҳВ„ в”ҳВҒв”ҳГЁ в•ӘШҙв”ҳВ„в•ӘШ° в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ ');\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  };\r\n\r\n  useEffect(() => {\r\n    fetchTasks();\r\n  }, []);\r\n\r\n  const filteredAndSortedTasks = useMemo(() => {\r\n    let result = [...tasks];\r\n\r\n    if (activeTab === 'pending') {\r\n      result = result.filter((task) => task.status === 'PENDING');\r\n    } else if (activeTab === 'inProgress') {\r\n      result = result.filter((task) => task.status === 'IN_PROGRESS');\r\n    } else if (activeTab === 'completed') {\r\n      result = result.filter((task) => task.status === 'COMPLETED');\r\n    } else if (statusFilter !== 'ALL') {\r\n      result = result.filter((task) => task.status === statusFilter);\r\n    }\r\n\r\n    if (searchTerm) {\r\n      const term = searchTerm.toLowerCase();\r\n      result = result.filter((task) =>\r\n      task.title.toLowerCase().includes(term) ||\r\n      task.description && task.description.toLowerCase().includes(term) ||\r\n      task.subject && task.subject.toLowerCase().includes(term)\r\n      );\r\n    }\r\n\r\n    result.sort((a, b) => {\r\n      if (sortBy === 'priority') {\r\n        return b.priority - a.priority;\r\n      }\r\n      if (sortBy === 'dueAt') {\r\n        if (!a.dueAt) return 1;\r\n        if (!b.dueAt) return -1;\r\n        return new Date(a.dueAt).getTime() - new Date(b.dueAt).getTime();\r\n      }\r\n      return 0;\r\n    });\r\n\r\n    return result;\r\n  }, [tasks, statusFilter, sortBy, searchTerm, activeTab]);\r\n\r\n  const handleAddTaskSubmit = async (data: z.infer<typeof taskSchema>) => {\r\n    try {\r\n      const { data: payload, error } = await safeFetch<{data?: Task;} | Task>(\r\n        '/api/tasks',\r\n        {\r\n          method: 'POST',\r\n          headers: { 'Content-Type': 'application/json' },\r\n          body: JSON.stringify(data)\r\n        },\r\n        null\r\n      );\r\n\r\n      if (error) {\r\n        throw error;\r\n      }\r\n\r\n      const newTask = extractTaskFromPayload(payload);\r\n      if (!newTask) {\r\n        throw new Error('в”ҳВҒв•Әв”Өв”ҳВ„ в”ҳВҒв”ҳГЁ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ');\r\n      }\r\n\r\n      setTasks([...tasks, newTask]);\r\n      reset();\r\n      setIsAddDialogOpen(false);\r\n      toast.success('в•ӘШІв”ҳГ в•ӘШІ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө');\r\n    } catch (error) {\r\n      logger.error('Error adding task:', error);\r\n      toast.error(error instanceof Error ? error.message : 'в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ');\r\n    }\r\n  };\r\n\r\n  const handleEditTaskSubmit = async (data: z.infer<typeof taskSchema>) => {\r\n    if (!editingTask) return;\r\n\r\n    try {\r\n      const { data: payload, error } = await safeFetch<{data?: Task;} | Task>(\r\n        `/api/tasks/${editingTask.id}`,\r\n        {\r\n          method: 'PUT',\r\n          headers: { 'Content-Type': 'application/json' },\r\n          body: JSON.stringify(data)\r\n        },\r\n        null\r\n      );\r\n\r\n      if (error) {\r\n        throw error;\r\n      }\r\n\r\n      const updatedTask = extractTaskFromPayload(payload);\r\n      if (!updatedTask) {\r\n        throw new Error('в”ҳВҒв•Әв”Өв”ҳВ„ в”ҳВҒв”ҳГЁ в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ');\r\n      }\r\n\r\n      setTasks(tasks.map((task) => task.id === editingTask.id ? updatedTask : task));\r\n      setEditingTask(null);\r\n      reset();\r\n      setIsEditDialogOpen(false);\r\n      toast.success('в•ӘШІв”ҳГ  в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө');\r\n    } catch (error) {\r\n      logger.error('Error updating task:', error);\r\n      toast.error(error instanceof Error ? error.message : 'в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ');\r\n    }\r\n  };\r\n\r\n  const handleStatusChange = async (id: string, status: TaskStatus) => {\r\n    const newStatus = status === 'COMPLETED' ? 'PENDING' : 'COMPLETED';\r\n\r\n    try {\r\n      const { data: payload, error } = await safeFetch<{data?: Task;} | Task>(\r\n        `/api/tasks/${id}`,\r\n        {\r\n          method: 'PUT',\r\n          headers: { 'Content-Type': 'application/json' },\r\n          body: JSON.stringify({ status: newStatus })\r\n        },\r\n        null\r\n      );\r\n\r\n      if (error) {\r\n        throw error;\r\n      }\r\n\r\n      const updatedTask = extractTaskFromPayload(payload);\r\n      if (!updatedTask) {\r\n        throw new Error('в”ҳВҒв•Әв”Өв”ҳВ„ в”ҳВҒв”ҳГЁ в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ');\r\n      }\r\n\r\n      setTasks(tasks.map((task) => task.id === id ? updatedTask : task));\r\n      toast.success(`в•ӘШІв”ҳГ  ${newStatus === 'COMPLETED' ? 'в•ӘШӯв”ҳГўв”ҳГ в•ӘШҜв”ҳВ„' : 'в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в”ҳВҒв•ӘШІв•ӘШө'} в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө`);\r\n    } catch (error) {\r\n      logger.error('Error updating task status:', error);\r\n      toast.error(error instanceof Error ? error.message : 'в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ');\r\n    }\r\n  };\r\n\r\n  const handleDeleteTask = async (id: string) => {\r\n    try {\r\n      const { error } = await safeFetch(`/api/tasks/${id}`, { method: 'DELETE' }, null);\r\n\r\n      if (error) {\r\n        throw error;\r\n      }\r\n\r\n      setTasks(tasks.filter((task) => task.id !== id));\r\n      toast.success('в•ӘШІв”ҳГ  в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө');\r\n    } catch (error) {\r\n      logger.error('Error deleting task:', error);\r\n      toast.error(error instanceof Error ? error.message : 'в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ');\r\n    }\r\n  };\r\n\r\n  const openEditDialog = (task: Task) => {\r\n    setEditingTask(task);\r\n    setValue('title', task.title);\r\n    setValue('description', task.description || '');\r\n    setValue('subject', task.subject || undefined);\r\n    setValue('dueAt', task.dueAt ? new Date(task.dueAt).toISOString().substring(0, 16) : '');\r\n    setValue('priority', task.priority);\r\n    setIsEditDialogOpen(true);\r\n  };\r\n\r\n  const getPriorityBadge = (priority: number) => {\r\n    switch (priority) {\r\n      case 2:\r\n        return <Badge className=\"bg-red-500/10 text-red-500 border-red-500/20 font-black\">в•ӘШ«в”ҳГ§в”ҳГ в”ҳГЁв•ӘШұ в”ҳГ в”ҳВ„в•ӘШөв”ҳГ в”ҳГЁв•ӘШұ</Badge>;\r\n      case 1:\r\n        return <Badge className=\"bg-amber-500/10 text-amber-500 border-amber-500/20 font-black\">в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ в”ҳГ©в•ӘШІв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШұ</Badge>;\r\n      default:\r\n        return <Badge className=\"bg-emerald-500/10 text-emerald-500 border-emerald-500/20 font-black\">в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ в•ӘШҙв•ӘШҜв”ҳВҶв•ӘШ°в”ҳГЁв•ӘШұ</Badge>;\r\n    }\r\n  };\r\n\r\n  const getStatusIcon = (status: TaskStatus) => {\r\n    switch (status) {\r\n      case 'COMPLETED':\r\n        return <CheckCircle2 className=\"h-5 w-5 text-emerald-500\" />;\r\n      case 'IN_PROGRESS':\r\n        return <Clock className=\"h-5 w-5 text-blue-500 animate-pulse\" />;\r\n      case 'PENDING':\r\n        return <Circle className=\"h-5 w-5 text-gray-600\" />;\r\n      default:\r\n        return <AlertCircle className=\"h-5 w-5 text-amber-500\" />;\r\n    }\r\n  };\r\n\r\n  const isOverdue = (dueAt: string | null | undefined) => {\r\n    if (!dueAt) return false;\r\n    return new Date(dueAt) < new Date();\r\n  };\r\n\r\n  if (loading) {\r\n    return (\r\n      <div className=\"flex min-h-screen items-center justify-center bg-background\">\r\n         <div className=\"h-12 w-12 animate-spin rounded-full border-b-2 border-primary\" />\r\n      </div>);\r\n\r\n  }\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-background text-gray-100 selection:bg-primary/30 selection:text-white\" dir=\"rtl\">\r\n      {/* --- Ambient Background --- */}\r\n      <div className=\"fixed inset-0 pointer-events-none -z-10\">\r\n        <div className=\"absolute top-0 right-0 w-[500px] h-[500px] bg-indigo-600/10 blur-[120px] rounded-full opacity-50\" />\r\n        <div className=\"absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.01)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.01)_1px,transparent_1px)] bg-[size:50px_50px]\" />\r\n      </div>\r\n\r\n      <div className=\"mx-auto w-full max-w-7xl px-4 py-8 sm:px-6 lg:px-8 space-y-10\">\r\n        \r\n        {/* --- Header Section --- */}\r\n        <motion.div\r\n          initial={{ opacity: 0, y: 20 }}\r\n          animate={{ opacity: 1, y: 0 }}\r\n          className=\"flex flex-col md:flex-row justify-between items-center gap-6\">\r\n          \r\n          <div className=\"space-y-4 text-center md:text-right\">\r\n             <div className=\"inline-flex items-center gap-2 rounded-full border border-amber-500/30 bg-amber-500/10 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-amber-500\">\r\n                <Scroll className=\"w-4 h-4\" />\r\n                <span>в•Әв”Ӯв•ӘШҙв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ  в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Өв•Әв•– (Quest Log)</span>\r\n             </div>\r\n             <h1 className=\"text-4xl md:text-5xl font-black tracking-tight\">\r\n               в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ <span className={STYLES.neonText}>в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ«в•ӘШҜв•Әв•–в•Әв–’ в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ </span>\r\n             </h1>\r\n             <p className=\"text-gray-400 font-medium max-w-xl text-lg\">\r\n                в•ӘШ«в”ҳГўв”ҳГ в”ҳВ„ в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ в”ҳГў в”ҳВ„в•Әв–’в•ӘШ°в•ӘШө в•Әв–’в•Әв•Ўв”ҳГЁв•ӘВ» XP в”ҳГӘв•Әв–’в”ҳВҒв•Әв•Ј в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГӘв•ӘШҜв”ҳГў. в•ӘШІв•Әв–‘в”ҳГўв•Әв–’в•ӘГ® в”ҳГўв”ҳВ„ в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ в•ӘШІв”ҳГ©в•Әв–’в•ӘШ°в”ҳГў в•ӘВ«в•Әв•–в”ҳГӘв•ӘШұ в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в”ҳВҶв•Әв•Ўв•Әв–’!\r\n             </p>\r\n          </div>\r\n          \r\n          <Dialog open={isAddDialogOpen} onOpenChange={setIsAddDialogOpen}>\r\n            <DialogTrigger asChild>\r\n              <Button onClick={() => reset()} className=\"h-14 px-8 bg-primary hover:bg-primary/90 text-white font-black rounded-2xl shadow-[0_10px_30px_rgba(var(--primary),0.3)] gap-3 border-2 border-white/10 group transition-all hover:scale-105 active:scale-95\">\r\n                <Plus className=\"h-6 w-6 group-hover:rotate-90 transition-transform\" />\r\n                <span>в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ в”ҳГ в”ҳВ„в•ӘШөв”ҳГ в”ҳГЁв•ӘШұ</span>\r\n              </Button>\r\n            </DialogTrigger>\r\n            <DialogContent className=\"sm:max-w-[425px] bg-background border-white/10 text-gray-100\">\r\n              <DialogHeader>\r\n                <DialogTitle className=\"text-2xl font-black\">в•ӘШӯв•Әв•Ўв•ӘВ»в•ӘШҜв•Әв–’ в•ӘШ«в”ҳГ в•Әв–’ в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ</DialogTitle>\r\n                <DialogDescription className=\"text-gray-400\">\r\n                  в•ӘШөв•ӘВ»в•ӘВ» в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Ўв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в•ӘВ» в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШ¬в”ҳГӘв”ҳВ„.\r\n                </DialogDescription>\r\n              </DialogHeader>\r\n              <form onSubmit={handleSubmit(handleAddTaskSubmit)} className=\"grid gap-4 py-4\">\r\n                <TaskForm control={control} register={register} errors={errors} />\r\n                <DialogFooter>\r\n                  <Button type=\"submit\" className=\"w-full bg-primary font-black\">в•ӘШІв•ӘШів•ӘШ°в”ҳГЁв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ</Button>\r\n                </DialogFooter>\r\n              </form>\r\n            </DialogContent>\r\n          </Dialog>\r\n        </motion.div>\r\n\r\n        {/* --- Analytics Row --- */}\r\n        <div className=\"grid grid-cols-1 md:grid-cols-4 gap-6\">\r\n           <div className={STYLES.glass + \" p-6 flex flex-col items-center justify-center text-center gap-2 group hover:border-primary/50 transition-all cursor-default\"}>\r\n              <Flame className=\"w-8 h-8 text-orange-500 group-hover:scale-110 transition-transform\" />\r\n              <p className=\"text-xs text-gray-500 font-bold uppercase\">в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ  в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Өв•Әв•–в•ӘШұ</p>\r\n              <p className=\"text-3xl font-black\">{tasks.filter((t) => t.status !== 'COMPLETED').length}</p>\r\n           </div>\r\n           <div className={STYLES.glass + \" p-6 flex flex-col items-center justify-center text-center gap-2 group hover:border-emerald-500/50 transition-all cursor-default\"}>\r\n              <Zap className=\"w-8 h-8 text-emerald-500 group-hover:scale-110 transition-transform\" />\r\n              <p className=\"text-xs text-gray-500 font-bold uppercase\">в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•ӘШҙв•Әв–“в•ӘШұ</p>\r\n              <p className=\"text-3xl font-black\">{tasks.filter((t) => t.status === 'COMPLETED').length}</p>\r\n           </div>\r\n           <div className={STYLES.glass + \" p-6 flex flex-col items-center justify-center text-center gap-2 group hover:border-red-500/50 transition-all cursor-default\"}>\r\n              <AlertCircle className=\"w-8 h-8 text-red-500 group-hover:scale-110 transition-transform\" />\r\n              <p className=\"text-xs text-gray-500 font-bold uppercase\">в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ  в”ҳГ в•ӘШІв•ӘШ«в•ӘВ«в•Әв–’в•ӘШұ</p>\r\n              <p className=\"text-3xl font-black text-red-500\">{tasks.filter((t) => isOverdue(t.dueAt) && t.status !== 'COMPLETED').length}</p>\r\n           </div>\r\n           <div className={STYLES.glass + \" p-6 flex flex-col items-center justify-center text-center gap-2 group hover:border-amber-500/50 transition-all cursor-default\"}>\r\n              <Sparkles className=\"w-8 h-8 text-amber-500 group-hover:scale-110 transition-transform\" />\r\n              <p className=\"text-xs text-gray-500 font-bold uppercase\">XP в•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв•ӘШІв•Әв”Ӯв•ӘШ°</p>\r\n              <p className=\"text-3xl font-black text-amber-400\">+{tasks.filter((t) => t.status === 'COMPLETED').length * 100}</p>\r\n           </div>\r\n        </div>\r\n\r\n        {/* --- Main Tasks Container --- */}\r\n        <div className={STYLES.glass + \" p-1 sm:p-2 md:p-8\"}>\r\n          \r\n          {/* Filters & Tabs Bar */}\r\n          <div className=\"flex flex-col lg:flex-row items-center justify-between gap-6 mb-10 p-4 rounded-3xl bg-white/[0.02] border border-white/5 backdrop-blur-3xl\">\r\n            <Tabs value={activeTab} onValueChange={setActiveTab} className=\"w-full lg:w-auto\">\r\n              <TabsList className=\"bg-white/5 border border-white/5 p-1 h-12 rounded-xl gap-1\">\r\n                <TabsTrigger value=\"all\" className=\"rounded-lg font-bold data-[state=active]:bg-primary\">в•ӘШҜв”ҳВ„в”ҳГўв”ҳВ„</TabsTrigger>\r\n                <TabsTrigger value=\"pending\" className=\"rounded-lg font-bold data-[state=active]:bg-primary\">в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Јв”ҳВ„в”ҳГ©в•ӘШұ</TabsTrigger>\r\n                <TabsTrigger value=\"inProgress\" className=\"rounded-lg font-bold data-[state=active]:bg-primary\">в•ӘШҜв”ҳВ„в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШІв”ҳВҶв”ҳВҒв”ҳГЁв•Әв–‘в”ҳГ§в•ӘШҜ</TabsTrigger>\r\n                <TabsTrigger value=\"completed\" className=\"rounded-lg font-bold data-[state=active]:bg-primary\">в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•ӘШІв”ҳГ§в”ҳГЁв•ӘШұ</TabsTrigger>\r\n              </TabsList>\r\n            </Tabs>\r\n\r\n            <div className=\"flex flex-wrap items-center justify-center gap-3 w-full lg:w-auto\">\r\n               <div className=\"relative group flex-1 min-w-[200px]\">\r\n                  <Search className=\"absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500 group-hover:text-primary transition-colors\" />\r\n                  <Input\r\n                  placeholder=\"в•ӘШ°в•ӘШөв•ӘШі в”ҳВҒв”ҳГЁ в•ӘШ«в•Әв–’в•Әв”Өв”ҳГЁв”ҳВҒ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ ...\"\r\n                  value={searchTerm}\r\n                  onChange={(e) => setSearchTerm(e.target.value)}\r\n                  className=\"h-12 pr-12 bg-white/5 border-white/10 rounded-xl focus:ring-primary focus:border-primary shadow-inner\" />\r\n                \r\n               </div>\r\n               \r\n               <Select value={sortBy} onValueChange={(value: 'dueAt' | 'priority') => setSortBy(value)}>\r\n                  <SelectTrigger className=\"w-[180px] h-12 bg-white/5 border-white/10 rounded-xl font-bold\">\r\n                      <SelectValue placeholder=\"в”ҳВҒв•Әв–’в•Әв–“ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв•Әв–’в•ӘШ°в”ҳГЁв”ҳВҶ\" />\r\n                  </SelectTrigger>\r\n                  <SelectContent className=\"bg-background border-white/10 text-gray-100\">\r\n                      <SelectItem value=\"priority\">в•ӘШөв•Әв”Ӯв•ӘШ° в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ§в”ҳГ в”ҳГЁв•ӘШұ</SelectItem>\r\n                      <SelectItem value=\"dueAt\">в•ӘШөв•Әв”Ӯв•ӘШ° в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГ©в•ӘШІ</SelectItem>\r\n                  </SelectContent>\r\n               </Select>\r\n            </div>\r\n          </div>\r\n\r\n          {/* Task List Component */}\r\n          <div className=\"min-h-[400px]\">\r\n            <AnimatePresence mode=\"wait\">\r\n              {loading ?\r\n              <motion.div\r\n                initial={{ opacity: 0 }}\r\n                animate={{ opacity: 1 }}\r\n                exit={{ opacity: 0 }}\r\n                className=\"flex items-center justify-center h-[400px]\">\r\n                \r\n                  <div className=\"h-10 w-10 animate-spin rounded-full border-b-2 border-primary\" />\r\n                </motion.div> :\r\n\r\n              <motion.div\r\n                key={activeTab}\r\n                initial={{ opacity: 0, y: 10 }}\r\n                animate={{ opacity: 1, y: 0 }}\r\n                exit={{ opacity: 0, y: -10 }}>\r\n                \r\n                   <TaskList\r\n                  tasks={filteredAndSortedTasks}\r\n                  onStatusChange={handleStatusChange}\r\n                  onEdit={openEditDialog}\r\n                  onDelete={handleDeleteTask}\r\n                  getPriorityBadge={getPriorityBadge}\r\n                  getStatusIcon={getStatusIcon}\r\n                  isOverdue={isOverdue} />\r\n                \r\n                    {filteredAndSortedTasks.length === 0 &&\r\n                <div className=\"text-center py-20 space-y-4\">\r\n                         <div className=\"mx-auto w-20 h-20 rounded-full bg-white/5 flex items-center justify-center\">\r\n                            <Sword className=\"w-10 h-10 text-gray-600\" />\r\n                         </div>\r\n                         <div className=\"space-y-1\">\r\n                            <p className=\"text-xl font-black\">в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ  в”ҳГ в•Әв”Ӯв•ӘШҙв”ҳВ„в•ӘШұ</p>\r\n                            <p className=\"text-gray-500\">в”ҳГ в”ҳВҶв•Әв•–в”ҳГ©в•ӘШІв”ҳГў в•ӘШӘв”ҳГ в”ҳВҶв•ӘШұ в•ӘШІв”ҳГ в•ӘШҜв”ҳГ в•ӘШҜв”ҳГҜв•ӘГ® в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в•ӘВ» в”ҳГ в•Әв–’в•ӘШІв•ӘШҜв•ӘШө.</p>\r\n                         </div>\r\n                      </div>\r\n                }\r\n                </motion.div>\r\n              }\r\n            </AnimatePresence>\r\n          </div>\r\n        </div>\r\n\r\n        {/* --- Edit Task Dialog --- */}\r\n        <Dialog open={isEditDialogOpen} onOpenChange={setIsEditDialogOpen}>\r\n            <DialogContent className=\"sm:max-w-[425px] bg-background border-white/10 text-gray-100\">\r\n              <DialogHeader>\r\n                <DialogTitle className=\"text-2xl font-black\">в•ӘШІв•Әв•Јв•ӘВ»в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГӘв•ӘШҜв”ҳГ в•Әв–’</DialogTitle>\r\n                <DialogDescription className=\"text-gray-400\">\r\n                  в”ҳГ©в”ҳГ  в•ӘШ°в•ӘШІв•Әв•Јв•ӘВ»в”ҳГЁв”ҳВ„ в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Ўв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШұ.\r\n                </DialogDescription>\r\n              </DialogHeader>\r\n              <form onSubmit={handleSubmit(handleEditTaskSubmit)} className=\"grid gap-4 py-4\">\r\n                 <TaskForm control={control} register={register} errors={errors} />\r\n                 <DialogFooter>\r\n                   <Button type=\"submit\" className=\"w-full bg-primary font-black\">в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ</Button>\r\n                 </DialogFooter>\r\n              </form>\r\n            </DialogContent>\r\n        </Dialog>\r\n\r\n      </div>\r\n    </div>);\r\n\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\time\\components\\AdvancedAnalytics.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\time\\components\\AdvancedReports.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\time\\components\\CircularProgress.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\time\\components\\CreateTaskDialog.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\time\\components\\DashboardTab.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Progress' is defined but never used. Allowed unused vars must match /^_/u.","line":6,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":6,"endColumn":18,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"Progress"},"fix":{"range":[209,262],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'subjects' is defined but never used. Allowed unused args must match /^_/u.","line":45,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":45,"endColumn":11}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"ЩҠв•—в”җ'use client';\n\nimport { Card, CardContent, CardDescription, CardHeader, CardTitle } from \"@/components/ui/card\";\nimport { Badge } from \"@/components/ui/badge\";\nimport { Button } from \"@/components/ui/button\";\nimport { Progress } from \"@/components/ui/progress\";\nimport { motion } from \"framer-motion\";\n\nimport {\n  Target,\n  CheckCircle2,\n  Clock,\n  Flame,\n  TrendingUp,\n  Trophy,\n  Zap,\n  BookOpen,\n  Sword,\n  ShieldAlert,\n  Star\n} from 'lucide-react';\nimport { formatTime } from '../utils/timeUtils';\nimport type { Task, Reminder, StudySession, TimeStats } from '../types';\nimport QuickActions from './QuickActions';\nimport UpcomingTasksCard from './UpcomingTasksCard';\nimport UpcomingRemindersCard from './UpcomingRemindersCard';\nimport CircularProgress from './CircularProgress';\n\ninterface DashboardTabProps {\n  stats: TimeStats;\n  subjects: string[];\n  tasks: Task[];\n  reminders: Reminder[];\n  studySessions: StudySession[];\n  showCompletedTasks: boolean;\n  showUpcomingRemindersOnly: boolean;\n  onTabChange: (tab: string) => void;\n  onToggleCompletedTasks: () => void;\n  onToggleUpcomingReminders: () => void;\n  onTimerToggle: (taskId?: string) => void;\n}\n\nexport default function DashboardTab({\n  stats,\n  subjects,\n  tasks,\n  reminders,\n  studySessions,\n  showCompletedTasks,\n  showUpcomingRemindersOnly,\n  onTabChange,\n  onToggleCompletedTasks,\n  onToggleUpcomingReminders,\n  onTimerToggle\n}: DashboardTabProps) {\n  const upcomingTasks = tasks\n    .filter((task) =>\n      task.dueAt &&\n      new Date(task.dueAt) > new Date() &&\n      (showCompletedTasks || task.status !== 'COMPLETED')\n    )\n    .sort((a, b) => new Date(a.dueAt!).getTime() - new Date(b.dueAt!).getTime())\n    .slice(0, 5);\n\n  const recentSessions = studySessions\n    .sort((a, b) => new Date(b.startTime).getTime() - new Date(a.startTime).getTime())\n    .slice(0, 3);\n\n  return (\n    <div className=\"space-y-8 animate-in fade-in duration-700\">\n      \n      {/* RPG Stats Indicators */}\n      <motion.div \n        initial={{ opacity: 0, y: 30 }}\n        animate={{ opacity: 1, y: 0 }}\n        transition={{ duration: 0.6, staggerChildren: 0.1 }}\n        className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6\"\n      >\n        <motion.div whileHover={{ y: -8, scale: 1.02 }} transition={{ type: \"spring\", stiffness: 300 }}>\n          <Card className=\"h-full bg-background/30 backdrop-blur-2xl border border-blue-500/20 shadow-[0_8px_32px_rgba(59,130,246,0.15)] relative overflow-hidden group rounded-3xl\">\n            <div className=\"absolute inset-0 bg-gradient-to-br from-blue-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500\" />\n            <div className=\"absolute -top-10 -right-10 w-32 h-32 bg-blue-500/20 rounded-full blur-3xl group-hover:bg-blue-500/30 transition-colors\" />\n            <CardHeader className=\"pb-2 text-center relative z-10\">\n              <CardTitle className=\"text-sm font-bold text-blue-400 uppercase tracking-widest flex items-center justify-center gap-2\">\n                <Sword className=\"h-4 w-4\" /> в”ҳГ в•Әв•Јв•ӘВ»в”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШҙв•ӘШҜв•Әв–“\n              </CardTitle>\n            </CardHeader>\n            <CardContent className=\"flex flex-col items-center justify-center pt-4 pb-6 relative z-10\">\n              <CircularProgress \n                value={tasks.length ? Math.round((stats.completedTasks / tasks.length) * 100) : 0} \n                max={100}\n                colorClass=\"text-blue-500\"\n                icon={<CheckCircle2 className=\"h-6 w-6\" />}\n                label={`${stats.completedTasks} в”ҳГ в”ҳГ§в”ҳГ в•ӘШұ в”ҳГ в”ҳГўв•ӘШІв”ҳГ в”ҳВ„в•ӘШұ`}\n                sublabel={`в”ҳГ в”ҳВҶ в•ӘШ«в•Әв•Ўв”ҳВ„ ${tasks.length} в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШҙв”ҳВ„в•ӘШұ`}\n              />\n            </CardContent>\n          </Card>\n        </motion.div>\n\n        <motion.div whileHover={{ y: -8, scale: 1.02 }} transition={{ type: \"spring\", stiffness: 300 }}>\n          <Card className=\"h-full bg-background/30 backdrop-blur-2xl border border-orange-500/20 shadow-[0_8px_32px_rgba(249,115,22,0.15)] relative overflow-hidden group rounded-3xl\">\n            <div className=\"absolute inset-0 bg-gradient-to-br from-orange-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500\" />\n            <div className=\"absolute -top-10 -right-10 w-32 h-32 bg-orange-500/20 rounded-full blur-3xl group-hover:bg-orange-500/30 transition-colors\" />\n            <CardHeader className=\"pb-2 text-center relative z-10\">\n              <CardTitle className=\"text-sm font-bold text-orange-400 uppercase tracking-widest flex items-center justify-center gap-2\">\n                <BookOpen className=\"h-4 w-4\" /> в•ӘШІв”ҳГ©в•ӘВ»в”ҳГ  в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв•ӘШұ\n              </CardTitle>\n            </CardHeader>\n             <CardContent className=\"flex flex-col items-center justify-center pt-4 pb-6 relative z-10\">\n               <CircularProgress \n                 value={Math.round(stats.weeklyGoalProgress)} \n                 max={100}\n                 colorClass=\"text-orange-500\"\n                 icon={<Star className=\"h-6 w-6\" />}\n                 label=\"в•ӘШҜв”ҳВ„в”ҳГ§в•ӘВ»в”ҳВҒ в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•ӘШ°в”ҳГӘв•Әв•Јв”ҳГЁ\"\n                 sublabel={`${stats.studyHours} в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘШҜв•ӘШІ в”ҳГ в•ӘШІв•Әв–’в•ӘШҜв”ҳГўв”ҳГ в•ӘШұ`}\n               />\n            </CardContent>\n          </Card>\n        </motion.div>\n\n        <motion.div whileHover={{ y: -8, scale: 1.02 }} transition={{ type: \"spring\", stiffness: 300 }}>\n          <Card className=\"h-full bg-background/30 backdrop-blur-2xl border border-purple-500/20 shadow-[0_8px_32px_rgba(168,85,247,0.15)] relative overflow-hidden group rounded-3xl\">\n            <div className=\"absolute inset-0 bg-gradient-to-br from-purple-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500\" />\n            <div className=\"absolute -top-10 -right-10 w-32 h-32 bg-purple-500/20 rounded-full blur-3xl group-hover:bg-purple-500/30 transition-colors\" />\n            <CardHeader className=\"pb-2 text-center relative z-10\">\n              <CardTitle className=\"text-sm font-bold text-purple-400 uppercase tracking-widest flex items-center justify-center gap-2\">\n                <ShieldAlert className=\"h-4 w-4\" /> в•ӘШҜв”ҳВ„в•ӘШҜв”ҳВҶв•Әв•ўв•ӘШ°в•ӘШҜв•Әв•–\n              </CardTitle>\n            </CardHeader>\n            <CardContent className=\"flex flex-col items-center justify-center pt-4 pb-6 relative z-10\">\n               <CircularProgress \n                 value={stats.disciplineScore} \n                 max={100}\n                 colorClass=\"text-purple-500\"\n                 icon={<Target className=\"h-6 w-6\" />}\n                 label=\"в•ӘШҜв”ҳВ„в”ҳГ©в”ҳГӘв•ӘШұ в”ҳГӘв•ӘШҜв”ҳВ„в•ӘШів•ӘШ°в•ӘШҜв•ӘШІ\"\n                 sublabel=\"в•ӘШҜв•Әв”Ӯв•ӘШІв”ҳГ в•Әв–’в•ӘШҜв•Әв–’в”ҳГЁв•ӘШұ в”ҳГӘв•ӘШІв•ӘШөв”ҳГ©в”ҳГЁв”ҳГ© в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ§в•ӘВ»в•ӘШҜв”ҳВҒ\"\n               />\n            </CardContent>\n          </Card>\n        </motion.div>\n\n        <motion.div whileHover={{ y: -8, scale: 1.02 }} transition={{ type: \"spring\", stiffness: 300 }}>\n          <Card className=\"h-full bg-background/30 backdrop-blur-2xl border border-emerald-500/20 shadow-[0_8px_32px_rgba(16,185,129,0.15)] relative overflow-hidden group rounded-3xl\">\n            <div className=\"absolute inset-0 bg-gradient-to-br from-emerald-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500\" />\n            <div className=\"absolute -top-10 -right-10 w-32 h-32 bg-emerald-500/20 rounded-full blur-3xl group-hover:bg-emerald-500/30 transition-colors\" />\n            <CardHeader className=\"pb-2 text-center relative z-10\">\n              <CardTitle className=\"text-sm font-bold text-emerald-400 uppercase tracking-widest flex items-center justify-center gap-2\">\n                <Trophy className=\"h-4 w-4\" /> в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШІв”ҳГ©в•ӘШҜв”ҳВҶ\n              </CardTitle>\n            </CardHeader>\n            <CardContent className=\"flex flex-col items-center justify-center pt-4 pb-6 relative z-10\">\n               <CircularProgress \n                 value={stats.masteryScore} \n                 max={100}\n                 colorClass=\"text-emerald-500\"\n                 icon={<Trophy className=\"h-6 w-6\" />}\n                 label=\"в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳГЁв•Әв•–в•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШҜв”ҳГ в•ӘШұ\"\n                 sublabel=\"в”ҳГўв”ҳВҒв•ӘШҜв•ӘШ©в•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв•ӘШұ в”ҳГӘв•ӘШҜв”ҳВ„в•ӘШІв•Әв–’в”ҳГўв”ҳГЁв•Әв–“ в•ӘШҜв”ҳВ„в”ҳВҒв•ӘШҜв•ӘШ®в”ҳГ©\"\n               />\n            </CardContent>\n          </Card>\n        </motion.div>\n      </motion.div>\n\n      {/* Main Boards */}\n      <motion.div \n        initial={{ opacity: 0, y: 30 }}\n        animate={{ opacity: 1, y: 0 }}\n        transition={{ duration: 0.6, delay: 0.2 }}\n        className=\"grid grid-cols-1 lg:grid-cols-3 gap-8\"\n      >\n        <div className=\"lg:col-span-2 space-y-8\">\n          \n          <Card className=\"bg-background/40 backdrop-blur-xl border-white/5 rounded-3xl shadow-[0_20px_40px_rgba(0,0,0,0.2)]\">\n            <CardHeader>\n              <CardTitle className=\"flex items-center gap-2 text-xl font-bold\">\n                 <Zap className=\"h-6 w-6 text-amber-500 fill-amber-500/20\" /> в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШҙв•Әв–’в•ӘШҜв•ӘШ©в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•Әв”Ӯв•Әв–’в”ҳГЁв•Әв•Јв•ӘШұ\n              </CardTitle>\n              <CardDescription>\n                в•ӘШҜв”ҳВ„в”ҳГӘв•Әв•Ўв”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв”Ӯв•Әв–’в”ҳГЁв•Әв•Ј в”ҳВ„в”ҳВ„в•ӘШ«в•ӘВ»в”ҳГӘв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв•ӘШІв•Әв–’в•ӘШҜв•ӘШІв”ҳГЁв•ӘШҙв”ҳГЁв•ӘШұ\n              </CardDescription>\n            </CardHeader>\n            <CardContent>\n              <QuickActions\n                onAction={(action) => {\n                  switch (action) {\n                    case 'new-task':\n                      onTabChange('tasks');\n                      return;\n                    case 'new-reminder':\n                      onTabChange('reminders');\n                      return;\n                    case 'start-timer':\n                    case 'quick-study':\n                      onTimerToggle(undefined);\n                      return;\n                    case 'set-goal':\n                      onTabChange('tasks');\n                      return;\n                    case 'view-schedule':\n                      onTabChange('schedule');\n                      return;\n                    case 'view-analytics':\n                      return;\n                    case 'view-history':\n                      onTabChange('history');\n                      return;\n                    default:\n                      return;\n                  }\n                }} />\n            </CardContent>\n          </Card>\n\n          <Card className=\"bg-background/40 backdrop-blur-xl border-white/5 rounded-3xl shadow-[0_20px_40px_rgba(0,0,0,0.2)]\">\n            <CardHeader className=\"flex flex-row items-center justify-between border-b border-white/5 pb-4\">\n              <div>\n                <CardTitle className=\"text-xl font-bold flex items-center gap-2\">\n                  <Sword className=\"h-5 w-5 text-indigo-400\" /> в•Әв”Ӯв•ӘШҜв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШІв•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв•ӘВ»в”ҳГ в•ӘШұ\n                </CardTitle>\n                <CardDescription>в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•ӘШІв•Әв••в•Әв–’в•ӘШұ в”ҳГ©в•Әв–’в”ҳГЁв•ӘШ°в•ӘШҜв”ҳГҜ</CardDescription>\n              </div>\n              <Button\n                variant=\"outline\"\n                size=\"sm\"\n                className=\"rounded-full shadow-sm hover:shadow-md transition-shadow\"\n                onClick={onToggleCompletedTasks}>\n                {showCompletedTasks ? 'в•ӘШӯв•ӘВ«в”ҳВҒв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•ӘШҙв•Әв–“в•ӘШұ' : 'в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в•Әв”Ӯв•ӘШҙв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв•ӘШІв”ҳГ в”ҳВ„'}\n              </Button>\n            </CardHeader>\n            <CardContent className=\"pt-6\">\n              <UpcomingTasksCard\n                tasks={upcomingTasks}\n                showCompleted={showCompletedTasks}\n                onToggleView={onToggleCompletedTasks}\n                onTabChange={onTabChange}\n                onTimerToggle={onTimerToggle} />\n            </CardContent>\n          </Card>\n        </div>\n\n        {/* Side Panel */}\n        <div className=\"space-y-8\">\n          \n          <Card className=\"bg-gradient-to-b from-orange-500/10 to-transparent border-orange-500/20 rounded-3xl backdrop-blur-xl shadow-[0_0_30px_rgba(249,115,22,0.1)] relative overflow-hidden group\">\n            <div className=\"absolute inset-x-0 bottom-0 h-1 bg-gradient-to-r from-orange-400 to-red-600 top-0 w-full animate-pulse opacity-50\"></div>\n            <CardHeader className=\"text-center pb-2 pt-8\">\n              <div className=\"mx-auto w-16 h-16 bg-orange-500/20 rounded-full flex items-center justify-center mb-2 shadow-[0_0_20px_rgba(249,115,22,0.5)] group-hover:scale-110 transition-transform\">\n                 <Flame className=\"h-8 w-8 text-orange-500 drop-shadow-md\" />\n              </div>\n              <CardTitle className=\"text-2xl font-black text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-red-500\">\n                в•Әв”Өв•Әв•Јв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШөв”ҳГ в•ӘШҜв•Әв”Ӯ\n              </CardTitle>\n              <CardDescription className=\"text-orange-200/60 font-medium\">в•ӘШ«в”ҳГЁв•ӘШҜв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШҜв”ҳВ„в•ӘШІв•Әв–“в•ӘШҜв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГ в•Әв–’</CardDescription>\n            </CardHeader>\n            <CardContent>\n              <div className=\"flex flex-col items-center justify-center pb-4\">\n                <div className=\"text-6xl font-black text-orange-500 drop-shadow-[0_0_20px_rgba(249,115,22,0.6)] group-hover:drop-shadow-[0_0_30px_rgba(249,115,22,0.8)] transition-all\">\n                   {stats.streakDays}\n                </div>\n                <div className=\"text-sm font-bold text-orange-300 tracking-wider\">в•ӘШ«в”ҳГЁв•ӘШҜв”ҳГ </div>\n              </div>\n              \n              <div className=\"bg-background/40 rounded-2xl p-4 mt-2 space-y-3 border border-orange-500/10\">\n                <div className=\"flex items-center justify-between text-sm\">\n                  <div className=\"flex items-center gap-2\"><Zap className=\"h-4 w-4 text-yellow-500\" /> в•Әв•–в•ӘШҜв”ҳГ©в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•Әв–’в”ҳГўв”ҳГЁв•Әв–“</div>\n                  <Badge variant=\"outline\" className=\"bg-yellow-500/10 text-yellow-500 border-yellow-500/20\">{stats.focusScore}%</Badge>\n                </div>\n                <div className=\"flex items-center justify-between text-sm\">\n                  <div className=\"flex items-center gap-2\"><TrendingUp className=\"h-4 w-4 text-emerald-500\" /> в”ҳГ в•Әв•Јв•ӘВ»в”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГўв”ҳВҒв•ӘШҜв•ӘШ©в•ӘШұ</div>\n                  <Badge variant=\"outline\" className=\"bg-emerald-500/10 text-emerald-500 border-emerald-500/20\">{stats.studyEfficiency}%</Badge>\n                </div>\n                <div className=\"flex items-center justify-between text-sm\">\n                  <div className=\"flex items-center gap-2\"><Clock className=\"h-4 w-4 text-purple-500\" /> в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШҙв•ӘШҜв•Әв–“</div>\n                  <Badge variant=\"outline\" className=\"bg-purple-500/10 text-purple-500 border-purple-500/20\">{stats.pomodoroSessions} в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШұ</Badge>\n                </div>\n              </div>\n            </CardContent>\n          </Card>\n\n          <Card className=\"bg-background/40 backdrop-blur-xl border-white/5 rounded-3xl shadow-[0_20px_40px_rgba(0,0,0,0.2)]\">\n            <CardHeader className=\"flex flex-row items-center justify-between border-b border-white/5 pb-4\">\n               <CardTitle className=\"text-lg font-bold flex items-center gap-2\">\n                 <ShieldAlert className=\"h-5 w-5 text-rose-400\" /> в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҶв•ӘШ°в”ҳГЁв”ҳГ§в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•ӘШІв•Әв••в•Әв–’в•ӘШұ\n               </CardTitle>\n              <Button\n                variant=\"ghost\"\n                size=\"sm\"\n                className=\"text-xs h-7\"\n                onClick={onToggleUpcomingReminders}>\n                {showUpcomingRemindersOnly ? 'в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в”ҳГўв”ҳВ„' : 'в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв•ӘВ»в”ҳГ в•ӘШұ в”ҳВҒв”ҳГ©в•Әв•–'}\n              </Button>\n            </CardHeader>\n            <CardContent className=\"pt-6\">\n              <UpcomingRemindersCard\n                reminders={reminders.filter((r) => {\n                  const now = new Date();\n                  const remindDate = new Date(r.remindAt);\n                  return remindDate > now;\n                })}\n                showUpcomingOnly={showUpcomingRemindersOnly}\n                onToggleView={onToggleUpcomingReminders}\n                onTabChange={onTabChange} />\n            </CardContent>\n          </Card>\n\n          <Card className=\"bg-background/40 backdrop-blur-xl border-white/5 rounded-3xl shadow-[0_20px_40px_rgba(0,0,0,0.2)]\">\n            <CardHeader className=\"border-b border-white/5 pb-4\">\n              <CardTitle className=\"text-lg font-bold\">в”ҳГ в•ӘВ«в•Әв•–в”ҳГӘв•Әв•–в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•Әв”Ӯв•ӘШҙв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ©в•ӘВ»в”ҳГЁв”ҳГ </CardTitle>\n              <CardDescription>в•ӘШ«в•ӘШөв•ӘВ»в•ӘШі в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШІв•Әв–’в”ҳГўв”ҳГЁв•Әв–“ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв•ӘШІв”ҳГ в”ҳВ„в•ӘШұ</CardDescription>\n            </CardHeader>\n            <CardContent className=\"pt-6\">\n              {recentSessions.length > 0 ?\n                <div className=\"space-y-4\">\n                  {recentSessions.map((session, index) =>\n                    <div\n                      key={`${session.id}-${index}`}\n                      className=\"flex items-center justify-between p-4 bg-muted/20 rounded-2xl border border-white/5 hover:bg-muted/40 transition-colors group\">\n                      \n                      <div className=\"flex-1 min-w-0\">\n                        <div className=\"font-medium truncate text-foreground/90 group-hover:text-primary transition-colors\">\n                          {session.taskId ?\n                            tasks.find((t) => t.id === session.taskId)?.title || 'в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШұ в•ӘШІв•ӘВ»в•Әв–’в”ҳГЁв•ӘШ° в”ҳГ в”ҳГўв•ӘШів”ҳВҒв•ӘШұ' :\n                            'в•ӘШІв•ӘШөв•Әв•Ўв”ҳГЁв”ҳВ„ в•Әв•Јв”ҳВ„в”ҳГ в”ҳГЁ'}\n                        </div>\n                        <div className=\"text-xs text-muted-foreground flex items-center gap-1.5 mt-1.5 font-medium\">\n                          <Clock className=\"h-3 w-3 text-primary/70\" />\n                          <span className=\"bg-background/50 px-2 py-0.5 rounded-md\">{formatTime(session.durationMin * 60)}</span>\n                          <span className=\"opacity-50\">ШёШҙШӘ</span>\n                          <span>{new Date(session.startTime).toLocaleDateString('ar-SA')}</span>\n                        </div>\n                      </div>\n                      <Badge variant=\"default\" className=\"ml-3 bg-primary/20 text-primary border-primary/20 group-hover:bg-primary group-hover:text-primary-foreground shadow-sm transition-all h-8 px-3\">\n                        {Math.floor(session.durationMin)} в•ӘВ»\n                      </Badge>\n                    </div>\n                  )}\n                </div> :\n                <div className=\"text-center text-muted-foreground py-8 bg-muted/10 rounded-2xl border border-dashed border-white/10\">\n                  <Clock className=\"h-8 w-8 mx-auto mb-3 opacity-20\" />\n                  <p>в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в”ҳГ в•ӘВ«в•Әв•–в”ҳГӘв•Әв•–в•ӘШҜв•ӘШІ в•ӘШІв•ӘВ»в•Әв–’в”ҳГЁв•ӘШ°в”ҳГЁв•ӘШұ в•ӘШ°в•Әв•Јв•ӘВ»</p>\n                </div>\n              }\n            </CardContent>\n          </Card>\n        </div>\n      </motion.div>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\time\\components\\ExportDialog.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\time\\components\\KeyboardShortcutsHelp.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\time\\components\\PerformanceMetrics.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":