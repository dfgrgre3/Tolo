rom 'date-fns';\r\nimport { motion } from 'framer-motion';\r\nimport {\r\n  Shield,\r\n  Key,\r\n  History,\r\n  AlertTriangle,\r\n  CheckCircle2,\r\n  Loader2,\r\n  ShieldCheck,\r\n  ShieldX,\r\n  Smartphone } from\r\n'lucide-react';\r\n\r\nimport { cn } from '@/lib/utils';\r\nimport { toast } from 'sonner';\r\nimport { useAuth } from '@/contexts/auth-context';\r\nimport { DeleteAccountDialog, TwoFactorSetupModal, PhoneVerificationModal } from '../components';\r\nimport { useRouter } from 'next/navigation';\r\nimport { logger } from '@/lib/logger';\r\n\r\ninterface SecurityLog {\r\n  id: string;\r\n  eventType: string;\r\n  createdAt: string;\r\n  ip: string;\r\n  userAgent: string;\r\n  location: string | null;\r\n}\r\n\r\nexport default function SecurityPage() {\r\n  const { logout, user, refreshUser } = useAuth();\r\n  const router = useRouter();\r\n  const [isChangingPassword, setIsChangingPassword] = useState(false);\r\n  const [passwordData, setPasswordData] = useState({\r\n    currentPassword: '',\r\n    newPassword: '',\r\n    confirmPassword: ''\r\n  });\r\n  const [isLoading, setIsLoading] = useState(false);\r\n\r\n  // Two-Factor Authentication State\r\n  const [is2FAEnabled, setIs2FAEnabled] = useState(false);\r\n  const [isLoading2FA, setIsLoading2FA] = useState(true);\r\n  const [show2FAModal, setShow2FAModal] = useState(false);\r\n  const [isDisabling2FA, setIsDisabling2FA] = useState(false);\r\n\r\n  // Phone Verification State\r\n  const [showPhoneModal, setShowPhoneModal] = useState(false);\r\n\r\n\r\n  // Security Logs State\r\n  const [recentLogs, setRecentLogs] = useState<SecurityLog[]>([]);\r\n  const [isLoadingLogs, setIsLoadingLogs] = useState(true);\r\n\r\n  const EVENT_LABELS: Record<string, string> = {\r\n    LOGIN_SUCCESS: 'в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳВҶв•ӘШҜв•ӘШҙв•ӘШө',\r\n    LOGIN_FAILED: 'в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳВҒв•ӘШҜв•Әв”Өв”ҳВ„в•ӘШұ',\r\n    LOGOUT: 'в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘВ«в•Әв–’в”ҳГӘв•ӘШҙ',\r\n    REGISTER: 'в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ° в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»',\r\n    PASSWORD_CHANGE: 'в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’',\r\n    MAGIC_LINK_REQUESTED: 'в•Әв•–в”ҳВ„в•ӘШ° в•Әв–’в•ӘШҜв•ӘШ°в•Әв•– в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„',\r\n    DEVICE_TRUST_CHANGE: 'в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШів”ҳГ©в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШҙв”ҳГ§в•ӘШҜв•Әв–“',\r\n    SUSPICIOUS_ACTIVITY: 'в”ҳВҶв•Әв”Өв•ӘШҜв•Әв•– в”ҳГ в•Әв”Өв•ӘШ°в”ҳГӘв”ҳГ§'\r\n  };\r\n\r\n  // Fetch 2FA Status\r\n  const fetch2FAStatus = useCallback(async () => {\r\n    try {\r\n      const res = await fetch('/api/auth/2fa/status');\r\n      if (res.ok) {\r\n        const data = await res.json();\r\n        setIs2FAEnabled(data.enabled);\r\n      }\r\n    } catch (_err) {\r\n      logger.error('Failed to fetch 2FA status');\r\n    } finally {\r\n      setIsLoading2FA(false);\r\n    }\r\n  }, []);\r\n\r\n\r\n  // Fetch Recent Security Logs\r\n  const fetchRecentLogs = useCallback(async () => {\r\n    try {\r\n      const res = await fetch('/api/auth/security-logs?limit=3');\r\n      if (!res.ok) throw new Error();\r\n      const data = await res.json();\r\n      setRecentLogs(data.logs || []);\r\n    } catch (_err) {\r\n      logger.error('Failed to fetch logs');\r\n    } finally {\r\n      setIsLoadingLogs(false);\r\n    }\r\n  }, []);\r\n\r\n  useEffect(() => {\r\n    fetch2FAStatus();\r\n    fetchRecentLogs();\r\n  }, [fetch2FAStatus, fetchRecentLogs]);\r\n\r\n  const handlePasswordChange = async (e: React.FormEvent) => {\r\n    e.preventDefault();\r\n    if (passwordData.newPassword !== passwordData.confirmPassword) {\r\n      toast.error('в”ҳГўв”ҳВ„в”ҳГ в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШІв•Әв•–в•ӘШҜв•ӘШ°в”ҳГ©в•ӘШұ');\r\n      return;\r\n    }\r\n\r\n    setIsLoading(true);\r\n    try {\r\n      const response = await fetch('/api/auth/change-password', {\r\n        method: 'POST',\r\n        headers: { 'Content-Type': 'application/json' },\r\n        body: JSON.stringify({\r\n          currentPassword: passwordData.currentPassword,\r\n          newPassword: passwordData.newPassword\r\n        })\r\n      });\r\n\r\n      if (!response.ok) {\r\n        const error = await response.json();\r\n        throw new Error(error.error || 'в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’');\r\n      }\r\n\r\n      toast.success('в•ӘШІв”ҳГ  в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө');\r\n      setIsChangingPassword(false);\r\n      setPasswordData({ currentPassword: '', newPassword: '', confirmPassword: '' });\r\n    } catch (error: unknown) {\r\n      toast.error(error instanceof Error ? error.message : 'в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’');\r\n    } finally {\r\n      setIsLoading(false);\r\n    }\r\n  };\r\n\r\n  // Handle 2FA Toggle\r\n  const handle2FAToggle = async () => {\r\n    if (is2FAEnabled) {\r\n      // Disable 2FA\r\n      setIsDisabling2FA(true);\r\n      try {\r\n        const res = await fetch('/api/auth/2fa/disable', { method: 'POST' });\r\n        if (res.ok) {\r\n          setIs2FAEnabled(false);\r\n          toast.success('в•ӘШІв”ҳГ  в•ӘШІв•Әв•Јв•Әв•–в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Ўв•ӘШҜв•ӘВ»в”ҳГ©в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШів”ҳВҶв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШұ');\r\n        } else {\r\n          const error = await res.json();\r\n          throw new Error(error.error || 'в”ҳВҒв•Әв”Өв”ҳВ„ в”ҳВҒв”ҳГЁ в•ӘШІв•Әв•Јв•Әв•–в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Ўв•ӘШҜв•ӘВ»в”ҳГ©в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШів”ҳВҶв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШұ');\r\n        }\r\n      } catch (error: unknown) {\r\n        toast.error(error instanceof Error ? error.message : 'в”ҳВҒв•Әв”Өв”ҳВ„ в”ҳВҒв”ҳГЁ в•ӘШІв•Әв•Јв•Әв•–в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Ўв•ӘШҜв•ӘВ»в”ҳГ©в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШів”ҳВҶв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШұ');\r\n      } finally {\r\n        setIsDisabling2FA(false);\r\n      }\r\n    } else {\r\n      // Enable 2FA - show modal\r\n      setShow2FAModal(true);\r\n    }\r\n  };\r\n\r\n  const handle2FASuccess = () => {\r\n    setIs2FAEnabled(true);\r\n    fetch2FAStatus();\r\n  };\r\n\r\n\r\n\r\n  const handleDeleteAccount = async () => {\r\n    if (!user?.id) return;\r\n\r\n    try {\r\n      const res = await fetch(`/api/users/${user.id}`, {\r\n        method: \"DELETE\",\r\n        headers: { \"Content-Type\": \"application/json\" },\r\n        credentials: \"include\"\r\n      });\r\n\r\n      if (res.ok) {\r\n        toast.success(\"в•ӘШІв”ҳГ  в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШҜв”ҳВ„в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ° в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө\");\r\n        localStorage.clear();\r\n        sessionStorage.clear();\r\n        setTimeout(() => {\r\n          router.push(\"/\");\r\n        }, 1000);\r\n      } else {\r\n        const errorData = await res.json().catch(() => ({ error: \"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв•Јв•Әв–’в”ҳГӘв”ҳВҒ\" }));\r\n        toast.error(errorData.error || \"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШҜв”ҳВ„в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°\");\r\n      }\r\n    } catch (error) {\r\n      logger.error(\"Error deleting account:\", error);\r\n      toast.error(\"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШҜв”ҳВ„в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°\");\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className=\"max-w-4xl mx-auto space-y-8\">\r\n      {/* Header */}\r\n      <div>\r\n        <h1 className=\"text-2xl font-bold text-white flex items-center gap-3\">\r\n          <Shield className=\"h-7 w-7 text-indigo-400\" />\r\n          в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ в•ӘШҜв”ҳВҶ\r\n        </h1>\r\n        <p className=\"text-sm text-slate-400 mt-1\">в•ӘШӯв•ӘВ»в•ӘШҜв•Әв–’в•ӘШұ в”ҳГӘв•ӘШөв”ҳГ в•ӘШҜв”ҳГЁв•ӘШұ в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°в”ҳГў в”ҳГӘв•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в”ҳГўв”ҳВ„в”ҳГ в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’</p>\r\n      </div>\r\n\r\n      {/* Password Section */}\r\n      <section className=\"rounded-2xl bg-white/5 border border-white/10 overflow-hidden\">\r\n        <div className=\"p-6\">\r\n          <div className=\"flex items-center justify-between mb-6\">\r\n            <div className=\"flex items-center gap-4\">\r\n              <div className=\"h-12 w-12 rounded-xl bg-indigo-500/10 flex items-center justify-center\">\r\n                <Key className=\"h-6 w-6 text-indigo-400\" />\r\n              </div>\r\n              <div>\r\n                <h3 className=\"font-semibold text-white\">в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’</h3>\r\n                <p className=\"text-sm text-slate-400\">в•ӘШӘв•ӘВ«в•Әв–’ в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’: в”ҳГ в”ҳВҶв•Әв–‘ 3 в•ӘШ«в•Әв”Өв”ҳГ§в•Әв–’</p>\r\n              </div>\r\n            </div>\r\n            <button\r\n              onClick={() => setIsChangingPassword(!isChangingPassword)}\r\n              className=\"px-4 py-2 rounded-xl bg-white/5 hover:bg-white/10 text-white transition-colors\">\r\n              \r\n              {isChangingPassword ? 'в•ӘШӯв”ҳВ„в•Әв•‘в•ӘШҜв•ӘШ©' : 'в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі'}\r\n            </button>\r\n          </div>\r\n\r\n          {isChangingPassword &&\r\n          <motion.form\r\n            initial={{ height: 0, opacity: 0 }}\r\n            animate={{ height: 'auto', opacity: 1 }}\r\n            onSubmit={handlePasswordChange}\r\n            className=\"space-y-4 border-t border-white/10 pt-6\">\r\n            \r\n              <div className=\"grid gap-4\">\r\n                <div className=\"space-y-2\">\r\n                  <label className=\"text-sm text-slate-300\">в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШұ</label>\r\n                  <input\r\n                  type=\"password\"\r\n                  required\r\n                  value={passwordData.currentPassword}\r\n                  onChange={(e) => setPasswordData({ ...passwordData, currentPassword: e.target.value })}\r\n                  className=\"w-full p-3 rounded-xl bg-white/5 border border-white/10 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500/50\" />\r\n                \r\n                </div>\r\n                <div className=\"grid sm:grid-cols-2 gap-4\">\r\n                  <div className=\"space-y-2\">\r\n                    <label className=\"text-sm text-slate-300\">в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ</label>\r\n                    <input\r\n                    type=\"password\"\r\n                    required\r\n                    value={passwordData.newPassword}\r\n                    onChange={(e) => setPasswordData({ ...passwordData, newPassword: e.target.value })}\r\n                    className=\"w-full p-3 rounded-xl bg-white/5 border border-white/10 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500/50\" />\r\n                  \r\n                  </div>\r\n                  <div className=\"space-y-2\">\r\n                    <label className=\"text-sm text-slate-300\">в•ӘШІв•ӘШ«в”ҳГўв”ҳГЁв•ӘВ» в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ</label>\r\n                    <input\r\n                    type=\"password\"\r\n                    required\r\n                    value={passwordData.confirmPassword}\r\n                    onChange={(e) => setPasswordData({ ...passwordData, confirmPassword: e.target.value })}\r\n                    className=\"w-full p-3 rounded-xl bg-white/5 border border-white/10 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500/50\" />\r\n                  \r\n                  </div>\r\n                </div>\r\n              </div>\r\n              <button\r\n              type=\"submit\"\r\n              disabled={isLoading}\r\n              className=\"w-full sm:w-auto px-6 py-2 rounded-xl bg-indigo-500 hover:bg-indigo-600 text-white transition-colors flex items-center justify-center gap-2\">\r\n              \r\n                {isLoading && <Loader2 className=\"h-4 w-4 animate-spin\" />}\r\n                в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’\r\n              </button>\r\n            </motion.form>\r\n          }\r\n        </div>\r\n      </section>\r\n\r\n      {/* Two-Factor Authentication */}\r\n      <section className=\"rounded-2xl bg-white/5 border border-white/10 p-6\">\r\n        <div className=\"flex items-center justify-between\">\r\n          <div className=\"flex items-center gap-4\">\r\n            <div className={cn(\r\n              \"h-12 w-12 rounded-xl flex items-center justify-center\",\r\n              is2FAEnabled ? \"bg-green-500/10\" : \"bg-slate-500/10\"\r\n            )}>\r\n              {isLoading2FA ?\r\n              <Loader2 className=\"h-6 w-6 text-slate-400 animate-spin\" /> :\r\n              is2FAEnabled ?\r\n              <ShieldCheck className=\"h-6 w-6 text-green-400\" /> :\r\n\r\n              <Shield className=\"h-6 w-6 text-slate-400\" />\r\n              }\r\n            </div>\r\n            <div>\r\n              <h3 className=\"font-semibold text-white\">в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Ўв•ӘШҜв•ӘВ»в”ҳГ©в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШів”ҳВҶв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШұ (2FA)</h3>\r\n              <p className=\"text-sm text-slate-400\">\r\n                {isLoading2FA ? 'в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„...' :\r\n                is2FAEnabled ? 'в”ҳГ в”ҳВҒв•Әв•Јв”ҳЩ‘в”ҳВ„в•ӘШұ - в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°в”ҳГў в”ҳГ в•ӘШөв”ҳГ в”ҳГЁ в•ӘШ°в•Әв•–в•ӘШ°в”ҳГ©в•ӘШұ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв”ҳГЁв•ӘШұ' :\r\n                'в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•Әв•–в•ӘШ°в”ҳГ©в•ӘШұ в•ӘШөв”ҳГ в•ӘШҜв”ҳГЁв•ӘШұ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв”ҳГЁв•ӘШұ в”ҳВ„в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°в”ҳГў'}\r\n              </p>\r\n            </div>\r\n          </div>\r\n          <button\r\n            onClick={handle2FAToggle}\r\n            disabled={isLoading2FA || isDisabling2FA}\r\n            className={cn(\r\n              \"px-4 py-2 rounded-xl transition-colors flex items-center gap-2 disabled:opacity-50\",\r\n              is2FAEnabled ?\r\n              \"bg-red-500/20 text-red-400 hover:bg-red-500/30 border border-red-500/30\" :\r\n              \"bg-green-500/20 text-green-400 hover:bg-green-500/30\"\r\n            )}>\r\n            \r\n            {isDisabling2FA ?\r\n            <Loader2 className=\"h-4 w-4 animate-spin\" /> :\r\n            is2FAEnabled ?\r\n            <>\r\n                <ShieldX className=\"h-4 w-4\" />\r\n                в•ӘШІв•Әв•Јв•Әв•–в”ҳГЁв”ҳВ„\r\n              </> :\r\n\r\n            <>\r\n                <ShieldCheck className=\"h-4 w-4\" />\r\n                в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„\r\n              </>\r\n            }\r\n          </button>\r\n        </div>\r\n        {is2FAEnabled &&\r\n        <div className=\"mt-4 p-3 rounded-xl bg-green-500/10 border border-green-500/20 flex items-start gap-3\">\r\n            <CheckCircle2 className=\"h-5 w-5 text-green-400 shrink-0 mt-0.5\" />\r\n            <div>\r\n              <p className=\"text-sm text-green-300\">в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Ўв•ӘШҜв•ӘВ»в”ҳГ©в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШів”ҳВҶв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШұ в”ҳГ в”ҳВҒв•Әв•Јв”ҳЩ‘в”ҳВ„в•ӘШұ</p>\r\n              <p className=\"text-xs text-green-400/70 mt-1\">\r\n                в•Әв”Ӯв”ҳГЁв•Әв••в”ҢГӘв•Әв•–в”ҳВ„в•ӘШ° в”ҳГ в”ҳВҶв”ҳГў в•Әв–’в”ҳГ в•Әв–“ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳГ в”ҳВҶ в•ӘШ«в•ӘШҙв”ҳГ§в•Әв–“в•ӘШұ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ\r\n              </p>\r\n            </div>\r\n          </div>\r\n        }\r\n      </section>\r\n      {/* Phone Verification */}\r\n      <section className=\"rounded-2xl bg-white/5 border border-white/10 p-6\">\r\n        <div className=\"flex items-center justify-between\">\r\n          <div className=\"flex items-center gap-4\">\r\n            <div className={cn(\r\n              \"h-12 w-12 rounded-xl flex items-center justify-center\",\r\n              user?.phoneVerified ? \"bg-indigo-500/10\" : \"bg-yellow-500/10\"\r\n            )}>\r\n              {user?.phoneVerified ?\r\n              <Smartphone className=\"h-6 w-6 text-indigo-400\" /> :\r\n\r\n              <Smartphone className=\"h-6 w-6 text-yellow-400\" />\r\n              }\r\n            </div>\r\n            <div>\r\n              <h3 className=\"font-semibold text-white\">в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в•Әв–’в”ҳГ©в”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ§в•ӘШҜв•ӘШІв”ҳВҒ</h3>\r\n              <p className=\"text-sm text-slate-400\">\r\n                {user?.phoneVerified ? `в”ҳГ в”ҳВҒв•Әв•Јв”ҳВ„: ${user?.phone}` : 'в”ҳВ„в”ҳГ  в”ҳГЁв•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в”ҳГ в”ҳВҶ в•Әв–’в”ҳГ©в”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ§в•ӘШҜв•ӘШІв”ҳВҒ в•ӘШ°в•Әв•Јв•ӘВ»'}\r\n              </p>\r\n            </div>\r\n          </div>\r\n          {!user?.phoneVerified &&\r\n          <button\r\n            onClick={() => setShowPhoneModal(true)}\r\n            className=\"px-4 py-2 rounded-xl bg-indigo-500 hover:bg-indigo-600 text-white transition-colors text-sm font-medium\">\r\n            \r\n              в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в•ӘШҜв”ҳВ„в•ӘШӘв”ҳВҶ\r\n            </button>\r\n          }\r\n          {user?.phoneVerified &&\r\n          <div className=\"flex items-center gap-2 text-green-400 text-sm font-medium\">\r\n              <CheckCircle2 className=\"h-4 w-4\" />\r\n              в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ©\r\n            </div>\r\n          }\r\n        </div>\r\n        {!user?.phoneVerified &&\r\n        <div className=\"mt-4 p-3 rounded-xl bg-yellow-500/10 border border-yellow-500/20 flex items-start gap-3\">\r\n            <AlertTriangle className=\"h-5 w-5 text-yellow-400 shrink-0 mt-0.5\" />\r\n            <p className=\"text-xs text-yellow-500/80\">\r\n              в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в”ҳГ в”ҳВҶ в•Әв–’в”ҳГ©в”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ§в•ӘШҜв•ӘШІв”ҳВҒ в”ҳГЁв•ӘШөв”ҳГ в”ҳГЁ в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°в”ҳГў в”ҳГӘв”ҳГЁв•Әв”Ӯв”ҳГ в•ӘШө в”ҳВ„в”ҳВҶв•ӘШҜ в•ӘШ°в•ӘШҜв”ҳВ„в•ӘШІв”ҳГӘв•ӘШҜв•Әв•Ўв”ҳВ„ в”ҳГ в•Әв•Јв”ҳГў в•ӘШ°в•ӘВ«в•Әв•Ўв”ҳГӘв•Әв•Ў в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в”ҳГӘв•Әв”Ӯ в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ§в•ӘШҜв”ҳГ в•ӘШұ.\r\n            </p>\r\n          </div>\r\n        }\r\n      </section>\r\n\r\n      \r\n      {/* Security Log Summary */}\r\n      <section className=\"rounded-2xl bg-white/5 border border-white/10 p-6\">\r\n        <div className=\"flex items-center justify-between mb-4\">\r\n          <h3 className=\"font-semibold text-white flex items-center gap-2\">\r\n            <History className=\"h-5 w-5 text-indigo-400\" />\r\n            в•Әв”Ӯв•ӘШҙв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Өв•ӘШҜв•Әв•–в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ в”ҳВҶв”ҳГЁв•ӘШұ\r\n          </h3>\r\n          <Link href=\"/settings/security/logs\" className=\"text-sm text-indigo-400 hover:underline\">в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в”ҳГўв”ҳВ„</Link>\r\n        </div>\r\n        <div className=\"space-y-4\">\r\n          {isLoadingLogs ?\r\n          <div className=\"flex items-center justify-center py-4\">\r\n              <Loader2 className=\"h-5 w-5 text-indigo-500 animate-spin\" />\r\n            </div> :\r\n          recentLogs.length > 0 ?\r\n          recentLogs.map((log) =>\r\n          <div key={log.id} className=\"flex items-center justify-between text-sm\">\r\n                <div className=\"flex items-center gap-2\">\r\n                  {log.eventType.includes('SUCCESS') || log.eventType === 'REGISTER' ?\r\n              <CheckCircle2 className=\"h-4 w-4 text-green-400\" /> :\r\n              log.eventType.includes('FAILED') || log.eventType.includes('SUSPICIOUS') ?\r\n              <AlertTriangle className=\"h-4 w-4 text-red-400\" /> :\r\n\r\n              <Shield className=\"h-4 w-4 text-indigo-400\" />\r\n              }\r\n                  <span className=\"text-slate-300\">\r\n                    {EVENT_LABELS[log.eventType] || log.eventType}\r\n                  </span>\r\n                </div>\r\n                <span className=\"text-slate-500\">\r\n                  {formatDistanceToNow(new Date(log.createdAt), { addSuffix: true, locale: ar })}\r\n                </span>\r\n              </div>\r\n          ) :\r\n\r\n          <p className=\"text-center text-xs text-slate-500 py-2\">в”ҳВ„в•ӘШҜ в”ҳГЁв”ҳГӘв•ӘШҙв•ӘВ» в”ҳВҶв•Әв”Өв•ӘШҜв•Әв•–в•ӘШҜв•ӘШІ в”ҳГ в•Әв”Ӯв•ӘШҙв”ҳВ„в•ӘШұ в•ӘШөв•ӘШІв”ҳГ« в•ӘШҜв”ҳВ„в•ӘШӘв”ҳВҶ</p>\r\n          }\r\n        </div>\r\n      </section>\r\n\r\n      {/* Danger Zone - Delete Account */}\r\n      <section className=\"rounded-2xl bg-red-500/5 border border-red-500/20 overflow-hidden\">\r\n        <div className=\"p-4 border-b border-red-500/20 bg-red-500/10\">\r\n          <h3 className=\"font-semibold text-red-400 flex items-center gap-2\">\r\n            <AlertTriangle className=\"h-5 w-5\" />\r\n            в”ҳГ в”ҳВҶв•Әв•–в”ҳГ©в•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ«в•Әв•–в•Әв–’\r\n          </h3>\r\n        </div>\r\n        <div className=\"p-6\">\r\n          <div className=\"flex items-start justify-between gap-4\">\r\n            <div>\r\n              <h4 className=\"font-medium text-white\">в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШҜв”ҳВ„в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ° в”ҳВҶв”ҳГ§в•ӘШҜв•ӘШ®в”ҳГЁв•ӘШҜв”ҳГҜ</h4>\r\n              <p className=\"text-sm text-slate-400 mt-1\">\r\n                в•Әв”Ӯв”ҳГЁв•ӘШІв”ҳГ  в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°в”ҳГў в”ҳГӘв•ӘШҙв”ҳГ в”ҳГЁв•Әв•Ј в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІв”ҳГў в•ӘШ°в•Әв”Өв”ҳГўв”ҳВ„ в•ӘВ»в•ӘШҜв•ӘШ®в”ҳГ . в”ҳГ§в•Әв–‘в•ӘШҜ в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШҙв•Әв–’в•ӘШҜв•ӘШ© в”ҳВ„в•ӘШҜ в”ҳГЁв”ҳГ в”ҳГўв”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШІв•Әв–’в•ӘШҜв•ӘШҙв•Әв•Ј в•Әв•Јв”ҳВҶв”ҳГ§.\r\n              </p>\r\n            </div>\r\n            <DeleteAccountDialog onConfirm={handleDeleteAccount} />\r\n          </div>\r\n        </div>\r\n      </section>\r\n\r\n      {/* 2FA Setup Modal */}\r\n      <TwoFactorSetupModal\r\n        isOpen={show2FAModal}\r\n        onClose={() => setShow2FAModal(false)}\r\n        onSuccess={handle2FASuccess} />\r\n      \r\n      {/* Phone Verification Modal */}\r\n      <PhoneVerificationModal\r\n        isOpen={showPhoneModal}\r\n        onClose={() => setShowPhoneModal(false)}\r\n        onSuccess={() => {\r\n          setShowPhoneModal(false);\r\n          refreshUser();\r\n        }}\r\n        initialPhone={user?.phone || ''} />\r\n      \r\n    </div>);\r\n\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\subscription\\fail\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\subscription\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'FileText' is defined but never used. Allowed unused vars must match /^_/u.","line":16,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":16,"endColumn":11,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"FileText"},"fix":{"range":[257,270],"text":""},"desc":"Remove unused variable \"FileText\"."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"ЩҠв•—в”җ\"use client\";\r\n\r\nimport React, { useState, useEffect } from \"react\";\r\nimport { motion } from \"framer-motion\";\r\nimport {\r\n  Wallet,\r\n  Clock,\r\n  CheckCircle2,\r\n  XCircle,\r\n  AlertCircle,\r\n  ArrowUpRight,\r\n  TrendingUp,\r\n  History,\r\n  ShieldCheck,\r\n  Calendar,\r\n  FileText,\r\n  Zap,\r\n  LayoutDashboard,\r\n  Download,\r\n  Bot,\r\n  BookOpen,\r\n  GraduationCap\r\n} from \"lucide-react\";\r\n\r\nimport { format } from \"date-fns\";\r\nimport { ar } from \"date-fns/locale\";\r\nimport { toast } from \"sonner\";\r\nimport Link from \"next/link\";\r\nimport { InvoiceTemplate } from \"@/components/billing/invoice-template\";\r\nimport { generateInvoicePDF } from \"@/utils/billing/generate-pdf\";\r\nimport { logger } from '@/lib/logger';\r\n\r\ninterface ActiveSubscription {\r\n  id: string;\r\n  status: string;\r\n  startDate: string;\r\n  endDate: string;\r\n  plan: {\r\n    name: string;\r\n    nameAr: string;\r\n    price: number;\r\n  };\r\n  payments?: {\r\n    provider: string;\r\n  }[];\r\n}\r\n\r\ninterface PaymentRecord {\r\n  id: string;\r\n  amount: number;\r\n  status: string;\r\n  createdAt: string;\r\n  paymentMethod: string | null;\r\n  transactionId: string | null;\r\n  orderId: string | null;\r\n  discountAmountValue?: number;\r\n  promoDiscount?: number;\r\n  prorationDiscount?: number;\r\n  balanceUsed?: number;\r\n  discountAmount?: number;\r\n  subscription?: {\r\n    plan?: {\r\n      nameAr?: string;\r\n    };\r\n  };\r\n}\r\n\r\ninterface BillingSummary {\r\n  name: string;\r\n  email: string;\r\n  balance: number;\r\n  additionalAiCredits: number;\r\n  additionalExamCredits: number;\r\n  activeSubscription: ActiveSubscription | null;\r\n  paymentHistory: PaymentRecord[];\r\n  stats: {\r\n    totalSpent: number;\r\n    paymentCount: number;\r\n    successCount: number;\r\n    pendingCount: number;\r\n    failedCount: number;\r\n  };\r\n}\r\n\r\ninterface Addon {\r\n  id: string;\r\n  name: string;\r\n  nameAr: string;\r\n  description: string;\r\n  price: number;\r\n  type: string;\r\n  value: number;\r\n}\r\n\r\nexport default function SubscriptionPage() {\r\n  const [summary, setSummary] = useState<BillingSummary | null>(null);\r\n  const [addons, setAddons] = useState<Addon[]>([]);\r\n  const [loading, setLoading] = useState(true);\r\n  const [purchasing, setPurchasing] = useState<string | null>(null);\r\n\r\n  useEffect(() => {\r\n    async function fetchSummary() {\r\n      try {\r\n        const [summaryRes, addonsRes] = await Promise.all([\r\n          fetch('/api/users/billing-summary'),\r\n          fetch('/api/subscriptions/addons')\r\n        ]);\r\n\r\n        if (summaryRes.ok) {\r\n          const data = await summaryRes.json();\r\n          setSummary(data);\r\n        }\r\n\r\n        if (addonsRes.ok) {\r\n          const data = await addonsRes.json();\r\n          setAddons(data.addons || []);\r\n        }\r\n      } catch (err: unknown) {\r\n        logger.error(err instanceof Error ? err.message : String(err));\r\n      } finally {\r\n        setLoading(false);\r\n      }\r\n    }\r\n    fetchSummary();\r\n  }, []);\r\n\r\n  const handlePurchaseAddon = async (addonId: string) => {\r\n    setPurchasing(addonId);\r\n    try {\r\n      const res = await fetch('/api/subscriptions/addons', {\r\n        method: 'POST',\r\n        headers: { 'Content-Type': 'application/json' },\r\n        body: JSON.stringify({ addonId })\r\n      });\r\n\r\n      if (res.ok) {\r\n        toast.success(\"в•ӘШІв”ҳГ в•ӘШІ в•Әв•Јв”ҳГ в”ҳВ„в”ҳГЁв•ӘШұ в•ӘШҜв”ҳВ„в•Әв”Өв•Әв–’в•ӘШҜв•ӘШ© в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө!\");\r\n        const summaryRes = await fetch('/api/users/billing-summary');\r\n        if (summaryRes.ok) setSummary(await summaryRes.json());\r\n      } else {\r\n        const data = await res.json();\r\n        toast.error(data.error || \"в”ҳВҒв•Әв”Өв”ҳВ„в•ӘШІ в•Әв•Јв”ҳГ в”ҳВ„в”ҳГЁв•ӘШұ в•ӘШҜв”ҳВ„в•Әв”Өв•Әв–’в•ӘШҜв•ӘШ©\");\r\n      }\r\n    } catch (err: unknown) {\r\n      toast.error(\"в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШІв”ҳГӘв”ҳГ©в•Әв•Ј\");\r\n      logger.error(err instanceof Error ? err.message : String(err));\r\n    } finally {\r\n      setPurchasing(null);\r\n    }\r\n  };\r\n\r\n  if (loading) {\r\n    return (\r\n      <div className=\"min-h-screen flex items-center justify-center bg-[#0a0a0c]\">\r\n        <div className=\"animate-spin rounded-full h-12 w-12 border-t-2 border-primary border-r-2\" />\r\n      </div>\r\n    );\r\n  }\r\n\r\n  if (!summary) {\r\n    return (\r\n      <div className=\"min-h-screen flex items-center justify-center bg-[#0a0a0c] text-white\">\r\n        <div className=\"text-center\">\r\n          <AlertCircle size={48} className=\"mx-auto text-red-500 mb-4\" />\r\n          <p>в”ҳГЁв•ӘШҙв•ӘШ° в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳВ„в•Әв•Јв•Әв–’в•Әв•ў в”ҳГ в”ҳВ„в•ӘВ«в•Әв•Ў в•ӘШҜв”ҳВ„в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°</p>\r\n          <Link href=\"/login\" className=\"text-blue-500 hover:underline mt-4 block\">в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„</Link>\r\n        </div>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-[#0a0a0c] text-white pt-24 pb-12 px-4\" dir=\"rtl\">\r\n      <div className=\"max-w-6xl mx-auto\">\r\n        <header className=\"flex flex-col md:flex-row md:items-center justify-between gap-6 mb-12\">\r\n          <div>\r\n            <div className=\"flex items-center gap-2 text-blue-400 text-sm mb-2\">\r\n              <LayoutDashboard size={16} />\r\n              в”ҳВҶв•Әв••в•Әв–’в•ӘШұ в•Әв•Јв•ӘШҜв”ҳГ в•ӘШұ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°\r\n            </div>\r\n            <h1 className=\"text-3xl font-bold\">в•ӘШӯв•ӘВ»в•ӘШҜв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Өв•ӘШІв•Әв–’в•ӘШҜв”ҳГў в”ҳГӘв•ӘШҜв”ҳВ„в”ҳВҒв”ҳГӘв•ӘШҜв•ӘШІв”ҳГЁв•Әв–’</h1>\r\n          </div>\r\n          <Link\r\n            href=\"/billing\"\r\n            className=\"px-6 py-3 bg-blue-600 hover:bg-blue-500 rounded-xl font-bold flex items-center gap-2 transition-all shadow-lg shadow-blue-600/20 active:scale-95 text-center justify-center\"\r\n          >\r\n            в•ӘШІв•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ» в•ӘШ«в”ҳГӘ в•ӘШІв•Әв–’в”ҳГ©в”ҳГЁв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Өв•ӘШІв•Әв–’в•ӘШҜв”ҳГў\r\n            <ArrowUpRight size={18} />\r\n          </Link>\r\n        </header>\r\n\r\n        {/* Stats Grid */}\r\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12\">\r\n          <motion.div whileHover={{ y: -5 }} className=\"bg-[#111114] border border-white/5 p-6 rounded-3xl\">\r\n            <div className=\"flex items-center justify-between mb-4\">\r\n              <div className=\"w-10 h-10 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-500\">\r\n                <Wallet size={20} />\r\n              </div>\r\n              <span className=\"text-xs text-green-400 bg-green-500/10 px-2 py-0.5 rounded-full\">в•Әв–’в•Әв•Ўв”ҳГЁв•ӘВ»в”ҳГў в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁ</span>\r\n            </div>\r\n            <div className=\"text-2xl font-bold mb-1\">{summary.balance.toLocaleString()} в•ӘШҙ.в”ҳГ </div>\r\n            <div className=\"text-gray-400 text-xs\">в”ҳГ в•ӘШІв•ӘШҜв•ӘШө в”ҳВ„в”ҳВ„в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в•ӘШҜв”ҳГ  в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•Әв•Ўв•ӘШұ</div>\r\n          </motion.div>\r\n\r\n          <motion.div whileHover={{ y: -5 }} className=\"bg-[#111114] border border-white/5 p-6 rounded-3xl\">\r\n            <div className=\"flex items-center justify-between mb-4\">\r\n              <div className=\"w-10 h-10 rounded-xl bg-purple-500/10 flex items-center justify-center text-purple-500\">\r\n                <TrendingUp size={20} />\r\n              </div>\r\n              <span className=\"text-xs text-gray-400\">в•ӘШӯв•ӘШҙв”ҳГ в•ӘШҜв”ҳВ„в”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ»в”ҳВҒв”ҳГӘв•Әв•Јв•ӘШҜв•ӘШІ</span>\r\n            </div>\r\n            <div className=\"text-2xl font-bold mb-1\">{summary.stats.totalSpent.toLocaleString()} в•ӘШҙ.в”ҳГ </div>\r\n            <div className=\"text-gray-400 text-xs\">в”ҳГ в•ӘШҙв”ҳГ в”ҳГӘв•Әв•Ј в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГ в”ҳВ„в”ҳГЁв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳВҶв•ӘШҜв•ӘШҙв•ӘШөв•ӘШұ</div>\r\n          </motion.div>\r\n\r\n          <motion.div whileHover={{ y: -5 }} className=\"bg-[#111114] border border-white/5 p-6 rounded-3xl\">\r\n            <div className=\"flex items-center justify-between mb-4\">\r\n              <div className=\"w-10 h-10 rounded-xl bg-green-500/10 flex items-center justify-center text-green-500\">\r\n                <CheckCircle2 size={20} />\r\n              </div>\r\n              <span className=\"text-xs text-gray-400\">в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Өв•ӘШІв•Әв–’в•ӘШҜв”ҳГўв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв•ӘШІв”ҳГ в”ҳВ„в•ӘШұ</span>\r\n            </div>\r\n            <div className=\"text-2xl font-bold mb-1\">{summary.stats.successCount}</div>\r\n            <div className=\"text-gray-400 text-xs\">в•Әв•Јв”ҳГ в”ҳВ„в”ҳГЁв•ӘШҜв•ӘШІ в”ҳГ в”ҳГўв•ӘШІв”ҳГ в”ҳВ„в•ӘШұ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө</div>\r\n          </motion.div>\r\n\r\n          <motion.div whileHover={{ y: -5 }} className=\"bg-[#111114] border border-white/5 p-6 rounded-3xl\">\r\n            <div className=\"flex items-center justify-between mb-4\">\r\n              <div className=\"w-10 h-10 rounded-xl bg-red-500/10 flex items-center justify-center text-red-500\">\r\n                <XCircle size={20} />\r\n              </div>\r\n              <span className=\"text-xs text-gray-400\">в•Әв•Јв”ҳГ в”ҳВ„в”ҳГЁв•ӘШҜв•ӘШІ в”ҳГ в•Әв•Јв”ҳВ„в”ҳГ©в•ӘШұ/в”ҳВҒв•ӘШҜв•Әв”Өв”ҳВ„в•ӘШұ</span>\r\n            </div>\r\n            <div className=\"text-2xl font-bold mb-1\">{summary.stats.pendingCount + summary.stats.failedCount}</div>\r\n            <div className=\"text-gray-400 text-xs\">в•ӘШІв•ӘШөв•ӘШІв•ӘШҜв•ӘШҙ в”ҳВ„в”ҳГ в•Әв–’в•ӘШҜв•ӘШҙв•Әв•Јв•ӘШұ</div>\r\n          </motion.div>\r\n        </div>\r\n\r\n        {/* Current Credits Section */}\r\n        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6 mb-12\">\r\n          <div className=\"bg-[#111114] border border-white/5 p-6 rounded-3xl relative overflow-hidden group\">\r\n            <div className=\"absolute top-0 right-0 w-32 h-32 bg-blue-500/5 rounded-full blur-3xl group-hover:bg-blue-500/10 transition-all\" />\r\n            <div className=\"flex items-center gap-4\">\r\n              <div className=\"w-12 h-12 rounded-2xl bg-blue-500/10 flex items-center justify-center text-blue-500\">\r\n                <Bot size={24} />\r\n              </div>\r\n              <div>\r\n                <h4 className=\"text-sm text-gray-400 font-bold\">в•Әв–’в•Әв•Ўв”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘВ» в•ӘШҜв”ҳВ„в•Әв–‘в”ҳГўв”ҳГЁ (AI)</h4>\r\n                <div className=\"text-2xl font-black mt-1\">\r\n                  {summary.additionalAiCredits} <span className=\"text-xs text-gray-500 font-normal\">в•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв”ҳГЁв•ӘШұ</span>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          <div className=\"bg-[#111114] border border-white/5 p-6 rounded-3xl relative overflow-hidden group\">\r\n            <div className=\"absolute top-0 right-0 w-32 h-32 bg-green-500/5 rounded-full blur-3xl group-hover:bg-green-500/10 transition-all\" />\r\n            <div className=\"flex items-center gap-4\">\r\n              <div className=\"w-12 h-12 rounded-2xl bg-green-500/10 flex items-center justify-center text-green-500\">\r\n                <GraduationCap size={24} />\r\n              </div>\r\n              <div>\r\n                <h4 className=\"text-sm text-gray-400 font-bold\">в•Әв–’в•Әв•Ўв”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв”ҳГЁв•ӘШұ</h4>\r\n                <div className=\"text-2xl font-black mt-1\">\r\n                  {summary.additionalExamCredits} <span className=\"text-xs text-gray-500 font-normal\">в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ</span>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        {/* Addons Store Section */}\r\n        <section className=\"mb-12\">\r\n          <div className=\"flex items-center justify-between mb-8\">\r\n            <div>\r\n              <h2 className=\"text-2xl font-bold\">в”ҳГ в•ӘШІв•ӘШҙв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•Әв”Ӯв•Әв–’в”ҳГЁв•Әв•Јв•ӘШұ</h2>\r\n              <p className=\"text-gray-400 text-sm\">в•ӘШҜв•Әв”Өв•ӘШөв”ҳВҶ в•Әв–’в•Әв•Ўв”ҳГЁв•ӘВ»в”ҳГў в•ӘШ°в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШҜв•ӘШІ в”ҳВ„в”ҳГ в•Әв–’в•ӘШұ в”ҳГӘв•ӘШҜв•ӘШөв•ӘВ»в•ӘШұ в”ҳВ„в•ӘВ»в•Әв•Јв”ҳГ  в•Әв–’в•ӘШөв”ҳВ„в•ӘШІв”ҳГў в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Јв”ҳВ„в”ҳГЁв”ҳГ в”ҳГЁв•ӘШұ</p>\r\n            </div>\r\n            <div className=\"hidden md:flex items-center gap-2 bg-white/5 px-4 py-2 rounded-full border border-white/5\">\r\n              <Wallet size={16} className=\"text-blue-500\" />\r\n              <span className=\"text-sm font-bold\">{summary.balance} в•ӘШҙ.в”ҳГ </span>\r\n            </div>\r\n          </div>\r\n\r\n          <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\r\n            {addons.map((addon) => (\r\n              <motion.div\r\n                key={addon.id}\r\n                whileHover={{ y: -8 }}\r\n                className=\"bg-[#111114] border border-white/5 rounded-[2rem] p-6 flex flex-col items-center text-center group relative overflow-hidden\"\r\n              >\r\n                <div className=\"absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-blue-500 to-transparent opacity-0 group-hover:opacity-100 transition-all\" />\r\n                <div className={`w-16 h-16 rounded-2xl mb-6 flex items-center justify-center ${\r\n                  addon.type === \"EXAM_PACK\" ? \"bg-purple-500/10 text-purple-500\" :\r\n                  addon.type === \"AI_CREDITS\" ? \"bg-blue-500/10 text-blue-500\" :\r\n                  \"bg-green-500/10 text-green-500\"\r\n                }`}>\r\n                  {addon.type === \"EXAM_PACK\" ? <GraduationCap size={32} /> :\r\n                  addon.type === \"AI_CREDITS\" ? <Bot size={32} /> : <BookOpen size={32} />}\r\n                </div>\r\n\r\n                <h3 className=\"text-lg font-bold mb-2\">{addon.nameAr || addon.name}</h3>\r\n                <p className=\"text-gray-400 text-xs mb-6 max-w-[200px] line-clamp-2\">{addon.description}</p>\r\n                <div className=\"mt-auto w-full\">\r\n                  <div className=\"text-2xl font-black text-white mb-6\">\r\n                    {addon.price} <span className=\"text-xs text-gray-500 font-bold uppercase\">в