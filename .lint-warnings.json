n\r\nimport { useState, useEffect, memo } from \"react\";\r\nimport { motion } from \"framer-motion\";\r\nimport { Card, CardContent } from \"@/components/ui/card\";\r\nimport { Badge } from \"@/components/ui/badge\";\r\nimport { \r\n  Wifi,\r\n  WifiOff,\r\n  Cloud,\r\n  CloudOff,\r\n  Bell,\r\n  BellOff,\r\n  Battery,\r\n  BatteryCharging,\r\n  Moon,\r\n  Sun,\r\n  CheckCircle2,\r\n  XCircle\r\n} from \"lucide-react\";\r\n\r\ninterface StatusIndicator {\r\n  id: string;\r\n  label: string;\r\n  status: \"online\" | \"offline\" | \"warning\" | \"error\";\r\n  value: string;\r\n  icon: React.ReactNode;\r\n  description: string;\r\n}\r\n\r\nexport const StatusIndicatorsSection = memo(function StatusIndicatorsSection() {\r\n  const [indicators, setIndicators] = useState<StatusIndicator[]>([]);\r\n  const [isOnline, setIsOnline] = useState(true);\r\n\r\n  useEffect(() => {\r\n    // Check online status\r\n    setIsOnline(navigator.onLine);\r\n    \r\n    const handleOnline = () => setIsOnline(true);\r\n    const handleOffline = () => setIsOnline(false);\r\n    \r\n    window.addEventListener(\"online\", handleOnline);\r\n    window.addEventListener(\"offline\", handleOffline);\r\n\r\n    // Initialize indicators\r\n    updateIndicators();\r\n\r\n    // Update periodically\r\n    const interval = setInterval(updateIndicators, 30000);\r\n\r\n    return () => {\r\n      window.removeEventListener(\"online\", handleOnline);\r\n      window.removeEventListener(\"offline\", handleOffline);\r\n      clearInterval(interval);\r\n    };\r\n  }, []);\r\n\r\n  useEffect(() => {\r\n    updateIndicators();\r\n  }, [isOnline]);\r\n\r\n  const updateIndicators = () => {\r\n    const now = new Date();\r\n    const hour = now.getHours();\r\n    const isDarkMode = typeof window !== 'undefined' && window.matchMedia ? (window.matchMedia(\"(prefers-color-scheme: dark)\").matches || hour >= 18 || hour <= 6) : (hour >= 18 || hour <= 6);\r\n\r\n    setIndicators([\r\n      {\r\n        id: \"connection\",\r\n        label: \"в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„ в•ӘШ°в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШІв•Әв–’в”ҳВҶв•ӘШІ\",\r\n        status: isOnline ? \"online\" : \"offline\",\r\n        value: isOnline ? \"в”ҳГ в•ӘШІв•Әв•Ўв”ҳВ„\" : \"в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШІв•Әв•Ўв”ҳВ„\",\r\n        icon: isOnline ? <Wifi className=\"h-5 w-5\" /> : <WifiOff className=\"h-5 w-5\" />,\r\n        description: isOnline ? \"в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„ в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГ©в•Әв–’\" : \"в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в”ҳГ в”ҳВҶ в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„в”ҳГў в•ӘШ°в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШІв•Әв–’в”ҳВҶв•ӘШІ\"\r\n      },\r\n      {\r\n        id: \"sync\",\r\n        label: \"в”ҳГ в•Әв–“в•ӘШҜв”ҳГ в”ҳВҶв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ\",\r\n        status: isOnline ? \"online\" : \"warning\",\r\n        value: isOnline ? \"в”ҳГ в•ӘШІв•Әв–“в•ӘШҜв”ҳГ в”ҳВҶ\" : \"в”ҳВҒв”ҳГЁ в”ҳГӘв•Әв•ўв•Әв•Ј в•Әв•Јв•ӘВ»в”ҳГ  в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„\",\r\n        icon: isOnline ? <Cloud className=\"h-5 w-5\" /> : <CloudOff className=\"h-5 w-5\" />,\r\n        description: isOnline ? \"в•ӘШҙв”ҳГ в”ҳГЁв•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в”ҳГ в•ӘШөв•ӘВ»в•ӘШів•ӘШұ\" : \"в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в”ҳГ в•ӘШөв”ҳВҒв”ҳГӘв•Әв••в•ӘШұ в”ҳГ в•ӘШөв”ҳВ„в”ҳГЁв•ӘШҜв”ҳГҜ\"\r\n      },\r\n      {\r\n        id: \"notifications\",\r\n        label: \"в•ӘШҜв”ҳВ„в•ӘШӯв•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ\",\r\n        status: checkNotificationPermission(),\r\n        value: getNotificationStatus(),\r\n        icon: checkNotificationPermission() === \"online\" ? <Bell className=\"h-5 w-5\" /> : <BellOff className=\"h-5 w-5\" />,\r\n        description: getNotificationDescription()\r\n      },\r\n      {\r\n        id: \"theme\",\r\n        label: \"в•ӘШҜв”ҳВ„в”ҳГӘв•Әв•ўв•Әв•Ј в•ӘШҜв”ҳВ„в”ҳВ„в”ҳГЁв”ҳВ„в”ҳГЁ\",\r\n        status: isDarkMode ? \"online\" : \"online\",\r\n        value: isDarkMode ? \"в”ҳГ в”ҳВҒв•Әв•Јв”ҳВ„\" : \"в”ҳГ в•Әв•Јв•Әв•–в”ҳВ„\",\r\n        icon: isDarkMode ? <Moon className=\"h-5 w-5\" /> : <Sun className=\"h-5 w-5\" />,\r\n        description: isDarkMode ? \"в•ӘШҜв”ҳВ„в”ҳГӘв•Әв•ўв•Әв•Ј в•ӘШҜв”ҳВ„в”ҳВ„в”ҳГЁв”ҳВ„в”ҳГЁ в”ҳВҶв•Әв”Өв•Әв•–\" : \"в•ӘШҜв”ҳВ„в”ҳГӘв•Әв•ўв•Әв•Ј в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ§в•ӘШҜв•Әв–’в”ҳГЁ в”ҳВҶв•Әв”Өв•Әв•–\"\r\n      },\r\n      {\r\n        id: \"storage\",\r\n        label: \"в”ҳГ в•Әв”Ӯв•ӘШҜв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•ӘВ«в•Әв–“в”ҳГЁв”ҳВҶ\",\r\n        status: \"online\",\r\n        value: getStorageInfo(),\r\n        icon: <Cloud className=\"h-5 w-5\" />,\r\n        description: \"в”ҳГ в•Әв”Ӯв•ӘШҜв•ӘШөв•ӘШұ в•ӘШІв•ӘВ«в•Әв–“в”ҳГЁв”ҳВҶ в”ҳГўв•ӘШҜв”ҳВҒв”ҳГЁв•ӘШұ\"\r\n      },\r\n      {\r\n        id: \"performance\",\r\n        label: \"в•ӘШ«в•ӘВ»в•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в”ҳВҶв•Әв••в•ӘШҜв”ҳГ \",\r\n        status: \"online\",\r\n        value: \"в”ҳГ в”ҳГ в•ӘШІв•ӘШҜв•Әв–“\",\r\n        icon: <BatteryCharging className=\"h-5 w-5\" />,\r\n        description: \"в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ»в•ӘШҜв•ӘШ© в•Әв•ўв”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГӘв”ҳГ« в•ӘШҜв”ҳВ„в•Әв•–в•ӘШ°в”ҳГЁв•Әв•Јв”ҳГЁ\"\r\n      }\r\n    ]);\r\n  };\r\n\r\n  const checkNotificationPermission = (): \"online\" | \"warning\" => {\r\n    if (typeof window === \"undefined\" || !(\"Notification\" in window)) {\r\n      return \"warning\";\r\n    }\r\n    return Notification.permission === \"granted\" ? \"online\" : \"warning\";\r\n  };\r\n\r\n  const getNotificationStatus = (): string => {\r\n    if (typeof window === \"undefined\" || !(\"Notification\" in window)) {\r\n      return \"в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘВ»в•Әв•Јв”ҳГӘв”ҳГ \";\r\n    }\r\n    switch (Notification.permission) {\r\n      case \"granted\":\r\n        return \"в”ҳГ в”ҳВҒв•Әв•Јв”ҳВ„\";\r\n      case \"denied\":\r\n        return \"в”ҳГ в•Әв•Јв•Әв•–в”ҳВ„\";\r\n      default:\r\n        return \"в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв”Ӯв”ҳГ в”ҳГӘв•ӘШө\";\r\n    }\r\n  };\r\n\r\n  const getNotificationDescription = (): string => {\r\n    if (typeof window === \"undefined\" || !(\"Notification\" in window)) {\r\n      return \"в•ӘШҜв”ҳВ„в”ҳГ в•ӘШІв•Әв•Ўв”ҳВҒв•ӘШө в”ҳВ„в•ӘШҜ в”ҳГЁв•ӘВ»в•Әв•Јв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШӯв•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ\";\r\n    }\r\n    switch (Notification.permission) {\r\n      case \"granted\":\r\n        return \"в•Әв”Ӯв•ӘШІв•ӘШІв”ҳВ„в”ҳГ©в”ҳГ« в•ӘШӯв•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ в•ӘШөв”ҳГӘв”ҳВ„ в•ӘШ«в”ҳВҶв•Әв”Өв•Әв•–в•ӘШІв”ҳГў\";\r\n      case \"denied\":\r\n        return \"в•ӘШҜв”ҳВ„в•ӘШӯв•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ в”ҳГ в•Әв•Јв•Әв•–в”ҳВ„в•ӘШұ - в”ҳГ©в”ҳГ  в•ӘШ°в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„ в”ҳГ в”ҳВҶ в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШІв•Әв•Ўв”ҳВҒв•ӘШө\";\r\n      default:\r\n        return \"в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳГ в•ӘШҜв•ӘШө в•ӘШ°в•ӘШҜв”ҳВ„в•ӘШӯв•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ в”ҳВ„в”ҳВ„в•ӘШөв•Әв•Ўв”ҳГӘв”ҳВ„ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШів•ӘШҜв•ӘШІ в”ҳВҒв”ҳГӘв•Әв–’в”ҳГЁв•ӘШұ\";\r\n    }\r\n  };\r\n\r\n  const getStorageInfo = (): string => {\r\n    if (typeof navigator !== \"undefined\" && \"storage\" in navigator && \"estimate\" in navigator.storage) {\r\n      // This is async, so we'll use a simple calculation\r\n      try {\r\n        const storage = localStorage;\r\n        let total = 0;\r\n        for (let key in storage) {\r\n          if (Object.prototype.hasOwnProperty.call(storage, key)) {\r\n            total += storage[key].length + key.length;\r\n          }\r\n        }\r\n        const usedMB = (total / 1024 / 1024).toFixed(2);\r\n        return `${usedMB} MB в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ `;\r\n      } catch {\r\n        return \"в•ӘШҙв”ҳГЁв•ӘВ»\";\r\n      }\r\n    }\r\n    return \"в•ӘШҙв”ҳГЁв•ӘВ»\";\r\n  };\r\n\r\n  const getStatusColor = (status: string) => {\r\n    switch (status) {\r\n      case \"online\":\r\n        return \"bg-emerald-500/20 text-emerald-400 border-emerald-500/30\";\r\n      case \"warning\":\r\n        return \"bg-amber-500/20 text-amber-400 border-amber-500/30\";\r\n      case \"error\":\r\n        return \"bg-rose-500/20 text-rose-400 border-rose-500/30\";\r\n      default:\r\n        return \"bg-white/10 text-gray-400 border-white/20\";\r\n    }\r\n  };\r\n\r\n  return (\r\n    <section className=\"relative overflow-hidden rounded-[2rem] border border-white/10 bg-black/40 px-6 md:px-12 py-12 shadow-2xl backdrop-blur-xl ring-1 ring-white/5\">\r\n      <div className=\"absolute inset-0 bg-gradient-to-br from-indigo-500/10 via-transparent to-purple-500/10 mix-blend-overlay\" />\r\n      \r\n      <div className=\"relative z-10\">\r\n        <motion.div\r\n          initial={{ opacity: 0, y: 20 }}\r\n          whileInView={{ opacity: 1, y: 0 }}\r\n          viewport={{ once: true }}\r\n          transition={{ duration: 0.5 }}\r\n          className=\"mb-8 text-center\"\r\n        >\r\n          <h2 className=\"text-3xl md:text-4xl font-extrabold text-white mb-4 drop-shadow-md\">\r\n            в”ҳГ в•ӘШ¬в•Әв”Өв•Әв–’в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ\r\n          </h2>\r\n          <p className=\"text-gray-400 text-lg\">\r\n            в•Әв–’в•Әв•Ўв•ӘВ» в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в”ҳВҶв•Әв••в•ӘШҜв”ҳГ  в”ҳГӘв•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„ в”ҳГӘв•ӘШҜв”ҳВ„в•ӘВ«в•ӘВ»в”ҳГ в•ӘШҜв•ӘШІ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГ©в•ӘШІ в•ӘШҜв”ҳВ„в”ҳВҒв•Әв•Јв”ҳВ„в”ҳГЁ\r\n          </p>\r\n        </motion.div>\r\n\r\n        <div className=\"grid gap-4 md:grid-cols-2 lg:grid-cols-3\">\r\n          {indicators.map((indicator, index) => (\r\n            <motion.div\r\n              key={indicator.id}\r\n              initial={{ opacity: 0, scale: 0.9 }}\r\n              whileInView={{ opacity: 1, scale: 1 }}\r\n              viewport={{ once: true }}\r\n              transition={{ delay: index * 0.05 }}\r\n              whileHover={{ scale: 1.02 }}\r\n            >\r\n              <Card className=\"bg-black/40 border-white/5 shadow-none hover:bg-white-[0.03] hover:border-white/10 transition-all rounded-2xl backdrop-blur-md\">\r\n                <CardContent className=\"p-5\">\r\n                  <div className=\"flex items-start justify-between mb-3\">\r\n                    <div className={`rounded-xl p-2.5 shadow-inner backdrop-blur-md border ${getStatusColor(indicator.status)}`}>\r\n                      {indicator.icon}\r\n                    </div>\r\n                    <Badge className={`${getStatusColor(indicator.status)} border bg-transparent bg-opacity-10 shadow-none`}>\r\n                      {indicator.status === \"online\" && <CheckCircle2 className=\"h-3 w-3 mr-1\" />}\r\n                      {indicator.status !== \"online\" && <XCircle className=\"h-3 w-3 mr-1\" />}\r\n                      {indicator.value}\r\n                    </Badge>\r\n                  </div>\r\n                  \r\n                  <h3 className=\"font-bold text-white mb-2 text-lg\">\r\n                    {indicator.label}\r\n                  </h3>\r\n                  <p className=\"text-sm text-gray-400 line-clamp-2\">\r\n                    {indicator.description}\r\n                  </p>\r\n                </CardContent>\r\n              </Card>\r\n            </motion.div>\r\n          ))}\r\n        </div>\r\n\r\n        {/* System Health Summary */}\r\n        <motion.div\r\n          initial={{ opacity: 0, y: 20 }}\r\n          whileInView={{ opacity: 1, y: 0 }}\r\n          viewport={{ once: true }}\r\n          transition={{ delay: 0.3 }}\r\n          className=\"mt-8\"\r\n        >\r\n          <Card className=\"border border-white/10 bg-gradient-to-r from-emerald-500/20 to-teal-500/20 backdrop-blur-xl shadow-[0_0_30px_rgba(16,185,129,0.15)] rounded-2xl mx-1\">\r\n            <CardContent className=\"p-6\">\r\n              <div className=\"flex flex-col md:flex-row items-center justify-between text-white gap-4\">\r\n                <div className=\"flex items-center gap-4\">\r\n                  <div className=\"rounded-full bg-emerald-500/20 p-4 backdrop-blur-md border border-emerald-500/30 shadow-inner\">\r\n                    <CheckCircle2 className=\"h-8 w-8 text-em