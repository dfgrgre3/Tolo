() => import(\"./components/quick-actions\").then(mod => mod.QuickActions), { ssr: false });\r\nimport { Clock } from \"./components/clock\";\r\n// Removed redundant Bot import to favor local custom SVG if needed, or aliased below\r\n\r\nconst STYLES = {\r\n  glass: \"relative overflow-hidden rounded-[2rem] border border-border bg-card/40 shadow-2xl backdrop-blur-2xl ring-1 ring-border/5\",\r\n  card: \"rpg-card h-full\",\r\n  neonText: \"rpg-neon-text font-black\",\r\n  goldText: \"rpg-gold-text font-black\",\r\n  divider: \"rpg-divider\"\r\n};\r\n\r\nconst quickLinks = [\r\n  {\r\n    title: \"в•ӘВ«в•Әв–’в”ҳГЁв•Әв•–в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв”ҳГ©в•ӘВ»в”ҳГ \",\r\n    description: \"в•Әв–’в•ӘШҜв”ҳГ©в•ӘШ° в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•Ј в”ҳВҶв”ҳВҒв”ҳГӘв•Әв–‘в”ҳГў в”ҳГӘв•ӘШӯв”ҳВҶв•ӘШҙв•ӘШҜв•Әв–“в•ӘШҜв•ӘШІв”ҳГў в”ҳВҒв”ҳГЁ в•Әв•Јв•ӘШҜв”ҳВ„в”ҳГ в”ҳГў в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв”ҳГЁ\",\r\n    href: \"/progress\",\r\n    icon: BarChart3,\r\n    color: \"text-blue-400\",\r\n    bgColor: \"bg-blue-400/10\",\r\n    delay: 0.1\r\n  },\r\n  {\r\n    title: \"в•Әв”Ӯв•ӘШҙв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ  (Quests)\",\r\n    description: \"в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГЁв”ҳГӘв”ҳГ в”ҳГЁв•ӘШұв•ӘГ® в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•ӘШ°в”ҳГӘв•Әв•Јв”ҳГЁв•ӘШұв•ӘГ® в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в”ҳГ в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в”ҳВ„в•ӘШөв”ҳГ в”ҳГЁв•ӘШұ\",\r\n    href: \"/tasks\",\r\n    icon: CheckSquare,\r\n    color: \"text-amber-400\",\r\n    bgColor: \"bg-amber-400/10\",\r\n    delay: 0.2\r\n  },\r\n  {\r\n    title: \"в•ӘШҙв•ӘВ»в”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Јв•ӘШҜв•Әв–’в”ҳГў\",\r\n    description: \"в•ӘШІв”ҳВҶв•Әв••в”ҳГЁв”ҳГ  в”ҳГӘв”ҳГ©в•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–‘в•ӘШҜв”ҳГўв•Әв–’в•ӘШұ в”ҳГӘв•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв•Әв•ўв”ҳГЁв•Әв–’ в”ҳВ„в”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв•ӘВ»в”ҳГ в•ӘШұ\",\r\n    href: \"/schedule\",\r\n    icon: Calendar,\r\n    color: \"text-emerald-400\",\r\n    bgColor: \"bg-emerald-400/10\",\r\n    delay: 0.3\r\n  },\r\n  {\r\n    title: \"в”ҳВ