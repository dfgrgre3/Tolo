}\n            </div>\n            <div className=\"min-w-0 space-y-1\">\n              <p className=\"truncate text-sm font-black\">{course.nameAr || course.name}</p>\n              <div className=\"flex flex-wrap items-center gap-1.5 text-[11px] text-muted-foreground\">\n                <GraduationCap className=\"h-3 w-3 shrink-0\" />\n                <span className=\"truncate\">{course.instructorName || \"в•ӘШ°в•ӘВ»в”ҳГӘв”ҳВҶ в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯ\"}</span>\n                {course.code && (\n                  <span className=\"text-primary/60 font-bold\">#{course.code}</span>\n                )}\n              </div>\n            </div>\n          </div>\n        );\n      },\n    },\n    {\n      accessorKey: \"price\",\n      header: \"в•ӘШҜв”ҳВ„в•Әв”Ӯв•Әв•Јв•Әв–’\",\n      cell: ({ row }) => (\n        <div className=\"flex items-center gap-1 text-sm font-black\">\n          {row.original.price === 0 ? (\n            <span className=\"text-teal-500\">в”ҳГ в•ӘШҙв•ӘШҜв”ҳВҶв”ҳГЁв•ӘШұ</span>\n          ) : (\n            <>\n              <DollarSign className=\"h-3.5 w-3.5 text-primary\" />\n              <span className=\"text-primary\">{row.original.price} в•ӘШҙ</span>\n            </>\n          )}\n        </div>\n      ),\n    },\n    {\n      accessorKey: \"durationHours\",\n      header: \"в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ»в•ӘШұ\",\n      cell: ({ row }) => (\n        <div className=\"flex items-center gap-1 text-sm font-medium text-muted-foreground\">\n          <Clock className=\"h-3.5 w-3.5\" />\n          {row.original.durationHours || 0}h\n        </div>\n      ),\n    },\n    {\n      id: \"enrollments\",\n      header: \"в•ӘШҜв”ҳВ„в•Әв•–в”ҳВ„в•ӘШҜв•ӘШ°\",\n      cell: ({ row }) => (\n        <div className=\"flex items-center gap-1 text-sm font-bold\">\n          <Users className=\"h-3.5 w-3.5 text-blue-500\" />\n          {row.original._count?.enrollments || 0}\n        </div>\n      ),\n    },\n    {\n      id: \"topics\",\n      header: \"в•ӘШҜв”ҳВ„в”ҳГӘв•ӘШөв•ӘВ»в•ӘШҜв•ӘШІ\",\n      cell: ({ row }) => (\n        <div className=\"flex items-center gap-1 text-sm font-bold\">\n          <LayoutGrid className=\"h-3.5 w-3.5 text-violet-500\" />\n          {row.original._count?.topics || 0}\n        </div>\n      ),\n    },\n    {\n      accessorKey: \"level\",\n      header: \"в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГӘв”ҳГ«\",\n      cell: ({ row }) => {\n        const level = (row.original.level || \"INTERMEDIATE\") as string;\n        return (\n          <Badge\n            variant=\"outline\"\n            className={cn(\n              \"rounded-full px-2.5 py-0.5 text-[11px] font-bold\",\n              levelStyles[level] || levelStyles.INTERMEDIATE\n            )}\n          >\n            {levelLabels[level] || level}\n          </Badge>\n        );\n      },\n    },\n    {\n      accessorKey: \"isPublished\",\n      header: \"в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Өв•Әв–’\",\n      cell: ({ row }) => (\n        <Badge\n          variant=\"outline\"\n          className={cn(\n            \"rounded-full px-2.5 py-0.5 text-[11px] font-bold\",\n            row.original.isPublished\n              ? \"border-emerald-500/20 bg-emerald-500/10 text-emerald-600\"\n              : \"border-border/60 bg-muted/30 text-muted-foreground\"\n          )}\n        >\n          {row.original.isPublished ? \"в”ҳГ в”ҳВҶв•Әв”Өв”ҳГӘв•Әв–’в•ӘШұ\" : \"в”ҳГ в•Әв”Ӯв”ҳГӘв•ӘВ»в•ӘШұ\"}\n        </Badge>\n      ),\n    },\n    {\n      accessorKey: \"isActive\",\n      header: \"в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ\",\n      cell: ({ row }) => (\n        <Badge\n          variant={row.original.isActive ? \"default\" : \"secondary\"}\n          className=\"rounded-full px-2.5 py-0.5 text-[11px] font-bold\"\n        >\n          {row.original.isActive ? \"в”ҳВҶв•Әв”Өв•Әв•–в•ӘШұ\" : \"в”ҳГ в”ҳГӘв”ҳГ©в”ҳГӘв”ҳВҒв•ӘШұ\"}\n        </Badge>\n      ),\n    },\n    {\n      id: \"actions\",\n      header: \"в•ӘШӯв•ӘШҙв•Әв–’в•ӘШҜв•ӘШ©в•ӘШҜв•ӘШІ\",\n      cell: ({ row }) => (\n        <RowActions\n          row={row.original}\n          onView={(course) => router.push(`/admin/courses/${course.id}`)}\n          onEdit={(course) => router.push(`/admin/courses/${course.id}`)}\n          onDelete={(course) => setDeleteDialog({ open: true, id: course.id })}\n          extraActions={[\n            {\n              icon: BookOpen,\n              label: \"в•ӘШӯв•ӘВ»в•ӘШҜв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв”ҳГ§в•ӘШҙ\",\n              onClick: (course) => router.push(`/admin/courses/${course.id}/curriculum`),\n            },\n            {\n              icon: TrendingUp,\n              label: \"в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳВ„в”ҳГЁв”ҳВ„в•ӘШҜв•ӘШІ\",\n              onClick: (course) => router.push(`/admin/courses/${course.id}/analytics`),\n            },\n            {\n              icon: ExternalLink,\n              label: \"в•Әв•Јв•Әв–’в•Әв•ў в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв”ҳГ©в•Әв•Ј\",\n              onClick: (course) => router.push(`/courses/${course.id}`),\n            },\n          ]}\n        />\n      ),\n    },\n  ];\n\n  // в”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙ Empty State в”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙ\n\n  const emptyState = (\n    <div className=\"col-span-full flex flex-col items-center justify-center gap-4 rounded-2xl border border-dashed border-border/40 bg-muted/10 py-20 text-center\">\n      <div className=\"rounded-3xl bg-primary/10 p-5\">\n        <BookOpen className=\"h-10 w-10 text-primary/60\" />\n      </div>\n      <div className=\"space-y-1\">\n        <p className=\"text-base font-black\">в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в•ӘВ»в”ҳГӘв•Әв–’в•ӘШҜв•ӘШІ в”ҳГ в•Әв•–в•ӘШҜв•ӘШ°в”ҳГ©в•ӘШұ</p>\n        <p className=\"text-sm text-muted-foreground\">\n          в•ӘШҙв•Әв–’в”ҳЩ‘в•ӘШ° в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШөв•ӘШі в•ӘШ«в”ҳГӘ в•ӘШҜв”ҳВ„в”ҳВҒв”ҳВ„в•ӘШҜв•ӘШІв•Әв–’в•ӘГ® в•ӘШ«в”ҳГӘ в•ӘШ«в”ҳВҶв•Әв”Өв•ӘШ® в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШӘв”ҳВҶ.\n        </p>\n      </div>\n      <AdminButton\n        onClick={() => router.push(\"/admin/courses/new\")}\n        className=\"gap-2 font-black\"\n      >\n        <Plus className=\"h-4 w-4\" />\n        в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ\n      </AdminButton>\n    </div>\n  );\n\n  // в”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙ Render в”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙ\n\n  return (\n    <div className=\"space-y-6 pb-20\" dir=\"rtl\">\n      {/* Header */}\n      <PageHeader\n        title=\"в•ӘШӯв•ӘВ»в•ӘШҜв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Јв”ҳВ„в”ҳГЁв”ҳГ в”ҳГЁв•ӘШұ\"\n        description=\"в•ӘШ«в”ҳВҶв•Әв”Өв•ӘШ® в”ҳГӘв•Әв–’в•ӘШҜв”ҳГ©в•ӘШ° в”ҳГӘв•ӘШҜв•ӘВ»в•Әв–’ в•ӘВ»в”ҳГӘв•Әв–’в•ӘШҜв•ӘШІв”ҳГў в”ҳГ в”ҳВҶ в•Әв”Өв•ӘШҜв•Әв”Өв•ӘШұ в”ҳГ в•Әв–’в”ҳГўв•Әв–“в”ҳГЁв•ӘШұ в”ҳГӘв•ӘШҜв•ӘШөв•ӘВ»в•ӘШұ в”ңШӘШёГ©ШҙШёВҖВЈ в”ҳВҶв•Әв”Өв•Әв–’в•ӘГ® в•ӘШІв•ӘШөв”ҳВ„в”ҳГЁв”ҳВ„в•ӘШҜв•ӘШІв•ӘГ® в”ҳГӘв•ӘШӯв•ӘВ»в•ӘШҜв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв”ҳГ§в•ӘШҙ.\"\n        badge={`${pagination?.total ?? courses.length} в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ`}\n      >\n        <div className=\"flex flex-wrap items-center gap-2\">\n          <AdminButton variant=\"outline\" icon={Tags} onClick={() => setCategoryDialogOpen(true)}>\n            в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Ўв”ҳВҶв”ҳГЁв”ҳВҒв•ӘШҜв•ӘШІ\n          </AdminButton>\n          <AdminButton variant=\"outline\" icon={Download} onClick={handleExport}>\n            в•ӘШІв•Әв•Ўв•ӘВ»в”ҳГЁв•Әв–’\n          </AdminButton>\n          <AdminButton icon={Plus} onClick={() => router.push(\"/admin/courses/new\")}>\n            в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ\n          </AdminButton>\n        </div>\n      </PageHeader>\n\n      {/* Stats */}\n      <CourseStats stats={statsData} />\n\n      {/* Filters */}\n      <CourseFilters\n        onSearch={setSearch}\n        onFilterChange={(filters) => {\n          setFilterLevel(filters.level);\n          setFilterStatus(filters.status);\n          setFilterCategory(filters.category);\n        }}\n        onViewChange={setView}\n        currentView={view}\n        categories={categories}\n        onRefresh={() => refetch()}\n        onAddCourse={() => router.push(\"/admin/courses/new\")}\n        totalCount={pagination?.total ?? courses.length}\n        isLoading={isFetching}\n      />\n\n      {/* Batch Actions Bar */}\n      {selectedIds.length > 0 && (\n        <div className=\"flex flex-wrap items-center gap-3 rounded-2xl border border-primary/20 bg-primary/5 px-4 py-3 animate-in slide-in-from-top-2 duration-300\">\n          <div className=\"flex items-center gap-2\">\n            <CheckCircle2 className=\"h-4 w-4 text-primary\" />\n            <span className=\"text-sm font-black text-primary\">\n              {selectedIds.length} в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ в”ҳГ в•ӘВ«в•ӘШІв•ӘШҜв•Әв–’в•ӘШұ\n            </span>\n          </div>\n          <div className=\"flex flex-wrap gap-2 mr-auto\">\n            <AdminButton\n              variant=\"outline\"\n              size=\"sm\"\n              className=\"h-8 rounded-xl text-xs font-black gap-1.5\"\n              onClick={() => handleBatchAction(\"publish\")}\n            >\n              <Globe className=\"h-3.5 w-3.5 text-emerald-500\" />\n              в”ҳВҶв•Әв”Өв•Әв–’\n            </AdminButton>\n            <AdminButton\n              variant=\"outline\"\n              size=\"sm\"\n              className=\"h-8 rounded-xl text-xs font-black gap-1.5\"\n              onClick={() => handleBatchAction(\"unpublish\")}\n            >\n              <EyeOff className=\"h-3.5 w-3.5 text-amber-500\" />\n              в•ӘШӯв•ӘВ«в”ҳВҒв•ӘШҜв•ӘШ©\n            </AdminButton>\n            <AdminButton\n              variant=\"outline\"\n              size=\"sm\"\n              className=\"h-8 rounded-xl text-xs font-black gap-1.5\"\n              onClick={() => handleBatchAction(\"activate\")}\n            >\n              <CheckCircle2 className=\"h-3.5 w-3.5 text-blue-500\" />\n              в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„\n            </AdminButton>\n            <AdminButton\n              variant=\"outline\"\n              size=\"sm\"\n              className=\"h-8 rounded-xl text-xs font-black gap-1.5 text-red-500 hover:bg-red-500/10\"\n              onClick={() => handleBatchAction(\"delete\")}\n            >\n              <AlertCircle className=\"h-3.5 w-3.5\" />\n              в•ӘШөв•Әв–‘в”ҳВҒ\n            </AdminButton>\n            <AdminButton\n              variant=\"ghost\"\n              size=\"sm\"\n              className=\"h-8 rounded-xl text-xs font-bold\"\n              onClick={() => setSelectedIds([])}\n            >\n              в•ӘШӯв”ҳВ„в•Әв•‘в•ӘШҜв•ӘШ©\n            </AdminButton>\n          </div>\n        </div>\n      )}\n\n      {/* Content */}\n      {view === \"grid\" ? (\n        isLoading ? (\n          <CourseGridSkeleton />\n        ) : courses.length === 0 ? (\n          emptyState\n        ) : (\n          <div className=\"grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 animate-in fade-in slide-in-from-bottom-3 duration-500\">\n            {courses.map((course) => (\n              <CourseCard\n                key={course.id}\n                course={course}\n                onEdit={(c) => router.push(`/admin/courses/${c.id}`)}\n                onDuplicate={handleDuplicate}\n                onDelete={(c) => setDeleteDialog({ open: true, id: c.id })}\n                onToggleStatus={handleToggleStatus}\n              />\n            ))}\n          </div>\n        )\n      ) : (\n        <AdminDataTable\n          columns={columns}\n          data={courses}\n          loading={isLoading}\n          selectable\n          serverSide\n          totalRows={pagination?.total || 0}\n          pageCount={totalPages}\n          currentPage={page}\n          onPageChange={setPage}\n          onPageSizeChange={setLimit}\n          pageSize={limit}\n          onSelectionChange={(rows) => setSelectedIds(rows.map((row) => row.id))}\n          bulkActions={[\n            { label: \"в”ҳВҶв•Әв”Өв•Әв–’\", onClick: () => handleBatchAction(\"publish\") },\n            { label: \"в•ӘШӯв•ӘВ«в”ҳВҒв•ӘШҜв•ӘШ©\", variant: \"outline\", onClick: () => handleBatchAction(\"unpublish\") },\n            { label: \"в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„\", variant: \"outline\", onClick: () => handleBatchAction(\"activate\") },\n            { label: \"в•ӘШӯв”ҳГЁв”ҳГ©в•ӘШҜв”ҳВҒ\", variant: \"outline\", onClick: () => handleBatchAction(\"deactivate\") },\n            { label: \"в•ӘШөв•Әв–‘в”ҳВҒ\", variant: \"destructive\", onClick: () => handleBatchAction(\"delete\") },\n          ]}\n          actions={{ onRefresh: () => refetch() }}\n          emptyMessage={{\n            title: \"в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в•ӘВ»в”ҳГӘв•Әв–’в•ӘШҜв•ӘШІ в”ҳГ в•Әв•–в•ӘШҜв•ӘШ°в”ҳГ©в•ӘШұ\",\n            description: \"в•ӘШҙв•Әв–’в”ҳЩ‘в•ӘШ° в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в•ӘШҜв”ҳВ„в”ҳВҒв”ҳВ„в•ӘШҜв•ӘШІв•Әв–’ в•ӘШ«в”ҳГӘ в•ӘШ«в”ҳВҶв•Әв”Өв•ӘШ® в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ.\",\n          }}\n          toolbar={\n            <AdminButton\n              variant=\"outline\"\n              size=\"sm\"\n              className=\"h-9 rounded-xl gap-2 font-bold\"\n              onClick={handleExport}\n            >\n              <Download className=\"h-4 w-4\" />\n              в•ӘШІв•Әв•Ўв•ӘВ»в”ҳГЁв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГўв”ҳВ„\n            </AdminButton>\n          }\n        />\n      )}\n\n      {/* Pagination for grid view */}\n      {view === \"grid\" && totalPages > 1 && (\n        <div className=\"flex items-center justify-center gap-2 pt-4\">\n          <AdminButton\n            variant=\"outline\"\n            size=\"sm\"\n            disabled={page <= 1}\n            onClick={() => setPage((p) => Math.max(1, p - 1))}\n            className=\"h-10 w-10 rounded-xl p-0\"\n          >\n            в”ңШӘШёГ©Шҙв•ӘШӨ\n          </AdminButton>\n          <div className=\"flex items-center gap-1\">\n            {Array.from({ length: Math.min(totalPages, 7) }, (_, i) => {\n              const pageNum = i + 1;\n              return (\n                <button\n                  key={pageNum}\n                  onClick={() => setPage(pageNum)}\n                  className={cn(\n                    \"h-10 w-10 rounded-xl text-sm font-bold transition-all\",\n                    pageNum === page\n                      ? \"bg-primary text-primary-foreground shadow-md\"\n                      : \"hover:bg-muted text-muted-foreground\"\n                  )}\n                >\n                  {pageNum}\n                </button>\n              );\n            })}\n          </div>\n          <AdminButton\n            variant=\"outline\"\n            size=\"sm\"\n            disabled={page >= totalPages}\n            onClick={() => setPage((p) => Math.min(totalPages, p + 1))}\n            className=\"h-10 w-10 rounded-xl p-0\"\n          >\n            ШёШҙв•Ј\n          </AdminButton>\n        </div>\n      )}\n\n      {/* в”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙ Quick Edit Dialog в”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙ */}\n      <Dialog\n        open={quickCreateOpen}\n        onOpenChange={(open) => {\n          setQuickCreateOpen(open);\n          if (!open) {\n            setEditingCourse(null);\n            quickForm.reset(quickCourseDefaults);\n          }\n        }}\n      >\n        <DialogContent className=\"max-w-5xl rounded-[2rem] p-0\">\n          <div className=\"grid max-h-[88vh] gap-0 overflow-hidden lg:grid-cols-[1.1fr_0.9fr]\">\n            {/* Form Side */}\n            <div className=\"overflow-y-auto p-6 sm:p-8\" dir=\"rtl\">\n              <DialogHeader className=\"space-y-2 text-right\">\n                <DialogTitle className=\"text-2xl font-black\">\n                  {editingCourse ? \"в•ӘШІв•Әв•Јв•ӘВ»в”ҳГЁв”ҳВ„ в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ\" : \"в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ в•Әв”Ӯв•Әв–’в”ҳГЁв•Әв•Ј\"}\n                </DialogTitle>\n                <p className=\"text-sm text-muted-foreground\">\n                  {editingCourse\n                    ? \"в•Әв•Јв•ӘВ»в”ҳЩ‘в”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•ӘШҜв•Әв”Ӯв”ҳГЁв•ӘШұ в”ңШӘШёГ©ШҙШёВҖВЈ в”ҳВ„в”ҳВ„в•ӘШІв•ӘШөв”ҳГўв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГўв•ӘШҜв”ҳГ в”ҳВ„ в•ӘШІв”ҳГӘв•ӘШҙв”ҳЩ‘в”ҳГ§ в”ҳВ„в•Әв•Ўв”ҳВҒв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•Әв–’в•Әв–’.\"\n                    : \"в•ӘШ«в•ӘВ»в•ӘВ«в”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•ӘШҜв•Әв”Ӯв”ҳГЁв•ӘШұ в•ӘШів”ҳГ  в•ӘШ«в•Әв•ўв”ҳВҒ в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв”ҳГ§в•ӘШҙ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв”ҳГЁ в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГӘв•Әв”Ӯв•ӘШҜв•ӘШ®в•Әв•– в”ҳГ в”ҳВҶ в•Әв•Ўв”ҳВҒв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ.\"}\n                </p>\n                {!editingCourse && (\n                  <div className=\"flex items-center gap-2 rounded-xl bg-primary/5 border border-primary/20 px-3 py-2\">\n                    <CheckCircle2 className=\"h-4 w-4 text-primary shrink-0\" />\n                    <p className=\"text-xs font-bold text-primary\">\n                      в•ӘШ°в•Әв•Јв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•Әв”Ӯв•ӘШІв•Әв••в”ҢГӘв”ҳГӘв•ӘШҙв”ҳВҗв”ҳЩ‘в”ҳГ§ в•ӘШІв”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГЁв”ҳГҜв•ӘШҜ в”ҳВ„в•Әв•Ўв”ҳВҒв•ӘШөв•ӘШұ в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•ӘШҜв”ҳВ„в”ҳВҒв•Әв•Ўв”ҳГӘв”ҳВ„ в”ҳГӘв•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в”ҳГӘв•Әв”Ӯ.\n                    </p>\n                  </div>\n                )}\n              </DialogHeader>\n\n              <Form {...quickForm}>\n                <form\n                  onSubmit={quickForm.handleSubmit(handleQuickSubmit)}\n                  className=\"mt-6 space-y-5\"\n                >\n                  {/* Names */}\n                  <div className=\"grid gap-4 sm:grid-cols-2\">\n                    <FormField\n                      control={quickForm.control}\n                      name=\"nameAr\"\n                      render={({ field }) => (\n                        <FormItem>\n                          <FormLabel className=\"font-bold\">в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ в•ӘШ°в•ӘШҜв”ҳВ„в•Әв•Јв•Әв–’в•ӘШ°в”ҳГЁв•ӘШұ *</FormLabel>\n                          <FormControl>\n                            <Input\n                              {...field}\n                              value={field.value || \"\"}\n                              placeholder=\"в”ҳГ в•ӘШів•ӘШҜв”ҳВ„: в•ӘШ«в•Әв”Ӯв•ӘШҜв•Әв”Ӯв”ҳГЁв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•Әв–’в”ҳГЁв•ӘШҜв•Әв•ўв”ҳГЁв•ӘШҜв•ӘШІ\"\n                              className=\"h-11 rounded-xl\"\n                            />\n                          </FormControl>\n                          <FormMessage />\n                        </FormItem>\n                      )}\n                    />\n                    <FormField\n                      control={quickForm.control}\n                      name=\"name\"\n                      render={({ field }) => (\n                        <FormItem>\n                          <FormLabel className=\"font-bold\">Course Name (EN) *</FormLabel>\n                          <FormControl>\n                            <Input\n                              {...field}\n                              value={field.value || \"\"}\n                              placeholder=\"Math Fundamentals\"\n                              dir=\"ltr\"\n                              className=\"h-11 rounded-xl\"\n                            />\n                          </FormControl>\n                          <FormMessage />\n                        </FormItem>\n                      )}\n                    />\n                  </div>\n\n                  {/* Code & Slug */}\n                  <div className=\"grid gap-4 sm:grid-cols-2\">\n                    <FormField\n                      control={quickForm.control}\n                      name=\"code\"\n                      render={({ field }) => (\n                        <FormItem>\n                          <FormLabel className=\"font-bold\">в”ҳГўв”ҳГӘв•ӘВ» в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ</FormLabel>\n                          <FormControl>\n                            <Input\n                              {...field}\n                              value={field.value || \"\"}\n                              placeholder=\"MATH-2026\"\n                              className=\"h-11 rounded-xl\"\n                            />\n                          </FormControl>\n                          <FormMessage />\n                        </FormItem>\n                      )}\n                    />\n                    <FormField\n                      control={quickForm.control}\n                      name=\"slug\"\n                      render={({ field }) => (\n                        <FormItem>\n                          <FormLabel className=\"font-bold\">в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҜв•ӘШ°в•Әв•– в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ«в•ӘШІв•Әв•Ўв•Әв–’</FormLabel>\n                          <FormControl>\n                            <Input\n                              {...field}\n                              value={field.value || \"\"}\n                              placeholder=\"math-fundamentals\"\n                              dir=\"ltr\"\n                              className=\"h-11 rounded-xl\"\n                            />\n                          </FormControl>\n                          <FormMessage />\n                        </FormItem>\n                      )}\n                    />\n                  </div>\n\n                  {/* Description */}\n                  <FormField\n                    control={quickForm.control}\n                    name=\"description\"\n                    render={({ field }) => (\n                      <FormItem>\n                        <FormLabel className=\"font-bold\">в•ӘШҜв”ҳВ„в”ҳГӘв•Әв•Ўв”ҳВҒ</FormLabel>\n                        <FormControl>\n                          <Textarea\n                            {...field}\n                            value={field.value || \"\"}\n                            placeholder=\"в”ҳГ в”ҳВ„в•ӘВ«в•Әв•Ў в”ҳГӘв•ӘШҜв•Әв•ўв•ӘШө в”ҳВ„в”ҳГ в•ӘШҜ в•Әв”Ӯв”ҳГЁв•ӘШІв•Әв•Јв”ҳВ„в”ҳГ в”ҳГ§ в•ӘШҜв”ҳВ„в•Әв•–в•ӘШҜв”ҳВ„в•ӘШ° в•ӘВ»в•ӘШҜв•ӘВ«в”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ...\"\n                            className=\"min-h-[90px] rounded-xl resize-none\"\n                          />\n                        </FormControl>\n                        <FormMessage />\n                      </FormItem>\n                    )}\n                  />\n\n                  {/* Price, Hours, Level, Language */}\n                  <div className=\"grid gap-4 sm:grid-cols-2 lg:grid-cols-4\">\n                    <FormField\n                      control={quickForm.control}\n                      name=\"price\"\n                      render={({ field }) => (\n                        <FormItem>\n                          <FormLabel className=\"font-bold\">в•ӘШҜв”ҳВ„в•Әв”Ӯв•Әв•Јв•Әв–’ (в•ӘШҙ)</FormLabel>\n                          <FormControl>\n                            <Input type=\"number\" {...field} className=\"h-11 rounded-xl\" />\n                          </FormControl>\n                          <FormMessage />\n                        </FormItem>\n                      )}\n                    />\n                    <FormField\n                      control={quickForm.control}\n                      name=\"durationHours\"\n                      render={({ field }) => (\n                        <FormItem>\n                          <FormLabel className=\"font-bold\">в•ӘШҜв”ҳВ„в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘШҜв•ӘШІ</FormLabel>\n                          <FormControl>\n                            <Input type=\"number\" {...field} className=\"h-11 rounded-xl\" />\n                          </FormControl>\n                          <FormMessage />\n                        </FormItem>\n                      )}\n                    />\n                    <FormField\n                      control={quickForm.control}\n                      name=\"level\"\n                      render={({ field }) => (\n                        <FormItem>\n                          <FormLabel className=\"font-bold\">в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГӘв”ҳГ«</FormLabel>\n                          <Select onValueChange={field.onChange} value={field.value}>\n                            <FormControl>\n                              <SelectTrigger className=\"h-11 rounded-xl\">\n                                <SelectValue />\n                              </SelectTrigger>\n                            </FormControl>\n                            <SelectContent>\n                              <SelectItem value=\"BEGINNER\">в”ҳГ в•ӘШ°в•ӘШІв•ӘВ»в•ӘШ®</SelectItem>\n                              <SelectItem value=\"INTERMEDIATE\">в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•–</SelectItem>\n                              <SelectItem value=\"ADVANCED\">в”ҳГ в•ӘШІв”ҳГ©в•ӘВ»в”ҳГ </SelectItem>\n                            </SelectContent>\n                          </Select>\n                          <FormMessage />\n                        </FormItem>\n                      )}\n                    />\n                    <FormField\n                      control={quickForm.control}\n                      name=\"language\"\n                      render={({ field }) => (\n                        <FormItem>\n                          <FormLabel className=\"font-bold\">в•ӘШҜв”ҳВ„в”ҳВ„в•Әв•‘в•ӘШұ</FormLabel>\n                          <Select onValueChange={field.onChange} value={field.value || \"ar\"}>\n                            <FormControl>\n                              <SelectTrigger className=\"h-11 rounded-xl\">\n                                <SelectValue />\n                              </SelectTrigger>\n                            </FormControl>\n                            <SelectContent>\n                              <SelectItem value=\"ar\">в•ӘШҜв”ҳВ„в•Әв•Јв•Әв–’в•ӘШ°в”ҳГЁв•ӘШұ</SelectItem>\n                              <SelectItem value=\"en\">English</SelectItem>\n                            </SelectContent>\n                          </Select>\n                          <FormMessage />\n                        </FormItem>\n                      )}\n                    />\n                  </div>\n\n                  {/* Instructor & Category */}\n                  <div className=\"grid gap-4 sm:grid-cols-2\">\n                    <FormField\n                      control={quickForm.control}\n                      name=\"instructorId\"\n                      render={({ field }) => (\n                        <FormItem>\n                          <FormLabel className=\"font-bold\">в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯ</FormLabel>\n                          <Select onValueChange={field.onChange} value={field.value || \"\"}>\n                            <FormControl>\n                              <SelectTrigger className=\"h-11 rounded-xl\">\n                                <SelectValue placeholder=\"в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯв”ҳГҜв•ӘШҜ\" />\n                              </SelectTrigger>\n                            </FormControl>\n                            <SelectContent>\n                              {teachers.map((t) => (\n                                <SelectItem key={t.id} value={t.id}>\n                                  {t.name}\n                                </SelectItem>\n                              ))}\n                            </SelectContent>\n                          </Select>\n                          <FormMessage />\n                        </FormItem>\n                      )}\n                    />\n                    <FormField\n                      control={quickForm.control}\n                      name=\"categoryId\"\n                      render={({ field }) => (\n                        <FormItem>\n                          <FormLabel className=\"font-bold\">в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Ўв”ҳВҶв”ҳГЁв”ҳВҒ</FormLabel>\n                          <Select onValueChange={field.onChange} value={field.value || \"\"}>\n                            <FormControl>\n                              <SelectTrigger className=\"h-11 rounded-xl\">\n                                <SelectValue placeholder=\"в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШІв•Әв•Ўв”ҳВҶв”ҳГЁв”ҳВҒв”ҳГҜв•ӘШҜ\" />\n                              </SelectTrigger>\n                            </FormControl>\n                            <SelectContent>\n                              {categories.map((cat) => (\n                                <SelectItem key={cat.id} value={cat.id}>\n                                  {cat.name}\n                                </SelectItem>\n                              ))}\n                            </SelectContent>\n                          </Select>\n                          <FormMessage />\n                        </FormItem>\n                      )}\n                    />\n                  </div>\n\n                  {/* Media */}\n                  <div className=\"grid gap-4 sm:grid-cols-2\">\n                    <FormField\n                      control={quickForm.control}\n                      name=\"thumbnailUrl\"\n                      render={({ field }) => (\n                        <FormItem>\n                          <FormLabel className=\"font-bold\">в•Әв•Ўв”ҳГӘв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в•Әв•‘в”ҳВ„в•ӘШҜв”ҳВҒ</FormLabel>\n                          <FormControl>\n                            <div className=\"space-y-2\">\n                              <Input\n                                {...field}\n                                value={field.value || \"\"}\n                                placeholder=\"в•Әв–’в•ӘШҜв•ӘШ°в•Әв•– в”ҳГ в•ӘШ°в•ӘШҜв•Әв”Өв•Әв–’ в”ҳВ„в”ҳВ„в•Әв•Ўв”ҳГӘв•Әв–’в•ӘШұ\"\n                                className=\"h-11 rounded-xl\"\n                              />\n                              <AdminUpload\n                                accept=\"image/*\"\n                                label=\"в•Әв–’в”ҳВҒв•Әв•Ј в•Әв•Ўв”ҳГӘв•Әв–’в•ӘШұ\"\n                                onUploadComplete={(url) => field.onChange(url)}\n                              />\n                            </div>\n                          </FormControl>\n                          <FormMessage />\n                        </FormItem>\n                      )}\n                    />\n                    <FormField\n                      control={quickForm.control}\n                      name=\"trailerUrl\"\n                      render={({ field }) => (\n                        <FormItem>\n                          <FormLabel className=\"font-bold\">в”ҳВҒв”ҳГЁв•ӘВ»в”ҳГЁв”ҳГӘ в•ӘШІв•Әв•Јв•Әв–’в”ҳГЁв”ҳВҒв”ҳГЁ</FormLabel>\n                          <FormControl>\n                            <div className=\"space-y-2\">\n                              <Input\n                                {...field}\n                                value={field.value || \"\"}\n                                placeholder=\"в•Әв–’в•ӘШҜв•ӘШ°в•Әв•– в”ҳГЁв”ҳГӘв•ӘШІв”ҳГЁв”ҳГӘв•ӘШ° в•ӘШ«в”ҳГӘ в”ҳВҒв”ҳГЁв•ӘВ»в”ҳГЁв”ҳГӘ в”ҳГ в•ӘШ°в•ӘШҜв•Әв”Өв•Әв–’\"\n                                className=\"h-11 rounded-xl\"\n                              />\n                              <AdminUpload\n                                accept=\"video/*\"\n                                label=\"в•Әв–’в”ҳВҒв•Әв•Ј в”ҳВҒв”ҳГЁв•ӘВ»в”ҳГЁв”ҳГӘ\"\n                                maxSize={5 * 1024}\n                                onUploadComplete={(url) => field.onChange(url)}\n                              />\n                            </div>\n                          </FormControl>\n                          <FormMessage />\n                        </FormItem>\n                      )}\n                    />\n                  </div>\n\n                  {/* Toggles */}\n                  <div className=\"grid gap-3 sm:grid-cols-3\">\n                    {([\"isActive\", \"isPublished\", \"isFeatured\"] as const).map((name) => {\n                      const labels = {\n                        isActive: { title: \"в•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ\", desc: \"в•ӘШІв”ҳШІв•Әв–’ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳВҶв•Әв••в•ӘШҜв”ҳГ \" },\n                        isPublished: { title: \"в”ҳВҶв•Әв”Өв•Әв–’ в”ҳВ„в”ҳВ„в•Әв•–в”ҳВ„в•ӘШҜв•ӘШ°\", desc: \"в”ҳГ в•Әв–’в•ӘШ®в”ҳГЁв•ӘШұ в”ҳВ„в”ҳВ„в•ӘШҙв”ҳГ в”ҳГ§в”ҳГӘв•Әв–’\" },\n                        isFeatured: { title: \"в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ в”ҳГ в”ҳГ в”ҳГЁв•Әв–“в•ӘШұ\", desc: \"в•ӘШІв”ҳГ в”ҳГЁв”ҳГЁв•Әв–“ в•ӘВ«в•ӘШҜв•Әв•Ў\" },\n                      };\n                      return (\n                        <div\n                          key={name}\n                          className=\"flex items-center justify-between rounded-2xl border bg-muted/20 p-3.5\"\n                        >\n                          <div>\n                            <p className=\"text-sm font-black\">{labels[name].title}</p>\n                            <p className=\"text-[10px] text-muted-foreground\">\n                              {labels[name].desc}\n                            </p>\n                          </div>\n                          <FormField\n                            control={quickForm.control}\n                            name={name}\n                            render={({ field }) => (\n                              <FormControl>\n                                <Switch\n                                  checked={field.value as boolean}\n                                  onCheckedChange={field.onChange}\n                                />\n                              </FormControl>\n                            )}\n                          />\n                        </div>\n                      );\n                    })}\n                  </div>\n\n                  <DialogFooter className=\"gap-2 pt-2\">\n                    {editingCourse && (\n                      <AdminButton\n                        type=\"button\"\n                        variant=\"outline\"\n                        onClick={() => router.push(`/admin/courses/${editingCourse.id}`)}\n                        className=\"gap-2\"\n                      >\n                        <ExternalLink className=\"h-4 w-4\" />\n                        в”ҳВҒв•ӘШІв•ӘШө в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•Әв–’в•Әв–’ в•ӘШҜв”ҳВ„в”ҳГўв•ӘШҜв”ҳГ в”ҳВ„\n                      </AdminButton>\n                    )}\n                    <AdminButton\n                      type=\"submit\"\n                      disabled={isSubmitting}\n                      className=\"flex-1 h-12 text-base font-black gap-2\"\n                    >\n                      {isSubmitting ? (\n                        <Loader2 className=\"h-4 w-4 animate-spin\" />\n                      ) : (\n                        <CheckCircle2 className=\"h-4 w-4\" />\n                      )}\n                      {editingCourse ? \"в•ӘШөв”ҳВҒв•Әв•• в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Јв•ӘВ»в”ҳГЁв”ҳВ„в•ӘШҜв•ӘШІ\" : \"в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ\"}\n                    </AdminButton>\n                  </DialogFooter>\n                </form>\n              </Form>\n            </div>\n\n            {/* Preview Side */}\n            <div className=\"border-r bg-muted/10 p-6 hidden lg:block\" dir=\"rtl\">\n              <div className=\"sticky top-0 space-y-5\">\n                <div>\n                  <p className=\"text-xs font-black uppercase tracking-[0.2em] text-muted-foreground\">\n                    в”ҳГ в•Әв•Јв•ӘШҜв”ҳГЁв”ҳВҶв•ӘШұ в•Әв”Ӯв•Әв–’в”ҳГЁв•Әв•Јв•ӘШұ\n                  </p>\n                  <h3 className=\"mt-2 text-xl font-black leading-snug\">\n                    {quickForm.watch(\"nameAr\") || quickForm.watch(\"name\") || \"в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ\"}\n                  </h3>\n                </div>\n\n                <div className=\"overflow-hidden rounded-[1.5rem] border bg-background shadow-sm\">\n                  <div className=\"relative aspect-video bg-gradient-to-br from-primary/10 to-primary/5\">\n                    {quickForm.watch(\"thumbnailUrl\") ? (\n                      <img\n                        src={quickForm.watch(\"thumbnailUrl\") || \"\"}\n                        alt=\"preview\"\n                        className=\"h-full w-full object-cover\"\n                      />\n                    ) : (\n                      <div className=\"flex h-full items-center justify-center\">\n                        <PlayCircle className=\"h-12 w-12 text-primary/30\" />\n                      </div>\n                    )}\n                    <div className=\"absolute top-3 right-3\">\n                      <Badge\n                        className={cn(\n                          \"rounded-lg text-[10px] font-black px-2 py-0.5 border\",\n                          quickForm.watch(\"isPublished\")\n                            ? \"bg-emerald-500/20 text-emerald-400 border-emerald-500/30\"\n                            : \"bg-orange-500/20 text-orange-400 border-orange-500/30\"\n                        )}\n                      >\n                        {quickForm.watch(\"isPublished\") ? \"в”ҳГ в”ҳВҶв•Әв”Өв”ҳГӘв•Әв–’в•ӘШұ\" : \"в”ҳГ в•Әв”Ӯв”ҳГӘв•ӘВ»в•ӘШұ\"}\n                      </Badge>\n                    </div>\n                  </div>\n                  <div className=\"space-y-4 p-4\">\n                    <div className=\"flex flex-wrap gap-1.5\">\n                      <Badge\n                        variant=\"outline\"\n                        className={cn(\n                          \"rounded-full text-[11px]\",\n                          levelStyles[quickForm.watch(\"level\")] || levelStyles.INTERMEDIATE\n                        )}\n                      >\n                        {levelLabels[quickForm.watch(\"level\")] || \"в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•–\"}\n                      </Badge>\n                      <Badge\n                        variant={quickForm.watch(\"isActive\") ? \"default\" : \"secondary\"}\n                        className=\"rounded-full text-[11px]\"\n                      >\n                        {quickForm.watch(\"isActive\") ? \"в”ҳВҶв•Әв”Өв•Әв•–в•ӘШұ\" : \"в”ҳГ в”ҳГӘв”ҳГ©в”ҳГӘв”ҳВҒв•ӘШұ\"}\n                      </Badge>\n                    </div>\n                    <p className=\"text-xs leading-6 text-muted-foreground line-clamp-3\">\n                      {quickForm.watch(\"description\") ||\n                        \"в•ӘШ«в•Әв•ўв”ҳВҒ в”ҳГӘв•Әв•Ўв”ҳВҒв”ҳГҜв•ӘШҜ в”ҳГЁв”ҳГӘв•Әв•ўв•ӘШө в”ҳГ©в”ҳГЁв”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШұ в”ҳВ„в”ҳВ„в•Әв•–в”ҳВ„в•ӘШҜв•ӘШ°...\"}\n                    </p>\n                    <div className=\"grid grid-cols-2 gap-2\">\n                      <div className=\"rounded-xl bg-muted/40 p-3\">\n                        <p className=\"text-[10px] font-bold text-muted-foreground\">в•ӘШҜв”ҳВ„в•Әв”Ӯв•Әв•Јв•Әв–’</p>\n                        <p className=\"mt-1 text-lg font-black\">\n                          {quickForm.watch(\"price\") === 0\n                            ? \"в”ҳГ в•ӘШҙв•ӘШҜв”ҳВҶв”ҳГЁв•ӘШұ\"\n                            : `${quickForm.watch(\"price\")} в•ӘШҙ`}\n                        </p>\n                      </div>\n                      <div className=\"rounded-xl bg-muted/40 p-3\">\n                        <p className=\"text-[10px] font-bold text-muted-foreground\">в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ»в•ӘШұ</p>\n                        <p className=\"mt-1 text-lg font-black\">\n                          {quickForm.watch(\"durationHours\") || 0}h\n                        </p>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n\n                <div className=\"rounded-2xl border border-dashed bg-background p-4\">\n                  <p className=\"text-xs font-black mb-1\">в•ӘШІв”ҳГӘв•Әв•Ўв”ҳГЁв•ӘШұ в”ҳГ©в•ӘШ°в”ҳВ„ в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Өв•Әв–’</p>\n                  <ul className=\"space-y-1.5 text-[11px] text-muted-foreground\">\n                    <li className=\"flex items-center gap-2\">\n                      {quickForm.watch(\"thumbnailUrl\") ? (\n                        <CheckCircle2 className=\"h-3 w-3 text-emerald-500 shrink-0\" />\n                      ) : (\n                        <AlertCircle className=\"h-3 w-3 text-amber-500 shrink-0\" />\n                      )}\n                      в•Әв•Ўв”ҳГӘв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в•Әв•‘в”ҳВ„в•ӘШҜв”ҳВҒ\n                    </li>\n                    <li className=\"flex items-center gap-2\">\n                      {(quickForm.watch(\"description\")?.length ?? 0) > 50 ? (\n                        <CheckCircle2 className=\"h-3 w-3 text-emerald-500 shrink-0\" />\n                      ) : (\n                        <AlertCircle className=\"h-3 w-3 text-amber-500 shrink-0\" />\n                      )}\n                      в”ҳГӘв•Әв•Ўв”ҳВҒ в•ӘШІв”ҳВҒв•Әв•Ўв”ҳГЁв”ҳВ„в”ҳГЁ в”ҳГўв•ӘШҜв”ҳВҒв”ҳВҚ\n                    </li>\n                    <li className=\"flex items-center gap-2\">\n                      {quickForm.watch(\"instructorId\") ? (\n                        <CheckCircle2 className=\"h-3 w-3 text-emerald-500 shrink-0\" />\n                      ) : (\n                        <AlertCircle className=\"h-3 w-3 text-amber-500 shrink-0\" />\n                      )}\n                      в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯ в”ҳГ в•Әв–’в•ӘШІв•ӘШ°в•Әв•–\n                    </li>\n                  </ul>\n                </div>\n              </div>\n            </div>\n          </div>\n        </DialogContent>\n      </Dialog>\n\n      {/* в”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙ Category Dialog в”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙв”ңШӘШёВҖШҘШёГ©Шҙ */}\n      <Dialog\n        open={categoryDialogOpen}\n        onOpenChange={(open) => {\n          setCategoryDialogOpen(open);\n          if (!open) {\n            setEditingCategory(null);\n            categoryForm.reset(defaultCategoryValues);\n          }\n        }}\n      >\n        <DialogContent className=\"max-w-2xl rounded-[2rem] p-0\">\n          <div className=\"p-6 sm:p-8\" dir=\"rtl\">\n            <DialogHeader className=\"space-y-2 text-right\">\n              <DialogTitle className=\"text-2xl font-black\">\n                {editingCategory ? \"в•ӘШІв•Әв•Јв•ӘВ»в”ҳГЁв”ҳВ„ в•ӘШІв•Әв•Ўв”ҳВҶв”ҳГЁв”ҳВҒ\" : \"в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•ӘШІв•Әв•Ўв”ҳВҶв”ҳГЁв”ҳВҒ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»\"}\n              </DialogTitle>\n              <p className=\"text-sm text-muted-foreground\">\n                в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Ўв”ҳВҶв”ҳГЁв”ҳВҒв•ӘШҜв•ӘШІ в”ҳВ„в•ӘШІв”ҳВҶв•Әв••в”ҳГЁв”ҳГ  в•ӘВ»в”ҳГӘв•Әв–’в•ӘШҜв•ӘШІв”ҳГў в”ҳВҒв”ҳГЁ в”ҳГ в•ӘШҙв”ҳГ в”ҳГӘв•Әв•Јв•ӘШҜв•ӘШІ в”ҳГ в”ҳВҶв•Әв•–в”ҳГ©в”ҳГЁв•ӘШұ.\n              </p>\n            </DialogHeader>\n\n            <Form {...categoryForm}>\n              <form\n                onSubmit={categoryForm.handleSubmit(handleCategorySubmit)}\n                className=\"mt-6 space-y-5\"\n              >\n                <div className=\"grid gap-4 sm:grid-cols-2\">\n                  <FormField\n                    control={categoryForm.control}\n                    name=\"name\"\n                    render={({ field }) => (\n                      <FormItem>\n                        <FormLabel className=\"font-bold\">в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Ўв”ҳВҶв”ҳГЁв”ҳВҒ *</FormLabel>\n                        <FormControl>\n                          <Input\n                            {...field}\n                            value={field.value || \"\"}\n                            placeholder=\"в”ҳГ в•ӘШів•ӘШҜв”ҳВ„: в•ӘШҜв”ҳВ„в•Әв–’в”ҳГЁв•ӘШҜв•Әв•ўв”ҳГЁв•ӘШҜв•ӘШІ\"\n                            className=\"h-11 rounded-xl\"\n                          />\n                        </FormControl>\n                        <FormMessage />\n                      </FormItem>\n                    )}\n                  />\n                  <FormField\n                    control={categoryForm.control}\n                    name=\"slug\"\n                    render={({ field }) => (\n                      <FormItem>\n                        <FormLabel className=\"font-bold\">в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҜв•ӘШ°в•Әв•– в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ«в•ӘШІв•Әв•Ўв•Әв–’</FormLabel>\n                        <FormControl>\n                          <Input\n                            {...field}\n                            value={field.value || \"\"}\n                            placeholder=\"mathematics\"\n                            dir=\"ltr\"\n                            className=\"h-11 rounded-xl\"\n                          />\n                        </FormControl>\n                        <FormMessage />\n                      </FormItem>\n                    )}\n                  />\n                </div>\n                <div className=\"grid gap-4 sm:grid-cols-2\">\n                  <FormField\n                    control={categoryForm.control}\n                    name=\"icon\"\n                    render={({ field }) => (\n                      <FormItem>\n                        <FormLabel className=\"font-bold\">в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГЁв”ҳГ©в”ҳГӘв”ҳВҶв•ӘШұ (в•ӘШҜв•Әв”Ӯв”ҳГ  Lucide)</FormLabel>\n                        <FormControl>\n                          <Input\n                            {...field}\n                            value={field.value || \"\"}\n                            placeholder=\"BookOpen\"\n                            className=\"h-11 rounded-xl\"\n                          />\n                        </FormControl>\n                        <FormMessage />\n                      </FormItem>\n                    )}\n                  />\n                  <div className=\"rounded-2xl border bg-muted/20 p-4\">\n                    <p className=\"text-xs font-black text-muted-foreground\">в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв•Әв–’в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в•ӘШІв•ӘШ°в•Әв•–в•ӘШұ</p>\n                    <p className=\"mt-2 text-3xl font-black\">{editingCategory?.coursesCount ?? 0}</p>\n                  </div>\n                </div>\n                <FormField\n                  control={categoryForm.control}\n                  name=\"description\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel className=\"font-bold\">в•ӘШҜв”ҳВ„в”ҳГӘв•Әв•Ўв”ҳВҒ</FormLabel>\n                      <FormControl>\n                        <Textarea\n                    