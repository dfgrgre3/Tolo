  color: \"text-amber-400\"\r\n  },\r\n  {\r\n    icon: <CalendarCheck className=\"h-6 w-6\" />,\r\n    title: \"в•ӘВ«в•Әв–’в”ҳГЁв•Әв•–в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ  (Schedule)\",\r\n    description: \"в•ӘШІв”ҳВҶв•Әв••в”ҳГЁв”ҳГ  в•ӘШҙв•ӘВ»в”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв•ӘШұ в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГ в”ҳГ§в•ӘШҜв”ҳГ  в•ӘШІв”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГЁв•ӘШҜв”ҳГҜ в•ӘШөв•Әв”Ӯв•ӘШ° в•ӘШ«в”ҳГӘв”ҳВ„в”ҳГӘв”ҳГЁв•ӘШҜв•ӘШІв”ҳГў.\",\r\n    delay: 0.7,\r\n    badge: \"в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»\",\r\n    color: \"text-cyan-400\"\r\n  },\r\n  {\r\n    icon: <Headphones className=\"h-6 w-6\" />,\r\n    title: \"в•ӘШҜв”ҳВ„в•ӘВ»в•Әв•Јв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШІв”ҳГ©в”ҳВҶв”ҳГЁ (Support)\",\r\n    description: \"в”ҳВҒв•Әв–’в”ҳГЁв”ҳГ© в•ӘШҙв•ӘШҜв”ҳГ§в•Әв–“ в”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШҜв”ҳВҶв•ӘВ»в•ӘШІв”ҳГў в”ҳВҒв”ҳГЁ в•ӘШ«в”ҳГЁ в”ҳГӘв”ҳГ©в•ӘШІ.\",\r\n    delay: 0.8,\r\n    color: \"text-pink-400\"\r\n  },\r\n];\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\components\\home\\sections\\AchievementsSection.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Target' is defined but never used. Allowed unused vars must match /^_/u.","line":6,"column":31,"nodeType":"Identifier","messageId":"unusedVar","endLine":6,"endColumn":37,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Target"},"fix":{"range":[155,163],"text":""},"desc":"Remove unused variable \"Target\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'BookOpen' is defined but never used. Allowed unused vars must match /^_/u.","line":6,"column":53,"nodeType":"Identifier","messageId":"unusedVar","endLine":6,"endColumn":61,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"BookOpen"},"fix":{"range":[177,187],"text":""},"desc":"Remove unused variable \"BookOpen\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Calendar' is defined but never used. Allowed unused vars must match /^_/u.","line":6,"column":63,"nodeType":"Identifier","messageId":"unusedVar","endLine":6,"endColumn":71,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Calendar"},"fix":{"range":[187,197],"text":""},"desc":"Remove unused variable \"Calendar\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Card' is defined but never used. Allowed unused vars must match /^_/u.","line":7,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":7,"endColumn":14,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Card"},"fix":{"range":[253,258],"text":""},"desc":"Remove unused variable \"Card\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'CardContent' is defined but never used. Allowed unused vars must match /^_/u.","line":7,"column":16,"nodeType":"Identifier","messageId":"unusedVar","endLine":7,"endColumn":27,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"CardContent"},"fix":{"range":[244,303],"text":""},"desc":"Remove unused import declaration."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":5,"fixableErrorCount":0,"fixableWarningCount":0,"source":"ЩҠв•—в”җ\"use client\";\r\n\r\nimport React, { memo } from 'react';\r\nimport Link from \"next/link\";\r\nimport { motion } from \"framer-motion\";\r\nimport { Trophy, Star, Award, Target, CheckCircle2, BookOpen, Calendar, ArrowRight, Sparkles } from \"lucide-react\";\r\nimport { Card, CardContent } from \"@/components/ui/card\";\r\nimport { Button } from \"@/components/ui/button\";\r\nimport { Badge } from \"@/components/ui/badge\";\r\nimport { rpgCommonStyles } from \"../constants\";\r\n\r\n// --- Types ---\r\nexport interface Achievement {\r\n  id: string;\r\n  icon?: React.ReactNode;\r\n  title: string;\r\n  description: string;\r\n  progress: number;\r\n  color?: string;\r\n  iconName?: string; // Fallback for serializable data\r\n}\r\n\r\nexport interface AchievementStat {\r\n  id: string;\r\n  icon?: React.ReactNode;\r\n  value: string | number;\r\n  label: string;\r\n  color?: string;\r\n}\r\n\r\ninterface AchievementsSectionProps {\r\n  achievements?: Achievement[];\r\n  stats?: AchievementStat[];\r\n  loading?: boolean;\r\n}\r\n\r\n// --- Constants & Defaults ---\r\nconst DEFAULT_ACHIEVEMENTS: Achievement[] = [\r\n  { id: '1', title: \"в•ӘШ°в•Әв•–в”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв•ӘШұ\", description: \"в•ӘШ«в”ҳГўв”ҳГ в”ҳВ„ 10 в•ӘШ«в”ҳГЁв•ӘШҜв”ҳГ  в”ҳГ в•ӘШІв•ӘШІв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШұ в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–‘в•ӘШҜв”ҳГўв•Әв–’в•ӘШұ\", progress: 70, color: \"from-yellow-400 to-amber-500\", icon: <Trophy className=\"text-white\" /> },\r\n  { id: '2', title: \"в”ҳВҶв•ӘШҙв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘШҜв•ӘВ»\", description: \"в•ӘШҜв•ӘШөв•Әв•Ўв”ҳВ„ в•Әв•Јв”ҳВ„в”ҳГ« в”ҳГ в•Әв•Јв•ӘВ»в”ҳВ„ 90% в”ҳВҒв”ҳГЁ 3 в”ҳГ в”ҳГӘв•ӘШҜв•ӘВ»\", progress: 45, color: \"from-blue-400 to-indigo-500\", icon: <Star className=\"text-white\" /> },\r\n  { id: '3', title: \"в”ҳГ в•ӘШөв”ҳВ„в”ҳВ„ в”ҳГ в”ҳГ в•ӘШІв•ӘШҜв•Әв–“\", description: \"в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в•ӘШ«в•ӘВ»в”ҳГӘв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳВ„в”ҳГЁв”ҳВ„ 5 в•ӘШ«в”ҳГЁв•ӘШҜв”ҳГ \", progress: 80, color: \"from-purple-400 to-pink-500\", icon: <Award className=\"text-white\" /> },\r\n];\r\n\r\nconst DEFAULT_STATS: AchievementStat[] = [\r\n  { id: 'completed', icon: <CheckCircle2 className=\"w-5 h-5 text-green-400\" />, value: \"12\", label: \"в•ӘШӯв”ҳВҶв•ӘШҙв•ӘШҜв•Әв–“ в”ҳГ в”ҳГўв•ӘШІв”ҳГ в”ҳВ„\", color: \"bg-green-500/10 border-green-500/20\" },\r\n  { id: 'points', icon: <Star className=\"w-5 h-5 text-yellow-400\" />, value: \"2,450\", label: \"в”ҳВҶв”ҳГ©в•Әв•–в•ӘШұ в”ҳГ в”ҳГўв•ӘШҜв”ҳВҒв•ӘШ«в•ӘШұ\", color: \"bg-yellow-500/10 border-yellow-500/20\" },\r\n  { id: 'rank', icon: <Trophy className=\"w-5 h-5 text-purple-400\" />, value: \"#42\", label: \"в•ӘШҜв”ҳВ„в•ӘШІв•Әв–’в•ӘШІв”ҳГЁв•ӘШ° в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁ\", color: \"bg-purple-500/10 border-purple-500/20\" },\r\n];\r\n\r\n// --- Sub-components ---\r\nconst AchievementCard = memo(({ achievement, index }: { achievement: Achievement; index: number }) => (\r\n  <motion.div\r\n    initial={{ opacity: 0, scale: 0.9 }}\r\n    whileInView={{ opacity: 1, scale: 1 }}\r\n    viewport={{ once: true }}\r\n    transition={{ delay: index * 0.1, duration: 0.4 }}\r\n    whileHover={{ y: -5 }}\r\n    className=\"h-full\"\r\n  >\r\n    <div className={`${rpgCommonStyles.card} p-5 group`}>\r\n      <div className={`absolute inset-0 bg-gradient-to-br ${achievement.color || \"from-primary to-primary/50\"} opacity-0 group-hover:opacity-10 transition-opacity duration-500`} />\r\n      \r\n      <div className=\"relative z-10 flex items-start gap-4\">\r\n        <div className={`w-12 h-12 rounded-xl bg-gradient-to-br ${achievement.color || \"from-gray-700 to-gray-600\"} flex items-center justify-center shrink-0 shadow-lg`}>\r\n          {achievement.icon || <Trophy className=\"h-6 w-6 text-white\" />}\r\n        </div>\r\n        <div className=\"flex-1 space-y-1\">\r\n          <h3 className=\"font-bold text-gray-100 group-hover:text-primary transition-colors\">{achievement.title}</h3>\r\n          <p className=\"text-xs text-muted-foreground leading-snug\">{achievement.description}</p>\r\n        </div>\r\n      </div>\r\n\r\n      <div className=\"mt-4 space-y-2 relative z-10\">\r\n        <div className=\"flex justify-between text-xs font-medium\">\r\n          <span className=\"text-gray-400\">в•ӘШҜв”ҳВ„в•ӘШІв”ҳГ©в•ӘВ»в”ҳГ </span>\r\n          <span className=\"text-primary\">{achievement.progress}%</span>\r\n        </div>\r\n        <div className=\"h-1.5 w-full bg-black/40 rounded-full overflow-hidden\">\r\n          <motion.div \r\n            initial={{ width: 0 }}\r\n            whileInView={{ width: `${achievement.progress}%` }}\r\n            transition={{ duration: 1, delay: 0.2 }}\r\n            className={`h-full rounded-full bg-gradient-to-r ${achievement.color || \"from-primary to-purple-500\"}`}\r\n          />\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </motion.div>\r\n));\r\nAchievementCard.displayName = \"AchievementCard\";\r\n\r\nexport const AchievementsSection = memo(function AchievementsSection({ \r\n  achievements = DEFAULT_ACHIEVEMENTS, \r\n  stats = DEFAULT_STATS, \r\n  loading = false \r\n}: AchievementsSectionProps) {\r\n  \r\n  if (loading) {\r\n     return <div className=\"h-64 animate-pulse bg-white/5 rounded-3xl\" />;\r\n  }\r\n\r\n  return (\r\n    <section className={rpgCommonStyles.glassPanel + \" px-6 py-10\"}>\r\n       <div className=\"absolute inset-0 bg-[url('/grid-pattern.svg')] opacity-5 mix-blend-overlay pointer-events-none\" />\r\n       \r\n       <div className=\"relative z-10\">\r\n         <div className=\"flex flex-col md:flex-row items-center justify-between gap-6 mb-10\">\r\n            <div className=\"text-center md:text-right\">\r\n              <Badge variant=\"outline\" className=\"mb-3 bg-yellow-500/10 text-yellow-400 border-yellow-500/20 hover:bg-yellow-500/20 backdrop-blur-sm\">\r\n                <Sparkles className=\"h-3 w-3 mr-2\" />\r\n                <span>в”ҳВ„в”ҳГӘв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•Әв”Өв•Әв–’в”ҳВҒ</span>\r\n              </Badge>\r\n              <h2 className={`text-3xl font-black ${rpgCommonStyles.goldText}`}>\r\n                в•ӘШӯв”ҳВҶв•ӘШҙв•ӘШҜв•Әв–“в•ӘШҜв•ӘШІв”ҳГў в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•Әв•–в”ҳГӘв•Әв–’в”ҳГЁв•ӘШұ\r\n              </h2>\r\n              <p className=\"text-muted-foreground text-sm mt-1\">в•Әв”Ӯв•ӘШҙв”ҳВ„в”ҳГў в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВҒв”ҳВ„ в•ӘШ°в•ӘШҜв”ҳВ„в•ӘШҜв”ҳВҶв•ӘШІв•Әв•Ўв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ в”ҳГӘв•ӘШҜв”ҳВ„в•ӘШ«в”ҳГӘв•Әв”Ӯв”ҳГ в•ӘШұ</p>\r\n            </div>\r\n\r\n            {/* Quick Stats Row */}\r\n            <div className=\"flex flex-wrap justify-center gap-3\">\r\n              {stats.map((stat) => (\r\n                <div key={stat.id} className={`flex items-center gap-3 px-4 py-2 rounded-xl border backdrop-blur-md ${stat.color || \"bg-white/5 border-white/10\"}`}>\r\n                  <div className=\"shrink-0\">{stat.icon}</div>\r\n                  <div className=\"text-center\">\r\n                    <div className=\"text-lg font-bold text-white leading-none\">{stat.value}</div>\r\n                    <div className=\"text-[10px] text-gray-400 mt-1\">{stat.label}</div>\r\n                  </div>\r\n                </div>\r\n              ))}\r\n            </div>\r\n         </div>\r\n\r\n         <div className=\"grid gap-4 md:gap-6 grid-cols-1 md:grid-cols-2 lg:grid-cols-3 mb-8\">\r\n           {achievements.map((ach, idx) => (\r\n             <AchievementCard key={ach.id} achievement={ach} index={idx} />\r\n           ))}\r\n         </div>\r\n\r\n         <div className=\"text-center\">\r\n            <Link href=\"/achievements\">\r\n              <Button size=\"lg\" variant=\"ghost\" className=\"group text-gray-300 hover:text-white hover:bg-white/10\">\r\n                <span>в•Әв•Јв•Әв–’в•Әв•ў в•Әв”Ӯв•ӘШҙв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГӘв•Әв”Ӯв”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГўв•ӘШҜв”ҳГ в”ҳВ„</span>\r\n                <ArrowRight className=\"mr-2 h-4 w-4 group-hover:translate-x-1 transition-transform rtl:rotate-180 rtl:group-hover:-translate-x-1\" />\r\n              </Button>\r\n            </Link>\r\n         </div>\r\n       </div>\r\n    </section>\r\n  );\r\n});\r\n\r\nexport default AchievementsSection;\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\components\\home\\sections\\AdvancedSearchSection.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Button' is defined but never used. Allowed unused vars must match /^_/u.","line":7,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":7,"endColumn":16,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"Button"},"fix":{"range":[242,292],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing depe