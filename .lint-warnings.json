ame=\"block w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\" />\r\n            \r\n            </div>\r\n\r\n            <div>\r\n              <label className=\"block text-sm font-medium text-gray-700 mb-1\">\r\n                в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•Әв•Ўв•ӘШұ (в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’в”ҳГЁ)\r\n              </label>\r\n              <select\r\n              value={selectedPlatform}\r\n              onChange={(e) => setSelectedPlatform(e.target.value)}\r\n              className=\"block w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\">\r\n              \r\n                <option value=\"\">в•ӘШҜв”ҳВ„в”ҳГўв”ҳВ„</option>\r\n                {platforms.map((platform) =>\r\n              <option key={platform} value={platform}>\r\n                    {platform}\r\n                  </option>\r\n              )}\r\n              </select>\r\n            </div>\r\n          </div>\r\n\r\n          {error &&\r\n        <div className=\"bg-red-50 text-red-700 p-3 rounded-lg\">\r\n              {error}\r\n            </div>\r\n        }\r\n\r\n          <button\r\n          type=\"submit\"\r\n          disabled={isSearching}\r\n          className=\"w-full bg-blue-500 hover:bg-blue-600 text-white font-medium py-2 px-4 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2\">\r\n          \r\n            {isSearching ?\r\n          <>\r\n                <Loader2 className=\"h-5 w-5 animate-spin\" />\r\n                в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШөв•ӘШі...\r\n              </> :\r\n\r\n          <>\r\n                <Search className=\"h-5 w-5\" />\r\n                в•ӘШ°в•ӘШөв•ӘШі в•Әв•Јв”ҳВҶ в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯв”ҳГЁв”ҳВҶ\r\n              </>\r\n          }\r\n          </button>\r\n        </form> :\r\n\r\n      <div className=\"space-y-6\">\r\n          <div className=\"flex items-center justify-between\">\r\n            <h3 className=\"font-medium text-gray-800\">в”ҳВҶв•ӘШІв•ӘШҜв•ӘШ®в•ӘШҙ в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШөв•ӘШі</h3>\r\n            <button\r\n            onClick={() => {\r\n              setTeachers(null);\r\n              setError('');\r\n            }}\r\n            className=\"text-blue-500 hover:text-blue-700 text-sm font-medium\">\r\n            \r\n              в•ӘШ°в•ӘШөв•ӘШі в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»\r\n            </button>\r\n          </div>\r\n\r\n          {teachers.localTeachers.length > 0 &&\r\n        <div>\r\n              <h4 className=\"text-sm font-medium text-gray-700 mb-3\">в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯв”ҳГЁв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв”ҳВҒв”ҳГӘв•Әв••в”ҳГЁв”ҳВҶ ({teachers.localTeachers.length})</h4>\r\n              <div className=\"space-y-3\">\r\n                {teachers.localTeachers.map((teacher) => renderTeacherCard(teacher, 'local'))}\r\n              </div>\r\n            </div>\r\n        }\r\n\r\n          {teachers.aiTeachers.length > 0 &&\r\n        <div>\r\n              <h4 className=\"text-sm font-medium text-gray-700 mb-3\">в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯв”ҳГЁв”ҳВҶ в”ҳГ в”ҳГӘв•Әв•Ўв”ҳГ« в•ӘШ°в”ҳГ§в”ҳГ  ({teachers.aiTeachers.length})</h4>\r\n              <div className=\"space-y-3\">\r\n                {teachers.aiTeachers.map((teacher) => renderTeacherCard(teacher, 'ai'))}\r\n              </div>\r\n            </div>\r\n        }\r\n\r\n          {teachers.youtubeResults.length > 0 &&\r\n        <div>\r\n              <h4 className=\"text-sm font-medium text-gray-700 mb-3\">в”ҳГ©в”ҳВҶв”ҳГӘв•ӘШҜв•ӘШІ в”ҳГЁв”ҳГӘв•ӘШІв”ҳГЁв”ҳГӘв•ӘШ° ({teachers.youtubeResults.length})</h4>\r\n              <div className=\"space-y-3\">\r\n                {teachers.youtubeResults.map((teacher) => renderTeacherCard(teacher, 'youtube'))}\r\n              </div>\r\n            </div>\r\n        }\r\n\r\n          {teachers.localTeachers.length === 0 &&\r\n        teachers.aiTeachers.length === 0 &&\r\n        teachers.youtubeResults.length === 0 &&\r\n        <div className=\"text-center py-8 text-gray-500\">\r\n              в”ҳВ„в”ҳГ  в”ҳГЁв•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•Әв•Јв•ӘШів”ҳГӘв•Әв–’ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШ«в”ҳГЁ в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯв”ҳГЁв”ҳВҶ. в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„в•ӘШұ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ« в•ӘШ°в”ҳГўв”ҳВ„в”ҳГ в•ӘШҜв•ӘШІ в”ҳГ в”ҳВҒв•ӘШІв•ӘШҜв•ӘШөв”ҳГЁв•ӘШұ в”ҳГ в•ӘВ«в•ӘШІв”ҳВ„в”ҳВҒв•ӘШұ.\r\n            </div>\r\n        }\r\n        </div>\r\n      }\r\n    </div>);\r\n\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\ai\\components\\TipsGenerator.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\ai\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\analytics\\components\\DailyProgressChart.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\analytics\\components\\OverviewStats.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\analytics\\components\\PerformanceMetrics.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'performanceMetrics' is defined but never used. Allowed unused args must match /^_/u.","line":32,"column":2,"nodeType":"Identifier","messageId":"unusedVar","endLine":32,"endColumn":20}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"ЩҠв•—в”җ'use client';\r\n\r\nimport { Card, CardContent, CardHeader, CardTitle } from \"@/components/ui/card\";\r\nimport { Progress } from \"@/components/ui/progress\";\r\nimport { Target, TrendingUp, TrendingDown, Activity, Zap, Award } from 'lucide-react';\r\n\r\ntype WeeklyData = { \r\n\tbySubject: Record<string, number>; \r\n\tbyDay: { date: string | Date; minutes: number }[] \r\n};\r\n\r\ntype SummaryData = {\r\n\ttotalMinutes: number;\r\n\taverageFocus: number;\r\n\ttasksCompleted: number;\r\n\tstreakDays: number;\r\n};\r\n\r\ninterface PerformanceMetricsData {\r\n\t[key: string]: unknown;\r\n}\r\n\r\ninterface PerformanceMetricsProps {\r\n\tsummary: SummaryData | null;\r\n\tweekly: WeeklyData | null;\r\n\tperformanceMetrics: PerformanceMetricsData | null;\r\n}\r\n\r\nconst PerformanceMetrics: React.FC<PerformanceMetricsProps> = ({  \r\n\tsummary, \r\n\tweekly, \r\n\tperformanceMetrics \r\n}) => {\r\n\tconst calculateMetrics = () => {\r\n\t\tif (!summary || !weekly) {\r\n\t\t\treturn {\r\n\t\t\t\tproductivityScore: 0,\r\n\t\t\t\tconsistencyScore: 0,\r\n\t\t\t\tengagementScore: 0,\r\n\t\t\t\tgrowthRate: 0\r\n\t\t\t};\r\n\t\t}\r\n\r\n\t\t// Productivity Score (0-100)\r\n\t\tconst totalHours = summary.totalMinutes / 60;\r\n\t\tconst weeklyHours = (weekly?.bySubject ? Object.values(weekly.bySubject) : []).reduce((a, b) => a + (b || 0), 0) / 60;\r\n\t\tconst productivityScore = Math.min(100, Math.round(\r\n\t\t\t(totalHours / 20 * 30) + // 30% weight for total hours\r\n\t\t\t(weeklyHours / 20 * 30) + // 30% weight for weekly hours\r\n\t\t\t(summary.averageFocus / 100 * 40) // 40% weight for focus\r\n\t\t));\r\n\r\n\t\t// Consistency Score (0-100)\r\n\t\tconst dailyMinutes = (weekly?.byDay || []).map(d => d.minutes || 0);\r\n\t\tconst activeDays = dailyMinutes.filter(m => m > 0).length;\r\n\t\tconst consistencyScore = Math.round((activeDays / 7) * 100);\r\n\r\n\t\t// Engagement Score (0-100)\r\n\t\tconst taskCompletionRate = summary.tasksCompleted > 0 \r\n\t\t\t? Math.min(100, (summary.tasksCompleted / (summary.tasksCompleted + 5)) * 100)\r\n\t\t\t: 0;\r\n\t\tconst engagementScore = Math.round(\r\n\t\t\t(taskCompletionRate * 0.5) + \r\n\t\t\t(summary.streakDays / 30 * 50)\r\n\t\t);\r\n\r\n\t\t// Growth Rate\r\n\t\tconst firstHalf = dailyMinutes.slice(0, Math.floor(dailyMinutes.length / 2));\r\n\t\tconst secondHalf = dailyMinutes.slice(Math.floor(dailyMinutes.length / 2));\r\n\t\tconst firstAvg = firstHalf.length > 0 \r\n\t\t\t? firstHalf.reduce((a, b) => a + b, 0) / firstHalf.length \r\n\t\t\t: 0;\r\n\t\tconst secondAvg = secondHalf.length > 0\r\n\t\t\t? secondHalf.reduce((a, b) => a + b, 0) / secondHalf.length\r\n\t\t\t: 0;\r\n\t\tconst growthRate = firstAvg > 0 \r\n\t\t\t? Math.round(((secondAvg - firstAvg) / firstAvg) * 100)\r\n\t\t\t: 0;\r\n\r\n\t\treturn {\r\n\t\t\tproductivityScore,\r\n\t\t\tconsistencyScore,\r\n\t\t\tengagementScore,\r\n\t\t\tgrowthRate\r\n\t\t};\r\n\t};\r\n\r\n\tconst metrics = calculateMetrics();\r\n\r\n\tconst getScoreColor = (score: number) => {\r\n\t\tif (score >= 80) return 'text-green-600 dark:text-green-400';\r\n\t\tif (score >= 60) return 'text-blue-600 dark:text-blue-400';\r\n\t\tif (score >= 40) return 'text-yellow-600 dark:text-yellow-400';\r\n\t\treturn 'text-red-600 dark:text-red-400';\r\n\t};\r\n\r\n\tconst getScoreLabel = (score: number) => {\r\n\t\tif (score >= 80) return 'в”ҳГ в”ҳГ в•ӘШІв•ӘШҜв•Әв–“';\r\n\t\tif (score >= 60) return 'в•ӘШҙв”ҳГЁв•ӘВ»';\r\n\t\tif (score >= 40) return 'в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•–';\r\n\t\treturn 'в”ҳГЁв•ӘШөв•ӘШІв•ӘШҜв•ӘШҙ в•ӘШІв•ӘШөв•Әв”Ӯв”ҳГЁв”ҳВҶ';\r\n\t};\r\n\r\n\tconst performanceCards = [\r\n\t\t{\r\n\t\t\ttitle: \"в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШІв•ӘШҜв•ӘШҙв”ҳГЁв•ӘШұ\",\r\n\t\t\tvalue: metrics.productivityScore,\r\n\t\t\ticon: Zap,\r\n\t\t\tcolor: \"from-blue-500 to-blue-600\",\r\n\t\t\tbgColor: \"bg-blue-50 dark:bg-blue-950/20\",\r\n\t\t\tborderColor: \"border-blue-200 dark:border-blue-800\",\r\n\t\t\tdescription: \"в”ҳГ в”ҳГ©в”ҳГЁв•ӘШҜв•Әв”Ӯ в•ӘШ«в•ӘВ»в•ӘШҜв•ӘШ®в”ҳГў в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШҙв”ҳГ в•ӘШҜв”ҳВ„в”ҳГЁ\"\r\n\t\t},\r\n\t\t{\r\n\t\t\ttitle: \"в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШҜв”ҳВҶв•ӘШІв•Әв••в•ӘШҜв”ҳГ \",\r\n\t\t\tvalue: metrics.consistencyScore,\r\n\t\t\ticon: Target,\r\n\t\t\tcolor: \"from-green-500 to-green-600\",\r\n\t\t\tbgColor: \"bg-green-50 dark:bg-green-950/20\",\r\n\t\t\tborderColor: \"border-green-200 dark:border-green-800\",\r\n\t\t\tdescription: \"в”ҳГ в•Әв•Јв•ӘВ»в”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–‘в•ӘШҜв”ҳГўв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•ӘШІв•Әв••в”ҳГ в•ӘШұ\"\r\n\t\t},\r\n\t\t{\r\n\t\t\ttitle: \"в•ӘВ»в•Әв–’в•ӘШҙв•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Өв•ӘШҜв•Әв–’в”ҳГўв•ӘШұ\",\r\n\t\t\tvalue: metrics.engagementScore,\r\n\t\t\ticon: Activity,\r\n\t\t\tcolor: \"from-purple-500 to-purple-600\",\r\n\t\t\tbgColor: \"bg-purple-50 dark:bg-purple-950/20\",\r\n\t\t\tborderColor: \"border-purple-200 dark:border-purple-800\",\r\n\t\t\tdescription: \"в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГӘв”ҳГ« в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Јв”ҳВ„в”ҳГў в”ҳГ в•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШІв”ҳГӘв”ҳГ«\"\r\n\t\t},\r\n\t\t{\r\n\t\t\ttitle: \"в”ҳГ в•Әв•Јв•ӘВ»в”ҳВ„ в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ в”ҳГӘ\",\r\n\t\t\tvalue: metrics.growthRate,\r\n\t\t\ticon: metrics.growthRate >= 0 ? TrendingUp : TrendingDown,\r\n\t\t\tcolor: metrics.growthRate >= 0 ? \"from-green-500 to-green-600\" : \"from-red-500 to-red-600\",\r\n\t\t\tbgColor: metrics.growthRate >= 0 ? \"bg-green-50 dark:bg-green-950/20\" : \"bg-red-50 dark:bg-red-950/20\",\r\n\t\t\tborderColor: metrics.growthRate >= 0 ? \"border-green-200 dark:border-green-800\" : \"border-red-200 dark:border-red-800\",\r\n\t\t\tdescription: \"в•ӘШҜв”ҳВ„в•ӘШІв•Әв•–в”ҳГӘв•Әв–’ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ»в•ӘШҜв•ӘШ©\",\r\n\t\t\tisPercentage: true\r\n\t\t}\r\n\t];\r\n\r\n\treturn (\r\n\t\t<div className=\"space-y-6\">\r\n\t\t\t{/* Performance Score Cards */}\r\n\t\t\t<div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4\">\r\n\t\t\t\t{performanceCards.map((card, index) => {\r\n\t\t\t\t\tconst Icon = card.icon;\r\n\t\t\t\t\treturn (\r\n\t\t\t\t\t\t<Card \r\n\t\t\t\t\t\t\tkey={index}\r\n\t\t\t\t\t\t\tclassName={`${card.bgColor} ${card.borderColor} border-2 hover:shadow-lg transition-all duration-300`}\r\n\t\t\t\t\t\t>\r\n\t\t\t\t\t\t\t<CardContent className=\"p-6\">\r\n\t\t\t\t\t\t\t\t<div className=\"flex items-start justify-between mb-4\">\r\n\t\t\t\t\t\t\t\t\t<div className=\"flex-1\">\r\n\t\t\t\t\t\t\t\t\t\t<p className=\"text-sm font-medium text-muted-foreground mb-1\">\r\n\t\t\t\t\t\t\t\t\t\t\t{card.title}\r\n\t\t\t\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t\t\t\t\t<p className={`text-3xl font-bold ${getScoreColor(card.value)} mb-1`}>\r\n\t\t\t\t\t\t\t\t\t\t\t{card.value}{card.isPercentage ? '%' : ''}\r\n\t\t\t\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t\t\t\t\t<p className=\"text-xs text-muted-foreground\">\r\n\t\t\t\t\t\t\t\t\t\t\t{card.description}\r\n\t\t\t\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t<div className={`p-3 rounded-lg bg-gradient-to-br ${card.color}`}>\r\n\t\t\t\t\t\t\t\t\t\t<Icon className=\"h-6 w-6 text-white\" />\r\n\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t{!card.isPercentage && (\r\n\t\t\t\t\t\t\t\t\t<>\r\n\t\t\t\t\t\t\t\t\t\t<Progress value={card.value} className=\"h-2 mt-4\" />\r\n\t\t\t\t\t\t\t\t\t\t<p className=\"text-xs text-muted-foreground mt-2 text-center\">\r\n\t\t\t\t\t\t\t\t\t\t\t{getScoreLabel(card.value)}\r\n\t\t\t\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t\t\t\t</>\r\n\t\t\t\t\t\t\t\t)}\r\n\t\t\t\t\t\t\t</CardContent>\r\n\t\t\t\t\t\t</Card>\r\n\t\t\t\t\t);\r\n\t\t\t\t})}\r\n\t\t\t</div>\r\n\r\n\t\t\t{/* Overall Performance Summary */}\r\n\t\t\t<Card className=\"border-2 border-primary/20 shadow-lg\">\r\n\t\t\t\t<CardHeader className=\"bg-gradient-to-r from-primary/5 to-primary/10 dark:from-primary/10 dark:to-primary/20\">\r\n\t\t\t\t\t<CardTitle className=\"flex items-center gap-2\">\r\n\t\t\t\t\t\t<Award className=\"h-5 w-5 text-primary\" />\r\n\t\t\t\t\t\tв”ҳГ в”ҳВ„в•ӘВ«в•Әв•Ў в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ»в•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•Әв”Өв•ӘШҜв”ҳГ в”ҳВ„\r\n\t\t\t\t\t</CardTitle>\r\n\t\t\t\t</CardHeader>\r\n\t\t\t\t<CardContent className=\"p-6\">\r\n\t\t\t\t\t<div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\r\n\t\t\t\t\t\t<div className=\"space-y-2\">\r\n\t\t\t\t\t\t\t<p className=\"text-sm font-medium text-muted-foreground\">в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•– в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ»в•ӘШҜв•ӘШ©</p>\r\n\t\t\t\t\t\t\t<p className={`text-3xl font-bold ${getScoreColor(\r\n\t\t\t\t\t\t\t\t(metrics.productivityScore + metrics.consistencyScore + metrics.engagementScore) / 3\r\n\t\t\t\t\t\t\t)}`}>\r\n\t\t\t\t\t\t\t\t{Math.round((metrics.productivityScore + metrics.consistencyScore + metrics.engagementScore) / 3)}%\r\n\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t\t<Progress \r\n\t\t\t\t\t\t\t\tvalue={(metrics.productivityScore + metrics.consistencyScore + metrics.engagementScore) / 3} \r\n\t\t\t\t\t\t\t\tclassName=\"h-3 mt-2\"\r\n\t\t\t\t\t\t\t/>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div className=\"space-y-2\">\r\n\t\t\t\t\t\t\t<p className=\"text-sm font-medium text-muted-foreground\">в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІв•ӘШҙв•ӘШҜв”ҳГ§</p>\r\n\t\t\t\t\t\t\t<div className=\"flex items-center gap-2\">\r\n\t\t\t\t\t\t\t\t{metrics.growthRate >= 0 ? (\r\n\t\t\t\t\t\t\t\t\t<>\r\n\t\t\t\t\t\t\t\t\t\t<TrendingUp className=\"h-6 w-6 text-green-600 dark:text-green-400\" />\r\n\t\t\t\t\t\t\t\t\t\t<p className=\"text-2xl font-bold text-green-600 dark:text-green-400\">\r\n\t\t\t\t\t\t\t\t\t\t\tв•ӘШІв•ӘШөв•Әв”Ӯв”ҳВҶ\r\n\t\t\t\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t\t\t\t</>\r\n\t\t\t\t\t\t\t\t) : (\r\n\t\t\t\t\t\t\t\t\t<>\r\n\t\t\t\t\t\t\t\t\t\t<TrendingDown className=\"h-6 w-6 text-red-600 dark:text-red-400\" />\r\n\t\t\t\t\t\t\t\t\t\t<p className=\"text-2xl font-bold text-red-600 dark:text-red-400\">\r\n\t\t\t\t\t\t\t\t\t\t\tв•ӘШІв•Әв–’в•ӘШҜв•ӘШҙв•Әв•Ј\r\n\t\t\t\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t\t\t\t</>\r\n\t\t\t\t\t\t\t\t)}\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t<p className=\"text-xs text-muted-foreground\">\r\n\t\t\t\t\t\t\t\t{metrics.growthRate >= 0 ? 'в•ӘШ«в•ӘВ»в•ӘШҜв•ӘШ¬в”ҳГў в”ҳВҒв”ҳГЁ в•ӘШІв•ӘШөв•Әв”Ӯв”ҳВҶ в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГ в•Әв–’' : 'в”ҳГЁв•ӘШөв•ӘШІв•ӘШҜв•ӘШҙ в•ӘШӯв”ҳВ„в”ҳГ« в•ӘШІв•ӘШөв•Әв”Ӯв”ҳГЁв”ҳВҶ'}\r\n\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div className=\"space-y-2\">\r\n\t\t\t\t\t\t\t<p className=\"text-sm font-medium text-muted-foreground\">в•ӘШҜв”ҳВ„в•ӘШІв”ҳГӘв•Әв•Ўв”ҳГЁв•ӘШұ</p>\r\n\t\t\t\t\t\t\t<p className=\"text-lg font-semibold\">\r\n\t\t\t\t\t\t\t\t{metrics.productivityScore >= 80 \r\n\t\t\t\t\t\t\t\t\t? 'в•ӘШҜв•Әв”Ӯв•ӘШІв”ҳГ в•Әв–’ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ»в•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ в•ӘШІв•ӘШҜв•Әв–“'\r\n\t\t\t\t\t\t\t\t\t: metrics.productivityScore >= 60\r\n\t\t\t\t\t\t\t\t\t? 'в•ӘШ«в”ҳВҶв•ӘШІ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•Әв•–в•Әв–’в”ҳГЁв”ҳГ© в•ӘШҜв”ҳВ„в•Әв•Ўв•ӘШөв”ҳГЁв•ӘШө'\r\n\t\t\t\t\t\t\t\t\t: 'в•Әв–’в”ҳГўв•Әв–“ в•Әв•Јв”ҳВ„в”ҳГ« в•Әв–“в”ҳГЁв•ӘШҜв•ӘВ»в•ӘШұ в”ҳГӘв”ҳГ©в•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–‘в•ӘШҜв”ҳГўв•Әв–’в•ӘШұ'\r\n\t\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t\t<p className=\"text-xs text-muted-foreground\">\r\n\t\t\t\t\t\t\t\tв•ӘШ°в”ҳВҶв•ӘШҜв•ӘШ©в”ҳГҜ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШІв•ӘШөв”ҳВ„в”ҳГЁв”ҳВ„ в•ӘШ«в•ӘВ»в•ӘШҜв•ӘШ®в”ҳГў\r\n\t\t\t\t\t\t\t</p>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</CardContent>\r\n\t\t\t</Card>\r\n\t\t</div>\r\n\t);\r\n};\r\n\r\nexport default PerformanceMetrics;\r\n\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\analytics\\components\\PredictionsSection.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\analytics\\components\\StatusMessage.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(dashboard)\\analytics\\components\\StudyPatterns.tsx","messages":[{"ruleId":"no-irregular-whitespace","severity":2,"message":"Irregular whitespace not allowed.","line":226,"column":14,"nodeType":"Program","messageId":"noIrregularWhitespace","endLine":226,"endColumn":15}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"ЩҠв•—в”җ'use client';\r\n\r\nimport { useMemo } from 'react';\r\nimport { Card, CardContent, CardHeader, CardTitle } from \"@/components/ui/card\";\r\nimport { Progress } from \"@/components/ui/progress\";\r\nimport { Brain, Clock, Calendar, Target, TrendingUp, Activity } from 'lucide-react';\r\nimport { format } from 'date-fns';\r\nimport { ar } from 'date-fns/locale';\r\n\r\ntype WeeklyData = { \r\n\tbySubject: Record<string, number>; \r\n\tbyDay: { date: string | Date; minutes: number }[] \r\n};\r\n\r\ninterface StudyPatternsProps {\r\n\tweekly: WeeklyData | null;\r\n}\r\n\r\nexport default function StudyPatterns({ weekly }: StudyPatternsProps) {\r\n\tconst patterns = useMemo(() => {\r\n\t\tif (!weekly || !weekly.byDay) return null;\r\n\r\n\t\tconst days = weekly.byDay.map(d => ({\r\n\t\t\tdate: new Date(d.date),\r\n\t\t\tminutes: d.minutes,\r\n\t\t\thours: d.minutes / 60\r\n\t\t}));\r\n\r\n\t\t// Calculate consistency\r\n\t\tconst activeDays = days.filter(d => d.minutes > 0).length;\r\n\t\tconst consistencyRate = days.length > 0 ? (activeDays / days.length) * 100 : 0;\r\n\r\n\t\t// Calculate average session length (assuming multiple sessions per day)\r\n\t\tconst totalMinutes = days.reduce((sum, d) => sum + d.minutes, 0);\r\n\t\tconst averageDailyMinutes = days.length > 0 ? totalMinutes / days.length : 0;\r\n\r\n\t\t// Find study streak\r\n\t\tlet currentStreak = 0;\r\n\t\tlet maxStreak = 0;\r\n\t\tdays.forEach(day => {\r\n\t\t\tif (day.minutes > 0) {\r\n\t\t\t\tcurrentStreak++;\r\n\t\t\t\tmaxStreak = Math.max(maxStreak, currentStreak);\r\n\t\t\t} else {\r\n\t\t\t\tcurrentStreak = 0;\r\n\t\t\t}\r\n\t\t});\r\n\r\n\t\t// Calculate variability\r\n\t\tconst minutes = days.map(d => d.minutes);\r\n\t\tconst mean = minutes.length > 0 ? minutes.reduce((a, b) => a + b, 0) / minutes.length : 0;\r\n\t\tconst variance = minutes.length > 0 \r\n\t\t\t? minutes.reduce((sum, m) => sum + Math.pow(m - mean, 2), 0) / minutes.length\r\n\t\t\t: 0;\r\n\t\tconst stdDev = Math.sqrt(variance);\r\n\t\tconst variability = mean > 0 ? (stdDev / mean) * 100 : 0;\r\n\r\n\t\t// Best time pattern (day of week)\r\n\t\tconst dayOfWeekStats: Record<number, number> = {};\r\n\t\tdays.forEach(day => {\r\n\t\t\tconst dayOfWeek = day.date.getDay();\r\n\t\t\tdayOfWeekStats[dayOfWeek] = (dayOfWeekStats[dayOfWeek] || 0) + day.minutes;\r\n\t\t});\r\n\t\tconst bestDayOfWeek = Object.entries(dayOfWeekStats || {})\r\n\t\t\t.sort(([, a], [, b]) => (b || 0) - (a || 0))[0]?.[0];\r\n\t\tconst bestDayName = bestDayOfWeek !== undefined \r\n\t\t\t? format(new Date(2024, 0, parseInt(bestDayOfWeek) + 1), 'EEEE', { locale: ar })\r\n\t\t\t: 'в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШөв•ӘВ»в•ӘВ»';\r\n\r\n\t\treturn {\r\n\t\t\tconsistencyRate,\r\n\t\t\taverageDailyMinutes,\r\n\t\t\tmaxStreak,\r\n\t\t\tvariability,\r\n\t\t\tbestDayOfWeek: bestDayName,\r\n\t\t\ttotalMinutes,\r\n\t\t\tactiveDays\r\n\t\t};\r\n\t}, [weekly]);\r\n\r\n\tif (!patterns) {\r\n\t\treturn (\r\n\t\t\t<Card>\r\n\t\t\t\t<CardContent className=\"p-6\">\r\n\t\t\t\t\t<div className=\"text-center py-8 text-muted-foreground\">\r\n\t\t\t\t\t\t<Brain className=\"h-12 w-12 mx-auto mb-4 opacity-50\" />\r\n\t\t\t\t\t\t<p>в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в”ҳВ„в•ӘШІв•ӘШөв”ҳВ„в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ«в”ҳВҶв”ҳГ в•ӘШҜв•Әв•–</p>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</CardContent>\r\n\t\t\t</Card>\r\n\t\t);\r\n\t}\r\n\r\n\tconst patternCards = [\r\n\t\t{\r\n\t\t\ttitle: \"в”ҳГ в•Әв•Јв•ӘВ»в”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШҜв”ҳВҶв•ӘШІв•Әв••в•ӘШҜв”ҳГ \",\r\n\t\t\tvalue: patterns.consistencyRate,\r\n\t\t\ticon: Target,\r\n\t\t\tcolor: \"from-blue-500 to-blue-600\",\r\n\t\t\tbgColor: \"bg-blue-50 dark:bg-blue-950/20\",\r\n\t\t\tborderColor: \"border-blue-200 dark:border-blue-800\",\r\n\t\t\tunit: \"%\",\r\n\t\t\tdescription: `${patterns.activeDays} в”ҳГ в”ҳВҶ ${weekly?.byDay.length || 7} в•ӘШ«в”ҳГЁв•ӘШҜв”ҳГ  в”ҳВҶв•Әв”Өв•Әв•–в•ӘШұ`\r\n\t\t},\r\n\t\t{\r\n\t\t\ttitle: \"в•ӘШ«в•Әв•–в”ҳГӘв”ҳВ„ в•Әв”Ӯв”ҳВ„в•Әв”Ӯв”ҳВ„в•ӘШұ\",\r\n\t\t\tvalue: patterns.maxStreak,\r\n\t\t\ticon: TrendingUp,\r\n\t\t\tcolor: \"from-green-500 to-green-600\",\r\n\t\t\tbgColor: \"bg-green-50 dark:bg-green-950/20\",\r\n\t\t\tborderColor: \"border-green-200 dark:border-green-800\",\r\n\t\t\tunit: \" в”ҳГЁв”ҳГӘв”ҳГ \",\r\n\t\t\tdescription: \"в•ӘШ«в”ҳГЁв•ӘШҜв”ҳГ  в”ҳГ в•ӘШІв•ӘШІв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШұ в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–‘в•ӘШҜв”ҳГўв•Әв–’в•ӘШұ\"\r\n\t\t},\r\n\t\t{\r\n\t\t\ttitle: \"в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•– в”ҳГЁв”ҳГӘв”ҳГ в”ҳГЁ\",\r\n\t\t\tvalue: (patterns.averageDailyMinutes / 60).toFixed(1),\r\n\t\t\ticon: Clock,\r\n\t\t\tcolor: \"from-purple-500 to-purple-600\",\r\n\t\t\tbgColor: \"bg-purple-50 dark:bg-purple-950/20\",\r\n\t\t\tborderColor: \"border-purple-200 dark:border-purple-800\",\r\n\t\t\tunit: \" в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘШұ\",\r\n\t\t\tdescription: \"в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•– в”ҳГӘв”ҳГ©в•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–‘в•ӘШҜв”ҳГўв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГЁв”ҳГӘв”ҳГ в”ҳГЁ\"\r\n\t\t},\r\n\t\t{\r\n\t\t\ttitle: \"в”ҳГ в•Әв•Јв•ӘВ»в”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШ°в•ӘШҜв”ҳГЁв”ҳВҶ\",\r\n\t\t\tvalue: patterns.variability.toFixed(1),\r\n\t\t\ticon: Activity,\r\n\t\t\tcolor: patterns.variability < 30 ? \"from-green-500 to-green-600\" : \"from-orange-500 to-orange-600\",\r\n\t\t\tbgColor: patterns.variability < 30 ? \"bg-green-50 dark:bg-green-950/20\" : \"bg-orange-50 dark:bg-orange-950/20\",\r\n\t\t\tborderColor: patterns.variability < 30 ? \"border-green-200 dark:border-green-800\" : \"border-orange-200 dark:border-orange-800\",\r\n\t\t\tunit: \"%\",\r\n\t\t\tdescription: patterns.variability < 30 ? \"в•ӘШ«в”ҳВҶв”ҳГ в•ӘШҜв•Әв•– в”ҳГ в”ҳВҶв•ӘШІв