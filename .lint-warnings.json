п»ҝ[{"filePath":"D:\\thanawy\\src\\app\\(admin)\\admin\\ab-testing\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(admin)\\admin\\achievements\\AchievementFormDialog.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(admin)\\admin\\achievements\\AchievementTable.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(admin)\\admin\\achievements\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(admin)\\admin\\achievements\\types.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(admin)\\admin\\ai\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(admin)\\admin\\analytics\\charts.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\thanawy\\src\\app\\(admin)\\admin\\analytics\\page.tsx","messages":[{"ruleId":"no-irregular-whitespace","severity":2,"message":"Irregular whitespace not allowed.","line":345,"column":53,"nodeType":"Program","messageId":"noIrregularWhitespace","endLine":345,"endColumn":54}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"ЩҠв•—в”җ\"use client\";\r\n\r\nimport * as React from \"react\";\r\nimport { PageHeader } from \"@/components/admin/ui/page-header\";\r\nimport { AdminStatsCard, AdminCard, AdminGridCard } from \"@/components/admin/ui/admin-card\";\r\nimport { AdminButton } from \"@/components/admin/ui/admin-button\";\r\nimport {\r\n  Select,\r\n  SelectContent,\r\n  SelectItem,\r\n  SelectTrigger,\r\n  SelectValue,\r\n} from \"@/components/ui/select\";\r\nimport { Tabs, TabsContent, TabsList, TabsTrigger } from \"@/components/ui/tabs\";\r\nimport {\r\n  Users, BookOpen, FileText, Trophy, Target, Activity, Zap, RefreshCw, Download, Move, Settings, Search, ArrowRight, MousePointerClick, TrendingUp, DollarSign, Wallet, Percent, PieChart\r\n} from \"lucide-react\";\r\nimport dynamic from \"next/dynamic\";\r\nimport { AnalyticsSkeleton } from \"@/components/admin/ui/loading-skeleton\";\r\nimport { useQuery } from \"@tanstack/react-query\";\r\nimport { AiCommandCenter } from \"@/components/admin/dashboard/ai-command-center\";\r\nimport { Reorder } from \"framer-motion\";\r\nimport { toast } from \"sonner\";\r\n\r\nconst DailyActiveUsersChart = dynamic(() => import('./charts').then(mod => mod.DailyActiveUsersChart), { ssr: false, loading: () => <div className=\"h-[300px] w-full animate-pulse bg-muted/50 rounded-xl\" /> });\r\nconst DailyRegistrationsChart = dynamic(() => import('./charts').then(mod => mod.DailyRegistrationsChart), { ssr: false, loading: () => <div className=\"h-[300px] w-full animate-pulse bg-muted/50 rounded-xl\" /> });\r\nconst RoleDistributionChart = dynamic(() => import('./charts').then(mod => mod.RoleDistributionChart), { ssr: false, loading: () => <div className=\"h-[200px] w-full animate-pulse bg-muted/50 rounded-xl\" /> });\r\n\r\nexport default function AdminAnalyticsPage() {\r\n  const [period, setPeriod] = React.useState(\"month\");\r\n  const [isEditMode, setIsEditMode] = React.useState(false);\r\n  const [widgetOrder, setWidgetOrder] = React.useState([\"users\", \"activity\", \"finance\", \"content\"]);\r\n\r\n  const { data, isLoading: loading, error: _queryError, refetch } = useQuery({\r\n    queryKey: ['admin', 'analytics', period],\r\n    queryFn: async () => {\r\n      const response = await fetch(`/api/admin/analytics?period=${period}`);\r\n      if (!response.ok) throw new Error(\"Failed to fetch analytics data\");\r\n      return response.json();\r\n    },\r\n    refetchInterval: 5 * 60 * 1000,\r\n  });\r\n\r\n  const saveLayout = () => {\r\n    setIsEditMode(false);\r\n    toast.success(\"в•ӘШІв”ҳГ  в•ӘШөв”ҳВҒв•Әв•• в•ӘШІв•ӘВ«в•Әв•–в”ҳГЁв•Әв•– в”ҳВ„в”ҳГӘв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГўв”ҳГ  в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШҜв•Әв•Ў в•ӘШ°в”ҳГў в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө!\");\r\n  };\r\n\r\n  const roleLabels: Record<string, string> = {\r\n    ADMIN: \"в”ҳГ в•ӘВ»в”ҳГЁв•Әв–’\", TEACHER: \"в”ҳГ в•Әв•Јв”ҳВ„в”ҳГ \", STUDENT: \"в•Әв•–в•ӘШҜв”ҳВ„в•ӘШ°\", MODERATOR: \"в”ҳГ в•Әв”Өв•Әв–’в”ҳВҒ\"\r\n  };\r\n\r\n  if (loading && !data) return <AnalyticsSkeleton />;\r\n\r\n  const roleChartData = Object.entries(data?.users?.byRole ?? {}).map(([role, count]) => ({\r\n    name: roleLabels[role] || role,\r\n    value: typeof count === \"number\" ? count : Number(count ?? 0),\r\n  }));\r\n\r\n  return (\r\n    <div className=\"space-y-6 pb-20\">\r\n      <PageHeader\r\n        title=\"в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳВ„в”ҳГЁв”ҳВ„в•ӘШҜв•ӘШІ в”ҳГӘв•Әв–‘в”ҳГўв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШ«в•Әв•Јв”ҳГ в•ӘШҜв”ҳВ„ (BI)\"\r\n        description=\"в”ҳВ„в”ҳГӘв•ӘШөв•ӘШҜв•ӘШІ в”ҳГ в•Әв•Јв”ҳВ„в”ҳГӘв”ҳГ в•ӘШҜв•ӘШІ в”ҳГ в•ӘВ«в•Әв•Ўв•Әв•Ўв•ӘШұв•ӘГ® в•ӘШІв”ҳГ©в•ӘШҜв•Әв–’в”ҳГЁв•Әв–’ в”ҳГ в•ӘШҜв”ҳВ„в”ҳГЁв•ӘШұв•ӘГ® в”ҳГӘв•ӘШІв•ӘШІв•ӘШ°в•Әв•Ј в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ в”ҳГЁв”ҳВҶ в”ҳВ„в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в”ҳВ„в•ӘШҜв•Әв•Ў в•ӘШҜв”ҳВ„в”ҳГ©в•Әв–’в•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ.\"\r\n      >\r\n        <div className=\"flex items-center gap-2\">\r\n          <Select value={period} onValueChange={setPeriod}>\r\n            <SelectTrigger className=\"w-40 rounded-xl\">\r\n              <SelectValue placeholder=\"в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в”ҳВҒв•ӘШІв•Әв–’в•ӘШұ\" />\r\n            </SelectTrigger>\r\n            <SelectContent className=\"rounded-xl\">\r\n              <SelectItem value=\"week\">в•ӘШӘв•ӘВ«в•Әв–’ в•ӘШ«в•Әв”Ӯв•ӘШ°в”ҳГӘв•Әв•Ј</SelectItem>\r\n              <SelectItem value=\"month\">в•ӘШӘв•ӘВ«в•Әв–’ в•Әв”Өв”ҳГ§в•Әв–’</SelectItem>\r\n              <SelectItem value=\"year\">в•ӘШӘв•ӘВ«в•Әв–’ в•Әв”Ӯв”ҳВҶв•ӘШұ</SelectItem>\r\n            </SelectContent>\r\n          </Select>\r\n          <AdminButton variant=\"outline\" size=\"sm\" icon={Download} className=\"hidden md:flex\">\r\n            в•ӘШІв•Әв•Ўв•ӘВ»в”ҳГЁв•Әв–’\r\n          </AdminButton>\r\n          <AdminButton variant=\"outline\" size=\"sm\" icon={RefreshCw} onClick={() => refetch()}>\r\n            в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі\r\n          </AdminButton>\r\n        </div>\r\n      </PageHeader>\r\n\r\n      <Tabs defaultValue=\"dashboard\" className=\"w-full\">\r\n        <TabsList className=\"w-full bg-background/50 h-14 p-1 border-border rounded-xl mb-6\">\r\n          <TabsTrigger value=\"dashboard\" className=\"w-full h-full text-base font-bold rounded-lg data-[state=active]:bg-primary/10 data-[state=active]:text-primary\">\r\n             в”ҳВ„в”ҳГӘв•ӘШөв•ӘШІв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ«в•Әв•Ўв•Әв•Ўв•ӘШұ (Custom Widgets)\r\n          </TabsTrigger>\r\n          <TabsTrigger value=\"finance\" className=\"w-full h-full text-base font-bold rounded-lg data-[state=active]:bg-emerald-500/10 data-[state=active]:text-emerald-500\">\r\n             в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв”ҳВ„в”ҳГЁв•ӘШҜв•ӘШІ в”ҳГӘ Unit Economics\r\n          </TabsTrigger>\r\n          <TabsTrigger value=\"journey\" className=\"w-full h-full text-base font-bold rounded-lg data-[state=active]:bg-purple-500/10 data-[state=active]:text-purple-500\">\r\n             в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ в”ҳГЁв”ҳВҶ (User Journey)\r\n          </TabsTrigger>\r\n        </TabsList>\r\n\r\n        {/* ====================================\r\n            TAB 1: DRAG & DROP DASHBOARDS\r\n            ==================================== */}\r\n        <TabsContent value=\"dashboard\" className=\"space-y-6\">\r\n           <div className=\"flex justify-between items-center bg-accent/20 p-4 rounded-2xl border border-border\">\r\n              <div className=\"flex items-center gap-3\">\r\n                 <div className=\"p-2 bg-primary/20 text-primary rounded-lg\"><Settings className=\"w-5 h-5\"/></div>\r\n                 <div>\r\n                    <h3 className=\"font-bold text-lg\">в”ҳГӘв•Әв•ўв•Әв•Ј в•ӘШІв•ӘВ«в•Әв•Ўв”ҳГЁв•Әв•Ў в•ӘШҜв”ҳВ„в”ҳВ„в”ҳГӘв•ӘШөв•ӘШұ (Widget Builder)</h3>\r\n                    <p className=\"text-xs text-muted-foreground\">в”ҳГ©в”ҳГ  в•ӘШ°в•ӘШІв•Әв–’в•ӘШІв”ҳГЁв•ӘШ° в”ҳГӘв•ӘШӯв•ӘВ«в”ҳВҒв•ӘШҜв•ӘШ©/в•ӘШӯв”ҳШІв•ӘШҜв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШІв”ҳГЁ в•ӘШІв”ҳГ§в”ҳГ в”ҳГў в”ҳВҒв”ҳГ©в•Әв•–.</p>\r\n                 </div>\r\n              </div>\r\n              <div>\r\n                 {!isEditMode ? (\r\n                   <AdminButton onClick={() => setIsEditMode(true)} variant=\"outline\" icon={Move}>в•ӘШІв•Әв•Јв•ӘВ»в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШІв•ӘВ«в•Әв•–в”ҳГЁв•Әв•–</AdminButton>\r\n                 ) : (\r\n                   <AdminButton onClick={saveLayout} variant=\"default\" className=\"bg-primary text-white\">в•ӘШөв”ҳВҒв•Әв•• в•ӘШҜв”ҳВ„в•ӘШІв•ӘВ«в•Әв•–в”ҳГЁв•Әв•–</AdminButton>\r\n                 )}\r\n              </div>\r\n           </div>\r\n\r\n           <AiCommandCenter />\r\n\r\n           <Reorder.Group axis=\"y\" values={widgetOrder} onReorder={setWidgetOrder} className=\"space-y-6\">\r\n              {widgetOrder.map((widgetBlock) => (\r\n                 <Reorder.Item \r\n                    key={widgetBlock} \r\n                    value={widgetBlock} \r\n                    drag={isEditMode ? \"y\" : false}\r\n                    className={`relative ${isEditMode ? \"cursor-grab active:cursor-grabbing border-2 border-dashed border-primary/50 rounded-3xl p-2 bg-primary/5\" : \"\"}`}\r\n                 >\r\n                    {isEditMode && (\r\n                      <div className=\"absolute top-4 right-4 z-10 p-2 bg-background border border-border rounded-lg shadow-xl text-primary flex items-center gap-2 font-black\">\r\n                         <Move className=\"w-4 h-4\" /> в•ӘШҜв•Әв”Ӯв•ӘШөв•ӘШ° в”ҳВ„в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШІв•Әв–’в•ӘШІв”ҳГЁв•ӘШ°\r\n                      </div>\r\n                    )}\r\n\r\n                    {widgetBlock === \"users\" && (\r\n                       <div className=\"grid gap-4 md:grid-cols-2 lg:grid-cols-4\">\r\n                         <AdminStatsCard title=\"в•ӘШӯв•ӘШҙв”ҳГ в•ӘШҜв”ҳВ„в”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ в”ҳГЁв”ҳВҶ\" value={(data?.users?.total ?? 0).toLocaleString()} description={`${data?.users?.new ?? 0} в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»`} icon={Users} color=\"blue\" />\r\n                         <AdminStatsCard title=\"в•ӘШҜв”ҳВ„в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Өв•Әв•–в•ӘШұ\" value={(data?.users?.active ?? 0).toLocaleString()} description=\"в”ҳГ§в•Әв–‘в•ӘШҜ в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•ӘШ°в”ҳГӘв•Әв•Ј\" icon={Activity} color=\"green\" />\r\n                         <AdminStatsCard title=\"в”ҳГ в•Әв•Јв•ӘВ»в”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШөв•ӘШІв”ҳВҒв•ӘШҜв•Әв••\" value=\"84%\" description=\"в•Әв–“в”ҳГЁв•ӘШҜв•ӘВ»в•ӘШұ 2% в•Әв•Јв”ҳВҶ в•ӘШҜв”ҳВ„в•Әв”Өв”ҳГ§в•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•Әв•ўв”ҳГЁ\" icon={Target} color=\"purple\" trend={{ value: 2, isPositive: true }} />\r\n                         <AdminStatsCard title=\"в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Јв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГЁв”ҳГӘв”ҳГ в”ҳГЁ\" value=\"12,500\" description=\"в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШұ в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв”ҳГЁв•ӘШұ\" icon={Zap} color=\"yellow\" />\r\n                       </div>\r\n                    )}\r\n\r\n                    {widgetBlock === \"activity\" && (\r\n                       <div className=\"grid gap-4 lg:grid-cols-2 mt-4\">\r\n                         <AdminGridCard title=\"в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ в”ҳГЁв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Өв•Әв•–в”ҳГЁв”ҳВҶ в”ҳГЁв”ҳГӘв”ҳГ в”ҳГЁв•ӘШҜв”ҳГҜ\" subtitle=\"в•Әв•Јв•ӘВ»в•ӘВ» в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ в”ҳГЁв”ҳВҶ в•ӘШҜв”ҳВ„в•Әв–‘в”ҳГЁв”ҳВҶ в•Әв”Ӯв•ӘШҙв”ҳВ„в”ҳГӘв•ӘШҜ в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„\" noPadding>\r\n                           <DailyActiveUsersChart data={data?.charts?.dailyActiveUsers ?? []} />\r\n                         </AdminGridCard>\r\n                         <AdminGridCard title=\"в•ӘШҜв”ҳВ„в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ\" subtitle=\"в”ҳГ в•Әв•Јв•ӘВ»в”ҳВ„ в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ в”ҳГӘ в•ӘШҜв”ҳВ„в”ҳГЁв”ҳГӘв”ҳГ в”ҳГЁ\" noPadding>\r\n                           <DailyRegistrationsChart data={data?.charts?.dailyRegistrations ?? []} />\r\n                         </AdminGridCard>\r\n                       </div>\r\n                    )}\r\n\r\n                    {widgetBlock === \"content\" && (\r\n                       <div className=\"grid gap-4 lg:grid-cols-3 mt-4\">\r\n                         <AdminGridCard title=\"в•ӘШҜв”ҳВ„в•ӘШІв”ҳГӘв•Әв–“в”ҳГЁв•Әв•Ј в•ӘШҜв”ҳВ„в•Әв•–в”ҳВ„в•ӘШҜв•ӘШ°в”ҳГЁ\" noPadding>\r\n                           <div className=\"p-4\"><RoleDistributionChart data={roleChartData} /></div>\r\n                         </AdminGridCard>\r\n                         <AdminGridCard title=\"в•ӘШӯв•ӘШөв•Әв•Ўв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШІв”ҳГӘв”ҳГ«\">\r\n                           <div className=\"space-y-4\">\r\n                             {[\r\n                               { label: \"в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘШҜв•ӘВ» в•ӘШҜв”ҳВ„в•ӘВ»в•Әв–’в•ӘШҜв•Әв”Ӯв”ҳГЁв•ӘШұ\", value: data?.content?.subjects ?? 0, icon: BookOpen },\r\n                               { label: \"в•ӘШҜв”ҳВ„в•ӘШҜв”ҳГ в•ӘШІв•ӘШөв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ\", value: data?.content?.exams ?? 0, icon: Target },\r\n                               { label: \"в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ©в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІ\", value: data?.content?.blogPosts ?? 0, icon: FileText },\r\n                             ].map((item) => (\r\n                               <div key={item.label} className=\"flex items-center justify-between\">\r\n                                 <div className=\"flex items-center gap-2\"><item.icon className=\"h-4 w-4 text-muted-foreground\" /><span className=\"text-sm\">{item.label}</span></div>\r\n                                 <span className=\"font-medium\">{item.value}</span>\r\n                               </div>\r\n                             ))}\r\n                           </div>\r\n                         </AdminGridCard>\r\n                         <AdminGridCard title=\"в•ӘШӯв•ӘШөв•Әв•Ўв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШ°в•Әв•–в”ҳГӘв”ҳВ„в•ӘШҜв•ӘШІ\">\r\n                           <div className=\"space-y-4\">\r\n                             <div className=\"flex items-center justify-between\"><div className=\"flex items-center gap-2\"><Trophy className=\"h-4 w-4 text-yellow-500\" /><span className=\"text-sm\">в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГӘв•Әв”Ӯв”ҳГ в•ӘШұ</span></div><span className=\"font-medium\">{data?.gamification?.achievementsEarned ?? 0}</span></div>\r\n                             <div className=\"flex items-center justify-between\"><div className=\"flex items-center gap-2\"><Target className=\"h-4 w-4 text-green-500\" /><span className=\"text-sm\">в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШҜв•ӘШІ</span></div><span className=\"font-medium\">{data?.gamification?.challengesCompleted ?? 0}</span></div>\r\n                             <div className=\"flex items-center justify-between\"><div className=\"flex items-center gap-2\"><Zap className=\"h-4 w-4 text-blue-500\" /><span className=\"text-sm\">XP в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•Әв–“в•Әв•Ј</span></div><span className=\"font-medium\">{(data?.gamification?.totalXP ?? 0).toLocaleString()}</span></div>\r\n                           </div>\r\n                         </AdminGridCard>\r\n                       </div>\r\n                    )}\r\n                 </Reorder.Item>\r\n              ))}\r\n           </Reorder.Group>\r\n        </TabsContent>\r\n\r\n        {/* ====================================\r\n            TAB 2: REGIONAL ECONOMICS (FINANCE)\r\n            ==================================== */}\r\n        <TabsContent value=\"finance\" className=\"space-y-6\">\r\n           <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\r\n             <AdminCard variant=\"glass\" className=\"border-emerald-500/20 shadow-lg shadow-emerald-500/5 relative overflow-hidden\">\r\n                <div className=\"absolute -right-4 -top-4 w-24 h-24 bg-emerald-500/10 rounded-full blur-2xl\"></div>\r\n                <div className=\"flex gap-4\">\r\n                   <div className=\"w-12 h-12 bg-emerald-500/10 text-emerald-500 rounded-2xl flex items-center justify-center shrink-0\"><DollarSign className=\"w-6 h-6\"/></div>\r\n                   <div>\r\n                      <p className=\"text-sm font-bold text-muted-foreground\">в•ӘШҜв”ҳВ„в”ҳГ©в”ҳГЁв”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ в”ҳВ„в”ҳВ„в•Әв•–в•ӘШҜв”ҳВ„в•ӘШ° (LTV)</p>\r\n                      <h3 className=\"text-3xl font-black mt-1 flex items-baseline gap-1\">450 <span className=\"text-sm font-bold text-muted-foreground\">в•ӘШҙ.в”ҳГ </span></h3>\r\n                      <p className=\"text-xs text-emerald-500 font-bold mt-2 flex items-center gap-1\"><TrendingUp className=\"w-3 h-3\"/> +12% в•Әв•Јв”ҳВҶ в•ӘШҜв”ҳВ„в•Әв”Өв”ҳГ§в•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•Әв•ўв”ҳГЁ</p>\r\n                   </div>\r\n                </div>\r\n             </AdminCard>\r\n             <AdminCard variant=\"glass\" className=\"border-red-500/20 shadow-lg shadow-red-500/5 relative overflow-hidden\">\r\n                <div className=\"absolute -right-4 -top-4 w-24 h-24 bg-red-500/10 rounded-full blur-2xl\"></div>\r\n                <div className=\"flex gap-4\">\r\n                   <div className=\"w-12 h-12 bg-red-500/10 text-red-500 rounded-2xl flex items-center justify-center shrink-0\"><Users className=\"w-6 h-6\"/></div>\r\n                   <div>\r\n                      <p className=\"text-sm font-bold text-muted-foreground\">в•ӘШІв”ҳГўв”ҳВ„в”ҳВҒв•ӘШұ в•ӘШҜв”ҳГўв•ӘШІв•Әв”Ӯв•ӘШҜв•ӘШ° в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГ в”ҳГЁв”ҳВ„ (CAC)</p>\r\n                      <h3 className=\"text-3xl font-black mt-1 flex items-baseline gap-1\">65 <span className=\"text-sm font-bold text-muted-foreground\">в•ӘШҙ.в”ҳГ </span></h3>\r\n                      <p className=\"text-xs text-red-500 font-bold mt-2 flex items-center gap-1\"><TrendingUp className=\"w-3 h-3\"/> в•ӘШҜв•Әв–’в•ӘШІв”ҳВҒв•Әв•Јв•ӘШІ в•ӘШ°в•Әв”Ӯв•ӘШ°в•ӘШ° в•ӘШөв”ҳГ в”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в”ҳВҒв”ҳГЁв•Әв”Ӯв•ӘШ°в”ҳГӘв”ҳГў</p>\r\n                   </div>\r\n                </div>\r\n             </AdminCard>\r\n             <AdminCard variant=\"glass\" className=\"border-blue-500/20 shadow-lg shadow-blue-500/5 relative overflow-hidden\">\r\n                <div className=\"absolute -right-4 -top-4 w-24 h-24 bg-blue-500/10 rounded-full blur-2xl\"></div>\r\n                <div className=\"flex gap-4\">\r\n                   <div className=\"w-12 h-12 bg-blue-500/10 text-blue-500 rounded-2xl flex items-center justify-center shrink-0\"><Percent className=\"w-6 h-6\"/></div>\r\n                   <div>\r\n                      <p className=\"text-sm font-bold text-muted-foreground\">в•Әв•Јв•ӘШҜв•ӘШ®в•ӘВ» в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘШів”ҳГ в•ӘШҜв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШІв•Әв”Ӯв”ҳГӘв”ҳГЁв”ҳГ©в”ҳГЁ (ROI)</p>\r\n                      <h3 className=\"text-3xl font-black mt-1 flex items-baseline gap-1\">592 <span className=\"text-sm font-bold text-muted-foreground\">%</span></h3>\r\n                      <p className=\"text-xs text-blue-500 font-bold mt-2 flex items-center gap-1\">в•ӘШҜв•Әв”Ӯв•ӘШІв”ҳГ©в•Әв–’в•ӘШҜв•Әв–’ в”ҳГ в”ҳГ в•ӘШІв•ӘШҜв•Әв–“ в”ҳВ„в”ҳВ„в”ҳГ в”ҳГЁв•Әв–“в•ӘШҜв”ҳВҶв”ҳГЁв•ӘШұ</p>\r\n                   </div>\r\n                </div>\r\n             </AdminCard>\r\n           </div>\r\n\r\n           <div className=\"grid lg:grid-cols-2 gap-6\">\r\n              <AdminCard variant=\"glass\">\r\n                 <div className=\"flex items-center justify-between mb-6\">\r\n                    <h3 className=\"text-xl font-black flex items-center gap-2\"><PieChart className=\"w-5 h-5 text-primary\" /> в•ӘШІв”ҳВҒв•Әв•Ўв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ«в•Әв–’в•ӘШ°в•ӘШҜв•ӘШө в•ӘШөв•Әв”Ӯв•ӘШ° в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•ӘВ»в•ӘШұ</h3>\r\n                 </div>\r\n                 <div className=\"space-y-5\">\r\n                    {[\r\n                      { name: \"в•ӘШҜв”ҳВ„в”ҳВҒв”ҳГЁв•Әв–“в”ҳГЁв•ӘШҜв•ӘШ© (в”ҳГ в•Әв–’в•ӘШҜв•ӘШҙв•Әв•Јв•ӘШұ в”ҳВҶв”ҳГ§в•ӘШҜв•ӘШ®в”ҳГЁв•ӘШұ)\", revenue: 45000, margin: 80 },\r\n                      { name: \"в•ӘШҜв”ҳВ„в”ҳГўв”ҳГЁв”ҳГ в”ҳГЁв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•Әв•Јв•Әв•ўв”ҳГӘв”ҳГЁв•ӘШұ\", revenue: 32000, margin: 65 },\r\n                      { name: \"в•ӘШҜв”ҳВ„в”ҳВ„в•Әв•‘в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШҙв”ҳВ„в”ҳГЁв•Әв–“в”ҳГЁв•ӘШұ\", revenue: 28000, margin: 90 },\r\n                    ].map((item, i) => (\r\n                      <div key={i} className=\"flex flex-col gap-2\">\r\n                         <div className=\"flex justify-between items-center text-sm font-bold\">\r\n                            <span>{item.name}</span>\r\n                            <span className=\"text-primary\">{item.revenue.toLocaleString()} в•ӘШҙ.в”ҳГ </span>\r\n                         </div>\r\n                         <div className=\"w-full h-3 bg-secondary rounded-full overflow-hidden flex\">\r\n                            <div className=\"h-full bg-primary rounded-full relative\" style={{ width: `${item.margin}%` }}></div>\r\n                         </div>\r\n                         <p className=\"text-[10px] text-muted-foreground font-black text-left\">в”ҳГ§в•ӘШҜв”ҳГ в•Әв”Ө в•ӘШҜв”ҳВ„в•Әв–’в•ӘШ°в•ӘШө {item.margin}%</p>\r\n                      </div>\r\n                    ))}\r\n                 </div>\r\n              </AdminCard>\r\n\r\n              <AdminCard variant=\"glass\">\r\n                 <div className=\"flex items-center justify-between mb-6\">\r\n                    <h3 className=\"text-xl font-black flex items-center gap-2\"><Wallet className=\"w-5 h-5 text-amber-500\" /> в”ҳГ в•Әв”Ӯв•ӘШІв•ӘШөв”ҳГ©в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Јв”ҳВ„в”ҳГ в”ҳГЁв”ҳВҶ</h3>\r\n                    <Select defaultValue=\"month\">\r\n                       <SelectTrigger className=\"w-32 h-8 text-xs rounded-lg\"><SelectValue/></SelectTrigger>\r\n                       <SelectContent><SelectItem value=\"month\">в”ҳГ§в•Әв–‘в•ӘШҜ в•ӘШҜв”ҳВ„в•Әв”Өв”ҳГ§в•Әв–’</SelectItem></SelectContent>\r\n                    </Select>\r\n                 </div>\r\n                 <div className=\"overflow-x-auto\">\r\n                    <table className=\"w-full text-sm text-right\">\r\n                       <thead>\r\n                          <tr className=\"border-b border-border/50 text-muted-foreground text-xs uppercase\">\r\n                             <th className=\"pb-3 px-2 font-bold\">в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Јв”ҳВ„в”ҳГ </th>\r\n                             <th className=\"pb-3 px-2 font-bold\">в•ӘШҜв”ҳВ„в”ҳГ в•ӘШ°в”ҳГЁв•Әв•Јв•ӘШҜв•ӘШІ</th>\r\n                             <th className=\"pb-3 px-2 font-bold\">в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГ в”ҳГӘв”ҳВ„в•ӘШұ</th>\r\n                             <th className=\"pb-3 px-2 font-bold\">в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ</th>\r\n                          </tr>\r\n                       </thead>\r\n                       <tbody>\r\n                          {[\r\n                             { name: \"в•ӘШ«. в”ҳГ в•ӘШөв”ҳГ в”ҳГӘв•ӘВ» в•Әв”Ӯв•ӘШҜв”ҳВ„в”ҳГ \", sales: 120, comission: 18000, status: \"pending\" },\r\n                             { name: \"в•ӘШ«. в•Әв”Ӯв•Әв•Јв•ӘШҜв•ӘВ» в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ в•Әв–’\", sales: 85, comission: 12750, status: \"paid\" },\r\n                             { name: \"в•ӘШ«. в•ӘШӯв•ӘШ°в•Әв–’в•ӘШҜв”ҳГ§в”ҳГЁв”ҳГ  в”ҳВҒв•ӘШ¬в•ӘШҜв•ӘВ»\", sales: 42, comission: 6300, status: \"pending\" },\r\n                          ].map((t, i) => (\r\n                             <tr key={i} className=\"border-b border-border/20 last:border-0 hover:bg-accent/10 transition-colors\">\r\n                                <td className=\"py-4 px-2 font-bold\">{t.name}</td>\r\n                                <td className=\"py-4 px-2\">{t.sales} в•ӘШҜв•Әв”Өв•ӘШІв•Әв–’в•ӘШҜв”ҳГў</td>\r\n                                <td className=\"py-4 px-2 font-black text-primary\">{t.comission.toLocaleString()} в•ӘШҙ.в”ҳГ </td>\r\n                                <td className=\"py-4 px-2\">\r\n                                   <span className={`px-2 py-1 rounded-md text-[10px] font-black uppercase ${t.status === 'paid' ? 'bg-emerald-500/10 text-emerald-500' : 'bg-amber-500/10 text-amber-500'}`}>\r\n                                      {t.status === 'paid' ? 'в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•ӘВ»в”ҳВҒв•Әв•Ј' : 'в”ҳГ в•Әв”Ӯв•ӘШІв•ӘШөв”ҳГ©'}\r\n                                   </span>\r\n                                </td>\r\n                             </tr>\r\n                          ))}\r\n                       </tbody>\r\n                    </table>\r\n                 </div>\r\n              </AdminCard>\r\n           </div>\r\n        </TabsContent>\r\n\r\n        {/* ====================================\r\n            TAB 3: USER JOURNEY MAPPING\r\n            ==================================== */}\r\n        <TabsContent value=\"journey\" className=\"space-y-6\">\r\n           <AdminCard variant=\"glass\" className=\"bg-gradient-to-br from-purple-500/5 to-transparent border-purple-500/20\">\r\n              <div className=\"flex items-center justify-between mb-6\">\r\n                 <div>\r\n                    <h3 className=\"text-2xl font-black flex items-center gap-3 text-purple-500\">\r\n                       <MousePointerClick className=\"w-6 h-6\" /> в•ӘВ«в•Әв–’в”ҳГЁв•Әв•–в•ӘШұ в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  (Funnel & Journey Mapping)\r\n                    </h3>\r\n                    <p className=\"text-muted-foreground mt-2 font-medium\">в•ӘШІв•ӘШІв•ӘШ°в•Әв•Ј в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв–’ в•ӘШҜв”ҳВ„в•Әв•–в•ӘШҜв”ҳВ„в•ӘШ° в”ҳГ в”ҳВҶв•Әв–‘ в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•Әв•Ўв•ӘШұ в”ҳГӘв•ӘШөв•ӘШІв”ҳГ« в•ӘШҜв”ҳВ„в•Әв”Өв•Әв–’в•ӘШҜв•ӘШ© в•ӘШ«в”ҳГӘ в•ӘШӯв”ҳГўв”ҳГ в•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГўв”ҳГӘв•Әв–’в•Әв”Ӯ в”ҳВ„в•ӘШҜв”ҳГўв•ӘШІв•Әв”Өв•ӘШҜв”ҳВҒ в”ҳВҶв”ҳГ©в•ӘШҜв•Әв•– в•ӘШҜв”ҳВ„в•ӘШҜв•ӘВ«в•ӘШІв”ҳВҶв•ӘШҜв”ҳГ© (Drop-offs).</p>\r\n                 </div>\r\n                 <div className=\"flex gap-2\">\r\n                    <Select defaultValue=\"course_a\">\r\n                       <SelectTrigger className=\"w-64 h-11 bg-background\"><SelectValue placeholder=\"в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв–’ в”ҳВ„в•ӘШІв•ӘШІв•ӘШ°в”ҢШІ\"/></SelectTrigger>\r\n                       <SelectContent>\r\n                          <SelectItem value=\"course_a\">в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШІв”ҳГӘв•ӘШҙв”ҳГЁв”ҳГ§в”ҳГЁ в•Әв•Јв”ҳВ„в”ҳГ в”ҳГЁ (в•Әв”Өв•Әв–’в•ӘШҜв•ӘШ© в”ҳГўв”ҳГӘв•Әв–’в•Әв”Ӯ)</SelectItem>\r\n                          <SelectItem value=\"register\">в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ» в”ҳГӘв•ӘШІв”ҳВҒв•Әв•Јв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°</SelectItem>\r\n                       </SelectContent>\r\n                    </Select>\r\n                 </div>\r\n              </div>\r\n\r\n              {/* Advanced Funnel UI */}\r\n              <div className=\"mt-12 mb-8 relative px-4 md:px-12\">\r\n                 <div className=\"absolute top-1/2 left-0 w-full h-1 bg-gradient-to-l from-primary via-purple-500 to-red-500 -translate-y-1/2 -z-10 rounded-full opacit