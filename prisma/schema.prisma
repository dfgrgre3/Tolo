generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  engineType      = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                            String                @id @default(cuid())
  email                         String                @unique
  name                          String?
  username                      String?
  avatar                        String?
  passwordHash                  String
  createdAt                     DateTime              @default(now())
  updatedAt                     DateTime              @updatedAt
  wakeUpTime                    String?
  sleepTime                     String?
  focusStrategy                 String?               @default("POMODORO")
  emailNotifications            Boolean?              @default(true)
  emailVerificationToken        String?
  emailVerificationExpires      DateTime?
  emailVerified                 Boolean?              @default(false)
  lastLogin                     DateTime?
  phone                         String?
  phoneVerified                 Boolean?              @default(false)
  phoneVerificationOTP          String?
  phoneVerificationExpires      DateTime?
  phoneVerificationAttempts     Int                   @default(0)
  phoneVerificationLastSent     DateTime?
  resetToken                    String?
  resetTokenExpires             DateTime?
  twoFactorEnabled              Boolean               @default(false)
  twoFactorSecret               String?
  recoveryCodes                 String?
  smsNotifications              Boolean?              @default(false)
  biometricEnabled              Boolean               @default(false)
  passwordChangedAt             DateTime?
  passwordExpiresAt             DateTime?
  passwordExpirationWarningSent Boolean               @default(false)
  totalXP                       Int                   @default(0)
  level                         Int                   @default(1)
  currentStreak                 Int                   @default(0)
  longestStreak                 Int                   @default(0)
  totalStudyTime                Int                   @default(0)
  tasksCompleted                Int                   @default(0)
  examsPassed                   Int                   @default(0)
  pomodoroSessions              Int                   @default(0)
  deepWorkSessions              Int                   @default(0)
  studyXP                       Int                   @default(0)
  taskXP                        Int                   @default(0)
  examXP                        Int                   @default(0)
  challengeXP                   Int                   @default(0)
  questXP                       Int                   @default(0)
  seasonXP                      Int                   @default(0)
  role                          UserRole              @default(USER)
  aiChatMessages                AiChatMessage[]
  aiGeneratedContent            AiGeneratedContent[]
  aiGeneratedExams              AiGeneratedExam[]
  biometricCredentials          BiometricCredential[]
  blogPosts                     BlogPost[]            @relation("BlogPostAuthor")
  challengeCompletions          ChallengeCompletion[]
  contentPreferences            ContentPreference[]
  customGoals                   CustomGoal[]
  organizedEvents               Event[]               @relation("EventOrganizer")
  examResults                   ExamResult[]
  forumPosts                    ForumPost[]           @relation("ForumPostAuthor")
  forumReplies                  ForumReply[]          @relation("ForumReplyAuthor")
  leaderboardEntries            LeaderboardEntry[]
  mlRecommendations             MlRecommendation[]
  notifications                 Notification[]
  offlineLessons                OfflineLesson[]
  passwordHistory               PasswordHistory[]
  progressSnapshots             ProgressSnapshot[]
  questProgresses               QuestProgress[]
  reminders                     Reminder[]
  schedules                     Schedule[]
  seasonParticipations          SeasonParticipation[]
  securityLogs                  SecurityLog[]
  securityQuestions             SecurityQuestion[]
  sentimentAnalyses             SentimentAnalysis[]
  sessions                      Session[]
  studySessions                 StudySession[]
  subjectEnrollments            SubjectEnrollment[]
  tasks                         Task[]
  achievements                  UserAchievement[]
  userGrades                    UserGrade[]
  userInteractions              UserInteraction[]
  userRewards                   UserReward[]
}

model SubjectEnrollment {
  id                String   @id @default(cuid())
  userId            String
  subjectId         String
  targetWeeklyHours Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  subject           Subject  @relation(fields: [subjectId], references: [id])
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId])
  @@index([userId])
  @@index([subjectId])
}

model StudySession {
  id          String         @id @default(cuid())
  userId      String
  subjectId   String?
  taskId      String?
  startTime   DateTime
  endTime     DateTime
  durationMin Int
  focusScore  Int            @default(0)
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  strategy    FocusStrategy?
  subject     Subject?       @relation(fields: [subjectId], references: [id])
  task        Task?          @relation(fields: [taskId], references: [id])
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, subjectId])
  @@index([subjectId])
  @@index([taskId])
}

model Task {
  id            String         @id @default(cuid())
  userId        String
  title         String
  description   String?
  subjectId     String?
  dueAt         DateTime?
  scheduledAt   DateTime?
  completedAt   DateTime?
  priority      Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  status        TaskStatus     @default(PENDING)
  studySessions StudySession[]
  subject       Subject?       @relation(fields: [subjectId], references: [id])
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, subjectId])
}

model Reminder {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String?
  remindAt  DateTime
  repeat    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProgressSnapshot {
  id                String   @id @default(cuid())
  userId            String
  date              DateTime
  totalStudyMinutes Int      @default(0)
  averageFocusScore Float    @default(0)
  completedTasks    Int      @default(0)
  streakDays        Int      @default(0)
  gradeAverage      Float?
  improvementRate   Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Resource {
  id          String   @id @default(cuid())
  subjectId   String
  title       String
  description String?
  url         String
  free        Boolean  @default(true)
  type        String
  source      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([subjectId])
}

model Book {
  id          String   @id @default(cuid())
  title       String
  author      String
  description String
  subjectId   String
  coverUrl    String?
  downloadUrl String
  rating      Float    @default(0)
  views       Int      @default(0)
  downloads   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tags        String[] @default([])
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([subjectId])
}

model Exam {
  id        String       @id @default(cuid())
  subjectId String
  title     String
  year      Int
  url       String
  type      String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  subject   Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  results   ExamResult[]

  @@index([subjectId])
}

model ExamResult {
  id        String   @id @default(cuid())
  userId    String
  examId    String
  score     Float
  takenAt   DateTime @default(now())
  teacherId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  exam      Exam     @relation(fields: [examId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, examId])
  @@index([examId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  userAgent    String
  ip           String
  deviceInfo   String?
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  lastAccessed DateTime @default(now())
  isActive     Boolean  @default(true)
  refreshToken String?
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SecurityLog {
  id         String   @id @default(cuid())
  userId     String?
  eventType  String
  ip         String
  userAgent  String
  deviceInfo String?
  location   String?
  metadata   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Achievement {
  id            String              @id
  key           String              @unique
  title         String
  description   String
  icon          String
  rarity        String              @default("common")
  xpReward      Int
  requirements  String
  isSecret      Boolean             @default(false)
  unlockedCount Int                 @default(0)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  category      AchievementCategory
  difficulty    Difficulty          @default(MEDIUM)
  users         UserAchievement[]
}

model UserAchievement {
  id             String      @id @default(cuid())
  userId         String
  achievementKey String
  earnedAt       DateTime    @default(now())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  achievement    Achievement @relation(fields: [achievementKey], references: [key], onDelete: Cascade)
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementKey])
  @@index([userId])
}

model CustomGoal {
  id           String    @id @default(cuid())
  userId       String
  title        String
  description  String?
  targetValue  Float
  currentValue Float     @default(0)
  unit         String
  category     String
  isCompleted  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  completedAt  DateTime?
  xpReward     Int       @default(10)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TwoFactorChallenge {
  id        String   @id @default(cuid())
  userId    String?
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model BiometricChallenge {
  id        String   @id @default(cuid())
  challenge String
  type      String
  userId    String?
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean          @default(false)
  actionUrl String?
  icon      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  type      NotificationType @default(INFO)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Season {
  id             String                @id @default(cuid())
  name           String
  description    String?
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean               @default(true)
  rewards        String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  leaderboards   LeaderboardEntry[]
  participations SeasonParticipation[]
}

model SeasonParticipation {
  id        String   @id @default(cuid())
  userId    String
  seasonId  String
  seasonXP  Int      @default(0)
  rank      Int?
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  season    Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId])
  @@index([seasonId])
  @@index([userId])
  @@index([userId, seasonId])
}

model Challenge {
  id           String                @id @default(cuid())
  title        String
  description  String
  type         String
  category     String
  xpReward     Int
  requirements String
  startDate    DateTime
  endDate      DateTime
  isActive     Boolean               @default(true)
  subjectId    String?
  levelRange   String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  difficulty   Difficulty            @default(MEDIUM)
  subject      Subject?              @relation(fields: [subjectId], references: [id])
  completions  ChallengeCompletion[]

  @@index([subjectId])
}

model ChallengeCompletion {
  id          String    @id @default(cuid())
  userId      String
  challengeId String
  completedAt DateTime  @default(now())
  progress    Float     @default(0)
  isCompleted Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([userId])
  @@index([challengeId])
}

model QuestChain {
  id          String          @id @default(cuid())
  title       String
  description String
  category    String
  totalQuests Int             @default(1)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  difficulty  Difficulty      @default(MEDIUM)
  quests      Quest[]
  progresses  QuestProgress[]
}

model Quest {
  id            String          @id @default(cuid())
  chainId       String
  title         String
  description   String
  order         Int
  xpReward      Int
  requirements  String
  prerequisites String?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  chain         QuestChain      @relation(fields: [chainId], references: [id], onDelete: Cascade)
  progresses    QuestProgress[]

  @@index([chainId])
}

model QuestProgress {
  id          String     @id @default(cuid())
  userId      String
  questId     String
  chainId     String
  progress    Float      @default(0)
  isCompleted Boolean    @default(false)
  completedAt DateTime?
  startedAt   DateTime   @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  chain       QuestChain @relation(fields: [chainId], references: [id], onDelete: Cascade)
  quest       Quest      @relation(fields: [questId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questId])
  @@index([userId])
  @@index([questId])
  @@index([chainId])
}

model Reward {
  id          String       @id @default(cuid())
  name        String
  description String
  type        String
  rarity      String
  imageUrl    String?
  metadata    String?
  isTradeable Boolean      @default(false)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  userRewards UserReward[]
}

model UserReward {
  id         String   @id @default(cuid())
  userId     String
  rewardId   String
  earnedAt   DateTime @default(now())
  source     String?
  nftTokenId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  reward     Reward   @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, rewardId])
  @@index([userId])
  @@index([rewardId])
}

model LeaderboardEntry {
  id          String   @id @default(cuid())
  userId      String
  type        String
  period      String?
  subjectId   String?
  levelRange  String?
  seasonId    String?
  totalXP     Int      @default(0)
  studyXP     Int      @default(0)
  taskXP      Int      @default(0)
  examXP      Int      @default(0)
  challengeXP Int      @default(0)
  questXP     Int      @default(0)
  rank        Int?
  level       Int      @default(1)
  lastUpdated DateTime @updatedAt
  season      Season?  @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  subject     Subject? @relation(fields: [subjectId], references: [id])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, period, subjectId, levelRange, seasonId])
  @@index([userId])
}

model SentimentAnalysis {
  id         String   @id @default(cuid())
  userId     String
  text       String
  sentiment  String
  score      Float
  confidence Float
  emotions   String?
  context    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AiChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  sentiment String?
  metadata  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AiGeneratedContent {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  content   String
  subjectId String?
  metadata  String?
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  subject   Subject? @relation(fields: [subjectId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([subjectId])
}

model UserInteraction {
  id        String   @id @default(cuid())
  userId    String
  type      String
  itemType  String
  itemId    String
  metadata  String?
  timestamp DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ContentPreference {
  id        String   @id @default(cuid())
  userId    String
  itemType  String
  itemValue String
  weight    Float    @default(1.0)
  source    String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemType, itemValue])
  @@index([userId])
}

model MlRecommendation {
  id          String    @id @default(cuid())
  userId      String
  itemType    String
  itemId      String
  score       Float
  algorithm   String
  reason      String?
  shownAt     DateTime?
  clickedAt   DateTime?
  completedAt DateTime?
  feedback    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Teacher {
  id        String   @id @default(cuid())
  name      String
  subjectId String
  onlineUrl String?
  rating    Float    @default(0)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([name, subjectId], name: "name_subject")
  @@index([subjectId])
}

model Subject {
  id                 String               @id @default(cuid())
  name               String               @unique
  nameAr             String?
  code               String?              @unique
  description        String?
  icon               String?
  color              String?
  type               String?
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  aiContent          AiGeneratedContent[]
  aiExams            AiGeneratedExam[]
  books              Book[]
  challenges         Challenge[]
  exams              Exam[]
  leaderboardEntries LeaderboardEntry[]
  offlineLessons     OfflineLesson[]
  resources          Resource[]
  schedules          Schedule[]
  studySessions      StudySession[]
  enrollments        SubjectEnrollment[]
  tasks              Task[]
  teachers           Teacher[]
  topics             Topic[]
  userGrades         UserGrade[]
}

model Topic {
  id          String     @id @default(cuid())
  subjectId   String
  name        String
  description String?
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  subTopics   SubTopic[]
  subject     Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([subjectId])
}

model SubTopic {
  id          String          @id @default(cuid())
  topicId     String
  name        String
  description String?
  content     String?
  videoUrl    String?
  order       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  topic       Topic           @relation(fields: [topicId], references: [id], onDelete: Cascade)
  progresses  TopicProgress[]

  @@index([topicId])
}

model TopicProgress {
  id          String    @id @default(cuid())
  userId      String
  subTopicId  String
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  subTopic    SubTopic  @relation(fields: [subTopicId], references: [id], onDelete: Cascade)

  @@unique([userId, subTopicId])
  @@index([userId])
  @@index([subTopicId])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([senderId])
  @@index([receiverId])
  @@index([senderId, receiverId])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  priority  String   @default("normal")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  slug        String       @unique
  icon        String?
  type        CategoryType @default(BLOG)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  blogPosts   BlogPost[]
  forumPosts  ForumPost[]
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  content     String
  excerpt     String?
  slug        String    @unique
  categoryId  String
  authorId    String
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  views       Int       @default(0)
  author      User      @relation("BlogPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([authorId])
}

model ForumPost {
  id         String       @id @default(cuid())
  title      String
  content    String
  categoryId String
  authorId   String
  isPinned   Boolean      @default(false)
  isLocked   Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  views      Int          @default(0)
  author     User         @relation("ForumPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  category   Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  replies    ForumReply[]

  @@index([categoryId])
  @@index([authorId])
}

model ForumReply {
  id        String    @id @default(cuid())
  content   String
  postId    String
  authorId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  author    User      @relation("ForumReplyAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
}

model Event {
  id           String          @id @default(cuid())
  title        String
  description  String?
  startDate    DateTime
  endDate      DateTime
  location     String?
  maxAttendees Int?
  imageUrl     String?
  organizerId  String
  category     String
  isPublic     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  tags         String[]        @default([])
  organizer    User            @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  attendees    EventAttendee[]

  @@index([organizerId])
}

model EventAttendee {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model Contest {
  id          String   @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  rules       String?
  prizes      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Schedule {
  id          String   @id @default(cuid())
  userId      String
  name        String?
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  subjectId   String?
  type        String   @default("study")
  color       String?
  active      Boolean  @default(true)
  planJson    String?
  version     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  subject     Subject? @relation(fields: [subjectId], references: [id])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, active], name: "userId_active")
  @@index([userId])
  @@index([subjectId])
}

model UserGrade {
  id        String    @id @default(cuid())
  userId    String
  subjectId String
  grade     Float
  maxGrade  Float
  examName  String?
  date      DateTime?
  examDate  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  subject   Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, subjectId])
  @@index([subjectId])
}

model OfflineLesson {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  subjectId   String
  teacherId   String?
  location    String?
  startTime   DateTime
  endTime     DateTime
  maxStudents Int?
  price       Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([subjectId])
  @@index([teacherId])
}

model AiGeneratedExam {
  id         String       @id @default(cuid())
  userId     String
  subjectId  String
  title      String
  duration   Int
  year       Int?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  difficulty Difficulty   @default(MEDIUM)
  subject    Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions  AiQuestion[]
  results    TestResult[]

  @@index([userId])
  @@index([subjectId])
}

model AiQuestion {
  id            String          @id @default(cuid())
  examId        String
  question      String
  correctAnswer String
  explanation   String?
  points        Int             @default(1)
  order         Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  options       String[]
  exam          AiGeneratedExam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
}

model TestResult {
  id          String          @id @default(cuid())
  userId      String
  examId      String
  score       Float
  totalScore  Float
  answers     String
  timeTaken   Int
  completedAt DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  exam        AiGeneratedExam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([examId])
  @@index([userId, examId])
}

model BiometricCredential {
  id           String   @id @default(cuid())
  userId       String
  credentialId String   @unique
  publicKey    String
  counter      Int      @default(0)
  deviceType   String?
  deviceName   String?
  transports   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([credentialId])
}

model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordPolicy {
  id               String   @id @default(cuid())
  role             String   @unique
  expirationDays   Int?
  minLength        Int      @default(8)
  maxLength        Int      @default(128)
  requireUppercase Boolean  @default(true)
  requireLowercase Boolean  @default(true)
  requireNumbers   Boolean  @default(true)
  requireSpecial   Boolean  @default(true)
  historyCount     Int      @default(10)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  warningDays      Int[]    @default([7, 3, 1])
  bannedPasswords  String[] @default([])
}

model SecurityQuestion {
  id         String   @id @default(cuid())
  userId     String
  question   String
  answerHash String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum UserRole {
  USER
  ADMIN
  TEACHER
  MODERATOR
}

enum FocusStrategy {
  POMODORO
  EIGHTY_TWENTY
  DEEP_WORK
  TIME_BLOCKING
  NO_DISTRACTION
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CategoryType {
  BLOG
  FORUM
}

enum AchievementCategory {
  STUDY
  TASKS
  EXAMS
  TIME
  STREAK
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}
