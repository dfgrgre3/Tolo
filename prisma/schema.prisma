  INACTIVE
  EXPIRED
  CANCELLED
  GRACE_PERIOD
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum AddonType {
  EXAM_PACK
  AI_CREDITS
  TEACHER_HOURS
  OTHER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}
