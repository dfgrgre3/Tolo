  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  answers    LessonAnswer[]
  subTopic   SubTopic       @relation(fields: [subTopicId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([subTopicId])
}

model LessonAnswer {
  id         String         @id @default(cuid())
  questionId String
  userId     String
  content    String
  isTeacher  Boolean        @default(false)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  question   LessonQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([userId])
}

model SubscriptionPlan {
  id             String         @id @default(cuid())
  name           String         @unique
  nameAr         String?
  description    String?
  descriptionAr  String?
  price          Float
  currency       String         @default("EGP")
  interval       PlanInterval   @default(MONTHLY)
  features       String[]       @default([])
  featuresAr     String[]       @default([])
  isActive       Boolean        @default(true)
  level          Int            @default(0)
  memberLimit    Int            @default(1)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  aiMessageLimit Int?
  examLimit      Int?
  extraExamPrice Float?         @default(0)
  subscriptions  Subscription[]

  @@index([isActive])
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String
  planId             String
  status             SubscriptionStatus @default(INACTIVE)
  startDate          DateTime           @default(now())
  endDate            DateTime
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  gracePeriodEndDate DateTime?
  payments           Payment[]
  plan               SubscriptionPlan   @relation(fields: [planId], references: [id])
  user               User               @relation("UserSubscription", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([planId])
  @@index([status])
}

model Payment {
  id                String          @id @default(cuid())
  userId            String
  subscriptionId    String?
  amount            Float
  currency          String          @default("EGP")
  status            PaymentStatus   @default(PENDING)
  provider          String          @default("PAYMOB")
  transactionId     String?         @unique
  orderId           String?         @unique
  paymentMethod     String?
  paymentData       String?
  errorMessage      String?
  couponId          String?
  discountAmount    Float?          @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  referralRewardId  String?         @unique
  creditAmount      Float?          @default(0)
  balanceUsed       Float?          @default(0)
  promoDiscount     Float?          @default(0)
  prorationDiscount Float?          @default(0)
  coupon            Coupon?         @relation(fields: [couponId], references: [id])
  referralReward    ReferralReward? @relation(fields: [referralRewardId], references: [id])
  subscription      Subscription?   @relation(fields: [subscriptionId], references: [id])
  user              User            @relation("UserPayments", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
  @@index([transactionId])
}

model Coupon {
  id              String       @id @default(cuid())
  code            String       @unique
  description     String?
  discountType    DiscountType @default(PERCENTAGE)
  discountValue   Float
  maxUses         Int?
  usedCount       Int          @default(0)
  expiryDate      DateTime?
  isActive        Boolean      @default(true)
  minOrderAmount  Float?       @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  isWinBack       Boolean?     @default(false)
  minInactiveDays Int?
  regionTarget    String?
  schoolTarget    String?
  userTargetId    String?
  payments        Payment[]

  @@index([code])
  @@index([userTargetId])
  @@index([isActive])
}

model ReferralReward {
  id         String   @id @default(cuid())
  referrerId String
  referredId String   @unique
  amount     Float
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  payment    Payment?
  referrer   User     @relation("UserReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
}

model GroupSubscription {
  id        String   @id @default(cuid())
  ownerId   String   @unique
  planId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  owner     User     @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members   User[]   @relation("GroupMembers")
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  metadata  String?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([userId])
}

model Addon {
  id          String    @id @default(cuid())
  name        String    @unique
  nameAr      String?
  description String?
  price       Float
  type        AddonType
  value       Int
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model user_preferences {
  userId        String   @id
  appearance    String   @default("{}")
  language      String   @default("{}")
  privacy       String   @default("{}")
  notifications String   @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())
  User          User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model ContentReport {
  id          String   @id @default(cuid())
  userId      String
  targetId    String   // ID of the video, exam, or lesson
  targetType  String   // "VIDEO", "EXAM", "LESSON", "BOOK"
  subjectId   String?
  issueType   String   // "ERROR", "TYPO", "VIDEO_ISSUE", "OTHER"
  description String
  status      String   @default("PENDING") // PENDING, INVESTIGATING, RESOLVED, DISMISSED
  adminNote   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation("UserReports", fields: [userId], references: [id], onDelete: Cascade)
  subject     Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@index([targetId])
  @@index([status])
  @@index([userId])
}

