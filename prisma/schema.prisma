generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model User {
  id                            String                @id @default(cuid())
  email                         String                @unique
  name                          String?
  username                      String?
  avatar                        String?
  passwordHash                  String
  createdAt                     DateTime              @default(now())
  updatedAt                     DateTime              @updatedAt
  wakeUpTime                    String?
  sleepTime                     String?
  focusStrategy                 String?               @default("POMODORO")
  emailNotifications            Boolean?              @default(true)
  emailVerificationToken        String?
  emailVerificationExpires      DateTime?
  emailVerified                 Boolean?              @default(false)
  lastLogin                     DateTime?
  phone                         String?
  phoneVerified                 Boolean?              @default(false)
  phoneVerificationOTP          String?
  phoneVerificationExpires      DateTime?
  phoneVerificationAttempts     Int                   @default(0)
  phoneVerificationLastSent     DateTime?
  resetToken                    String?
  resetTokenExpires             DateTime?
  twoFactorEnabled              Boolean               @default(false)
  twoFactorSecret               String?
  recoveryCodes                 String?
  smsNotifications              Boolean?              @default(false)
  biometricEnabled              Boolean               @default(false)
  magicLinkToken                String?
  magicLinkExpires              DateTime?
  googleId                      String?               @unique
  githubId                      String?               @unique
  passwordChangedAt             DateTime?
  passwordExpiresAt             DateTime?
  passwordExpirationWarningSent Boolean               @default(false)
  role                          UserRole              @default(STUDENT)
  status                        UserStatus            @default(ACTIVE)
  xp                            UserXP?
  activity                      UserActivity?
  wallet                        UserWallet?
  country                       String?
  dateOfBirth                   DateTime?
  gender                        String?
  alternativePhone              String?
  gradeLevel                    String?
  educationType                 String?
  section                       String?
  interestedSubjects            String[]              @default([])
  studyGoal                     String?
  subjectsTaught                String[]              @default([])
  classesTaught                 String[]              @default([])
  experienceYears               String?
  bio                           String?
  permissions                   String[]              @default([])
  school                        String?
  referralCode                  String?               @unique
  referredById                  String?
  additionalAiCredits           Int                   @default(0)
  additionalExamCredits         Int                   @default(0)
  aiChatMessages                AiChatMessage[]
  aiGeneratedContent            AiGeneratedContent[]
  aiGeneratedExams              AiGeneratedExam[]
  automationLogs                AutomationLog[]
  biometricCredentials          BiometricCredential[]
  blogPosts                     BlogPost[]            @relation("BlogPostAuthor")
  uploadedBooks                 Book[]                @relation("BookUploader")
  bookProgresses                BookProgress[]
  bookReviews                   BookReview[]
  challengeCompletions          ChallengeCompletion[]
  contentPreferences            ContentPreference[]
  customGoals                   CustomGoal[]
  organizedEvents               Event[]               @relation("EventOrganizer")
  organizedContests            Contest[]             @relation("ContestOrganizer")
  examResults                   ExamResult[]
  forumPosts                    ForumPost[]           @relation("ForumPostAuthor")
  forumReplies                  ForumReply[]          @relation("ForumReplyAuthor")
  ownedGroup                    GroupSubscription?    @relation("GroupOwner")
  leaderboardEntries            LeaderboardEntry[]
  lessonAnswers                 LessonAnswer[]
  lessonNotes                   LessonNote[]
  lessonQuestions               LessonQuestion[]
  mlRecommendations             MlRecommendation[]
  notifications                 Notification[]
  offlineLessons                OfflineLesson[]
  passwordHistory               PasswordHistory[]
  payments                      Payment[]             @relation("UserPayments")
  progressSnapshots             ProgressSnapshot[]
  questProgresses               QuestProgress[]
  referralRewards               ReferralReward[]      @relation("UserReferrer")
  reminders                     Reminder[]
  schedules                     Schedule[]
  seasonParticipations          SeasonParticipation[]
  securityLogs                  SecurityLog[]
  securityQuestions             SecurityQuestion[]
  sentimentAnalyses             SentimentAnalysis[]
  sessions                      Session[]
  studySessions                 StudySession[]
  certificates                  SubjectCertificate[]
  subjectEnrollments            SubjectEnrollment[]
  reviews                       SubjectReview[]
  subscriptions                 Subscription[]        @relation("UserSubscription")
  tasks                         Task[]
  referredBy                    User?                 @relation("ReferralStory", fields: [referredById], references: [id])
  referrals                     User[]                @relation("ReferralStory")
  achievements                  UserAchievement[]
  userGrades                    UserGrade[]
  userInteractions              UserInteraction[]
  userRewards                   UserReward[]
  user_preferences              user_preferences?
  announcements                 Announcement[]        @relation("AnnouncementAuthor")
  memberGroups                  GroupSubscription[]   @relation("GroupMembers")
  reports                       ContentReport[]       @relation("UserReports")
  teacherProfile                Teacher?
  progress                      TopicProgress[]
  isDeleted                     Boolean               @default(false)
  deletedAt                     DateTime?

  @@index([role])
  @@index([lastLogin])
  @@index([emailVerified])
  @@index([isDeleted])
}

model UserXP {
  userId           String   @id
  totalXP          Int      @default(0)
  level            Int      @default(1)
  studyXP          Int      @default(0)
  taskXP           Int      @default(0)
  examXP           Int      @default(0)
  challengeXP      Int      @default(0)
  questXP          Int      @default(0)
  seasonXP         Int      @default(0)
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([totalXP(sort: Desc)])
  @@index([level])
}

model UserActivity {
  userId           String   @id
  currentStreak    Int      @default(0)
  longestStreak    Int      @default(0)
  totalStudyTime   Int      @default(0)
  tasksCompleted   Int      @default(0)
  examsPassed      Int      @default(0)
  pomodoroSessions Int      @default(0)
  deepWorkSessions Int      @default(0)
  lastActiveAt     DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lastActiveAt])
  @@index([currentStreak])
}

model UserWallet {
  userId    String   @id
  balance   Float    @default(0)
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SubjectEnrollment {
  id                String   @id @default(cuid())
  userId            String
  subjectId         String
  targetWeeklyHours Int           @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  paymentStatus     PaymentStatus @default(PENDING)
  progress          Int      @default(0)
  subject           Subject  @relation(fields: [subjectId], references: [id])
  user              User     @relation(fields: [userId], references: [id], onDelete: NoAction)
  isDeleted         Boolean  @default(false)
  deletedAt         DateTime?

  @@unique([userId, subjectId])
  @@index([userId])
  @@index([subjectId])
  @@index([isDeleted])
}

model StudySession {
  id          String         @id @default(cuid())
  userId      String
  subjectId   String?
  taskId      String?
  startTime   DateTime
  endTime     DateTime
  durationMin Int
  focusScore  Int            @default(0)
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  strategy    FocusStrategy?
  subject     Subject?       @relation(fields: [subjectId], references: [id])
  task        Task?          @relation(fields: [taskId], references: [id])
  user        User           @relation(fields: [userId], references: [id], onDelete: NoAction)
  isDeleted   Boolean        @default(false)
  deletedAt   DateTime?

  @@index([userId, subjectId])
  @@index([userId, startTime(sort: Desc)])
  @@index([subjectId])
  @@index([taskId])
  @@index([startTime(sort: Desc)])
  @@index([isDeleted])
}

model Task {
  id            String         @id @default(cuid())
  userId        String
  title         String
  description   String?
  subjectId     String?
  dueAt         DateTime?
  scheduledAt   DateTime?
  completedAt   DateTime?
  priority      Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  status        TaskStatus     @default(PENDING)
  studySessions StudySession[]
  subject       Subject?       @relation(fields: [subjectId], references: [id])
  user          User           @relation(fields: [userId], references: [id], onDelete: NoAction)
  isDeleted     Boolean        @default(false)
  deletedAt     DateTime?

  @@index([userId, subjectId])
  @@index([userId, status])
  @@index([status, dueAt])
  @@index([dueAt])
  @@index([isDeleted])
}

model Reminder {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String?
  remindAt  DateTime
  repeat    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProgressSnapshot {
  id                String   @id @default(cuid())
  userId            String
  date              DateTime
  totalStudyMinutes Int      @default(0)
  averageFocusScore Float    @default(0)
  completedTasks    Int      @default(0)
  streakDays        Int      @default(0)
  gradeAverage      Float?
  improvementRate   Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Resource {
  id           String   @id @default(cuid())
  subjectId    String
  title        String
  description  String?
  url          String
  free         Boolean  @default(true)
  type         String
  source       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  price        Float?   @default(0)
  minPlanLevel Int      @default(0)
  subject      Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([subjectId])
}

model Book {
  id          String         @id @default(cuid())
  title       String
  author      String
  description String
  subjectId   String
  coverUrl    String?
  downloadUrl String
  rating      Float          @default(0)
  views       Int            @default(0)
  downloads   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  tags        String[]       @default([])
  price       Float?         @default(0)
  uploaderId  String?
  subject     Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  uploader    User?          @relation("BookUploader", fields: [uploaderId], references: [id])
  progresses  BookProgress[]
  reviews     BookReview[]

  @@index([subjectId])
  @@index([uploaderId])
}

model BookReview {
  id        String   @id @default(cuid())
  bookId    String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bookId, userId])
  @@index([bookId])
  @@index([userId])
}

model BookProgress {
  id          String   @id @default(cuid())
  userId      String
  bookId      String
  progress    Float    @default(0)
  lastReadAt  DateTime @default(now())
  isCompleted Boolean  @default(false)
  currentPage Int      @default(0)
  totalPages  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  book        Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId])
  @@index([bookId])
}

model Exam {
  id        String       @id @default(cuid())
  subjectId String
  title     String
  year      Int
  url       String
  type      String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  subject   Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  results   ExamResult[]

  @@index([subjectId])
}

model ExamResult {
  id        String   @id @default(cuid())
  userId    String
  examId    String
  score     Float
  takenAt   DateTime @default(now())
  teacherId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  exam      Exam     @relation(fields: [examId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([examId])
  @@unique([userId, examId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  userAgent    String
  ip           String
  deviceInfo   String?
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  lastAccessed DateTime @default(now())
  isActive     Boolean  @default(true)
  isTrusted    Boolean  @default(false)
  location     String?
  refreshToken String?
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SecurityLog {
  id         String   @id @default(cuid())
  userId     String?
  eventType  String
  ip         String
  userAgent  String
  deviceInfo String?
  location   String?
  metadata   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Achievement {
  id            String              @id
  key           String              @unique
  title         String
  description   String
  icon          String
  rarity        String              @default("common")
  xpReward      Int
  requirements  String
  isSecret      Boolean             @default(false)
  unlockedCount Int                 @default(0)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  category      AchievementCategory
  difficulty    Difficulty          @default(MEDIUM)
  users         UserAchievement[]
}

model UserAchievement {
  id             String      @id @default(cuid())
  userId         String
  achievementKey String
  earnedAt       DateTime    @default(now())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  achievement    Achievement @relation(fields: [achievementKey], references: [key], onDelete: Cascade)
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementKey])
  @@index([userId])
}

model CustomGoal {
  id           String    @id @default(cuid())
  userId       String
  title        String
  description  String?
  targetValue  Float
  currentValue Float     @default(0)
  unit         String
  category     String
  isCompleted  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  completedAt  DateTime?
  xpReward     Int       @default(10)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TwoFactorChallenge {
  id        String   @id @default(cuid())
  userId    String?
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model BiometricChallenge {
  id        String   @id @default(cuid())
  challenge String
  type      String
  userId    String?
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean          @default(false)
  actionUrl String?
  icon      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  type      NotificationType @default(INFO)
  user      User             @relation(fields: [userId], references: [id], onDelete: NoAction)
  isDeleted Boolean          @default(false)
  deletedAt DateTime?

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt(sort: Desc)])
  @@index([isDeleted])
}

model Season {
  id             String                @id @default(cuid())
  name           String
  description    String?
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean               @default(true)
  rewards        String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  leaderboards   LeaderboardEntry[]
  participations SeasonParticipation[]
}

model SeasonParticipation {
  id        String   @id @default(cuid())
  userId    String
  seasonId  String
  seasonXP  Int      @default(0)
  rank      Int?
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  season    Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId])
  @@index([seasonId])
  @@index([userId])
  @@index([userId, seasonId])
}

model Challenge {
  id           String                @id @default(cuid())
  title        String
  description  String
  type         String
  category     String
  xpReward     Int
  requirements String
  startDate    DateTime
  endDate      DateTime
  isActive     Boolean               @default(true)
  subjectId    String?
  levelRange   String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  difficulty   Difficulty            @default(MEDIUM)
  subject      Subject?              @relation(fields: [subjectId], references: [id])
  completions  ChallengeCompletion[]

  @@index([subjectId])
}

model ChallengeCompletion {
  id          String    @id @default(cuid())
  userId      String
  challengeId String
  completedAt DateTime  @default(now())
  progress    Float     @default(0)
  isCompleted Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([userId])
  @@index([challengeId])
}

model QuestChain {
  id          String          @id @default(cuid())
  title       String
  description String
  category    String
  totalQuests Int             @default(1)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  difficulty  Difficulty      @default(MEDIUM)
  quests      Quest[]
  progresses  QuestProgress[]
}

model Quest {
  id            String          @id @default(cuid())
  chainId       String
  title         String
  description   String
  order         Int
  xpReward      Int
  requirements  String
  prerequisites String?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  chain         QuestChain      @relation(fields: [chainId], references: [id], onDelete: Cascade)
  progresses    QuestProgress[]

  @@index([chainId])
}

model QuestProgress {
  id          String     @id @default(cuid())
  userId      String
  questId     String
  chainId     String
  progress    Float      @default(0)
  isCompleted Boolean    @default(false)
  completedAt DateTime?
  startedAt   DateTime   @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  chain       QuestChain @relation(fields: [chainId], references: [id], onDelete: Cascade)
  quest       Quest      @relation(fields: [questId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questId])
  @@index([userId])
  @@index([questId])
  @@index([chainId])
}

model Reward {
  id          String       @id @default(cuid())
  name        String
  description String
  type        String
  rarity      String
  imageUrl    String?
  metadata    String?
  isTradeable Boolean      @default(false)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  userRewards UserReward[]
}

model UserReward {
  id         String   @id @default(cuid())
  userId     String
  rewardId   String
  earnedAt   DateTime @default(now())
  source     String?
  nftTokenId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  reward     Reward   @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, rewardId])
  @@index([userId])
  @@index([rewardId])
}

model LeaderboardEntry {
  id          String   @id @default(cuid())
  userId      String
  type        String
  period      String?
  subjectId   String?
  levelRange  String?
  seasonId    String?
  totalXP     Int      @default(0)
  studyXP     Int      @default(0)
  taskXP      Int      @default(0)
  examXP      Int      @default(0)
  challengeXP Int      @default(0)
  questXP     Int      @default(0)
  rank        Int?
  level       Int      @default(1)
  lastUpdated DateTime @updatedAt
  season      Season?  @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  subject     Subject? @relation(fields: [subjectId], references: [id])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, period, subjectId, levelRange, seasonId])
  @@index([userId])
}

model SentimentAnalysis {
  id         String   @id @default(cuid())
  userId     String
  text       String
  sentiment  String
  score      Float
  confidence Float
  emotions   String?
  context    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AiChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  sentiment String?
  metadata  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AiGeneratedContent {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  content   String
  subjectId String?
  metadata  String?
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  subject   Subject? @relation(fields: [subjectId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([subjectId])
}

model UserInteraction {
  id        String   @id @default(cuid())
  userId    String
  type      String
  itemType  String
  itemId    String
  metadata  String?
  timestamp DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ContentPreference {
  id        String   @id @default(cuid())
  userId    String
  itemType  String
  itemValue String
  weight    Float    @default(1.0)
  source    String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemType, itemValue])
  @@index([userId])
}

model MlRecommendation {
  id          String    @id @default(cuid())
  userId      String
  itemType    String
  itemId      String
  score       Float
  algorithm   String
  reason      String?
  shownAt     DateTime?
  clickedAt   DateTime?
  completedAt DateTime?
  feedback    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Teacher {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String
  bio       String?  @db.Text
  image     String?
  onlineUrl String?
  rating    Float    @default(0.0)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects  Subject[] @relation("SubjectToTeacher")

  @@index([userId])
}

model Subject {
  id                 String               @id @default(cuid())
  name               String               @unique
  nameAr             String?
  code               String?              @unique
  description        String?
  icon               String?
  color              String?
  type               String?
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  categoryId         String?
  durationHours      Int?                 @default(0)
  enrolledCount      Int?                 @default(0)
  instructorId       String?
  instructorName     String?
  isPublished        Boolean              @default(false)
  learningObjectives String?
  level              Level                @default(BEGINNER)
  price              Float?               @default(0)
  rating             Float?               @default(0)
  requirements       String?
  thumbnailUrl       String?
  trailerUrl         String?
  aiContent          AiGeneratedContent[]
  aiExams            AiGeneratedExam[]
  books              Book[]
  challenges         Challenge[]
  exams              Exam[]
  leaderboardEntries LeaderboardEntry[]
  offlineLessons     OfflineLesson[]
  resources          Resource[]
  schedules          Schedule[]
  studySessions      StudySession[]
  certificates       SubjectCertificate[]
  enrollments        SubjectEnrollment[]
  reviews            SubjectReview[]
  reports            ContentReport[]
  tasks              Task[]
  seoTitle           String?
  seoDescription     String?
  slug               String?              @unique


  teachers           Teacher[]            @relation("SubjectToTeacher")
  topics             Topic[]
  userGrades         UserGrade[]

  @@index([categoryId])
  @@index([isActive, createdAt(sort: Desc)])
  @@index([instructorName])
  @@index([enrolledCount(sort: Desc)])
  @@index([rating(sort: Desc)])
}

model Topic {
  id          String     @id @default(cuid())
  subjectId   String
  title       String @default("")
  description String?
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  subTopics   SubTopic[]
  subject     Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([subjectId])
}

model SubTopic {
  id              String             @id @default(cuid())
  topicId         String
  title           String @default("")
  description     String?
  content         String?
  videoUrl        String?
  order           Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  durationMinutes Int                @default(0)
  isFree          Boolean            @default(false)
  type            LessonType         @default(VIDEO)
  attachments LessonAttachment[]
  notes       LessonNote[]
  questions   LessonQuestion[]
  topic       Topic              @relation(fields: [topicId], references: [id], onDelete: Cascade)
