  USER
  STUDENT
  ADMIN
  TEACHER
  MODERATOR
}

enum FocusStrategy {
  POMODORO
  EIGHTY_TWENTY
  DEEP_WORK
  TIME_BLOCKING
  NO_DISTRACTION
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

