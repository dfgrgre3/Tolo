# Example Terraform Variables
# Copy this file to terraform.tfvars and update with your actual values

# Environment (dev, staging, production)
environment = "production"

# VPC ID where the load balancer will be deployed
vpc_id = "vpc-0123456789abcdef0"

# Public subnet IDs (at least 2 in different availability zones)
public_subnet_ids = [
  "subnet-0123456789abcdef0",
  "subnet-0123456789abcdef1"
]

# SSL Certificate ARN from AWS Certificate Manager
# Create one at: https://console.aws.amazon.com/acm/
ssl_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/12345678-1234-1234-1234-123456789012"

# Application port (default: 3000)
# app_port = 3000
